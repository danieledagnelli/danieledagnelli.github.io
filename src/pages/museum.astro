---
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Exhibition: {siteMetadata.name} — A Retrospective</title>
    <meta name="description" content="A curated retrospective exhibition of Daniele D'Agnelli's career — 15+ years of digital transformation, AI deployments, and cybersecurity leadership presented as a museum exhibition catalog." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/museum" />

    <!-- Open Graph -->
    <meta property="og:title" content="Exhibition: Daniele D'Agnelli — A Retrospective" />
    <meta property="og:description" content="A curated retrospective exhibition exploring 15+ years of digital transformation, AI deployments, and cybersecurity leadership." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/museum" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Exhibition: Daniele D'Agnelli — A Retrospective" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Exhibition: Daniele D'Agnelli — A Retrospective" />
    <meta name="twitter:description" content="A curated retrospective exhibition exploring 15+ years of digital transformation and AI leadership." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations. Specializing in AI deployments and cybersecurity for global enterprises."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Inter:wght@300;400;500;600&family=Noto+Serif+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- TEXTURE OVERLAY -->
    <div class="texture-overlay" aria-hidden="true"></div>

    <!-- INTRO: MUSEUM DOORS -->
    <div class="intro" id="intro">
        <div class="door door-left" id="doorLeft"></div>
        <div class="door door-right" id="doorRight"></div>
        <div class="intro-title-card" id="introTitleCard">
            <span class="intro-overline">The Gallery presents</span>
            <h1 class="intro-name">{siteMetadata.name}</h1>
            <span class="intro-subtitle">A Retrospective</span>
            <span class="intro-date">Exhibition 2012 — Present</span>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="catalog" id="catalog">
        <div class="museum-narrative">
            <h1 class="exhibit-title">EXHIBITION: THE MAKING OF AN ENGINEER</h1>
            <div class="exhibit-meta">a retrospective | curated by daniele d'agnelli</div>

            <div class="gallery">
                <h2>GALLERY I — FOUNDATIONS (2005-2011)</h2>
                <p>bsc computer science, university of bari aldo moro, italy. where the code began. algorithms, data structures, the classical training.</p>
            </div>

            <div class="gallery">
                <h2>GALLERY II — THE FIELD YEARS (2012-2021)</h2>
                <p>a decade of applied practice: software engineering at accenture (milan), consulting across codec (dublin), accenture (london), and deloitte (london). each role a new medium, each client a new canvas.</p>
            </div>

            <div class="gallery">
                <h2>GALLERY III — THE RETURN TO STUDY (2021-2023)</h2>
                <p>msc ethical hacking & cybersecurity, abertay university, dundee. gchq-certified programme. graduated with distinction. because the best practitioners never stop being students.</p>
            </div>

            <div class="permanent">
                <h2>PERMANENT COLLECTION</h2>
                <p>stanford machine learning (2016) · deeplearning.ai neural networks · deep reinforcement learning nanodegree · imperial college mathematics for ml · stanford probabilistic graphical models (with honors) · hack the box · claude code / ai engineering</p>
            </div>

            <div class="museum-footer">
                <a href="mailto:daniele@dagnelli.net">[exhibition continues]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>
    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --white: #fafafa;
        --charcoal: #2a2a2a;
        --gold: #b8860b;
        --gold-light: #d4a843;
        --warm-gray: #f0ece4;
        --accent-blue: #1a3a5c;
        --text-secondary: #6b6560;
        --text-tertiary: #9a9490;
        --border-light: #e0dbd3;
        --border-subtle: #ebe7e0;
        --heading: 'Cormorant Garamond', 'Georgia', serif;
        --body: 'Inter', 'Helvetica Neue', sans-serif;
        --accent: 'Noto Serif Display', 'Georgia', serif;
    }

    body {
        background: var(--white);
        color: var(--charcoal);
        font-family: var(--body);
        font-size: 15px;
        line-height: 1.7;
        overflow: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    a {
        color: var(--accent-blue);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    a:hover {
        color: var(--gold);
    }

    ::selection {
        background: var(--gold);
        color: var(--white);
    }

    /* =========================================
       TEXTURE OVERLAY
       ========================================= */
    .texture-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        opacity: 0.5;
    }

    /* =========================================
       INTRO: MUSEUM DOORS
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: auto;
    }

    .door {
        position: absolute;
        top: 0;
        width: 50%;
        height: 100%;
        background: var(--charcoal);
        z-index: 2;
        transition: transform 1.2s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .door::after {
        content: '';
        position: absolute;
        top: 0;
        width: 3px;
        height: 100%;
        background: var(--gold);
    }
    .door-left {
        left: 0;
    }
    .door-left::after {
        right: 0;
    }
    .door-right {
        right: 0;
    }
    .door-right::after {
        left: 0;
    }

    .intro.open .door-left {
        transform: translateX(-100%);
    }
    .intro.open .door-right {
        transform: translateX(100%);
    }
    .intro.done {
        pointer-events: none;
        visibility: hidden;
    }

    .intro-title-card {
        position: relative;
        z-index: 1;
        text-align: center;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;
        padding: 2rem;
    }
    .intro.open .intro-title-card {
        opacity: 1;
        transform: translateY(0);
    }

    .intro-overline {
        display: block;
        font-family: var(--body);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1rem;
    }

    .intro-name {
        font-family: var(--heading);
        font-size: clamp(36px, 7vw, 72px);
        font-weight: 300;
        color: var(--charcoal);
        line-height: 1.1;
        margin-bottom: 0.5rem;
    }

    .intro-subtitle {
        display: block;
        font-family: var(--accent);
        font-style: italic;
        font-size: clamp(16px, 3vw, 24px);
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
    }

    .intro-date {
        display: block;
        font-family: var(--body);
        font-size: 12px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--text-tertiary);
    }

    /* =========================================
       MAIN CATALOG — VIEWPORT LOCKED
       ========================================= */
    .catalog {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
    }
    .catalog.visible {
        opacity: 1;
    }

    /* =========================================
       MUSEUM NARRATIVE
       ========================================= */
    .museum-narrative {
        max-width: 620px;
        padding: 1.5rem;
    }

    .exhibit-title {
        font-size: 1rem;
        text-align: center;
        margin-bottom: 0.2rem;
    }

    .exhibit-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .gallery {
        margin-bottom: 0.7rem;
    }

    .gallery h2 {
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        margin-bottom: 0.2rem;
    }

    .gallery p {
        font-size: 0.78rem;
        line-height: 1.5;
    }

    .permanent {
        margin: 0.7rem 0;
    }

    .permanent h2 {
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        margin-bottom: 0.2rem;
    }

    .permanent p {
        font-size: 0.72rem;
        line-height: 1.5;
        opacity: 0.8;
    }

    .museum-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .museum-footer a {
        text-decoration: none;
    }

    /* =========================================
       RESPONSIVE - MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .gallery p {
            font-size: 0.72rem;
        }
        .permanent p {
            font-size: 0.68rem;
        }
    }

    @media (max-width: 600px) {
        .intro-name { font-size: 28px; }
        .intro-subtitle { font-size: 16px; }
    }

    @media (max-width: 380px) {
        .intro-name { font-size: 22px; }
        .intro-overline { font-size: 9px; }
    }
</style>

<script>
    /* =============================================
       INTRO: MUSEUM DOORS
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const catalogEl = document.getElementById('catalog')!;

    function openDoors() {
        introEl.classList.add('open');
        setTimeout(() => {
            catalogEl.classList.add('visible');
        }, 800);
        setTimeout(() => {
            introEl.classList.add('done');
        }, 2200);
    }

    function skipIntro() {
        introEl.classList.add('open');
        introEl.classList.add('done');
        catalogEl.classList.add('visible');
    }

    // Check sessionStorage
    if (sessionStorage.getItem('museum-intro-seen')) {
        skipIntro();
    } else {
        // Small delay before doors open
        setTimeout(() => {
            sessionStorage.setItem('museum-intro-seen', '1');
            openDoors();
        }, 1200);
    }

    // Click or key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('museum-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('museum-intro-seen', '1');
            skipIntro();
        }
    });
</script>
