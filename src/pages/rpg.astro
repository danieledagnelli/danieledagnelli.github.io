</html>

<style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --parchment: #1a1510;
        --paper: #2a2318;
        --gold: #d4a744;
        --gold-dim: #8a6d2b;
        --blood: #8b1a1a;
        --mana: #2a5ca8;
        --health: #2d8b2d;
        --silver: #a8a8a8;
        --text: #c9b896;
        --text-dim: #7a6d58;
        --border: #4a3d2a;
        --ember: #e8722a;
    }

    html { scroll-behavior: smooth; }

    body {
        background: var(--parchment);
        color: var(--text);
        font-family: 'Crimson Text', Georgia, serif;
        font-size: 17px;
        line-height: 1.65;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
    }

    a { color: var(--gold); text-decoration: none; transition: color 0.2s; }
    a:hover, a:focus { color: #f0c860; text-decoration: underline; }

    /* ===== EMBER PARTICLES ===== */
    .embers {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
    }

    .ember {
        position: absolute;
        width: 3px;
        height: 3px;
        background: var(--ember);
        border-radius: 50%;
        opacity: 0;
        animation: ember-rise linear infinite;
        box-shadow: 0 0 4px var(--ember), 0 0 8px rgba(232, 114, 42, 0.3);
    }

    @keyframes ember-rise {
        0% { opacity: 0; transform: translateY(0) translateX(0); }
        10% { opacity: 0.8; }
        90% { opacity: 0.3; }
        100% { opacity: 0; transform: translateY(-100vh) translateX(30px); }
    }

    /* ===== INTRO SEQUENCE ===== */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        cursor: pointer;
        transition: opacity 0.6s ease;
    }

    .intro.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .rune-canvas {
        position: absolute;
        width: 300px;
        height: 300px;
        opacity: 0.6;
    }

    .intro-text {
        position: relative;
        z-index: 2;
        text-align: center;
        opacity: 0;
    }

    .intro-text.visible { opacity: 1; transition: opacity 0.5s ease; }

    .intro-summoned {
        font-family: 'MedievalSharp', cursive;
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        color: var(--gold);
        letter-spacing: 0.3em;
        opacity: 0;
        transform: scale(1.5);
        text-shadow: 0 0 20px rgba(212, 167, 68, 0.6), 0 0 40px rgba(212, 167, 68, 0.3);
    }

    .intro-summoned.flash {
        animation: summon-flash 1s ease forwards;
    }

    @keyframes summon-flash {
        0% { opacity: 0; transform: scale(1.5); }
        30% { opacity: 1; transform: scale(1.1); }
        60% { opacity: 1; transform: scale(1); }
        100% { opacity: 0; transform: scale(1); }
    }

    .intro-name {
        font-family: 'MedievalSharp', cursive;
        font-size: clamp(2rem, 6vw, 3.5rem);
        color: var(--gold);
        margin-top: 1rem;
        opacity: 0;
        text-shadow: 0 0 10px rgba(212, 167, 68, 0.4);
    }

    .intro-name.reveal { animation: text-reveal 0.8s ease forwards; }

    .intro-class {
        font-family: 'Crimson Text', serif;
        font-size: clamp(1rem, 2.5vw, 1.4rem);
        color: var(--silver);
        margin-top: 0.5rem;
        opacity: 0;
    }

    .intro-class.reveal { animation: text-reveal 0.8s ease 0.2s forwards; }

    .intro-race {
        font-family: 'Crimson Text', serif;
        font-size: clamp(0.9rem, 2vw, 1.1rem);
        color: var(--text-dim);
        margin-top: 0.3rem;
        opacity: 0;
    }

    .intro-race.reveal { animation: text-reveal 0.8s ease 0.4s forwards; }

    @keyframes text-reveal {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .intro-sparkles {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 3;
    }

    .sparkle {
        position: absolute;
        width: 4px;
        height: 4px;
        background: var(--gold);
        border-radius: 50%;
        animation: sparkle-burst 0.8s ease-out forwards;
        box-shadow: 0 0 6px var(--gold);
    }

    @keyframes sparkle-burst {
        0% { opacity: 1; transform: translate(0, 0) scale(1); }
        100% { opacity: 0; transform: translate(var(--sx), var(--sy)) scale(0); }
    }

    /* ===== MAIN SHEET (viewport-locked) ===== */
    .sheet {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.8s ease;
        position: relative;
        z-index: 2;
    }

    .sheet.visible { opacity: 1; }

    /* ===== CHARACTER SHEET ===== */
    .character-sheet {
        max-width: 550px;
        padding: 1.5rem;
        background: var(--paper);
        border: 1px solid var(--border);
        border-radius: 4px;
        position: relative;
        animation: torch-flicker 4s ease-in-out infinite alternate;
    }

    @keyframes torch-flicker {
        0% { box-shadow: 0 0 15px rgba(232, 114, 42, 0.08), inset 0 0 30px rgba(0,0,0,0.3); }
        50% { box-shadow: 0 0 20px rgba(232, 114, 42, 0.12), inset 0 0 30px rgba(0,0,0,0.25); }
        100% { box-shadow: 0 0 12px rgba(232, 114, 42, 0.06), inset 0 0 30px rgba(0,0,0,0.35); }
    }

    .sheet-title {
        font-family: 'MedievalSharp', cursive;
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        color: var(--gold);
        text-align: center;
        margin-bottom: 1rem;
        background: linear-gradient(90deg, var(--gold), #f0d080, var(--gold));
        background-size: 200% 100%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .char-info {
        margin-bottom: 1rem;
        text-align: center;
    }

    .char-name {
        font-family: 'MedievalSharp', cursive;
        font-size: clamp(1.3rem, 4vw, 1.8rem);
        color: var(--gold);
        line-height: 1.2;
        text-shadow: 0 0 10px rgba(212, 167, 68, 0.3);
    }

    .char-meta {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-dim);
        margin-top: 0.4rem;
        line-height: 1.6;
    }

    .attributes {
        margin-bottom: 1rem;
    }

    .attributes h2,
    .achievements h2,
    .quest-log h2 {
        font-family: 'MedievalSharp', cursive;
        font-size: clamp(0.9rem, 2vw, 1.1rem);
        color: var(--gold);
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .attr {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        line-height: 1.8;
        color: var(--text);
        white-space: pre;
    }

    .achievements {
        margin-bottom: 1rem;
    }

    .achievement {
        font-family: 'Crimson Text', Georgia, serif;
        font-size: 0.78rem;
        color: var(--text);
        line-height: 1.7;
    }

    .quest-log {
        margin-bottom: 1rem;
    }

    .quest-log p {
        font-family: 'Crimson Text', Georgia, serif;
        font-size: 0.78rem;
        font-style: italic;
        color: var(--text);
        line-height: 1.7;
    }

    .sheet-footer {
        text-align: center;
        padding-top: 0.8rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: center;
        gap: 1.2rem;
    }

    .sheet-footer a {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--gold);
        transition: color 0.2s;
    }

    .sheet-footer a:hover,
    .sheet-footer a:focus {
        color: #f0c860;
        text-decoration: none;
    }

    /* ===== RESPONSIVE: 768px ===== */
    @media (max-width: 768px) {
        .character-sheet {
            max-width: 90vw;
            padding: 1.2rem;
        }

        .sheet-title {
            font-size: clamp(1rem, 3vw, 1.3rem);
        }

        .char-name {
            font-size: clamp(1.1rem, 3.5vw, 1.5rem);
        }

        .attr {
            font-size: 0.68rem;
            line-height: 1.7;
        }

        .achievement {
            font-size: 0.7rem;
        }

        .quest-log p {
            font-size: 0.7rem;
        }

        .char-meta {
            font-size: 0.65rem;
        }

        .attributes h2,
        .achievements h2,
        .quest-log h2 {
            font-size: 0.85rem;
        }
    }

    /* ===== RESPONSIVE: 480px ===== */
    @media (max-width: 480px) {
        .character-sheet {
            padding: 1rem;
        }

        .sheet-title {
            font-size: 0.95rem;
            margin-bottom: 0.7rem;
        }

        .char-name {
            font-size: 1.1rem;
        }

        .attr {
            font-size: 0.62rem;
            line-height: 1.6;
        }

        .achievement {
            font-size: 0.65rem;
        }

        .quest-log p {
            font-size: 0.65rem;
        }

        .char-meta {
            font-size: 0.6rem;
        }

        .attributes h2,
        .achievements h2,
        .quest-log h2 {
            font-size: 0.8rem;
            margin-bottom: 0.3rem;
        }

        .sheet-footer a {
            font-size: 0.68rem;
        }

        .attributes,
        .achievements,
        .quest-log,
        .char-info {
            margin-bottom: 0.7rem;
        }
    }

    /* ===== RESPONSIVE: 380px ===== */
    @media (max-width: 380px) {
        .character-sheet {
            padding: 0.75rem;
        }

        .attr {
            font-size: 0.56rem;
            line-height: 1.5;
        }

        .achievement {
            font-size: 0.6rem;
        }

        .quest-log p {
            font-size: 0.6rem;
        }

        .sheet-footer {
            gap: 0.8rem;
        }

        .sheet-footer a {
            font-size: 0.62rem;
        }
    }
</style>

<script>
    // ===== EMBER PARTICLES =====
    function createEmbers() {
        const container = document.getElementById('embers');
        if (!container) return;
        const count = 25;
        for (let i = 0; i < count; i++) {
            const ember = document.createElement('div');
            ember.className = 'ember';
            ember.style.left = Math.random() * 100 + '%';
            ember.style.bottom = -(Math.random() * 20) + '%';
            ember.style.animationDuration = (6 + Math.random() * 8) + 's';
            ember.style.animationDelay = (Math.random() * 10) + 's';
            ember.style.width = (2 + Math.random() * 2) + 'px';
            ember.style.height = ember.style.width;
            container.appendChild(ember);
        }
    }

    // ===== INTRO SEQUENCE =====
    function runIntro() {
        const intro = document.getElementById('intro');
        const sheet = document.getElementById('sheet');
        const canvas = document.getElementById('runeCanvas') as HTMLCanvasElement;
        const introText = document.getElementById('introText')!;
        const summoned = document.getElementById('introSummoned')!;
        const heroName = document.getElementById('introName')!;
        const heroClass = document.getElementById('introClass')!;
        const heroRace = document.getElementById('introRace')!;
        const sparklesEl = document.getElementById('introSparkles')!;

        if (!intro || !sheet) return;

        // Check sessionStorage
        if (sessionStorage.getItem('rpg-intro')) {
            intro.style.display = 'none';
            sheet.classList.add('visible');
            return;
        }

        let skipped = false;

        function skip() {
            if (skipped) return;
            skipped = true;
            sessionStorage.setItem('rpg-intro', '1');
            intro.classList.add('hidden');
            setTimeout(() => {
                intro.style.display = 'none';
                sheet.classList.add('visible');
            }, 600);
        }

        intro.addEventListener('click', skip);
        document.addEventListener('keydown', function handler(e: KeyboardEvent) {
            if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter') {
                skip();
                document.removeEventListener('keydown', handler);
            }
        });

        // Draw rune circle on canvas
        if (canvas) {
            const ctx = canvas.getContext('2d')!;
            const w = canvas.width = 300;
            const h = canvas.height = 300;
            const cx = w / 2;
            const cy = h / 2;
            const radius = 100;
            let progress = 0;

            function drawRune() {
                if (skipped) return;
                ctx.clearRect(0, 0, w, h);
                ctx.strokeStyle = '#d4a744';
                ctx.lineWidth = 1.5;
                ctx.shadowColor = '#d4a744';
                ctx.shadowBlur = 8;

                // Outer circle
                ctx.beginPath();
                ctx.arc(cx, cy, radius, 0, Math.PI * 2 * Math.min(progress, 1));
                ctx.stroke();

                // Inner circle
                if (progress > 0.3) {
                    ctx.beginPath();
                    ctx.arc(cx, cy, radius * 0.6, 0, Math.PI * 2 * Math.min((progress - 0.3) / 0.7, 1));
                    ctx.stroke();
                }

                // Rune lines
                if (progress > 0.5) {
                    const lineProgress = Math.min((progress - 0.5) / 0.5, 1);
                    for (let i = 0; i < 6; i++) {
                        const angle = (Math.PI * 2 * i) / 6;
                        const x1 = cx + Math.cos(angle) * radius * 0.6 * lineProgress;
                        const y1 = cy + Math.sin(angle) * radius * 0.6 * lineProgress;
                        const x2 = cx + Math.cos(angle) * radius * lineProgress;
                        const y2 = cy + Math.sin(angle) * radius * lineProgress;
                        ctx.beginPath();
                        ctx.moveTo(cx, cy);
                        ctx.lineTo(x1, y1);
                        ctx.moveTo(x1, y1);
                        ctx.lineTo(x2, y2);
                        ctx.stroke();
                    }
                }

                // Small rune marks
                if (progress > 0.7) {
                    const markProgress = (progress - 0.7) / 0.3;
                    for (let i = 0; i < 12; i++) {
                        const angle = (Math.PI * 2 * i) / 12;
                        const r = radius * 0.8;
                        const x = cx + Math.cos(angle) * r;
                        const y = cy + Math.sin(angle) * r;
                        ctx.globalAlpha = markProgress;
                        ctx.fillStyle = '#d4a744';
                        ctx.beginPath();
                        ctx.arc(x, y, 2, 0, Math.PI * 2);
                        ctx.fill();
                    }
                    ctx.globalAlpha = 1;
                }

                progress += 0.012;
                if (progress < 1.2) {
                    requestAnimationFrame(drawRune);
                }
            }

            drawRune();
        }

        // Sequence timeline
        setTimeout(() => {
            if (skipped) return;
            introText.classList.add('visible');
            summoned.classList.add('flash');
        }, 1200);

        setTimeout(() => {
            if (skipped) return;
            heroName.classList.add('reveal');
            heroClass.classList.add('reveal');
            heroRace.classList.add('reveal');
        }, 2200);

        // Sparkle burst
        setTimeout(() => {
            if (skipped) return;
            for (let i = 0; i < 30; i++) {
                const sparkle = document.createElement('div');
                sparkle.className = 'sparkle';
                const angle = Math.random() * Math.PI * 2;
                const dist = 60 + Math.random() * 120;
                sparkle.style.left = '50%';
                sparkle.style.top = '50%';
                sparkle.style.setProperty('--sx', Math.cos(angle) * dist + 'px');
                sparkle.style.setProperty('--sy', Math.sin(angle) * dist + 'px');
                sparkle.style.animationDelay = (Math.random() * 0.3) + 's';
                sparklesEl.appendChild(sparkle);
            }
        }, 3200);

        // Finish
        setTimeout(() => {
            if (skipped) return;
            skip();
        }, 4200);
    }

    // ===== INIT =====
    createEmbers();
    runIntro();
</script>
