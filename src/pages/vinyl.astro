---
import { siteMetadata } from "../siteMetadata";

const catalogNumber = "DAG-2012-LP01";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Greatest Hits</title>
    <meta name="description" content="Greatest Hits — A career anthology by Daniele D'Agnelli. 15+ years of digital transformation, AI, and cybersecurity presented as a concept album." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/vinyl" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Greatest Hits" />
    <meta property="og:description" content="A career anthology — 15+ years of digital transformation, AI deployments, and cybersecurity presented as a vinyl concept album." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/vinyl" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Greatest Hits" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Greatest Hits" />
    <meta name="twitter:description" content="A career anthology — 15+ years presented as a vinyl concept album." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <!-- Structured Data (WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "description": "Personal website of Daniele D'Agnelli — Greatest Hits career anthology."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Nunito+Sans:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- CRACKLE TEXTURE OVERLAY -->
    <div class="crackle-overlay" aria-hidden="true"></div>

    <!-- NOW PLAYING BAR -->
    <div class="now-playing-bar" id="nowPlayingBar" aria-hidden="true">
        <div class="np-left">
            <div class="mini-record" id="miniRecord" aria-hidden="true">
                <div class="mini-record-label"></div>
            </div>
            <span class="np-text">Now Playing</span>
        </div>
        <div class="np-progress">
            <div class="np-progress-fill" id="progressFill"></div>
        </div>
        <div class="np-right">
            <div class="equalizer" aria-hidden="true">
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
            </div>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-record" id="introRecord" aria-hidden="true">
            <div class="record-grooves"></div>
            <div class="record-label">
                <span class="label-artist">D'Agnelli</span>
                <span class="label-cat">{catalogNumber}</span>
            </div>
            <div class="record-hole"></div>
        </div>
        <div class="intro-needle" id="introNeedle" aria-hidden="true">
            <div class="needle-arm"></div>
            <div class="needle-head"></div>
        </div>
        <div class="intro-text" id="introText">
            <p class="intro-crackle" id="introCrackle">click... ssssss...</p>
            <h1 class="intro-title" id="introTitle">Greatest Hits</h1>
            <p class="intro-artist" id="introArtist">Daniele D'Agnelli</p>
            <p class="intro-subtitle" id="introSubtitle">A Career Anthology &bull; 2012&ndash;Present</p>
            <p class="intro-now-playing" id="introNowPlaying">Now Playing...</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="album" id="content">

        <div class="vinyl-narrative">
            <h1 class="album-title">GREATEST HITS — DANIELE D'AGNELLI</h1>
            <div class="album-meta">label: professional services | format: 15-year career | remastered 2025</div>

            <div class="tracklist">
                <div class="side-label">SIDE A</div>
                <div class="track">
                    <span class="track-num">1.</span>
                    <span class="track-name">swiss manufacturer (c3 ai)</span>
                    <div class="track-detail">100+ plants, 2,000+ users, $18m ebit impact — "the one that went platinum"</div>
                </div>
                <div class="track">
                    <span class="track-num">2.</span>
                    <span class="track-name">british telco (deloitte)</span>
                    <div class="track-detail">first enterprise-wide deployment across 7 business units — "the debut that built the practice"</div>
                </div>
                <div class="track">
                    <span class="track-num">3.</span>
                    <span class="track-name">american bank (deloitte)</span>
                    <div class="track-detail">data architecture transformation, 75k employees — "the deep cut fans love"</div>
                </div>
                <div class="side-label">SIDE B</div>
                <div class="track">
                    <span class="track-num">4.</span>
                    <span class="track-name">uk investment firm (deloitte)</span>
                    <div class="track-detail">financial planning, £170.3b aum — "the quiet masterpiece"</div>
                </div>
                <div class="track">
                    <span class="track-num">5.</span>
                    <span class="track-name">aerospace co (accenture)</span>
                    <div class="track-detail">demand forecasting, design lead — "the early single"</div>
                </div>
            </div>

            <div class="liner-notes">produced by 15 years of relentless craft. engineered with python, ml, and genai. mixed in london. mastered with a gchq-certified msc.</div>

            <div class="vinyl-footer">
                <a href="mailto:daniele@dagnelli.net">[now streaming]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>

    </main>

</body>
</html>

<style>
    /* ============================================
       CSS CUSTOM PROPERTIES
       ============================================ */
    :root {
        --vinyl-black: #0d0d0d;
        --sleeve-cream: #f0e6d0;
        --label-red: #cc2a2a;
        --groove-silver: #b0b0b0;
        --worn-gold: #c4a02a;
        --warm-orange: #e87020;
        --font-display: 'Anton', sans-serif;
        --font-body: 'Nunito Sans', sans-serif;
        --font-credits: 'Courier Prime', monospace;
    }

    /* ============================================
       RESET & BASE
       ============================================ */
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        font-size: 16px;
    }

    body {
        background: var(--vinyl-black);
        color: var(--sleeve-cream);
        font-family: var(--font-body);
        line-height: 1.6;
        overflow: hidden;
        height: 100dvh;
    }

    a {
        color: var(--worn-gold);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    a:hover, a:focus {
        color: var(--warm-orange);
        text-decoration: underline;
    }

    /* ============================================
       CRACKLE TEXTURE OVERLAY
       ============================================ */
    .crackle-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
    }

    /* ============================================
       NOW PLAYING BAR
       ============================================ */
    .now-playing-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 48px;
        background: rgba(13, 13, 13, 0.95);
        border-bottom: 1px solid rgba(196, 160, 42, 0.3);
        display: flex;
        align-items: center;
        padding: 0 20px;
        z-index: 1000;
        gap: 16px;
        opacity: 0;
        transform: translateY(-100%);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .now-playing-bar.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .np-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .mini-record {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: radial-gradient(circle at center, #333 0%, #111 40%, #222 42%, #111 60%, #1a1a1a 100%);
        animation: spin 3s linear infinite;
        position: relative;
        border: 1px solid #333;
    }
    .mini-record-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--label-red);
    }

    .np-text {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--groove-silver);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .np-progress {
        flex: 1;
        height: 3px;
        background: rgba(176, 176, 176, 0.2);
        border-radius: 2px;
        overflow: hidden;
    }
    .np-progress-fill {
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, var(--label-red), var(--warm-orange));
        border-radius: 2px;
    }

    .np-right {
        flex-shrink: 0;
    }

    /* Equalizer */
    .equalizer {
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 20px;
    }
    .eq-bar {
        display: block;
        width: 3px;
        background: var(--worn-gold);
        border-radius: 1px 1px 0 0;
        animation: eqBounce 0.8s ease-in-out infinite alternate;
    }
    .eq-bar:nth-child(1) { height: 6px; animation-delay: 0s; }
    .eq-bar:nth-child(2) { height: 14px; animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { height: 8px; animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { height: 18px; animation-delay: 0.15s; }
    .eq-bar:nth-child(5) { height: 10px; animation-delay: 0.05s; }
    .eq-bar:nth-child(6) { height: 16px; animation-delay: 0.25s; }
    .eq-bar:nth-child(7) { height: 5px; animation-delay: 0.3s; }

    @keyframes eqBounce {
        0% { transform: scaleY(0.3); }
        100% { transform: scaleY(1); }
    }

    /* ============================================
       INTRO SEQUENCE
       ============================================ */
    .intro {
        position: fixed;
        inset: 0;
        background: var(--vinyl-black);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .intro.hidden {
        display: none;
    }
    .intro.fade-out {
        animation: introFadeOut 0.8s ease forwards;
    }

    /* Record */
    .intro-record {
        position: absolute;
        width: 340px;
        height: 340px;
        border-radius: 50%;
        background: radial-gradient(
            circle at center,
            #1a1a1a 0%,
            #0f0f0f 20%,
            #1c1c1c 21%,
            #111 35%,
            #1a1a1a 36%,
            #0f0f0f 50%,
            #181818 51%,
            #111 65%,
            #1a1a1a 66%,
            #0f0f0f 80%,
            #1a1a1a 81%,
            #111 100%
        );
        border: 2px solid #333;
        transform: translateX(120vw);
        opacity: 0;
    }
    .intro-record.slide-in {
        animation: recordSlideIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .intro-record.spinning {
        animation: spin 2.5s linear infinite;
    }

    .record-grooves {
        position: absolute;
        inset: 10px;
        border-radius: 50%;
        background: repeating-radial-gradient(
            circle at center,
            transparent 0px,
            rgba(255, 255, 255, 0.03) 1px,
            transparent 2px,
            transparent 4px
        );
    }

    .record-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: radial-gradient(circle at 40% 40%, var(--label-red), #8a1a1a);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
    }
    .label-artist {
        font-family: var(--font-display);
        font-size: 0.8rem;
        color: var(--sleeve-cream);
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .label-cat {
        font-family: var(--font-credits);
        font-size: 0.55rem;
        color: rgba(240, 230, 208, 0.7);
    }

    .record-hole {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--vinyl-black);
        border: 1px solid #444;
    }

    /* Needle */
    .intro-needle {
        position: absolute;
        right: 15%;
        top: 20%;
        transform-origin: top right;
        opacity: 0;
    }
    .intro-needle.visible {
        opacity: 1;
        animation: needleDrop 1s ease-out forwards;
    }
    .needle-arm {
        width: 3px;
        height: 180px;
        background: linear-gradient(to bottom, var(--groove-silver), #888);
        border-radius: 2px;
        transform: rotate(-25deg);
        transform-origin: top center;
    }
    .needle-head {
        width: 8px;
        height: 8px;
        background: var(--groove-silver);
        border-radius: 50%;
        position: absolute;
        bottom: -4px;
        left: -2.5px;
    }

    /* Intro Text */
    .intro-text {
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .intro-crackle {
        font-family: var(--font-credits);
        font-size: 1rem;
        color: var(--groove-silver);
        opacity: 0;
        letter-spacing: 3px;
    }
    .intro-crackle.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 8vw, 5rem);
        color: var(--sleeve-cream);
        text-transform: uppercase;
        letter-spacing: 4px;
        opacity: 0;
        margin-top: 16px;
    }
    .intro-title.visible { animation: fadeInUp 0.8s ease forwards; }

    .intro-artist {
        font-family: var(--font-body);
        font-size: clamp(1rem, 3vw, 1.5rem);
        color: var(--worn-gold);
        opacity: 0;
        margin-top: 8px;
    }
    .intro-artist.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-subtitle {
        font-family: var(--font-credits);
        font-size: clamp(0.7rem, 2vw, 0.9rem);
        color: var(--groove-silver);
        opacity: 0;
        margin-top: 8px;
        letter-spacing: 2px;
    }
    .intro-subtitle.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-now-playing {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--warm-orange);
        opacity: 0;
        margin-top: 24px;
        text-transform: uppercase;
        letter-spacing: 3px;
    }
    .intro-now-playing.visible { animation: fadeInPulse 1s ease forwards; }

    /* ============================================
       KEYFRAMES
       ============================================ */
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes recordSlideIn {
        0% { transform: translateX(120vw) rotate(0deg); opacity: 0; }
        30% { opacity: 1; }
        100% { transform: translateX(0) rotate(-720deg); opacity: 1; }
    }

    @keyframes needleDrop {
        0% { transform: rotate(-15deg); }
        60% { transform: rotate(5deg); }
        100% { transform: rotate(0deg); }
    }

    @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInPulse {
        0% { opacity: 0; }
        50% { opacity: 1; }
        75% { opacity: 0.6; }
        100% { opacity: 1; }
    }

    @keyframes introFadeOut {
        0% { opacity: 1; }
        100% { opacity: 0; pointer-events: none; }
    }

    @keyframes contentFadeIn {
        0% { opacity: 0; transform: translateY(30px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    /* ============================================
       MAIN CONTENT — VIEWPORT-LOCKED
       ============================================ */
    .album {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
    }
    .album.visible {
        animation: contentFadeIn 0.8s ease forwards;
    }

    /* ============================================
       VINYL NARRATIVE
       ============================================ */
    .vinyl-narrative {
        max-width: 580px;
        padding: 1.5rem;
    }

    .album-title {
        font-family: var(--font-display);
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 0.2rem;
        color: var(--sleeve-cream);
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .album-meta {
        font-family: var(--font-credits);
        font-size: 0.68rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
        color: var(--groove-silver);
        letter-spacing: 1px;
    }

    .tracklist {
        font-family: var(--font-body);
    }

    .side-label {
        font-family: var(--font-display);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        opacity: 0.6;
        margin: 0.6rem 0 0.3rem;
        color: var(--worn-gold);
        text-transform: uppercase;
    }

    .track {
        margin-bottom: 0.4rem;
    }

    .track-num {
        font-family: var(--font-credits);
        font-size: 0.7rem;
        opacity: 0.6;
        color: var(--label-red);
    }

    .track-name {
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: bold;
        color: var(--sleeve-cream);
    }

    .track-detail {
        font-family: var(--font-body);
        font-size: 0.72rem;
        opacity: 0.8;
        font-style: italic;
        color: var(--sleeve-cream);
    }

    .liner-notes {
        font-family: var(--font-credits);
        font-size: 0.72rem;
        opacity: 0.7;
        margin: 0.8rem 0;
        text-align: center;
        color: var(--groove-silver);
    }

    .vinyl-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 0.8rem;
    }

    .vinyl-footer a {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        text-decoration: none;
        color: var(--worn-gold);
    }
    .vinyl-footer a:hover, .vinyl-footer a:focus {
        color: var(--warm-orange);
        text-decoration: none;
    }

    /* ============================================
       RESPONSIVE — 768px
       ============================================ */
    @media (max-width: 768px) {
        .track-detail {
            font-size: 0.68rem;
        }
        .track-name {
            font-size: 0.78rem;
        }

        .intro-record {
            width: 240px;
            height: 240px;
        }
        .record-label {
            width: 80px;
            height: 80px;
        }
        .label-artist { font-size: 0.65rem; }
        .label-cat { font-size: 0.45rem; }

        .intro-needle {
            right: 10%;
        }
        .needle-arm {
            height: 130px;
        }

        .now-playing-bar {
            padding: 0 12px;
            height: 44px;
        }
        .np-text {
            font-size: 0.65rem;
        }
        .eq-bar {
            width: 2px;
        }
    }

    /* ============================================
       RESPONSIVE — 480px
       ============================================ */
    @media (max-width: 480px) {
        .intro-record {
            width: 180px;
            height: 180px;
        }
        .record-label {
            width: 60px;
            height: 60px;
        }
        .needle-arm { height: 100px; }
    }

    /* ============================================
       RESPONSIVE — 380px
       ============================================ */
    @media (max-width: 380px) {
        .intro-record {
            width: 140px;
            height: 140px;
        }
        .record-label {
            width: 48px;
            height: 48px;
        }
        .label-artist { font-size: 0.5rem; }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const intro = document.getElementById("intro") as HTMLElement;
        const content = document.getElementById("content") as HTMLElement;
        const npBar = document.getElementById("nowPlayingBar") as HTMLElement;

        const introRecord = document.getElementById("introRecord") as HTMLElement;
        const introNeedle = document.getElementById("introNeedle") as HTMLElement;
        const introCrackle = document.getElementById("introCrackle") as HTMLElement;
        const introTitle = document.getElementById("introTitle") as HTMLElement;
        const introArtist = document.getElementById("introArtist") as HTMLElement;
        const introSubtitle = document.getElementById("introSubtitle") as HTMLElement;
        const introNowPlaying = document.getElementById("introNowPlaying") as HTMLElement;

        let introComplete = false;
        let introTimers: number[] = [];

        function showContent(): void {
            introComplete = true;
            introTimers.forEach(t => clearTimeout(t));
            introTimers = [];

            intro.classList.add("fade-out");
            setTimeout(() => {
                intro.classList.add("hidden");
                content.classList.add("visible");
                npBar.classList.add("visible");
            }, 800);

            sessionStorage.setItem("vinyl-intro", "done");
        }

        function skipIntro(): void {
            if (!introComplete) {
                showContent();
            }
        }

        // Skip handlers
        intro.addEventListener("click", skipIntro);
        document.addEventListener("keydown", (e: KeyboardEvent) => {
            if (e.key === "Escape" || e.key === " " || e.key === "Enter") {
                if (!introComplete) {
                    e.preventDefault();
                    skipIntro();
                }
            }
        });

        // Check sessionStorage
        if (sessionStorage.getItem("vinyl-intro") === "done") {
            intro.classList.add("hidden");
            content.classList.add("visible");
            npBar.classList.add("visible");
        } else {
            // Run intro sequence
            const t1 = window.setTimeout(() => {
                introRecord.classList.add("slide-in");
            }, 300);
            introTimers.push(t1);

            const t2 = window.setTimeout(() => {
                introRecord.classList.remove("slide-in");
                introRecord.classList.add("spinning");
            }, 1600);
            introTimers.push(t2);

            const t3 = window.setTimeout(() => {
                introNeedle.classList.add("visible");
            }, 2000);
            introTimers.push(t3);

            const t4 = window.setTimeout(() => {
                introCrackle.classList.add("visible");
            }, 2800);
            introTimers.push(t4);

            const t5 = window.setTimeout(() => {
                introTitle.classList.add("visible");
            }, 3600);
            introTimers.push(t5);

            const t6 = window.setTimeout(() => {
                introArtist.classList.add("visible");
            }, 4200);
            introTimers.push(t6);

            const t7 = window.setTimeout(() => {
                introSubtitle.classList.add("visible");
            }, 4800);
            introTimers.push(t7);

            const t8 = window.setTimeout(() => {
                introNowPlaying.classList.add("visible");
            }, 5400);
            introTimers.push(t8);

            const t9 = window.setTimeout(() => {
                showContent();
            }, 6800);
            introTimers.push(t9);
        }
    });
</script>
