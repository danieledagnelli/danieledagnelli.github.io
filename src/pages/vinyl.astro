<script>
    document.addEventListener("DOMContentLoaded", () => {
        const intro = document.getElementById("intro") as HTMLElement;
        const content = document.getElementById("content") as HTMLElement;
        const npBar = document.getElementById("nowPlayingBar") as HTMLElement;
        const progressFill = document.getElementById("progressFill") as HTMLElement;

        const introRecord = document.getElementById("introRecord") as HTMLElement;
        const introNeedle = document.getElementById("introNeedle") as HTMLElement;
        const introCrackle = document.getElementById("introCrackle") as HTMLElement;
        const introTitle = document.getElementById("introTitle") as HTMLElement;
        const introArtist = document.getElementById("introArtist") as HTMLElement;
        const introSubtitle = document.getElementById("introSubtitle") as HTMLElement;
        const introNowPlaying = document.getElementById("introNowPlaying") as HTMLElement;

        let introComplete = false;
        let introTimers: number[] = [];

        function showContent(): void {
            introComplete = true;
            introTimers.forEach(t => clearTimeout(t));
            introTimers = [];

            intro.classList.add("fade-out");
            setTimeout(() => {
                intro.classList.add("hidden");
                content.classList.add("visible");
                npBar.classList.add("visible");
            }, 800);

            sessionStorage.setItem("vinyl-intro", "done");
        }

        function skipIntro(): void {
            if (!introComplete) {
                showContent();
            }
        }

        // Skip handlers
        intro.addEventListener("click", skipIntro);
        document.addEventListener("keydown", (e: KeyboardEvent) => {
            if (e.key === "Escape" || e.key === " " || e.key === "Enter") {
                if (!introComplete) {
                    e.preventDefault();
                    skipIntro();
                }
            }
        });

        // Check sessionStorage
        if (sessionStorage.getItem("vinyl-intro") === "done") {
            intro.classList.add("hidden");
            content.classList.add("visible");
            npBar.classList.add("visible");
        } else {
            // Run intro sequence
            const t1 = window.setTimeout(() => {
                introRecord.classList.add("slide-in");
            }, 300);
            introTimers.push(t1);

            const t2 = window.setTimeout(() => {
                introRecord.classList.remove("slide-in");
                introRecord.classList.add("spinning");
            }, 1600);
            introTimers.push(t2);

            const t3 = window.setTimeout(() => {
                introNeedle.classList.add("visible");
            }, 2000);
            introTimers.push(t3);

            const t4 = window.setTimeout(() => {
                introCrackle.classList.add("visible");
            }, 2800);
            introTimers.push(t4);

            const t5 = window.setTimeout(() => {
                introTitle.classList.add("visible");
            }, 3600);
            introTimers.push(t5);

            const t6 = window.setTimeout(() => {
                introArtist.classList.add("visible");
            }, 4200);
            introTimers.push(t6);

            const t7 = window.setTimeout(() => {
                introSubtitle.classList.add("visible");
            }, 4800);
            introTimers.push(t7);

            const t8 = window.setTimeout(() => {
                introNowPlaying.classList.add("visible");
            }, 5400);
            introTimers.push(t8);

            const t9 = window.setTimeout(() => {
                showContent();
            }, 6800);
            introTimers.push(t9);
        }

        // Scroll-based progress bar
        function updateProgress(): void {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
            progressFill.style.width = `${Math.min(pct, 100)}%`;
        }

        window.addEventListener("scroll", updateProgress, { passive: true });
        updateProgress();
    });
</script>
