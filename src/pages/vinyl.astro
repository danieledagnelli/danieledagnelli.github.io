---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";

const chronological = [...experience].reverse();
const midpoint = Math.ceil(chronological.length / 2);
const sideA = chronological.slice(0, midpoint);
const sideB = chronological.slice(midpoint);

function trackNum(side: string, idx: number): string {
  return `${side}${idx + 1}`;
}

function extractYear(period: string): string {
  const match = period.match(/\d{4}/);
  return match ? match[0] : "";
}

const catalogNumber = "DAG-2012-LP01";
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Greatest Hits</title>
    <meta name="description" content="Greatest Hits — A career anthology by Daniele D'Agnelli. 15+ years of digital transformation, AI, and cybersecurity presented as a concept album." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/vinyl" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Greatest Hits" />
    <meta property="og:description" content="A career anthology — 15+ years of digital transformation, AI deployments, and cybersecurity presented as a vinyl concept album." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/vinyl" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Greatest Hits" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Greatest Hits" />
    <meta name="twitter:description" content="A career anthology — 15+ years presented as a vinyl concept album." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <!-- Structured Data (WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "description": "Personal website of Daniele D'Agnelli — Greatest Hits career anthology."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Nunito+Sans:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- CRACKLE TEXTURE OVERLAY -->
    <div class="crackle-overlay" aria-hidden="true"></div>

    <!-- NOW PLAYING BAR -->
    <div class="now-playing-bar" id="nowPlayingBar" aria-hidden="true">
        <div class="np-left">
            <div class="mini-record" id="miniRecord" aria-hidden="true">
                <div class="mini-record-label"></div>
            </div>
            <span class="np-text">Now Playing</span>
        </div>
        <div class="np-progress">
            <div class="np-progress-fill" id="progressFill"></div>
        </div>
        <div class="np-right">
            <div class="equalizer" aria-hidden="true">
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
            </div>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-record" id="introRecord" aria-hidden="true">
            <div class="record-grooves"></div>
            <div class="record-label">
                <span class="label-artist">D'Agnelli</span>
                <span class="label-cat">{catalogNumber}</span>
            </div>
            <div class="record-hole"></div>
        </div>
        <div class="intro-needle" id="introNeedle" aria-hidden="true">
            <div class="needle-arm"></div>
            <div class="needle-head"></div>
        </div>
        <div class="intro-text" id="introText">
            <p class="intro-crackle" id="introCrackle">click... ssssss...</p>
            <h1 class="intro-title" id="introTitle">Greatest Hits</h1>
            <p class="intro-artist" id="introArtist">Daniele D'Agnelli</p>
            <p class="intro-subtitle" id="introSubtitle">A Career Anthology &bull; 2012&ndash;Present</p>
            <p class="intro-now-playing" id="introNowPlaying">Now Playing...</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="album" id="content">

        <!-- ALBUM COVER / HEADER -->
        <section class="album-cover">
            <div class="cover-art">
                <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="320" height="320" class="cover-photo" />
                <div class="cover-overlay" aria-hidden="true"></div>
            </div>
            <div class="cover-info">
                <span class="cover-label-tag">Original Recording</span>
                <h1 class="cover-title">Greatest Hits</h1>
                <h2 class="cover-artist">{siteMetadata.name}</h2>
                <p class="cover-subtitle">A Career Anthology &bull; 2012&ndash;Present</p>
                <div class="cover-record-label" aria-hidden="true">
                    <div class="label-circle">
                        <span class="label-inner-text">DAGNELLI<br/>RECORDS</span>
                        <div class="label-hole"></div>
                    </div>
                </div>
                <div class="cover-meta">
                    <span class="cover-cat">Cat. No. {catalogNumber}</span>
                    <span class="cover-format">Double LP &bull; Gatefold</span>
                </div>
                <div class="cover-links">
                    <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener" class="cover-link">GitHub</a>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener" class="cover-link">LinkedIn</a>
                    <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener" class="cover-link">Bluesky</a>
                    <a href={`mailto:${siteMetadata.email}`} class="cover-link">Contact</a>
                </div>
            </div>
        </section>

        <!-- LINER NOTES -->
        <section class="gatefold-section liner-notes" id="linerNotes">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9835;</span>
                <h2 class="section-title">Liner Notes</h2>
            </div>
            <div class="liner-notes-content">
                <p class="liner-text">{summary}</p>
                <div class="liner-metrics">
                    {metrics.map(m => (
                        <div class="metric-badge">
                            <span class="metric-value">{m.value}</span>
                            <span class="metric-label">{m.label}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- TRACK LISTING — SIDE A -->
        <section class="gatefold-section track-listing" id="trackListing">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9834;</span>
                <h2 class="section-title">Track Listing</h2>
            </div>

            <div class="side-header">
                <div class="side-groove" aria-hidden="true"></div>
                <h3 class="side-label">Side A — The Early Sessions</h3>
                <div class="side-groove" aria-hidden="true"></div>
            </div>

            <div class="tracks">
                {sideA.map((exp, i) => (
                    <div class="track">
                        <div class="track-number">{trackNum("A", i)}</div>
                        <div class="track-body">
                            <div class="track-header">
                                <span class="track-title">{exp.roles[0].title}</span>
                                <span class="track-duration">{exp.roles[0].period}</span>
                            </div>
                            <span class="track-album">{exp.company} &bull; {exp.location}</span>
                            {exp.roles[0].description && (
                                <p class="track-desc">{exp.roles[0].description}</p>
                            )}
                            {exp.roles[0].bullets && exp.roles[0].bullets.length > 0 && (
                                <ul class="track-notes">
                                    {exp.roles[0].bullets.map(b => <li>{b}</li>)}
                                </ul>
                            )}
                        </div>
                    </div>
                ))}
            </div>

            <!-- SIDE B -->
            <div class="side-header">
                <div class="side-groove" aria-hidden="true"></div>
                <h3 class="side-label">Side B — The Main Stage</h3>
                <div class="side-groove" aria-hidden="true"></div>
            </div>

            <div class="tracks">
                {sideB.map((exp, i) => (
                    <div class="track">
                        <div class="track-number">{trackNum("B", i)}</div>
                        <div class="track-body">
                            <div class="track-header">
                                <span class="track-title">{exp.roles[0].title}</span>
                                <span class="track-duration">{exp.roles[0].period}</span>
                            </div>
                            <span class="track-album">{exp.company} &bull; {exp.location}</span>
                            {exp.roles[0].description && (
                                <p class="track-desc">{exp.roles[0].description}</p>
                            )}
                            {exp.roles[0].bullets && exp.roles[0].bullets.length > 0 && (
                                <ul class="track-notes">
                                    {exp.roles[0].bullets.map(b => <li>{b}</li>)}
                                </ul>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- INSTRUMENTS & EQUIPMENT -->
        <section class="gatefold-section instruments" id="instruments">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9839;</span>
                <h2 class="section-title">Instruments &amp; Equipment</h2>
            </div>
            <div class="instruments-grid">
                <div class="instrument-group">
                    <h3 class="instrument-category">Technical Instruments</h3>
                    <div class="instrument-list">
                        {skills.map(s => (
                            <span class="instrument-tag">{s}</span>
                        ))}
                    </div>
                </div>
                <div class="instrument-group">
                    <h3 class="instrument-category">Studio Equipment</h3>
                    <div class="instrument-list">
                        {managementSkills.map(s => (
                            <span class="instrument-tag studio">{s}</span>
                        ))}
                    </div>
                </div>
                <div class="instrument-group">
                    <h3 class="instrument-category">Genres</h3>
                    <div class="instrument-list">
                        {industries.map(ind => (
                            <span class="instrument-tag genre">{ind}</span>
                        ))}
                    </div>
                </div>
                <div class="instrument-group">
                    <h3 class="instrument-category">Languages</h3>
                    <div class="instrument-list">
                        {languages.map(l => (
                            <span class="instrument-tag lang">{l}</span>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- FEATURED COLLABORATIONS -->
        <section class="gatefold-section collaborations" id="collaborations">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9733;</span>
                <h2 class="section-title">Featured Collaborations</h2>
            </div>
            <div class="collab-grid">
                {engagements.map((eng, i) => (
                    <div class="collab-card">
                        <div class="collab-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
                        <div class="collab-details">
                            <span class="collab-client">feat. {eng.client}</span>
                            <span class="collab-sector">{eng.sector}</span>
                            <span class="collab-scope">{eng.scope}</span>
                            <span class="collab-impact">{eng.impact}</span>
                        </div>
                        <div class={`collab-trend ${eng.trend}`} aria-hidden="true">
                            {eng.trend === 'positive' ? '\u2197' : '\u2192'}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- INFLUENCES & TRAINING -->
        <section class="gatefold-section influences" id="influences">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9836;</span>
                <h2 class="section-title">Influences &amp; Training</h2>
            </div>
            <div class="influences-list">
                {education.map(edu => (
                    <div class="influence-card">
                        <div class="influence-icon" aria-hidden="true">&#127926;</div>
                        <div class="influence-info">
                            <span class="influence-name">{edu.institution}</span>
                            <span class="influence-degree">{edu.degree}</span>
                            <span class="influence-meta">{edu.period} &bull; {edu.location}{edu.distinction ? ` \u2014 ${edu.distinction}` : ''}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- GOLD & PLATINUM RECORDS -->
        <section class="gatefold-section awards" id="awards">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#127942;</span>
                <h2 class="section-title">Gold &amp; Platinum Records</h2>
            </div>
            <div class="awards-grid">
                {certifications.map((cert, i) => (
                    <div class="award-disc">
                        <div class="disc-surface" aria-hidden="true">
                            <div class="disc-shine"></div>
                            <div class="disc-label-center">
                                <span class="disc-number">{String(i + 1).padStart(2, '0')}</span>
                            </div>
                        </div>
                        <span class="award-name">{cert}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- B-SIDES & RARITIES -->
        <section class="gatefold-section bsides" id="bsides">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9835;</span>
                <h2 class="section-title">B-Sides &amp; Rarities</h2>
            </div>
            <div class="bsides-list">
                {continuousLearning.map((item, i) => (
                    <div class="bside-track">
                        <span class="bside-number">B{String(i + 1).padStart(2, '0')}</span>
                        <span class="bside-title">{item}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- CREDITS -->
        <section class="gatefold-section credits" id="credits">
            <div class="section-header">
                <span class="section-icon" aria-hidden="true">&#9834;</span>
                <h2 class="section-title">Credits</h2>
            </div>
            <div class="credits-content">
                <div class="credits-block">
                    <p class="credit-line"><span class="credit-role">Produced by</span> {siteMetadata.name}</p>
                    <p class="credit-line"><span class="credit-role">Engineered at</span> C3 AI, London</p>
                    <p class="credit-line"><span class="credit-role">Previously recorded at</span> Deloitte &bull; Accenture &bull; Codec</p>
                    <p class="credit-line"><span class="credit-role">Mixed at</span> Home Studio, {siteMetadata.location}</p>
                    <p class="credit-line"><span class="credit-role">Mastered by</span> 15+ Years of Experience</p>
                </div>
                <div class="credits-thanks">
                    <h3 class="thanks-title">Special Thanks</h3>
                    <p class="thanks-text">
                        To every team, client, and collaborator who made these tracks possible.
                        To the open-source community for the instruments.
                        To London, Dublin, Milan, and Bari for the inspiration.
                        And to everyone who still believes in the power of great engineering.
                    </p>
                </div>
                <div class="credits-footer">
                    <div class="barcode" aria-hidden="true">
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:3px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:3px"></span>
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:3px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                        <span class="barcode-line" style="width:3px"></span>
                        <span class="barcode-line" style="width:2px"></span>
                        <span class="barcode-line" style="width:1px"></span>
                    </div>
                    <div class="credits-legal">
                        <p>{catalogNumber} &bull; DAGNELLI RECORDS &bull; {currentYear}</p>
                        <p>&copy; {currentYear} {siteMetadata.name}. All rights reserved.</p>
                        <p>Unauthorized duplication is a violation of applicable laws.</p>
                    </div>
                    <div class="back-link">
                        <a href="/">Back to Main</a>
                    </div>
                </div>
            </div>
        </section>

    </main>

</body>
</html>

<style>
    /* ============================================
       CSS CUSTOM PROPERTIES
       ============================================ */
    :root {
        --vinyl-black: #0d0d0d;
        --sleeve-cream: #f0e6d0;
        --label-red: #cc2a2a;
        --groove-silver: #b0b0b0;
        --worn-gold: #c4a02a;
        --warm-orange: #e87020;
        --font-display: 'Anton', sans-serif;
        --font-body: 'Nunito Sans', sans-serif;
        --font-credits: 'Courier Prime', monospace;
    }

    /* ============================================
       RESET & BASE
       ============================================ */
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        scroll-behavior: smooth;
        font-size: 16px;
    }

    body {
        background: var(--vinyl-black);
        color: var(--sleeve-cream);
        font-family: var(--font-body);
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a {
        color: var(--worn-gold);
        text-decoration: none;
        transition: color 0.2s ease;
    }
    a:hover, a:focus {
        color: var(--warm-orange);
        text-decoration: underline;
    }

    /* ============================================
       CRACKLE TEXTURE OVERLAY
       ============================================ */
    .crackle-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
    }

    /* ============================================
       NOW PLAYING BAR
       ============================================ */
    .now-playing-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 48px;
        background: rgba(13, 13, 13, 0.95);
        border-bottom: 1px solid rgba(196, 160, 42, 0.3);
        display: flex;
        align-items: center;
        padding: 0 20px;
        z-index: 1000;
        gap: 16px;
        opacity: 0;
        transform: translateY(-100%);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .now-playing-bar.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .np-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .mini-record {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: radial-gradient(circle at center, #333 0%, #111 40%, #222 42%, #111 60%, #1a1a1a 100%);
        animation: spin 3s linear infinite;
        position: relative;
        border: 1px solid #333;
    }
    .mini-record-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--label-red);
    }

    .np-text {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--groove-silver);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .np-progress {
        flex: 1;
        height: 3px;
        background: rgba(176, 176, 176, 0.2);
        border-radius: 2px;
        overflow: hidden;
    }
    .np-progress-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--label-red), var(--warm-orange));
        border-radius: 2px;
        transition: width 0.1s linear;
    }

    .np-right {
        flex-shrink: 0;
    }

    /* Equalizer */
    .equalizer {
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 20px;
    }
    .eq-bar {
        display: block;
        width: 3px;
        background: var(--worn-gold);
        border-radius: 1px 1px 0 0;
        animation: eqBounce 0.8s ease-in-out infinite alternate;
    }
    .eq-bar:nth-child(1) { height: 6px; animation-delay: 0s; }
    .eq-bar:nth-child(2) { height: 14px; animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { height: 8px; animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { height: 18px; animation-delay: 0.15s; }
    .eq-bar:nth-child(5) { height: 10px; animation-delay: 0.05s; }
    .eq-bar:nth-child(6) { height: 16px; animation-delay: 0.25s; }
    .eq-bar:nth-child(7) { height: 5px; animation-delay: 0.3s; }

    @keyframes eqBounce {
        0% { transform: scaleY(0.3); }
        100% { transform: scaleY(1); }
    }

    /* ============================================
       INTRO SEQUENCE
       ============================================ */
    .intro {
        position: fixed;
        inset: 0;
        background: var(--vinyl-black);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .intro.hidden {
        display: none;
    }
    .intro.fade-out {
        animation: introFadeOut 0.8s ease forwards;
    }

    /* Record */
    .intro-record {
        position: absolute;
        width: 340px;
        height: 340px;
        border-radius: 50%;
        background: radial-gradient(
            circle at center,
            #1a1a1a 0%,
            #0f0f0f 20%,
            #1c1c1c 21%,
            #111 35%,
            #1a1a1a 36%,
            #0f0f0f 50%,
            #181818 51%,
            #111 65%,
            #1a1a1a 66%,
            #0f0f0f 80%,
            #1a1a1a 81%,
            #111 100%
        );
        border: 2px solid #333;
        transform: translateX(120vw);
        opacity: 0;
    }
    .intro-record.slide-in {
        animation: recordSlideIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .intro-record.spinning {
        animation: spin 2.5s linear infinite;
    }

    .record-grooves {
        position: absolute;
        inset: 10px;
        border-radius: 50%;
        background: repeating-radial-gradient(
            circle at center,
            transparent 0px,
            rgba(255, 255, 255, 0.03) 1px,
            transparent 2px,
            transparent 4px
        );
    }

    .record-label {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: radial-gradient(circle at 40% 40%, var(--label-red), #8a1a1a);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
    }
    .label-artist {
        font-family: var(--font-display);
        font-size: 0.8rem;
        color: var(--sleeve-cream);
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .label-cat {
        font-family: var(--font-credits);
        font-size: 0.55rem;
        color: rgba(240, 230, 208, 0.7);
    }

    .record-hole {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--vinyl-black);
        border: 1px solid #444;
    }

    /* Needle */
    .intro-needle {
        position: absolute;
        right: 15%;
        top: 20%;
        transform-origin: top right;
        opacity: 0;
    }
    .intro-needle.visible {
        opacity: 1;
        animation: needleDrop 1s ease-out forwards;
    }
    .needle-arm {
        width: 3px;
        height: 180px;
        background: linear-gradient(to bottom, var(--groove-silver), #888);
        border-radius: 2px;
        transform: rotate(-25deg);
        transform-origin: top center;
    }
    .needle-head {
        width: 8px;
        height: 8px;
        background: var(--groove-silver);
        border-radius: 50%;
        position: absolute;
        bottom: -4px;
        left: -2.5px;
    }

    /* Intro Text */
    .intro-text {
        position: relative;
        z-index: 2;
        text-align: center;
    }
    .intro-crackle {
        font-family: var(--font-credits);
        font-size: 1rem;
        color: var(--groove-silver);
        opacity: 0;
        letter-spacing: 3px;
    }
    .intro-crackle.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 8vw, 5rem);
        color: var(--sleeve-cream);
        text-transform: uppercase;
        letter-spacing: 4px;
        opacity: 0;
        margin-top: 16px;
    }
    .intro-title.visible { animation: fadeInUp 0.8s ease forwards; }

    .intro-artist {
        font-family: var(--font-body);
        font-size: clamp(1rem, 3vw, 1.5rem);
        color: var(--worn-gold);
        opacity: 0;
        margin-top: 8px;
    }
    .intro-artist.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-subtitle {
        font-family: var(--font-credits);
        font-size: clamp(0.7rem, 2vw, 0.9rem);
        color: var(--groove-silver);
        opacity: 0;
        margin-top: 8px;
        letter-spacing: 2px;
    }
    .intro-subtitle.visible { animation: fadeInUp 0.6s ease forwards; }

    .intro-now-playing {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--warm-orange);
        opacity: 0;
        margin-top: 24px;
        text-transform: uppercase;
        letter-spacing: 3px;
    }
    .intro-now-playing.visible { animation: fadeInPulse 1s ease forwards; }

    /* ============================================
       KEYFRAMES
       ============================================ */
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @keyframes recordSlideIn {
        0% { transform: translateX(120vw) rotate(0deg); opacity: 0; }
        30% { opacity: 1; }
        100% { transform: translateX(0) rotate(-720deg); opacity: 1; }
    }

    @keyframes needleDrop {
        0% { transform: rotate(-15deg); }
        60% { transform: rotate(5deg); }
        100% { transform: rotate(0deg); }
    }

    @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInPulse {
        0% { opacity: 0; }
        50% { opacity: 1; }
        75% { opacity: 0.6; }
        100% { opacity: 1; }
    }

    @keyframes introFadeOut {
        0% { opacity: 1; }
        100% { opacity: 0; pointer-events: none; }
    }

    @keyframes contentFadeIn {
        0% { opacity: 0; transform: translateY(30px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    /* ============================================
       MAIN CONTENT — ALBUM LAYOUT
       ============================================ */
    .album {
        max-width: 960px;
        margin: 0 auto;
        padding: 80px 24px 60px;
        opacity: 0;
    }
    .album.visible {
        animation: contentFadeIn 0.8s ease forwards;
    }

    /* ============================================
       ALBUM COVER / HEADER
       ============================================ */
    .album-cover {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 40px;
        align-items: start;
        margin-bottom: 60px;
        padding-bottom: 40px;
        border-bottom: 1px solid rgba(196, 160, 42, 0.2);
    }

    .cover-art {
        position: relative;
        width: 320px;
        height: 320px;
        overflow: hidden;
        border: 3px solid rgba(196, 160, 42, 0.3);
    }
    .cover-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: contrast(1.2) saturate(0.8) sepia(0.15) brightness(0.95);
    }
    .cover-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(232, 112, 32, 0.1) 0%, transparent 50%, rgba(196, 160, 42, 0.1) 100%);
        mix-blend-mode: overlay;
    }

    .cover-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .cover-label-tag {
        font-family: var(--font-credits);
        font-size: 0.7rem;
        color: var(--groove-silver);
        text-transform: uppercase;
        letter-spacing: 3px;
    }

    .cover-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3.5rem);
        color: var(--sleeve-cream);
        text-transform: uppercase;
        line-height: 1.05;
        letter-spacing: 2px;
    }

    .cover-artist {
        font-family: var(--font-body);
        font-size: clamp(1rem, 2.5vw, 1.4rem);
        color: var(--worn-gold);
        font-weight: 300;
    }

    .cover-subtitle {
        font-family: var(--font-credits);
        font-size: 0.8rem;
        color: var(--groove-silver);
        letter-spacing: 2px;
    }

    .cover-record-label {
        margin: 16px 0;
    }
    .label-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: radial-gradient(circle at 40% 40%, var(--label-red), #7a1515);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border: 2px solid rgba(196, 160, 42, 0.3);
    }
    .label-inner-text {
        font-family: var(--font-credits);
        font-size: 0.45rem;
        color: var(--sleeve-cream);
        text-align: center;
        letter-spacing: 1px;
        line-height: 1.3;
        text-transform: uppercase;
    }
    .label-hole {
        position: absolute;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--vinyl-black);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .cover-meta {
        display: flex;
        gap: 16px;
        font-family: var(--font-credits);
        font-size: 0.7rem;
        color: var(--groove-silver);
        letter-spacing: 1px;
    }

    .cover-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 8px;
    }
    .cover-link {
        font-family: var(--font-credits);
        font-size: 0.8rem;
        padding: 6px 14px;
        border: 1px solid var(--worn-gold);
        border-radius: 2px;
        color: var(--worn-gold);
        transition: all 0.2s ease;
        min-width: 44px;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .cover-link:hover, .cover-link:focus {
        background: var(--worn-gold);
        color: var(--vinyl-black);
        text-decoration: none;
    }

    /* ============================================
       GATEFOLD SECTIONS
       ============================================ */
    .gatefold-section {
        margin-bottom: 56px;
        padding: 32px;
        background: rgba(240, 230, 208, 0.03);
        border: 1px solid rgba(196, 160, 42, 0.1);
        border-radius: 2px;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 28px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--label-red);
    }
    .section-icon {
        font-size: 1.3rem;
        color: var(--worn-gold);
    }
    .section-title {
        font-family: var(--font-display);
        font-size: clamp(1.4rem, 3vw, 1.8rem);
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--sleeve-cream);
    }

    /* ============================================
       LINER NOTES
       ============================================ */
    .liner-notes-content {
        background: rgba(240, 230, 208, 0.05);
        padding: 24px;
        border-left: 3px solid var(--worn-gold);
    }
    .liner-text {
        font-family: var(--font-body);
        font-size: 1rem;
        line-height: 1.8;
        color: var(--sleeve-cream);
        font-style: italic;
    }
    .liner-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 24px;
    }
    .metric-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 12px 18px;
        background: rgba(204, 42, 42, 0.1);
        border: 1px solid rgba(204, 42, 42, 0.3);
        border-radius: 2px;
        min-width: 100px;
    }
    .metric-value {
        font-family: var(--font-display);
        font-size: 1.4rem;
        color: var(--warm-orange);
    }
    .metric-label {
        font-family: var(--font-credits);
        font-size: 0.65rem;
        color: var(--groove-silver);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-top: 4px;
    }

    /* ============================================
       TRACK LISTING
       ============================================ */
    .side-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 32px 0 20px;
    }
    .side-header:first-of-type {
        margin-top: 0;
    }
    .side-groove {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--groove-silver), transparent);
    }
    .side-label {
        font-family: var(--font-display);
        font-size: 1.1rem;
        color: var(--worn-gold);
        text-transform: uppercase;
        letter-spacing: 3px;
        white-space: nowrap;
    }

    .tracks {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .track {
        display: grid;
        grid-template-columns: 48px 1fr;
        gap: 16px;
        padding: 18px 0;
        border-bottom: 1px solid rgba(176, 176, 176, 0.1);
        transition: background 0.2s ease;
    }
    .track:hover {
        background: rgba(240, 230, 208, 0.03);
    }
    .track:last-child {
        border-bottom: none;
    }

    .track-number {
        font-family: var(--font-display);
        font-size: 1.3rem;
        color: var(--label-red);
        text-align: center;
        padding-top: 2px;
    }

    .track-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .track-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 12px;
        flex-wrap: wrap;
    }
    .track-title {
        font-family: var(--font-body);
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--sleeve-cream);
    }
    .track-duration {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--groove-silver);
        white-space: nowrap;
        letter-spacing: 0.5px;
    }
    .track-album {
        font-family: var(--font-credits);
        font-size: 0.8rem;
        color: var(--worn-gold);
    }
    .track-desc {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: rgba(240, 230, 208, 0.75);
        margin-top: 4px;
        line-height: 1.6;
    }
    .track-notes {
        list-style: none;
        margin-top: 6px;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    .track-notes li {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: rgba(240, 230, 208, 0.6);
        padding-left: 16px;
        position: relative;
    }
    .track-notes li::before {
        content: "\25B8";
        position: absolute;
        left: 0;
        color: var(--label-red);
    }

    /* ============================================
       INSTRUMENTS & EQUIPMENT
       ============================================ */
    .instruments-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 28px;
    }

    .instrument-category {
        font-family: var(--font-display);
        font-size: 0.95rem;
        color: var(--worn-gold);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 12px;
    }
    .instrument-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .instrument-tag {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        padding: 5px 12px;
        border: 1px solid rgba(176, 176, 176, 0.3);
        border-radius: 2px;
        color: var(--sleeve-cream);
        background: rgba(176, 176, 176, 0.05);
        transition: all 0.2s ease;
    }
    .instrument-tag:hover {
        border-color: var(--worn-gold);
        background: rgba(196, 160, 42, 0.1);
    }
    .instrument-tag.studio {
        border-color: rgba(232, 112, 32, 0.3);
    }
    .instrument-tag.studio:hover {
        border-color: var(--warm-orange);
        background: rgba(232, 112, 32, 0.1);
    }
    .instrument-tag.genre {
        border-color: rgba(204, 42, 42, 0.3);
    }
    .instrument-tag.genre:hover {
        border-color: var(--label-red);
        background: rgba(204, 42, 42, 0.1);
    }
    .instrument-tag.lang {
        border-color: rgba(196, 160, 42, 0.4);
        color: var(--worn-gold);
    }

    /* ============================================
       FEATURED COLLABORATIONS
       ============================================ */
    .collab-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .collab-card {
        display: grid;
        grid-template-columns: 40px 1fr 40px;
        gap: 16px;
        align-items: center;
        padding: 16px;
        background: rgba(240, 230, 208, 0.03);
        border: 1px solid rgba(176, 176, 176, 0.1);
        border-radius: 2px;
        transition: border-color 0.2s ease;
    }
    .collab-card:hover {
        border-color: var(--worn-gold);
    }
    .collab-number {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--label-red);
        text-align: center;
    }
    .collab-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px 16px;
    }
    .collab-client {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--sleeve-cream);
        text-transform: capitalize;
    }
    .collab-sector {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--worn-gold);
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .collab-scope {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: rgba(240, 230, 208, 0.7);
    }
    .collab-impact {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: var(--warm-orange);
        font-weight: 600;
    }
    .collab-trend {
        font-size: 1.2rem;
        text-align: center;
    }
    .collab-trend.positive { color: var(--worn-gold); }
    .collab-trend.neutral { color: var(--groove-silver); }

    /* ============================================
       INFLUENCES & TRAINING
       ============================================ */
    .influences-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .influence-card {
        display: flex;
        gap: 16px;
        align-items: flex-start;
        padding: 16px;
        background: rgba(240, 230, 208, 0.03);
        border-left: 3px solid var(--worn-gold);
    }
    .influence-icon {
        font-size: 1.5rem;
        flex-shrink: 0;
        margin-top: 2px;
    }
    .influence-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .influence-name {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--sleeve-cream);
    }
    .influence-degree {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--worn-gold);
    }
    .influence-meta {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--groove-silver);
        letter-spacing: 0.5px;
    }

    /* ============================================
       GOLD & PLATINUM RECORDS (AWARDS)
       ============================================ */
    .awards-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .award-disc {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        text-align: center;
    }
    .disc-surface {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #e8d68e, var(--worn-gold), #8a6e15);
        position: relative;
        overflow: hidden;
        border: 2px solid rgba(196, 160, 42, 0.5);
    }
    .disc-shine {
        position: absolute;
        top: -20%;
        left: -20%;
        width: 60%;
        height: 60%;
        background: radial-gradient(ellipse, rgba(255, 255, 255, 0.3), transparent 70%);
        transform: rotate(-30deg);
    }
    .disc-label-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--vinyl-black);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .disc-number {
        font-family: var(--font-credits);
        font-size: 0.6rem;
        color: var(--worn-gold);
    }
    .award-name {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--sleeve-cream);
        letter-spacing: 0.5px;
        line-height: 1.4;
    }

    /* ============================================
       B-SIDES & RARITIES
       ============================================ */
    .bsides-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .bside-track {
        display: flex;
        gap: 16px;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid rgba(176, 176, 176, 0.08);
    }
    .bside-track:last-child { border-bottom: none; }
    .bside-number {
        font-family: var(--font-credits);
        font-size: 0.75rem;
        color: var(--label-red);
        min-width: 36px;
        letter-spacing: 1px;
    }
    .bside-title {
        font-family: var(--font-body);
        font-size: 0.95rem;
        color: var(--sleeve-cream);
    }

    /* ============================================
       CREDITS
       ============================================ */
    .credits-content {
        font-family: var(--font-credits);
    }
    .credits-block {
        margin-bottom: 28px;
    }
    .credit-line {
        font-size: 0.8rem;
        color: var(--groove-silver);
        line-height: 2;
    }
    .credit-role {
        color: var(--worn-gold);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .credits-thanks {
        margin-bottom: 32px;
        padding: 20px;
        background: rgba(240, 230, 208, 0.04);
        border: 1px solid rgba(196, 160, 42, 0.15);
    }
    .thanks-title {
        font-family: var(--font-display);
        font-size: 1rem;
        color: var(--worn-gold);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }
    .thanks-text {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: rgba(240, 230, 208, 0.7);
        line-height: 1.8;
        font-style: italic;
    }

    .credits-footer {
        display: flex;
        flex-direction: column;
