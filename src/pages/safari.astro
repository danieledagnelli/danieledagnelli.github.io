---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Safari Expedition Log</title>
    <meta name="description" content="Wildlife Safari Expedition Log — A field journal documenting the career and capabilities of Daniele D'Agnelli, Senior Engagement Manager." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/safari" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta property="og:description" content="A field expedition journal documenting 15+ years of habitat migrations across professional services, AI, and cybersecurity." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/safari" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta name="twitter:description" content="A field expedition journal documenting 15+ years of habitat migrations across professional services, AI, and cybersecurity." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,600;0,700;1,400&family=Caveat:wght@400;600;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- DUST PARTICLES -->
    <canvas id="dustCanvas" class="dust-canvas" aria-hidden="true"></canvas>

    <!-- COMPASS BEARING -->
    <div class="compass-bearing" id="compassBearing" aria-hidden="true">
        <span class="compass-icon">&#9678;</span>
        <span class="compass-dir" id="compassDir">N</span>
        <span class="compass-deg" id="compassDeg">0&deg;</span>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="dawn-sky" id="dawnSky" aria-hidden="true"></div>
        <div class="silhouette" id="silhouette" aria-hidden="true">
            <svg viewBox="0 0 800 200" preserveAspectRatio="xMidYMax meet" class="silhouette-svg">
                <!-- Acacia tree -->
                <ellipse cx="600" cy="60" rx="90" ry="50" fill="#1a1a1a"/>
                <rect x="596" y="100" width="8" height="80" fill="#1a1a1a"/>
                <ellipse cx="580" cy="80" rx="40" ry="25" fill="#1a1a1a"/>
                <ellipse cx="630" cy="70" rx="35" ry="22" fill="#1a1a1a"/>
                <!-- Grass -->
                <path d="M0,180 Q50,160 80,180 Q110,155 140,180 Q170,158 200,180 Q230,160 260,180 Q290,155 320,180 Q350,162 380,180 Q410,155 440,180 Q470,160 500,180 Q530,158 560,180 Q590,160 620,180 Q650,155 680,180 Q710,162 740,180 Q770,158 800,180 L800,200 L0,200 Z" fill="#1a1a1a"/>
                <!-- Small distant tree -->
                <ellipse cx="200" cy="120" rx="25" ry="18" fill="#1a1a1a"/>
                <rect x="198" y="132" width="4" height="30" fill="#1a1a1a"/>
                <!-- Bird silhouettes -->
                <path d="M350,40 Q355,35 360,40 Q365,35 370,40" fill="none" stroke="#1a1a1a" stroke-width="2"/>
                <path d="M380,30 Q384,26 388,30 Q392,26 396,30" fill="none" stroke="#1a1a1a" stroke-width="1.5"/>
            </svg>
        </div>
        <div class="binocular-mask" id="binocularMask" aria-hidden="true"></div>
        <div class="intro-text" id="introText">
            <div class="intro-line" id="introLine1"></div>
            <div class="intro-line" id="introLine2"></div>
            <div class="intro-line" id="introLine3"></div>
        </div>
        <div class="intro-skip">click / esc / space to skip</div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journal" id="journal">

        <div class="safari-narrative">
            <h1 class="expedition-title">EXPEDITION LOG — D'AGNELLI SURVEY</h1>
            <div class="expedition-meta">field seasons: 2012-present | base camp: london</div>

            <h2 class="section-title">HABITATS DOCUMENTED</h2>

            <div class="habitat">
                <strong>manufacturing</strong> — the dominant biome. 100+ sites catalogued for swiss industrial giant. predictive maintenance species identified. $18m yield.
            </div>
            <div class="habitat">
                <strong>telecom</strong> — dense urban habitat. first enterprise-wide deployment across 7 territories for british telco.
            </div>
            <div class="habitat">
                <strong>financial services</strong> — two distinct subspecies observed. american bank (75k-strong colony, data architecture). uk investment firm (&pound;170.3b foraging range, financial planning).
            </div>
            <div class="habitat">
                <strong>healthcare &middot; oil &amp; gas &middot; aerospace &amp; defence</strong> — additional biomes explored. high-sensitivity environments. resilient solutions deployed.
            </div>

            <div class="credentials">
                EXPEDITION LEADER CREDENTIALS: msc ethical hacking (distinction) | bsc computer science | prince2 practitioner | stanford ml certified
            </div>

            <div class="safari-footer">
                <a href="mailto:daniele@dagnelli.net">[field contact]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* ========================================
       SAFARI EXPEDITION — GLOBAL STYLES
       ======================================== */

    :root {
        --savanna-gold: #c9a84c;
        --dusty-khaki: #d4c5a0;
        --safari-green: #3a5a20;
        --earth-brown: #5c3d2e;
        --sunset-orange: #d4660a;
        --sky-blue: #5a9fce;
        --canvas: #f0e8d4;
        --canvas-dark: #e5d9c0;
        --leather: #8b6914;
        --ink: #2c1810;
        --ink-light: #5a4535;

        --font-serif: 'Bitter', Georgia, 'Times New Roman', serif;
        --font-handwriting: 'Caveat', cursive;
        --font-sans: 'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: var(--font-serif);
        background: var(--canvas);
        color: var(--ink);
        line-height: 1.7;
        overflow-x: hidden;
        position: relative;
        min-height: 100vh;
    }

    /* Topographic contour lines background */
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.04;
        background-image:
            repeating-radial-gradient(ellipse at 20% 50%, transparent 0, transparent 40px, var(--earth-brown) 40px, var(--earth-brown) 41px, transparent 41px, transparent 80px),
            repeating-radial-gradient(ellipse at 80% 30%, transparent 0, transparent 55px, var(--earth-brown) 55px, var(--earth-brown) 56px, transparent 56px, transparent 110px),
            repeating-radial-gradient(ellipse at 50% 80%, transparent 0, transparent 35px, var(--earth-brown) 35px, var(--earth-brown) 36px, transparent 36px, transparent 70px);
    }

    /* Warm golden hour gradient overlay */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background: linear-gradient(
            175deg,
            rgba(201, 168, 76, 0.06) 0%,
            rgba(212, 102, 10, 0.03) 40%,
            transparent 70%
        );
        animation: goldenShift 20s ease-in-out infinite alternate;
    }

    @keyframes goldenShift {
        0% { opacity: 0.8; }
        50% { opacity: 1; }
        100% { opacity: 0.7; }
    }

    a {
        color: var(--earth-brown);
        text-decoration: underline;
        text-decoration-color: var(--savanna-gold);
        text-underline-offset: 3px;
        transition: color 0.2s;
    }

    a:hover {
        color: var(--sunset-orange);
    }

    /* ========================================
       DUST PARTICLES CANVAS
       ======================================== */

    .dust-canvas {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        width: 100%;
        height: 100%;
    }

    /* ========================================
       COMPASS BEARING
       ======================================== */

    .compass-bearing {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(240, 232, 212, 0.9);
        border: 1px solid var(--dusty-khaki);
        border-radius: 4px;
        padding: 6px 12px;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--earth-brown);
        letter-spacing: 0.05em;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .compass-icon {
        font-size: 1rem;
        color: var(--savanna-gold);
    }

    .compass-dir {
        font-size: 0.85rem;
        min-width: 1.6em;
        text-align: center;
    }

    .compass-deg {
        color: var(--ink-light);
        font-size: 0.7rem;
    }

    /* ========================================
       INTRO SEQUENCE
       ======================================== */

    .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .intro.hidden {
        display: none;
    }

    .dawn-sky {
        position: absolute;
        inset: 0;
        background: #0a1628;
        transition: background 1s ease;
    }

    .dawn-sky.phase1 {
        background: linear-gradient(to top, #d4660a 0%, #c9a84c 30%, #2a3a5c 70%, #0a1628 100%);
    }

    .dawn-sky.phase2 {
        background: linear-gradient(to top, #e8a030 0%, #d4660a 20%, #c9a84c 45%, #5a9fce 80%, #2a3a5c 100%);
    }

    .silhouette {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 200px;
        z-index: 2;
        opacity: 0;
        transition: opacity 0.8s ease;
    }

    .silhouette.visible {
        opacity: 1;
    }

    .silhouette-svg {
        width: 100%;
        height: 100%;
    }

    .binocular-mask {
        position: absolute;
        inset: 0;
        z-index: 3;
        background: radial-gradient(ellipse 22% 35% at 38% 50%, transparent 98%, #000 100%),
                    radial-gradient(ellipse 22% 35% at 62% 50%, transparent 98%, #000 100%),
                    radial-gradient(ellipse 50% 50% at 50% 50%, transparent 30%, #000 70%);
        opacity: 1;
        transition: opacity 1s ease;
    }

    .binocular-mask.open {
        opacity: 0;
    }

    .intro-text {
        position: relative;
        z-index: 4;
        text-align: center;
        padding: 0 20px;
    }

    .intro-line {
        font-family: var(--font-handwriting);
        color: var(--canvas);
        font-size: 1.6rem;
        font-weight: 600;
        margin-bottom: 0.5em;
        text-shadow: 0 2px 8px rgba(0,0,0,0.6);
        min-height: 1.3em;
        letter-spacing: 0.03em;
    }

    .intro-line:first-child {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
    }

    .intro-skip {
        position: absolute;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 5;
        font-family: var(--font-sans);
        font-size: 0.7rem;
        color: rgba(240, 232, 212, 0.5);
        letter-spacing: 0.15em;
        text-transform: uppercase;
    }

    /* ========================================
       JOURNAL — MAIN CONTAINER (VIEWPORT-LOCKED)
       ======================================== */

    .journal {
        position: relative;
        z-index: 2;
        margin: 0 auto;
        opacity: 0;
        transition: opacity 0.8s ease;
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .journal.visible {
        opacity: 1;
    }

    /* ========================================
       SAFARI NARRATIVE — SINGLE VIEWPORT
       ======================================== */

    .safari-narrative {
        max-width: 620px;
        padding: 1.5rem;
    }

    .expedition-title {
        font-family: var(--font-sans);
        font-size: 1rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.2rem;
        color: var(--earth-brown);
        letter-spacing: 0.1em;
        animation: heatHaze 6s ease-in-out infinite;
    }

    .expedition-meta {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
        letter-spacing: 0.05em;
    }

    .section-title {
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        margin-bottom: 0.5rem;
        color: var(--earth-brown);
    }

    .habitat {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
        color: var(--ink);
    }

    .habitat strong {
        color: var(--safari-green);
        font-weight: 600;
    }

    .credentials {
        font-family: var(--font-sans);
        font-size: 0.7rem;
        opacity: 0.7;
        margin: 0.8rem 0;
        line-height: 1.5;
    }

    .safari-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .safari-footer a {
        font-family: var(--font-sans);
        font-size: 0.78rem;
        text-decoration: none;
    }

    /* ========================================
       ANIMATIONS (kept for Kodachrome aesthetic)
       ======================================== */

    @keyframes heatHaze {
        0%, 100% { filter: blur(0px); transform: translateX(0); }
        25% { filter: blur(0.3px); transform: translateX(0.3px); }
        50% { filter: blur(0px); transform: translateX(0); }
        75% { filter: blur(0.2px); transform: translateX(-0.2px); }
    }

    /* ========================================
       RESPONSIVE — 768px
       ======================================== */

    @media (max-width: 768px) {
        .habitat {
            font-size: 0.72rem;
        }

        .safari-narrative {
            padding: 1rem;
        }

        .intro-line {
            font-size: 1.2rem;
        }

        .intro-line:first-child {
            font-size: 0.85rem;
        }
    }

    /* ========================================
       RESPONSIVE — 380px
       ======================================== */

    @media (max-width: 380px) {
        .compass-bearing {
            top: 8px;
            right: 8px;
            padding: 4px 8px;
            font-size: 0.65rem;
        }
    }
</style>

<script>
    /* ========================================
       SAFARI — INTRO SEQUENCE
       ======================================== */

    (function() {
        const STORAGE_KEY = 'safari-intro';
        const intro = document.getElementById('intro');
        const journal = document.getElementById('journal');
        const dawnSky = document.getElementById('dawnSky');
        const silhouette = document.getElementById('silhouette');
        const binocularMask = document.getElementById('binocularMask');
        const introLine1 = document.getElementById('introLine1');
        const introLine2 = document.getElementById('introLine2');
        const introLine3 = document.getElementById('introLine3');

        if (!intro || !journal) return;

        function showMainContent() {
            intro.classList.add('hidden');
            journal.classList.add('visible');
            sessionStorage.setItem(STORAGE_KEY, '1');
        }

        // Skip intro if already seen
        if (sessionStorage.getItem(STORAGE_KEY)) {
            showMainContent();
            return;
        }

        // Show journal when intro ends
        let introFinished = false;

        function finishIntro() {
            if (introFinished) return;
            introFinished = true;
            if (binocularMask) binocularMask.classList.add('open');
            setTimeout(showMainContent, 800);
        }

        // Skip handlers
        function skipIntro(e: Event) {
            if (e instanceof KeyboardEvent) {
                if (!['Escape', ' ', 'Enter'].includes(e.key)) return;
            }
            e.preventDefault();
            finishIntro();
        }

        document.addEventListener('click', skipIntro);
        document.addEventListener('keydown', skipIntro);

        // Typewriter effect
        function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
            return new Promise((resolve) => {
                let i = 0;
                function type() {
                    if (introFinished) { el.textContent = text; resolve(); return; }
                    if (i < text.length) {
                        el.textContent += text.charAt(i);
                        i++;
                        setTimeout(type, speed);
                    } else {
                        resolve();
                    }
                }
                type();
            });
        }

        // Run intro sequence
        async function runIntro() {
            // Phase 1: dawn sky gradient
            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (dawnSky) dawnSky.classList.add('phase1');

            await new Promise(r => setTimeout(r, 800));
            if (introFinished) return;
            if (dawnSky) dawnSky.classList.add('phase2');

            // Phase 2: silhouette appears
            await new Promise(r => setTimeout(r, 600));
            if (introFinished) return;
            if (silhouette) silhouette.classList.add('visible');

            // Phase 3: text types in
            await new Promise(r => setTimeout(r, 500));
            if (introFinished) return;
            if (introLine1) await typeText(introLine1, 'EXPEDITION LOG \u2014 DAY 1', 45);

            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (introLine2) await typeText(introLine2, 'Specimen Identified: Daniele D\'Agnelli', 35);

            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (introLine3) await typeText(introLine3, 'Habitat: London, UK \u2014 Classification: Homo Technologicus', 30);

            // Phase 4: binocular opens
            await new Promise(r => setTimeout(r, 1200));
            finishIntro();
        }

        runIntro();

        // Cleanup listeners on finish
        const observer = new MutationObserver(() => {
            if (intro.classList.contains('hidden')) {
                document.removeEventListener('click', skipIntro);
                document.removeEventListener('keydown', skipIntro);
                observer.disconnect();
            }
        });
        observer.observe(intro, { attributes: true, attributeFilter: ['class'] });
    })();

    /* ========================================
       DUST PARTICLES
       ======================================== */

    (function() {
        const canvas = document.getElementById('dustCanvas') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let w = 0, h = 0;

        interface Particle {
            x: number;
            y: number;
            r: number;
            dx: number;
            dy: number;
            opacity: number;
            fadeDir: number;
        }

        const particles: Particle[] = [];
        const PARTICLE_COUNT = 40;

        function resize() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
        }

        function init() {
            resize();
            particles.length = 0;
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                particles.push({
                    x: Math.random() * w,
                    y: Math.random() * h,
                    r: Math.random() * 1.8 + 0.5,
                    dx: (Math.random() - 0.5) * 0.3,
                    dy: (Math.random() - 0.5) * 0.15 - 0.05,
                    opacity: Math.random() * 0.3 + 0.1,
                    fadeDir: Math.random() > 0.5 ? 1 : -1,
                });
            }
        }

        function draw() {
            ctx!.clearRect(0, 0, w, h);
            for (const p of particles) {
                p.x += p.dx;
                p.y += p.dy;
                p.opacity += p.fadeDir * 0.002;
                if (p.opacity > 0.4) p.fadeDir = -1;
                if (p.opacity < 0.05) p.fadeDir = 1;

                if (p.x < -10) p.x = w + 10;
                if (p.x > w + 10) p.x = -10;
                if (p.y < -10) p.y = h + 10;
                if (p.y > h + 10) p.y = -10;

                ctx!.beginPath();
                ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx!.fillStyle = `rgba(212, 197, 160, ${p.opacity})`;
                ctx!.fill();
            }
            requestAnimationFrame(draw);
        }

        init();
        draw();
        window.addEventListener('resize', resize);
    })();

    /* ========================================
       COMPASS BEARING
       ======================================== */

    (function() {
        const dirEl = document.getElementById('compassDir');
        const degEl = document.getElementById('compassDeg');
        if (!dirEl || !degEl) return;

        const directions = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];

        function update() {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const ratio = docHeight > 0 ? scrollTop / docHeight : 0;
            const deg = Math.round(ratio * 360);
            const idx = Math.round(ratio * 7) % 8;
            dirEl!.textContent = directions[idx];
            degEl!.innerHTML = deg + '&deg;';
        }

        window.addEventListener('scroll', update, { passive: true });
        update();
    })();
</script>
