<script>
    /* ========================================
       SAFARI — INTRO SEQUENCE
       ======================================== */

    (function() {
        const STORAGE_KEY = 'safari-intro';
        const intro = document.getElementById('intro');
        const journal = document.getElementById('journal');
        const dawnSky = document.getElementById('dawnSky');
        const silhouette = document.getElementById('silhouette');
        const binocularMask = document.getElementById('binocularMask');
        const introLine1 = document.getElementById('introLine1');
        const introLine2 = document.getElementById('introLine2');
        const introLine3 = document.getElementById('introLine3');

        if (!intro || !journal) return;

        function showMainContent() {
            intro.classList.add('hidden');
            journal.classList.add('visible');
            sessionStorage.setItem(STORAGE_KEY, '1');
        }

        // Skip intro if already seen
        if (sessionStorage.getItem(STORAGE_KEY)) {
            showMainContent();
            return;
        }

        // Show journal when intro ends
        let introFinished = false;

        function finishIntro() {
            if (introFinished) return;
            introFinished = true;
            if (binocularMask) binocularMask.classList.add('open');
            setTimeout(showMainContent, 800);
        }

        // Skip handlers
        function skipIntro(e: Event) {
            if (e instanceof KeyboardEvent) {
                if (!['Escape', ' ', 'Enter'].includes(e.key)) return;
            }
            e.preventDefault();
            finishIntro();
        }

        document.addEventListener('click', skipIntro);
        document.addEventListener('keydown', skipIntro);

        // Typewriter effect
        function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
            return new Promise((resolve) => {
                let i = 0;
                function type() {
                    if (introFinished) { el.textContent = text; resolve(); return; }
                    if (i < text.length) {
                        el.textContent += text.charAt(i);
                        i++;
                        setTimeout(type, speed);
                    } else {
                        resolve();
                    }
                }
                type();
            });
        }

        // Run intro sequence
        async function runIntro() {
            // Phase 1: dawn sky gradient
            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (dawnSky) dawnSky.classList.add('phase1');

            await new Promise(r => setTimeout(r, 800));
            if (introFinished) return;
            if (dawnSky) dawnSky.classList.add('phase2');

            // Phase 2: silhouette appears
            await new Promise(r => setTimeout(r, 600));
            if (introFinished) return;
            if (silhouette) silhouette.classList.add('visible');

            // Phase 3: text types in
            await new Promise(r => setTimeout(r, 500));
            if (introFinished) return;
            if (introLine1) await typeText(introLine1, 'EXPEDITION LOG \u2014 DAY 1', 45);

            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (introLine2) await typeText(introLine2, 'Specimen Identified: Daniele D\'Agnelli', 35);

            await new Promise(r => setTimeout(r, 300));
            if (introFinished) return;
            if (introLine3) await typeText(introLine3, 'Habitat: London, UK \u2014 Classification: Homo Technologicus', 30);

            // Phase 4: binocular opens
            await new Promise(r => setTimeout(r, 1200));
            finishIntro();
        }

        runIntro();

        // Cleanup listeners on finish
        const observer = new MutationObserver(() => {
            if (intro.classList.contains('hidden')) {
                document.removeEventListener('click', skipIntro);
                document.removeEventListener('keydown', skipIntro);
                observer.disconnect();
            }
        });
        observer.observe(intro, { attributes: true, attributeFilter: ['class'] });
    })();

    /* ========================================
       DUST PARTICLES
       ======================================== */

    (function() {
        const canvas = document.getElementById('dustCanvas') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let w = 0, h = 0;

        interface Particle {
            x: number;
            y: number;
            r: number;
            dx: number;
            dy: number;
            opacity: number;
            fadeDir: number;
        }

        const particles: Particle[] = [];
        const PARTICLE_COUNT = 40;

        function resize() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
        }

        function init() {
            resize();
            particles.length = 0;
            for (let i = 0; i < PARTICLE_COUNT; i++) {
                particles.push({
                    x: Math.random() * w,
                    y: Math.random() * h,
                    r: Math.random() * 1.8 + 0.5,
                    dx: (Math.random() - 0.5) * 0.3,
                    dy: (Math.random() - 0.5) * 0.15 - 0.05,
                    opacity: Math.random() * 0.3 + 0.1,
                    fadeDir: Math.random() > 0.5 ? 1 : -1,
                });
            }
        }

        function draw() {
            ctx!.clearRect(0, 0, w, h);
            for (const p of particles) {
                p.x += p.dx;
                p.y += p.dy;
                p.opacity += p.fadeDir * 0.002;
                if (p.opacity > 0.4) p.fadeDir = -1;
                if (p.opacity < 0.05) p.fadeDir = 1;

                if (p.x < -10) p.x = w + 10;
                if (p.x > w + 10) p.x = -10;
                if (p.y < -10) p.y = h + 10;
                if (p.y > h + 10) p.y = -10;

                ctx!.beginPath();
                ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx!.fillStyle = `rgba(212, 197, 160, ${p.opacity})`;
                ctx!.fill();
            }
            requestAnimationFrame(draw);
        }

        init();
        draw();
        window.addEventListener('resize', resize);
    })();

    /* ========================================
       COMPASS BEARING
       ======================================== */

    (function() {
        const dirEl = document.getElementById('compassDir');
        const degEl = document.getElementById('compassDeg');
        if (!dirEl || !degEl) return;

        const directions = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];

        function update() {
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            const ratio = docHeight > 0 ? scrollTop / docHeight : 0;
            const deg = Math.round(ratio * 360);
            const idx = Math.round(ratio * 7) % 8;
            dirEl!.textContent = directions[idx];
            degEl!.innerHTML = deg + '&deg;';
        }

        window.addEventListener('scroll', update, { passive: true });
        update();
    })();
</script>
