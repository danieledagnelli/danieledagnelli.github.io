---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Safari Expedition Log</title>
    <meta name="description" content="Wildlife Safari Expedition Log — A field journal documenting the career and capabilities of Daniele D'Agnelli, Senior Engagement Manager." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/safari" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta property="og:description" content="A field expedition journal documenting 15+ years of habitat migrations across professional services, AI, and cybersecurity." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/safari" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Safari Expedition Log" />
    <meta name="twitter:description" content="A field expedition journal documenting 15+ years of habitat migrations across professional services, AI, and cybersecurity." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,600;0,700;1,400&family=Caveat:wght@400;600;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- DUST PARTICLES -->
    <canvas id="dustCanvas" class="dust-canvas" aria-hidden="true"></canvas>

    <!-- COMPASS BEARING -->
    <div class="compass-bearing" id="compassBearing" aria-hidden="true">
        <span class="compass-icon">&#9678;</span>
        <span class="compass-dir" id="compassDir">N</span>
        <span class="compass-deg" id="compassDeg">0&deg;</span>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="dawn-sky" id="dawnSky" aria-hidden="true"></div>
        <div class="silhouette" id="silhouette" aria-hidden="true">
            <svg viewBox="0 0 800 200" preserveAspectRatio="xMidYMax meet" class="silhouette-svg">
                <!-- Acacia tree -->
                <ellipse cx="600" cy="60" rx="90" ry="50" fill="#1a1a1a"/>
                <rect x="596" y="100" width="8" height="80" fill="#1a1a1a"/>
                <ellipse cx="580" cy="80" rx="40" ry="25" fill="#1a1a1a"/>
                <ellipse cx="630" cy="70" rx="35" ry="22" fill="#1a1a1a"/>
                <!-- Grass -->
                <path d="M0,180 Q50,160 80,180 Q110,155 140,180 Q170,158 200,180 Q230,160 260,180 Q290,155 320,180 Q350,162 380,180 Q410,155 440,180 Q470,160 500,180 Q530,158 560,180 Q590,160 620,180 Q650,155 680,180 Q710,162 740,180 Q770,158 800,180 L800,200 L0,200 Z" fill="#1a1a1a"/>
                <!-- Small distant tree -->
                <ellipse cx="200" cy="120" rx="25" ry="18" fill="#1a1a1a"/>
                <rect x="198" y="132" width="4" height="30" fill="#1a1a1a"/>
                <!-- Bird silhouettes -->
                <path d="M350,40 Q355,35 360,40 Q365,35 370,40" fill="none" stroke="#1a1a1a" stroke-width="2"/>
                <path d="M380,30 Q384,26 388,30 Q392,26 396,30" fill="none" stroke="#1a1a1a" stroke-width="1.5"/>
            </svg>
        </div>
        <div class="binocular-mask" id="binocularMask" aria-hidden="true"></div>
        <div class="intro-text" id="introText">
            <div class="intro-line" id="introLine1"></div>
            <div class="intro-line" id="introLine2"></div>
            <div class="intro-line" id="introLine3"></div>
        </div>
        <div class="intro-skip">click / esc / space to skip</div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journal" id="journal">

        <!-- JOURNAL COVER -->
        <header class="journal-cover">
            <div class="journal-binding" aria-hidden="true"></div>
            <div class="cover-content">
                <div class="cover-stamp">FIELD EXPEDITION JOURNAL</div>
                <h1 class="cover-title">Wildlife Safari<br/>Expedition Log</h1>
                <div class="cover-subject">
                    <span class="cover-label">Subject:</span>
                    {siteMetadata.name}
                </div>
                <div class="cover-meta">
                    <span class="cover-label">Classification:</span> Homo Technologicus
                </div>
                <div class="cover-meta">
                    <span class="cover-label">Base Camp:</span> {siteMetadata.location}
                </div>
                <div class="cover-meta">
                    <span class="cover-label">Lead Researcher:</span> You, the reader
                </div>
            </div>
        </header>

        <!-- SPECIMEN PHOTOGRAPH -->
        <section class="section specimen-photo-section">
            <div class="polaroid">
                <div class="tape tape-left" aria-hidden="true"></div>
                <div class="tape tape-right" aria-hidden="true"></div>
                <img src="/assets/dani.jpeg" alt="Specimen photograph of Daniele D'Agnelli" class="specimen-img" width="280" height="280" loading="eager" />
                <div class="polaroid-label">
                    <span class="label-handwritten">Specimen #001</span>
                    <span class="label-date">Photographed in natural habitat</span>
                </div>
            </div>
            <div class="specimen-tag">
                <div class="tag-header">FIELD IDENTIFICATION TAG</div>
                <div class="tag-row"><span class="tag-key">Common Name:</span> <span class="tag-val">{siteMetadata.name}</span></div>
                <div class="tag-row"><span class="tag-key">Classification:</span> <span class="tag-val">Homo Technologicus</span></div>
                <div class="tag-row"><span class="tag-key">Habitat:</span> <span class="tag-val">{siteMetadata.location}</span></div>
                <div class="tag-row"><span class="tag-key">Temperament:</span> <span class="tag-val">Collaborative, Persistent</span></div>
                <div class="tag-row"><span class="tag-key">Contact:</span> <span class="tag-val">{siteMetadata.email}</span></div>
                <div class="tag-row links-row">
                    <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener noreferrer">GitHub</a>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
                    <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener noreferrer">Bluesky</a>
                </div>
            </div>
        </section>

        <!-- SECTION DIVIDER -->
        <div class="divider" aria-hidden="true"><span class="divider-tracks">&#128062; &middot; &#128062; &middot; &#128062;</span></div>

        <!-- FIELD OBSERVATION SUMMARY -->
        <section class="section" id="summary">
            <div class="section-header">
                <div class="gps-stamp">GPS: 51.5074&deg; N, 0.1278&deg; W</div>
                <div class="date-stamp">Date: 2024.03.15 &mdash; 06:42 UTC</div>
            </div>
            <h2 class="section-title">Field Observation Summary</h2>
            <div class="margin-note" aria-hidden="true">First sighting &mdash; remarkable specimen</div>
            <div class="journal-entry">
                <p class="observation-text">{summary}</p>
            </div>
            <div class="field-metrics">
                {metrics.map((m) => (
                    <div class="metric-card">
                        <div class="metric-value">{m.value}</div>
                        <div class="metric-label">{m.label}</div>
                    </div>
                ))}
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-compass">&#9733;</span></div>

        <!-- HABITAT MIGRATION HISTORY -->
        <section class="section" id="experience">
            <div class="section-header">
                <div class="gps-stamp">GPS: 51.5155&deg; N, 0.0922&deg; W</div>
                <div class="date-stamp">Date: 2024.03.16 &mdash; 08:15 UTC</div>
            </div>
            <h2 class="section-title">Habitat Migration History</h2>
            <div class="margin-note" aria-hidden="true">Tracked across multiple continents</div>
            <div class="migration-timeline">
                {experience.map((exp, i) => (
                    <article class="habitat-card">
                        <div class="habitat-marker" aria-hidden="true">
                            <span class="marker-num">{String(i + 1).padStart(2, '0')}</span>
                        </div>
                        <div class="habitat-content">
                            <div class="habitat-header">
                                <h3 class="habitat-name">{exp.company}</h3>
                                <span class="habitat-location">{exp.location}</span>
                            </div>
                            {exp.roles.map((role) => (
                                <div class="observation-entry">
                                    <div class="observation-role">{role.title}</div>
                                    <div class="observation-period">{role.period}</div>
                                    {role.description && (
                                        <p class="observation-desc">{role.description}</p>
                                    )}
                                    {role.bullets && role.bullets.length > 0 && (
                                        <ul class="observation-findings">
                                            {role.bullets.map((b) => (
                                                <li>{b}</li>
                                            ))}
                                        </ul>
                                    )}
                                </div>
                            ))}
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-tracks">&#128062; &middot; &#128062; &middot; &#128062;</span></div>

        <!-- OBSERVED CAPABILITIES -->
        <section class="section" id="skills">
            <div class="section-header">
                <div class="gps-stamp">GPS: 51.5033&deg; N, 0.1195&deg; W</div>
                <div class="date-stamp">Date: 2024.03.17 &mdash; 14:30 UTC</div>
            </div>
            <h2 class="section-title">Observed Capabilities</h2>
            <div class="margin-note" aria-hidden="true">Catalogued from multiple field sessions</div>

            <div class="catalog-group">
                <h3 class="catalog-subhead">Technical Proficiencies</h3>
                <div class="specimen-cards">
                    {skills.map((skill) => (
                        <div class="specimen-card">
                            <div class="card-pin" aria-hidden="true"></div>
                            <div class="card-content">{skill}</div>
                        </div>
                    ))}
                </div>
            </div>

            <div class="catalog-group">
                <h3 class="catalog-subhead">Management &amp; Leadership</h3>
                <div class="specimen-cards">
                    {managementSkills.map((skill) => (
                        <div class="specimen-card">
                            <div class="card-pin" aria-hidden="true"></div>
                            <div class="card-content">{skill}</div>
                        </div>
                    ))}
                </div>
            </div>

            <div class="catalog-group">
                <h3 class="catalog-subhead">Observed Territories (Industries)</h3>
                <div class="specimen-cards">
                    {industries.map((ind) => (
                        <div class="specimen-card territory-card">
                            <div class="card-pin" aria-hidden="true"></div>
                            <div class="card-content">{ind}</div>
                        </div>
                    ))}
                </div>
            </div>

            <div class="catalog-group">
                <h3 class="catalog-subhead">Vocalizations (Languages)</h3>
                <div class="specimen-cards">
                    {languages.map((lang) => (
                        <div class="specimen-card lang-card">
                            <div class="card-pin" aria-hidden="true"></div>
                            <div class="card-content">{lang}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-compass">&#9733;</span></div>

        <!-- NOTABLE ENCOUNTERS -->
        <section class="section" id="engagements">
            <div class="section-header">
                <div class="gps-stamp">GPS: 51.5142&deg; N, 0.0931&deg; W</div>
                <div class="date-stamp">Date: 2024.03.18 &mdash; 10:00 UTC</div>
            </div>
            <h2 class="section-title">Notable Encounters</h2>
            <div class="margin-note" aria-hidden="true">Each sighting confirmed by multiple observers</div>
            <div class="encounter-log">
                {engagements.map((eng) => (
                    <div class="encounter-row">
                        <div class="encounter-client">{eng.client}</div>
                        <div class="encounter-detail">
                            <span class="encounter-sector">{eng.sector}</span>
                            <span class="encounter-scope">{eng.scope}</span>
                        </div>
                        <div class="encounter-impact">
                            <span class={`trend-indicator ${eng.trend}`} aria-hidden="true">{eng.trend === 'positive' ? '\u25B2' : '\u25C6'}</span>
                            {eng.impact}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-tracks">&#128062; &middot; &#128062; &middot; &#128062;</span></div>

        <!-- NATURALIST TRAINING -->
        <section class="section" id="education">
            <div class="section-header">
                <div class="gps-stamp">GPS: 56.4620&deg; N, 2.9707&deg; W</div>
                <div class="date-stamp">Date: 2024.03.19 &mdash; 09:20 UTC</div>
            </div>
            <h2 class="section-title">Naturalist Training</h2>
            <div class="margin-note" aria-hidden="true">Formal instruction in the wild sciences</div>
            <div class="training-entries">
                {education.map((edu) => (
                    <div class="training-card">
                        <div class="training-institution">{edu.institution}</div>
                        <div class="training-degree">{edu.degree}</div>
                        <div class="training-meta">
                            <span>{edu.period}</span>
                            <span>&mdash;</span>
                            <span>{edu.location}</span>
                        </div>
                        {edu.distinction && (
                            <div class="training-distinction">{edu.distinction}</div>
                        )}
                    </div>
                ))}
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-compass">&#9733;</span></div>

        <!-- EXPEDITION CREDENTIALS -->
        <section class="section" id="certifications">
            <div class="section-header">
                <div class="gps-stamp">GPS: 51.4988&deg; N, 0.1749&deg; W</div>
                <div class="date-stamp">Date: 2024.03.20 &mdash; 11:45 UTC</div>
            </div>
            <h2 class="section-title">Expedition Credentials</h2>
            <div class="margin-note" aria-hidden="true">Permits &amp; certifications verified</div>
            <div class="credentials-grid">
                {certifications.map((cert) => (
                    <div class="credential-badge">
                        <div class="badge-seal" aria-hidden="true">&#9673;</div>
                        <div class="badge-text">{cert}</div>
                    </div>
                ))}
            </div>
        </section>

        <div class="divider" aria-hidden="true"><span class="divider-tracks">&#128062; &middot; &#128062; &middot; &#128062;</span></div>

        <!-- ONGOING FIELDWORK -->
        <section class="section" id="learning">
            <div class="section-header">
                <div class="gps-stamp">GPS: 37.4419&deg; N, 122.1430&deg; W</div>
                <div class="date-stamp">Date: 2024.03.21 &mdash; 16:00 UTC</div>
            </div>
            <h2 class="section-title">Ongoing Fieldwork</h2>
            <div class="margin-note" aria-hidden="true">Subject continues to evolve</div>
            <div class="fieldwork-list">
                {continuousLearning.map((item) => (
                    <div class="fieldwork-entry">
                        <span class="fieldwork-bullet" aria-hidden="true">&#9670;</span>
                        <span>{item}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- JOURNAL FOOTER -->
        <footer class="journal-footer">
            <div class="footer-stamp">END OF EXPEDITION LOG</div>
            <div class="footer-note">
                Field journal maintained by {siteMetadata.name} &mdash; {siteMetadata.location}
            </div>
            <div class="footer-links">
                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
                <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener noreferrer">Bluesky</a>
                <a href={`mailto:${siteMetadata.email}`}>Email</a>
            </div>
            <div class="footer-copy">&copy; {new Date().getFullYear()} {siteMetadata.name}. All field observations reserved.</div>
        </footer>

    </main>
</body>
</html>

<style>
    /* ========================================
       SAFARI EXPEDITION — GLOBAL STYLES
       ======================================== */

    :root {
        --savanna-gold: #c9a84c;
        --dusty-khaki: #d4c5a0;
        --safari-green: #3a5a20;
        --earth-brown: #5c3d2e;
        --sunset-orange: #d4660a;
        --sky-blue: #5a9fce;
        --canvas: #f0e8d4;
        --canvas-dark: #e5d9c0;
        --leather: #8b6914;
        --ink: #2c1810;
        --ink-light: #5a4535;

        --font-serif: 'Bitter', Georgia, 'Times New Roman', serif;
        --font-handwriting: 'Caveat', cursive;
        --font-sans: 'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: var(--font-serif);
        background: var(--canvas);
        color: var(--ink);
        line-height: 1.7;
        overflow-x: hidden;
        position: relative;
        min-height: 100vh;
    }

    /* Topographic contour lines background */
    body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.04;
        background-image:
            repeating-radial-gradient(ellipse at 20% 50%, transparent 0, transparent 40px, var(--earth-brown) 40px, var(--earth-brown) 41px, transparent 41px, transparent 80px),
            repeating-radial-gradient(ellipse at 80% 30%, transparent 0, transparent 55px, var(--earth-brown) 55px, var(--earth-brown) 56px, transparent 56px, transparent 110px),
            repeating-radial-gradient(ellipse at 50% 80%, transparent 0, transparent 35px, var(--earth-brown) 35px, var(--earth-brown) 36px, transparent 36px, transparent 70px);
    }

    /* Warm golden hour gradient overlay */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background: linear-gradient(
            175deg,
            rgba(201, 168, 76, 0.06) 0%,
            rgba(212, 102, 10, 0.03) 40%,
            transparent 70%
        );
        animation: goldenShift 20s ease-in-out infinite alternate;
    }

    @keyframes goldenShift {
        0% { opacity: 0.8; }
        50% { opacity: 1; }
        100% { opacity: 0.7; }
    }

    a {
        color: var(--earth-brown);
        text-decoration: underline;
        text-decoration-color: var(--savanna-gold);
        text-underline-offset: 3px;
        transition: color 0.2s;
    }

    a:hover {
        color: var(--sunset-orange);
    }

    /* ========================================
       DUST PARTICLES CANVAS
       ======================================== */

    .dust-canvas {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        width: 100%;
        height: 100%;
    }

    /* ========================================
       COMPASS BEARING
       ======================================== */

    .compass-bearing {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(240, 232, 212, 0.9);
        border: 1px solid var(--dusty-khaki);
        border-radius: 4px;
        padding: 6px 12px;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--earth-brown);
        letter-spacing: 0.05em;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .compass-icon {
        font-size: 1rem;
        color: var(--savanna-gold);
    }

    .compass-dir {
        font-size: 0.85rem;
        min-width: 1.6em;
        text-align: center;
    }

    .compass-deg {
        color: var(--ink-light);
        font-size: 0.7rem;
    }

    /* ========================================
       INTRO SEQUENCE
       ======================================== */

    .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .intro.hidden {
        display: none;
    }

    .dawn-sky {
        position: absolute;
        inset: 0;
        background: #0a1628;
        transition: background 1s ease;
    }

    .dawn-sky.phase1 {
        background: linear-gradient(to top, #d4660a 0%, #c9a84c 30%, #2a3a5c 70%, #0a1628 100%);
    }

    .dawn-sky.phase2 {
        background: linear-gradient(to top, #e8a030 0%, #d4660a 20%, #c9a84c 45%, #5a9fce 80%, #2a3a5c 100%);
    }

    .silhouette {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 200px;
        z-index: 2;
        opacity: 0;
        transition: opacity 0.8s ease;
    }

    .silhouette.visible {
        opacity: 1;
    }

    .silhouette-svg {
        width: 100%;
        height: 100%;
    }

    .binocular-mask {
        position: absolute;
        inset: 0;
        z-index: 3;
        background: radial-gradient(ellipse 22% 35% at 38% 50%, transparent 98%, #000 100%),
                    radial-gradient(ellipse 22% 35% at 62% 50%, transparent 98%, #000 100%),
                    radial-gradient(ellipse 50% 50% at 50% 50%, transparent 30%, #000 70%);
        opacity: 1;
        transition: opacity 1s ease;
    }

    .binocular-mask.open {
        opacity: 0;
    }

    .intro-text {
        position: relative;
        z-index: 4;
        text-align: center;
        padding: 0 20px;
    }

    .intro-line {
        font-family: var(--font-handwriting);
        color: var(--canvas);
