    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* =========================================
       RESPONSIVE -- TABLET (601-1024px)
       ========================================= */
    @media (max-width: 1024px) {
        body { font-size: 15px; }
        .paper { max-width: 680px; padding: 50px 32px 80px; }
        .paper-title { font-size: clamp(20px, 3vw, 26px); }
        .intro-grid { grid-template-columns: 1fr 180px; gap: 20px; }
        .figure-frame img { width: 160px; height: 160px; }
        .experiment-institution { font-size: 16px; }
        .data-table { font-size: 12px; }
        .data-table th, .data-table td { padding: 8px 10px; }
    }

    /* =========================================
       RESPONSIVE -- SMALL TABLET / LARGE PHONE (481-600px)
       ========================================= */
    @media (max-width: 600px) {
        body { font-size: 14px; }
        .paper { padding: 40px 18px 60px; }
        .paper-title { font-size: 20px; }

        /* Header */
        .journal-line { flex-direction: column; gap: 4px; }
        .journal-name { font-size: 10px; letter-spacing: 1.5px; }
        .author-primary { font-size: 15px; }
        .paper-links { gap: 10px; font-size: 11px; }
        .paper-dates { font-size: 10px; }

        /* Intro grid: stack */
        .intro-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        .figure-container { order: -1; }
        .figure-frame img { width: 140px; height: 140px; }

        /* Text */
        .body-text { font-size: 14px; text-align: left; }
        .abstract-text { font-size: 13px; }
        .abstract-box { padding: 14px 16px; }

        /* Headings */
        .section-heading { font-size: 18px; }
        .subsection-heading { font-size: 15px; }

        /* Apparatus */
        .apparatus-item { font-size: 11px; padding: 4px 8px; }
        .apparatus-id { font-size: 9px; min-width: 24px; }

        /* Timeline */
        .experiment-block { padding-left: 14px; }
        .experiment-header { gap: 6px; }
        .experiment-institution { font-size: 15px; }
        .experiment-phase { font-size: 9px; }
        .role-title { font-size: 14px; }
        .experiment-role { flex-direction: column; gap: 2px; }

        /* Tables */
        .data-table { font-size: 11px; }
        .data-table th, .data-table td { padding: 6px 8px; }
        .data-table th { font-size: 10px; }

        /* Qualifications */
        .qual-degree { font-size: 14px; }
        .cert-item { font-size: 13px; }

        /* References */
        .reference { font-size: 12px; padding-left: 20px; text-indent: -20px; }
        .footer-meta { font-size: 10px; }

        /* Dividers */
        .section-rule { margin: 1.5rem 0; }

        /* Hypothesis */
