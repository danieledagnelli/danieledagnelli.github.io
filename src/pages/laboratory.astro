    /* =========================================
       INTRODUCTION GRID (text + figure)
       ========================================= */
    .intro-grid {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 30px;
        align-items: start;
    }
    .figure-container {
        text-align: center;
