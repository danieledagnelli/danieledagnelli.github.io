---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>A Comprehensive Study of Professional Excellence: D'Agnelli et al.</title>
    <meta name="description" content="A peer-reviewed analysis of Daniele D'Agnelli's career in Professional Services, AI deployments, and cybersecurity. Scientific research paper format portfolio." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/laboratory" />

    <!-- Open Graph -->
    <meta property="og:title" content="A Comprehensive Study of Professional Excellence: D'Agnelli et al." />
    <meta property="og:description" content="Peer-reviewed analysis of 15+ years leading digital transformations. AI, cybersecurity, and programme management research." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/laboratory" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="D'Agnelli et al. — Research Paper Portfolio" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="A Comprehensive Study of Professional Excellence: D'Agnelli et al." />
    <meta name="twitter:description" content="Peer-reviewed analysis of 15+ years leading digital transformations in AI and cybersecurity." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Fira+Code:wght@400;500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- GRID PAPER OVERLAY -->
    <div class="grid-overlay" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner">
            <div class="journal-badge">Journal of Professional Excellence</div>
            <div class="intro-title">Loading Manuscript...</div>
            <div class="progress-track">
                <div class="progress-bar" id="progressBar"></div>
            </div>
            <div class="progress-label" id="progressLabel">Peer Review Status: Under Review...</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="paper" id="paper">

        <!-- PAPER HEADER -->
        <header class="paper-header reveal">
            <div class="journal-line">
                <span class="journal-name">Journal of Professional Excellence & Applied Technology</span>
                <span class="journal-meta">Vol. 15 | Issue 3 | 2024</span>
            </div>
            <div class="paper-type">Original Research Article</div>
            <h1 class="paper-title">A Comprehensive Study of Professional Excellence in Digital Transformation, Artificial Intelligence, and Cybersecurity</h1>
            <div class="authors">
                <span class="author-primary">{siteMetadata.name}<sup>1,2*</sup></span>
            </div>
            <div class="affiliations">
                <div class="affiliation"><sup>1</sup> C3 AI, {siteMetadata.location}</div>
                <div class="affiliation"><sup>2</sup> Independent Researcher, AI & Cybersecurity</div>
                <div class="affiliation correspondence">* Correspondence: <a href={`mailto:${siteMetadata.email}`}>{siteMetadata.email}</a></div>
            </div>
            <div class="paper-dates">
                <span>Received: April 2012</span>
                <span class="date-sep">|</span>
                <span>Revised: August 2021</span>
                <span class="date-sep">|</span>
                <span>Accepted: Present</span>
            </div>
            <div class="paper-links">
                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">[GitHub Repository]</a>
                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">[Author Profile]</a>
                <a href={`mailto:${siteMetadata.email}`}>[Correspondence]</a>
            </div>
        </header>

        <hr class="section-rule" />

        <!-- ABSTRACT -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="0">Abstract</h2>
            <div class="abstract-box">
                <p class="abstract-text" id="abstractText">{summary}</p>
            </div>
            <div class="keywords">
                <strong>Keywords:</strong> {industries.map((ind, i) => (
                    <span class="keyword">{ind}{i < industries.length - 1 ? '; ' : ''}</span>
                ))}
            </div>
        </section>

        <hr class="section-rule" />

        <!-- 1. INTRODUCTION -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="1">Introduction</h2>
            <div class="intro-grid">
                <div class="intro-text">
                    <p class="body-text">
                        This paper presents a longitudinal study of professional practice spanning 15 years across multiple sectors of the global technology industry. The subject, {siteMetadata.name}, has demonstrated sustained excellence in the domains of digital transformation, artificial intelligence deployment, and cybersecurity research.
                    </p>
                    <p class="body-text">
                        Operating from {siteMetadata.location}, the subject has led engagements exceeding $15M in programme value, achieving measurable outcomes including $18M EBIT impact, NPS scores consistently above 70, and deployment across 100+ manufacturing plants reaching 2,000+ end users.
                    </p>
                    <div class="hypothesis-box">
                        <div class="hypothesis-label">Hypothesis H<sub>1</sub></div>
                        <p>A professional combining deep technical expertise in software engineering, ML/AI, and cybersecurity with programme management capabilities will consistently deliver above-benchmark results in complex enterprise transformations.</p>
                    </div>
                </div>
                <div class="figure-container">
                    <div class="figure-frame">
                        <img src="/assets/dani.jpeg" alt={`${siteMetadata.name} — Principal Investigator`} width="200" height="200" />
                    </div>
                    <div class="figure-caption">
                        <strong>Fig. 1.</strong> Principal Investigator, {siteMetadata.name}. Photographed at research facility, {siteMetadata.location}.
                    </div>
                </div>
            </div>
        </section>

        <hr class="section-rule" />

        <!-- 2. METHODS: APPARATUS AND TECHNIQUES -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="2">Methods: Apparatus and Techniques</h2>
            <p class="body-text">The following instruments and methodologies were employed across all experimental phases. Apparatus is categorized by domain of application.</p>

            <h3 class="subsection-heading" data-number="2.1">Technical Instruments</h3>
            <div class="apparatus-grid">
                {skills.map((s, i) => (
                    <div class="apparatus-item" style={`--i:${i}`}>
                        <span class="apparatus-id">T-{String(i + 1).padStart(2, '0')}</span>
                        <span class="apparatus-name">{s}</span>
                    </div>
                ))}
            </div>

            <h3 class="subsection-heading" data-number="2.2">Management Methodologies</h3>
            <div class="apparatus-grid">
                {managementSkills.map((s, i) => (
                    <div class="apparatus-item management" style={`--i:${i}`}>
                        <span class="apparatus-id">M-{String(i + 1).padStart(2, '0')}</span>
                        <span class="apparatus-name">{s}</span>
                    </div>
                ))}
            </div>

            <h3 class="subsection-heading" data-number="2.3">Languages</h3>
            <div class="apparatus-grid">
                {languages.map((l, i) => (
                    <div class="apparatus-item language">
                        <span class="apparatus-id">L-{String(i + 1).padStart(2, '0')}</span>
                        <span class="apparatus-name">{l}</span>
                    </div>
                ))}
            </div>
        </section>

        <hr class="section-rule" />

        <!-- 3. EXPERIMENTAL TIMELINE -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="3">Experimental Timeline</h2>
            <p class="body-text">The following chronology documents each experimental phase, ordered from most recent to earliest. Each phase represents a distinct institutional affiliation and research focus.</p>

            {experience.map((exp, i) => (
                <div class="experiment-block reveal">
                    <div class="experiment-header">
                        <span class="experiment-phase">Phase {experience.length - i}</span>
                        <span class="experiment-institution">{exp.company}</span>
                        <span class="experiment-location">{exp.location}</span>
                    </div>
                    {exp.roles.map(role => (
                        <div class="experiment-body">
                            <div class="experiment-role">
                                <span class="role-title">{role.title}</span>
                                <span class="role-period">{role.period}</span>
                            </div>
                            {role.description && (
                                <p class="experiment-desc">{role.description}</p>
                            )}
                            {role.bullets && role.bullets.length > 0 && (
                                <div class="findings-list">
                                    <span class="findings-label">Key Findings:</span>
                                    <ul>
                                        {role.bullets.map((b, j) => (
                                            <li><span class="finding-ref">[{i + 1}.{j + 1}]</span> {b}</li>
                                        ))}
                                    </ul>
                                </div>
                            )}
                        </div>
                    ))}
                </div>
            ))}
        </section>

        <hr class="section-rule" />

        <!-- 4. RESULTS AND DISCUSSION -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="4">Results and Discussion</h2>

            <h3 class="subsection-heading" data-number="4.1">Quantitative Metrics</h3>
            <p class="body-text">Table 1 presents the aggregate quantitative outcomes observed across all experimental phases.</p>

            <div class="table-container">
                <div class="table-caption"><strong>Table 1.</strong> Summary of Key Performance Metrics</div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Metric</th>
                            <th>Observed Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        {metrics.map(m => (
                            <tr>
                                <td>{m.label}</td>
                                <td class="metric-value">{m.value}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>

            <h3 class="subsection-heading" data-number="4.2">Experimental Results by Engagement</h3>
            <p class="body-text">Table 2 details outcomes from individual experimental engagements, classified by sector and scope of intervention.</p>

            <div class="table-container">
                <div class="table-caption"><strong>Table 2.</strong> Engagement-Level Experimental Results</div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Sector</th>
                            <th>Scope</th>
                            <th>Measured Impact</th>
                        </tr>
                    </thead>
                    <tbody>
                        {engagements.map(eng => (
                            <tr>
                                <td class="client-cell">{eng.client}</td>
                                <td>{eng.sector}</td>
                                <td>{eng.scope}</td>
                                <td class={`impact-cell ${eng.trend}`}>{eng.impact}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>

            <div class="hypothesis-box result">
                <div class="hypothesis-label">Result: H<sub>1</sub> Supported</div>
                <p>The data strongly supports the hypothesis. Across all experimental phases, the combination of technical depth and management expertise yielded consistently above-benchmark results, with measurable positive outcomes in adoption rates, financial impact, and client satisfaction.</p>
            </div>
        </section>

        <hr class="section-rule" />

        <!-- 5. RESEARCHER QUALIFICATIONS -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="5">Researcher Qualifications</h2>

            <h3 class="subsection-heading" data-number="5.1">Academic Credentials</h3>
            {education.map((edu, i) => (
                <div class="qualification-block reveal">
                    <div class="qual-institution">
                        <span class="qual-degree">{edu.degree}</span>
                        {edu.distinction && <span class="qual-distinction">{edu.distinction}</span>}
                    </div>
                    <div class="qual-meta">
                        <span>{edu.institution}, {edu.location}</span>
                        <span class="qual-period">{edu.period}</span>
                    </div>
                </div>
            ))}

            <h3 class="subsection-heading" data-number="5.2">Professional Certifications</h3>
            <div class="cert-grid">
                {certifications.map((c, i) => (
                    <div class="cert-item">
                        <span class="cert-number">[C{i + 1}]</span>
                        <span>{c}</span>
                    </div>
                ))}
            </div>

            <h3 class="subsection-heading" data-number="5.3">Continuing Professional Development</h3>
            <div class="cert-grid">
                {continuousLearning.map((l, i) => (
                    <div class="cert-item">
                        <span class="cert-number">[D{i + 1}]</span>
                        <span>{l}</span>
                    </div>
                ))}
            </div>
        </section>

        <hr class="section-rule" />

        <!-- 6. CONCLUSION -->
        <section class="section reveal">
            <h2 class="section-heading" data-number="6">Conclusion</h2>
            <p class="body-text">This study has demonstrated that {siteMetadata.name} possesses a rare combination of deep technical competency and strategic management acumen, validated across 15 years of empirical practice. The evidence presented in Sections 3 and 4 conclusively supports Hypothesis H<sub>1</sub>.</p>
            <p class="body-text">Future research directions include continued investigation into generative AI applications, advanced cybersecurity frameworks, and the intersection of machine learning with enterprise-scale operational challenges.</p>
        </section>

        <hr class="section-rule" />

        <!-- REFERENCES -->
        <footer class="paper-footer reveal">
            <h2 class="section-heading" data-number="R">References</h2>
            <div class="references-list">
                <div class="reference">[1] D'Agnelli, D. (2012-2014). "Foundational Studies in Software Engineering." <em>Accenture Research, Milan.</em></div>
                <div class="reference">[2] D'Agnelli, D. (2015-2017). "Applied Consulting Methodologies." <em>Codec Research, Dublin.</em></div>
                <div class="reference">[3] D'Agnelli, D. (2017-2018). "Demand Forecasting in Aerospace & Defence." <em>Accenture Strategy, London.</em></div>
                <div class="reference">[4] D'Agnelli, D. (2018-2021). "Enterprise Analytics Platform Deployment at Scale." <em>Deloitte Consulting, London.</em></div>
                <div class="reference">[5] D'Agnelli, D. (2021-Present). "AI-Driven Enterprise Transformation: A Multi-Sector Study." <em>C3 AI, London.</em></div>
                <div class="reference">[6] D'Agnelli, D. (2023). "MSc Ethical Hacking and Cybersecurity." <em>Abertay University, Dundee.</em> (Distinction)</div>
            </div>
            <div class="footer-meta">
                <span class="footer-doi">DOI: 10.xxxx/dagnelli.2024.portfolio</span>
                <span class="footer-license">Open Access | CC BY 4.0</span>
            </div>
            <div class="footer-contact">
                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                <span class="footer-sep">|</span>
                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                <span class="footer-sep">|</span>
                <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">Bluesky</a>
                <span class="footer-sep">|</span>
                <a href={`mailto:${siteMetadata.email}`}>{siteMetadata.email}</a>
            </div>
        </footer>
    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --lab-white: #ffffff;
        --lab-blue: #1a5276;
        --graph-red: #c0392b;
        --annotation-green: #27ae60;
        --paper-gray: #f8f9fa;
        --border: #dee2e6;
        --text-primary: #212529;
        --text-secondary: #495057;
        --text-muted: #6c757d;
        --serif: 'Source Serif 4', 'Georgia', serif;
        --mono: 'Fira Code', 'Courier New', monospace;
        --sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        scrollbar-width: thin;
        scrollbar-color: var(--lab-blue) var(--paper-gray);
    }

    body {
        background: var(--lab-white);
        color: var(--text-primary);
        font-family: var(--serif);
        font-size: 16px;
        line-height: 1.8;
        overflow-x: hidden;
        min-height: 100vh;
        counter-reset: line-number;
    }

    a { color: var(--lab-blue); text-decoration: none; }
    a:hover { color: var(--graph-red); text-decoration: underline; }

    ::selection { background: rgba(26, 82, 118, 0.2); color: var(--text-primary); }

    /* =========================================
       GRID PAPER OVERLAY
       ========================================= */
    .grid-overlay {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
            linear-gradient(rgba(26, 82, 118, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(26, 82, 118, 0.03) 1px, transparent 1px);
        background-size: 20px 20px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        background: var(--lab-white);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        transition: opacity 0.4s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }
    .intro-inner {
        text-align: center;
        max-width: 480px;
        width: 100%;
    }
    .journal-badge {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--lab-blue);
        border: 2px solid var(--lab-blue);
        display: inline-block;
        padding: 6px 18px;
        margin-bottom: 28px;
    }
    .intro-title {
        font-family: var(--serif);
        font-size: 18px;
        color: var(--text-secondary);
        margin-bottom: 24px;
        font-style: italic;
    }
    .progress-track {
        width: 100%;
        height: 6px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 12px;
    }
    .progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--lab-blue), var(--annotation-green));
        border-radius: 3px;
        transition: width 0.1s linear;
    }
    .progress-label {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--text-muted);
        letter-spacing: 0.5px;
    }

    /* =========================================
       MAIN PAPER
       ========================================= */
    .paper {
        position: relative;
        z-index: 1;
        max-width: 780px;
        margin: 0 auto;
        padding: 60px 48px 100px;
        opacity: 0;
        transition: opacity 0.5s ease 0.2s;
        background: var(--lab-white);
    }
    .paper.visible { opacity: 1; }

    /* =========================================
       SECTION RULES
       ========================================= */
    .section-rule {
        border: none;
        height: 1px;
        background: var(--border);
        margin: 2.5rem 0;
    }

    /* =========================================
       PAPER HEADER
       ========================================= */
    .journal-line {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 8px;
        padding-bottom: 8px;
        border-bottom: 2px solid var(--lab-blue);
    }
    .journal-name {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--lab-blue);
    }
    .journal-meta {
        font-family: var(--sans);
        font-size: 11px;
        color: var(--text-muted);
    }
    .paper-type {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--annotation-green);
        margin-bottom: 20px;
        margin-top: 12px;
    }
    .paper-title {
        font-family: var(--serif);
        font-size: clamp(22px, 3.5vw, 30px);
        font-weight: 700;
        line-height: 1.3;
        color: var(--text-primary);
        margin-bottom: 16px;
    }
    .authors {
        margin-bottom: 8px;
    }
    .author-primary {
        font-family: var(--serif);
        font-size: 17px;
        font-weight: 600;
        color: var(--lab-blue);
    }
    .author-primary sup {
        font-size: 11px;
        color: var(--graph-red);
    }
    .affiliations {
        margin-bottom: 14px;
    }
    .affiliation {
        font-family: var(--sans);
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.6;
    }
    .affiliation sup {
        font-size: 10px;
        color: var(--graph-red);
        margin-right: 2px;
    }
    .affiliation.correspondence {
        margin-top: 4px;
        font-style: italic;
    }
    .paper-dates {
        font-family: var(--sans);
        font-size: 11px;
        color: var(--text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 12px;
    }
    .date-sep { color: var(--border); }
    .paper-links {
        display: flex;
        gap: 16px;
        font-family: var(--mono);
        font-size: 12px;
        flex-wrap: wrap;
    }

    /* =========================================
       SECTION HEADINGS
       ========================================= */
    .section { margin-bottom: 0; }

    .section-heading {
        font-family: var(--serif);
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 16px;
        padding-bottom: 6px;
        border-bottom: 1px solid var(--border);
    }
    .section-heading::before {
        content: attr(data-number) ". ";
        color: var(--lab-blue);
        font-weight: 700;
    }
    .section-heading[data-number="0"]::before {
        content: "";
    }
    .section-heading[data-number="R"]::before {
        content: "";
    }

    .subsection-heading {
        font-family: var(--serif);
        font-size: 16px;
        font-weight: 600;
        color: var(--text-secondary);
        margin-top: 20px;
        margin-bottom: 12px;
    }
    .subsection-heading::before {
        content: attr(data-number) " ";
        color: var(--lab-blue);
    }

    /* =========================================
       BODY TEXT
       ========================================= */
    .body-text {
        font-family: var(--serif);
        font-size: 15px;
        line-height: 1.8;
        color: var(--text-secondary);
        margin-bottom: 14px;
