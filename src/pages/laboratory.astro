    /* =========================================
       RESPONSIVE -- SMALL PHONE (<=380px)
       ========================================= */
    @media (max-width: 380px) {
        body { font-size: 13px; }
        .paper { padding: 30px 12px 50px; }
        .paper-title { font-size: 18px; }
        .journal-badge { font-size: 9px; letter-spacing: 2px; padding: 4px 12px; }
        .figure-frame img { width: 120px; height: 120px; }
        .apparatus-item { font-size: 10px; padding: 3px 6px; }
        .experiment-institution { font-size: 14px; }
        .data-table { font-size: 10px; }
        .data-table th, .data-table td { padding: 5px 6px; }
