        font-size: 14px;
        font-style: italic;
        line-height: 1.8;
        color: var(--text-secondary);
    }
    .keywords {
        font-family: var(--sans);
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.8;
    }
    .keywords strong {
        color: var(--text-secondary);
    }
    .keyword {
        font-style: italic;
    }

    /* =========================================
       HYPOTHESIS BOX
       ========================================= */
    .hypothesis-box {
        border: 2px solid var(--lab-blue);
        background: rgba(26, 82, 118, 0.03);
        padding: 18px 22px;
        margin: 20px 0;
        position: relative;
    }
    .hypothesis-box.result {
        border-color: var(--annotation-green);
        background: rgba(39, 174, 96, 0.03);
    }
    .hypothesis-label {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--lab-blue);
