    /* =========================================
       TOUCH: larger tap targets on mobile
       ========================================= */
    @media (hover: none) and (pointer: coarse) {
        .paper-links a {
            padding: 6px 4px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
        }
        .apparatus-item {
            padding: 8px 12px;
            min-height: 36px;
        }
        .footer-contact a {
            padding: 6px 4px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
        }
    }

    /* =========================================
       PRINT STYLES
       ========================================= */
    @media print {
        .grid-overlay, .intro { display: none !important; }
        .paper { opacity: 1 !important; max-width: 100%; padding: 0; }
        .reveal { opacity: 1 !important; transform: none !important; }
        body { font-size: 12pt; }
    }
</style>

<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const paperEl = document.getElementById('paper')!;
    const progressBar = document.getElementById('progressBar')!;
    const progressLabel = document.getElementById('progressLabel')!;

    function skipIntro() {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            paperEl.classList.add('visible');
        }, 400);
    }

    async function runIntro() {
        if (sessionStorage.getItem('laboratory-intro-seen')) {
            skipIntro();
            return;
        }

        const stages = [
            { pct: 15, label: 'Peer Review Status: Formatting check...' },
            { pct: 30, label: 'Peer Review Status: Reviewer 1 assigned...' },
            { pct: 50, label: 'Peer Review Status: Reviewer 2 assigned...' },
            { pct: 65, label: 'Peer Review Status: Minor revisions requested...' },
            { pct: 80, label: 'Peer Review Status: Revisions submitted...' },
            { pct: 92, label: 'Peer Review Status: Final review...' },
            { pct: 100, label: 'Peer Review Status: Accepted' },
        ];

        for (const stage of stages) {
            progressBar.style.width = stage.pct + '%';
            progressLabel.textContent = stage.label;
            await new Promise(r => setTimeout(r, 300 + Math.random() * 200));
        }

        await new Promise(r => setTimeout(r, 600));
        sessionStorage.setItem('laboratory-intro-seen', '1');
        skipIntro();
    }

    // Click/key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('laboratory-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('laboratory-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       CITATION NUMBERING (auto-superscript)
       ============================================= */
    let citationCounter = 0;
    document.querySelectorAll('.experiment-block').forEach(block => {
        citationCounter++;
        const phase = block.querySelector('.experiment-phase');
        if (phase) {
            const sup = document.createElement('sup');
            sup.textContent = `[${citationCounter}]`;
            sup.style.cssText = 'font-size:10px;color:#c0392b;margin-left:4px;font-family:Fira Code,monospace;';
            const inst = block.querySelector('.experiment-institution');
            if (inst) inst.appendChild(sup);
        }
    });
</script>
