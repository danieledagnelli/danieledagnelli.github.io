    }

    /* =========================================
       ABSTRACT
       ========================================= */
    .abstract-box {
        background: var(--paper-gray);
        border-left: 4px solid var(--lab-blue);
        padding: 20px 24px;
        margin-bottom: 16px;
    }
    .abstract-text {
