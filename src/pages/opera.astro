---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Grand Opera Playbill | Senior Engagement Manager</title>
    <meta name="description" content="Daniele D'Agnelli — A Grand Opera Playbill. Senior Engagement Manager with 15+ years in Professional Services, AI deployments, cybersecurity, and digital transformation." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/opera" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta property="og:description" content="15+ years leading high-impact digital transformations. A career told through the grand tradition of opera." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/opera" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta name="twitter:description" content="15+ years leading high-impact digital transformations. A career told through the grand tradition of opera." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400;1,600&family=Italiana&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- CURTAIN OVERLAY -->
    <div class="curtain-overlay" id="curtainOverlay" aria-hidden="true">
        <div class="curtain-left"></div>
        <div class="curtain-right"></div>
        <div class="curtain-valance"></div>
        <div class="curtain-title-card" id="curtainTitle">
            <div class="curtain-ornament">&#9830; &#9830; &#9830;</div>
            <h1 class="curtain-name">Teatro D'Agnelli</h1>
            <div class="curtain-subtitle">presents</div>
            <div class="curtain-ornament">&#9830; &#9830; &#9830;</div>
        </div>
    </div>

    <!-- SPOTLIGHT OVERLAY -->
    <div class="spotlight-overlay" id="spotlightOverlay" aria-hidden="true"></div>

    <!-- MAIN CONTENT -->
    <main class="playbill" id="playbill">

        <div class="opera-narrative">
            <h1 class="opera-title">THE GRAND OPERA OF CLIENT EXCELLENCE</h1>
            <div class="opera-meta">a performance in four acts | libretto by daniele d'agnelli</div>

            <div class="act">
                <h2>ACT I — THE OVERTURE</h2>
                <p>fifteen years of professional services. from the conservatory of bari to the grand stages of london. every performance, a new client. every client, a new aria.</p>
            </div>

            <div class="act">
                <h2>ACT II — THE ARIAS</h2>
                <p>the swiss manufacturer: a sweeping production across 100+ venues. 2,000 in the audience. standing ovation: $18m ebit. the british telco: seven movements, one unified score. the american bank: 75,000 voices harmonised.</p>
            </div>

            <div class="act">
                <h2>ACT III — THE REVIEWS</h2>
                <p>"nps above 70" — sustained across all engagements. "known for building trust-based client relationships." "adept at navigating ambiguity." the critics agree: this is not performance. this is presence.</p>
            </div>

            <div class="act">
                <h2>ACT IV — THE ENCORE</h2>
                <p>the maestro continues. c3 ai. $15m production budget. 70+ in the ensemble. genai and rag systems now in the repertoire. the curtain does not fall.</p>
            </div>

            <div class="opera-footer">
                <a href="mailto:daniele@dagnelli.net">[stage door]</a>
                <a href="https://linkedin.com/in/dagnelli">[programme]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --velvet: #6b0f1a;
        --gold: #d4a744;
        --cream: #faf5e8;
        --burgundy: #3d0c14;
        --stage-black: #0a0a0a;
        --spotlight: #fff8e7;
        --gold-dim: #a07830;
        --text-dark: #2a1a0a;
        --text-body: #4a3828;
        --text-light: #8a7a68;
        --border-gold: #c49a3c;
        --heading: 'Cinzel', 'Times New Roman', serif;
        --body: 'Cormorant Garamond', 'Georgia', serif;
        --accent: 'Italiana', 'Cinzel', serif;
    }

    body {
        background: var(--cream);
        color: var(--text-body);
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.7;
        overflow: hidden;
        margin: 0;
    }

    a { color: var(--velvet); text-decoration: none; transition: color 0.3s; }
    a:hover { color: var(--gold); }

    ::selection { background: var(--gold); color: var(--stage-black); }

    /* =========================================
       CURTAIN OVERLAY
       ========================================= */
    .curtain-overlay {
        position: fixed;
        inset: 0;
        z-index: 10001;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: auto;
        overflow: hidden;
    }

    .curtain-left,
    .curtain-right {
        position: absolute;
        top: 0;
        width: 50%;
        height: 100%;
        background: linear-gradient(
            180deg,
            #4a0a12 0%,
            var(--velvet) 15%,
            #7a1420 40%,
            var(--velvet) 60%,
            #4a0a12 85%,
            #2a0608 100%
        );
        transition: transform 1.8s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .curtain-left {
        left: 0;
        background-image:
            repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(0,0,0,0.08) 40px, rgba(0,0,0,0.08) 42px),
            linear-gradient(180deg, #4a0a12 0%, var(--velvet) 15%, #7a1420 40%, var(--velvet) 60%, #4a0a12 85%, #2a0608 100%);
        box-shadow: inset -30px 0 60px rgba(0,0,0,0.4);
    }
    .curtain-right {
        right: 0;
        background-image:
            repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(0,0,0,0.08) 40px, rgba(0,0,0,0.08) 42px),
            linear-gradient(180deg, #4a0a12 0%, var(--velvet) 15%, #7a1420 40%, var(--velvet) 60%, #4a0a12 85%, #2a0608 100%);
        box-shadow: inset 30px 0 60px rgba(0,0,0,0.4);
    }

    .curtain-overlay.open .curtain-left {
        transform: translateX(-105%);
    }
    .curtain-overlay.open .curtain-right {
        transform: translateX(105%);
    }

    .curtain-valance {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 60px;
        background: linear-gradient(180deg, #3d0c14, var(--velvet) 70%, transparent);
        z-index: 2;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        border-bottom: 3px solid var(--gold-dim);
        transition: opacity 1.2s ease 0.6s;
    }
    .curtain-overlay.open .curtain-valance {
        opacity: 0;
    }

    .curtain-overlay.done {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s ease;
    }

    .curtain-title-card {
        position: relative;
        z-index: 3;
        text-align: center;
        color: var(--gold);
        opacity: 1;
        transition: opacity 0.4s ease;
    }
    .curtain-overlay.open .curtain-title-card {
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .curtain-name {
        font-family: var(--heading);
        font-size: clamp(28px, 5vw, 56px);
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        text-shadow: 0 2px 20px rgba(212, 167, 68, 0.4);
        margin: 8px 0;
    }
    .curtain-subtitle {
        font-family: var(--accent);
        font-size: clamp(16px, 2.5vw, 24px);
        letter-spacing: 6px;
        text-transform: lowercase;
        opacity: 0.8;
    }
    .curtain-ornament {
        font-size: 14px;
        letter-spacing: 12px;
        opacity: 0.6;
        margin: 4px 0;
    }

    /* =========================================
       SPOTLIGHT OVERLAY
       ========================================= */
    .spotlight-overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: radial-gradient(
            ellipse 600px 800px at 50% 30%,
            rgba(255, 248, 231, 0.06) 0%,
            transparent 70%
        );
        opacity: 0;
        transition: opacity 1s ease;
    }
    .spotlight-overlay.active {
        opacity: 1;
    }

    /* =========================================
       MAIN PLAYBILL — VIEWPORT LOCKED
       ========================================= */
    .playbill {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.8s ease 0.3s;
        background: var(--cream);
        position: relative;
    }
    .playbill.visible { opacity: 1; }

    /* =========================================
       OPERA NARRATIVE
       ========================================= */
    .opera-narrative {
        max-width: 600px;
        padding: 1.5rem;
        text-align: center;
    }

    .opera-title {
        font-family: var(--heading);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--burgundy);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 0.2rem;
    }

    .opera-meta {
        font-family: var(--accent);
        font-size: 0.7rem;
        opacity: 0.7;
        margin-bottom: 1rem;
        letter-spacing: 2px;
        color: var(--text-light);
    }

    .act {
        margin-bottom: 0.7rem;
        text-align: left;
    }

    .act h2 {
        font-family: var(--heading);
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        margin-bottom: 0.2rem;
        text-align: center;
        color: var(--burgundy);
        font-weight: 600;
    }

    .act p {
        font-family: var(--body);
        font-size: 0.78rem;
        line-height: 1.5;
        color: var(--text-body);
    }

    .opera-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .opera-footer a {
        text-decoration: none;
        font-family: var(--accent);
        font-size: 0.8rem;
        letter-spacing: 1px;
    }

    /* =========================================
       RESPONSIVE -- MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .act p {
            font-size: 0.72rem;
        }
        .act {
            margin-bottom: 0.5rem;
        }
    }

    @media (max-width: 600px) {
        .curtain-name { font-size: 28px; letter-spacing: 2px; }
    }

    @media (max-width: 380px) {
        .curtain-name { font-size: 22px; }
        .curtain-subtitle { font-size: 14px; }
    }
</style>

<script>
    /* =============================================
       CURTAIN INTRO SEQUENCE
       ============================================= */
    const curtainEl = document.getElementById('curtainOverlay')!;
    const spotlightEl = document.getElementById('spotlightOverlay')!;
    const playbillEl = document.getElementById('playbill')!;

    function skipIntro() {
        curtainEl.classList.add('open');
        setTimeout(() => {
            curtainEl.classList.add('done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
        }, 800);
    }

    function runIntro() {
        // Skip if already seen
        if (sessionStorage.getItem('opera-intro-seen')) {
            curtainEl.classList.add('open', 'done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
            return;
        }

        // Show title card, then open curtains after a pause
        setTimeout(() => {
            curtainEl.classList.add('open');
        }, 2200);

        setTimeout(() => {
            curtainEl.classList.add('done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
            sessionStorage.setItem('opera-intro-seen', '1');
        }, 4000);
    }

    // Click/key to skip
    curtainEl.addEventListener('click', () => {
        sessionStorage.setItem('opera-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!curtainEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('opera-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SPOTLIGHT FOLLOW (subtle mouse tracking)
       ============================================= */
    document.addEventListener('mousemove', (e) => {
        const x = e.clientX;
        const y = e.clientY;
        spotlightEl.style.background = `radial-gradient(
            ellipse 600px 800px at ${x}px ${y}px,
            rgba(255, 248, 231, 0.06) 0%,
            transparent 70%
        )`;
    });
</script>
