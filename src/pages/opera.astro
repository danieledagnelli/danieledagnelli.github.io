---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Grand Opera Playbill | Senior Engagement Manager</title>
    <meta name="description" content="Daniele D'Agnelli — A Grand Opera Playbill. Senior Engagement Manager with 15+ years in Professional Services, AI deployments, cybersecurity, and digital transformation." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/opera" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta property="og:description" content="15+ years leading high-impact digital transformations. A career told through the grand tradition of opera." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/opera" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Grand Opera Playbill" />
    <meta name="twitter:description" content="15+ years leading high-impact digital transformations. A career told through the grand tradition of opera." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400;1,600&family=Italiana&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- CURTAIN OVERLAY -->
    <div class="curtain-overlay" id="curtainOverlay" aria-hidden="true">
        <div class="curtain-left"></div>
        <div class="curtain-right"></div>
        <div class="curtain-valance"></div>
        <div class="curtain-title-card" id="curtainTitle">
            <div class="curtain-ornament">&#9830; &#9830; &#9830;</div>
            <h1 class="curtain-name">Teatro D'Agnelli</h1>
            <div class="curtain-subtitle">presents</div>
            <div class="curtain-ornament">&#9830; &#9830; &#9830;</div>
        </div>
    </div>

    <!-- SPOTLIGHT OVERLAY -->
    <div class="spotlight-overlay" id="spotlightOverlay" aria-hidden="true"></div>

    <!-- MAIN CONTENT -->
    <main class="playbill" id="playbill">

        <!-- PLAYBILL COVER -->
        <section class="section cover" data-section="header">
            <div class="cover-border">
                <div class="ornament-top">&#10045;</div>
                <div class="filigree-line"></div>
                <div class="theater-name">Teatro D'Agnelli</div>
                <div class="season-label">Season {new Date().getFullYear()}</div>
                <h1 class="opera-title">La Trasformazione Digitale</h1>
                <div class="opera-subtitle">An Opera in Five Acts</div>
                <div class="filigree-line"></div>
                <div class="cover-meta">
                    <span class="meta-item">{siteMetadata.location}</span>
                    <span class="meta-divider">&#8226;</span>
                    <span class="meta-item">Est. 2012</span>
                    <span class="meta-divider">&#8226;</span>
                    <span class="meta-item">15 Seasons</span>
                </div>
                <div class="ornament-bottom">&#10045;</div>
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- PRINCIPAL CAST -->
        <section class="section reveal" data-section="summary">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">Principal Cast</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="cast-grid">
                <div class="cast-photo-frame">
                    <div class="photo-inner">
                        <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="180" height="180" />
                    </div>
                    <div class="photo-nameplate">{siteMetadata.name}</div>
                </div>
                <div class="cast-details">
                    <div class="cast-role-title">Primo Maestro &mdash; Lead Conductor</div>
                    <p class="cast-bio">{summary}</p>
                    <div class="cast-contacts">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                        <span class="contact-dot">&#8226;</span>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                        <span class="contact-dot">&#8226;</span>
                        <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">Bluesky</a>
                        <span class="contact-dot">&#8226;</span>
                        <a href={`mailto:${siteMetadata.email}`}>Correspondence</a>
                    </div>
                    <div class="cast-languages">
                        <span class="lang-label">Languages Performed In:</span>
                        {languages.map((lang, i) => (
                            <span class="lang-item">{lang}{i < languages.length - 1 ? ',' : ''}</span>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- OVERTURE: METRICS -->
        <section class="section reveal" data-section="experience">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">Overture &mdash; Career Highlights</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="metrics-grid">
                {metrics.map(m => (
                    <div class="metric-card reveal">
                        <span class="metric-value">{m.value}</span>
                        <span class="metric-label">{m.label}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- ACTS & SCENES (EXPERIENCE) -->
        <section class="section reveal" data-section="skills">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">Acts &amp; Scenes</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="acts-container">
                {experience.map((exp, actNum) => (
                    <div class="act-block reveal">
                        <div class="act-header">
                            <span class="act-number">Act {actNum + 1}</span>
                            <span class="act-company">{exp.company}</span>
                            <span class="act-location">{exp.location}</span>
                        </div>
                        {exp.roles.map(role => (
                            <div class="scene">
                                <div class="scene-header">
                                    <span class="scene-role">{role.title}</span>
                                    <span class="scene-period">{role.period}</span>
                                </div>
                                {role.description && <p class="scene-direction">{role.description}</p>}
                                {role.bullets && role.bullets.length > 0 && (
                                    <ul class="scene-notes">
                                        {role.bullets.map(b => <li>{b}</li>)}
                                    </ul>
                                )}
                            </div>
                        ))}
                    </div>
                ))}
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- ORCHESTRA (SKILLS) -->
        <section class="section reveal" data-section="engagements">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">The Orchestra</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="orchestra-sections">
                <div class="orchestra-group">
                    <h3 class="group-name">First Chairs &mdash; Technical Instruments</h3>
                    <div class="instrument-grid">
                        {skills.map(s => (
                            <span class="instrument">{s}</span>
                        ))}
                    </div>
                </div>
                <div class="orchestra-group">
                    <h3 class="group-name">Second Chairs &mdash; Management Repertoire</h3>
                    <div class="instrument-grid">
                        {managementSkills.map(s => (
                            <span class="instrument">{s}</span>
                        ))}
                    </div>
                </div>
                <div class="orchestra-group">
                    <h3 class="group-name">Stage &mdash; Industries Performed</h3>
                    <div class="instrument-grid">
                        {industries.map(ind => (
                            <span class="instrument industry">{ind}</span>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- FEATURED PERFORMANCES (ENGAGEMENTS) -->
        <section class="section reveal" data-section="education">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">Featured Performances</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="performances-grid">
                {engagements.map(eng => (
                    <div class="performance-card reveal">
                        <div class="perf-header">
                            <span class="perf-client">{eng.client}</span>
                            <span class="perf-sector">{eng.sector}</span>
                        </div>
                        <div class="perf-body">
                            <span class="perf-scope">{eng.scope}</span>
                            <span class={`perf-impact ${eng.trend}`}>{eng.impact}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- ARTIST'S TRAINING (EDUCATION + CERTS) -->
        <section class="section reveal" data-section="certifications">
            <div class="section-header">
                <div class="header-ornament-left">&#10048;</div>
                <h2 class="section-title">Conservatory Training</h2>
                <div class="header-ornament-right">&#10048;</div>
            </div>
            <div class="training-container">
                <div class="training-group">
                    <h3 class="training-label">Formal Education</h3>
                    {education.map(edu => (
                        <div class="training-item reveal">
                            <div class="training-degree">{edu.degree}</div>
                            <div class="training-institution">{edu.institution} &mdash; {edu.location}</div>
                            <div class="training-period">{edu.period}</div>
                            {edu.distinction && <div class="training-distinction">{edu.distinction}</div>}
                        </div>
                    ))}
                </div>
                <div class="training-group">
                    <h3 class="training-label">Certifications &amp; Honours</h3>
                    {certifications.map(c => (
                        <div class="training-item">
                            <div class="training-degree">{c}</div>
                        </div>
                    ))}
                </div>
                <div class="training-group">
                    <h3 class="training-label">Continued Studies &amp; Masterclasses</h3>
                    {continuousLearning.map(l => (
                        <div class="training-item">
                            <div class="training-degree">{l}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="program-divider"><span class="divider-ornament">&#9733;</span></div>

        <!-- STANDING OVATION / FINALE -->
        <section class="section finale" data-section="footer">
            <div class="finale-ornament">&#10045; &#10045; &#10045;</div>
            <div class="finale-text">Standing Ovation</div>
            <div class="finale-sub">The curtain falls. The audience rises.</div>
            <div class="finale-links">
                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                <span class="finale-dot">&#8226;</span>
                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                <span class="finale-dot">&#8226;</span>
                <a href={`mailto:${siteMetadata.email}`}>Write to the Maestro</a>
            </div>
            <div class="finale-ornament">&#10045; &#10045; &#10045;</div>
            <div class="finale-copyright">&copy; {new Date().getFullYear()} {siteMetadata.name}. All rights reserved.</div>
        </section>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --velvet: #6b0f1a;
        --gold: #d4a744;
        --cream: #faf5e8;
        --burgundy: #3d0c14;
        --stage-black: #0a0a0a;
        --spotlight: #fff8e7;
        --gold-dim: #a07830;
        --text-dark: #2a1a0a;
        --text-body: #4a3828;
        --text-light: #8a7a68;
        --border-gold: #c49a3c;
        --heading: 'Cinzel', 'Times New Roman', serif;
        --body: 'Cormorant Garamond', 'Georgia', serif;
        --accent: 'Italiana', 'Cinzel', serif;
        scrollbar-width: thin;
        scrollbar-color: var(--gold) var(--burgundy);
    }

    body {
        background: var(--cream);
        color: var(--text-body);
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--velvet); text-decoration: none; transition: color 0.3s; }
    a:hover { color: var(--gold); }

    ::selection { background: var(--gold); color: var(--stage-black); }

    /* =========================================
       CURTAIN OVERLAY
       ========================================= */
    .curtain-overlay {
        position: fixed;
        inset: 0;
        z-index: 10001;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: auto;
        overflow: hidden;
    }

    .curtain-left,
    .curtain-right {
        position: absolute;
        top: 0;
        width: 50%;
        height: 100%;
        background: linear-gradient(
            180deg,
            #4a0a12 0%,
            var(--velvet) 15%,
            #7a1420 40%,
            var(--velvet) 60%,
            #4a0a12 85%,
            #2a0608 100%
        );
        transition: transform 1.8s cubic-bezier(0.65, 0, 0.35, 1);
    }
    .curtain-left {
        left: 0;
        background-image:
            repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(0,0,0,0.08) 40px, rgba(0,0,0,0.08) 42px),
            linear-gradient(180deg, #4a0a12 0%, var(--velvet) 15%, #7a1420 40%, var(--velvet) 60%, #4a0a12 85%, #2a0608 100%);
        box-shadow: inset -30px 0 60px rgba(0,0,0,0.4);
    }
    .curtain-right {
        right: 0;
        background-image:
            repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(0,0,0,0.08) 40px, rgba(0,0,0,0.08) 42px),
            linear-gradient(180deg, #4a0a12 0%, var(--velvet) 15%, #7a1420 40%, var(--velvet) 60%, #4a0a12 85%, #2a0608 100%);
        box-shadow: inset 30px 0 60px rgba(0,0,0,0.4);
    }

    .curtain-overlay.open .curtain-left {
        transform: translateX(-105%);
    }
    .curtain-overlay.open .curtain-right {
        transform: translateX(105%);
    }

    .curtain-valance {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 60px;
        background: linear-gradient(180deg, #3d0c14, var(--velvet) 70%, transparent);
        z-index: 2;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        border-bottom: 3px solid var(--gold-dim);
        transition: opacity 1.2s ease 0.6s;
    }
    .curtain-overlay.open .curtain-valance {
        opacity: 0;
    }

    .curtain-overlay.done {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s ease;
    }

    .curtain-title-card {
        position: relative;
        z-index: 3;
        text-align: center;
        color: var(--gold);
        opacity: 1;
        transition: opacity 0.4s ease;
    }
    .curtain-overlay.open .curtain-title-card {
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .curtain-name {
        font-family: var(--heading);
        font-size: clamp(28px, 5vw, 56px);
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        text-shadow: 0 2px 20px rgba(212, 167, 68, 0.4);
        margin: 8px 0;
    }
    .curtain-subtitle {
        font-family: var(--accent);
        font-size: clamp(16px, 2.5vw, 24px);
        letter-spacing: 6px;
        text-transform: lowercase;
        opacity: 0.8;
    }
    .curtain-ornament {
        font-size: 14px;
        letter-spacing: 12px;
        opacity: 0.6;
        margin: 4px 0;
    }

    /* =========================================
       SPOTLIGHT OVERLAY
       ========================================= */
    .spotlight-overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: radial-gradient(
            ellipse 600px 800px at 50% 30%,
            rgba(255, 248, 231, 0.06) 0%,
            transparent 70%
        );
        opacity: 0;
        transition: opacity 1s ease;
    }
    .spotlight-overlay.active {
        opacity: 1;
    }

    /* =========================================
       MAIN PLAYBILL
       ========================================= */
    .playbill {
        max-width: 800px;
        margin: 0 auto;
        padding: 60px 40px 80px;
        opacity: 0;
        transition: opacity 0.8s ease 0.3s;
        background: var(--cream);
        position: relative;
    }
    .playbill::before,
    .playbill::after {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(
            180deg,
            transparent 0%,
            var(--gold) 5%,
            var(--gold) 95%,
            transparent 100%
        );
        opacity: 0.3;
    }
    .playbill::before { left: 12px; }
    .playbill::after { right: 12px; }
    .playbill.visible { opacity: 1; }

    /* =========================================
       SECTION STRUCTURE
       ========================================= */
    .section { margin-bottom: 0; }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin-bottom: 28px;
        text-align: center;
    }
    .section-title {
        font-family: var(--heading);
        font-size: clamp(20px, 3vw, 28px);
        font-weight: 600;
        color: var(--burgundy);
        letter-spacing: 3px;
        text-transform: uppercase;
    }
    .header-ornament-left,
    .header-ornament-right {
        color: var(--gold);
        font-size: 18px;
        opacity: 0.6;
    }

    /* REVEAL ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* PROGRAM DIVIDER */
    .program-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 2.5rem 0;
        position: relative;
    }
    .program-divider::before,
    .program-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border-gold), transparent);
        opacity: 0.4;
    }
    .divider-ornament {
        padding: 0 20px;
        color: var(--gold);
        font-size: 14px;
        opacity: 0.5;
    }

    /* =========================================
       PLAYBILL COVER
       ========================================= */
    .cover { text-align: center; }

    .cover-border {
        border: 2px solid var(--border-gold);
        padding: 48px 32px;
        position: relative;
        background: linear-gradient(
            135deg,
            rgba(212, 167, 68, 0.03) 0%,
            transparent 50%,
            rgba(212, 167, 68, 0.03) 100%
        );
    }
    .cover-border::before {
        content: '';
        position: absolute;
        inset: 6px;
        border: 1px solid var(--border-gold);
        opacity: 0.3;
        pointer-events: none;
    }

    .ornament-top,
    .ornament-bottom {
        color: var(--gold);
        font-size: 20px;
        opacity: 0.5;
        letter-spacing: 8px;
    }

    .filigree-line {
        width: 200px;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent);
        margin: 16px auto;
        opacity: 0.5;
    }

    .theater-name {
        font-family: var(--heading);
        font-size: clamp(14px, 2vw, 18px);
        color: var(--gold-dim);
        letter-spacing: 8px;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .season-label {
        font-family: var(--accent);
        font-size: 14px;
        color: var(--text-light);
        letter-spacing: 4px;
        margin-bottom: 16px;
    }

    .opera-title {
        font-family: var(--heading);
        font-size: clamp(28px, 5vw, 48px);
        font-weight: 700;
        color: var(--burgundy);
        line-height: 1.2;
        margin-bottom: 8px;
        letter-spacing: 2px;
    }

    .opera-subtitle {
        font-family: var(--accent);
        font-size: clamp(16px, 2.5vw, 22px);
        color: var(--text-light);
        font-style: italic;
        letter-spacing: 3px;
        margin-bottom: 16px;
    }

    .cover-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-family: var(--accent);
        font-size: 14px;
        color: var(--text-light);
        letter-spacing: 2px;
    }
    .meta-divider { color: var(--gold); opacity: 0.5; }

    /* =========================================
       PRINCIPAL CAST
       ========================================= */
    .cast-grid {
        display: flex;
        gap: 32px;
