<script>
    /* =============================================
       CURTAIN INTRO SEQUENCE
       ============================================= */
    const curtainEl = document.getElementById('curtainOverlay')!;
    const spotlightEl = document.getElementById('spotlightOverlay')!;
    const playbillEl = document.getElementById('playbill')!;

    function skipIntro() {
        curtainEl.classList.add('open');
        setTimeout(() => {
            curtainEl.classList.add('done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
        }, 800);
    }

    function runIntro() {
        // Skip if already seen
        if (sessionStorage.getItem('opera-intro-seen')) {
            curtainEl.classList.add('open', 'done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
            return;
        }

        // Show title card, then open curtains after a pause
        setTimeout(() => {
            curtainEl.classList.add('open');
        }, 2200);

        setTimeout(() => {
            curtainEl.classList.add('done');
            playbillEl.classList.add('visible');
            spotlightEl.classList.add('active');
            sessionStorage.setItem('opera-intro-seen', '1');
        }, 4000);
    }

    // Click/key to skip
    curtainEl.addEventListener('click', () => {
        sessionStorage.setItem('opera-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!curtainEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('opera-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       SPOTLIGHT FOLLOW (subtle mouse tracking)
       ============================================= */
    document.addEventListener('mousemove', (e) => {
        const x = e.clientX;
        const y = e.clientY;
        spotlightEl.style.background = `radial-gradient(
            ellipse 600px 800px at ${x}px ${y}px,
            rgba(255, 248, 231, 0.06) 0%,
            transparent 70%
        )`;
    });
</script>
