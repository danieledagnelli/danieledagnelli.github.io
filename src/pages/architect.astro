<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const introInner = document.getElementById('introInner')!;
    const introSvg = document.getElementById('introSvg')!;
    const introTitleText = document.getElementById('introTitleText')!;
    const introSubtitleText = document.getElementById('introSubtitleText')!;
    const introDimensions = document.querySelector('.intro-dimensions')!;
    const introMeta = document.getElementById('introMeta')!;
    const blueprintEl = document.getElementById('blueprint')!;

    function skipIntro() {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            blueprintEl.classList.add('visible');
        }, 500);
    }

    async function runIntro() {
        if (sessionStorage.getItem('architect-intro')) {
            skipIntro();
            return;
        }

        await sleep(300);

        // Unroll the rectangle
        introInner.classList.add('visible');
        introInner.classList.add('unrolling');

        await sleep(1200);

        // Draw title text via stroke animation
        introTitleText.classList.add('draw');
        introSubtitleText.classList.add('draw');

        await sleep(1500);

        // Show dimension lines
        introDimensions.classList.add('show');

        await sleep(600);

        // Show meta text
        introMeta.classList.add('show');

        await sleep(1200);

        sessionStorage.setItem('architect-intro', '1');
        skipIntro();
    }

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    // Skip on click / key
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('architect-intro', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            e.preventDefault();
            sessionStorage.setItem('architect-intro', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       AMBIENT: Dimension arrows on scroll
       ============================================= */
    const sections = document.querySelectorAll('.bp-section');

    function addScrollDimensions() {
        sections.forEach((section) => {
            const rect = section.getBoundingClientRect();
            const inView = rect.top < window.innerHeight * 0.85 && rect.bottom > 0;
            if (inView) {
                section.classList.add('dim-visible');
            }
        });
    }

    window.addEventListener('scroll', addScrollDimensions, { passive: true });
    addScrollDimensions();
</script>
