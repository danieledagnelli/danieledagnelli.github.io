<body>

    <!-- BLUEPRINT GRID BACKGROUND -->
    <div class="grid-bg" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner" id="introInner">
            <svg class="intro-title-svg" id="introSvg" viewBox="0 0 800 60" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <text x="400" y="28" text-anchor="middle" class="intro-title-text" id="introTitleText">
                    ARCHITECTURAL SURVEY
                </text>
                <text x="400" y="50" text-anchor="middle" class="intro-subtitle-text" id="introSubtitleText">
                    DANIELE D'AGNELLI
                </text>
            </svg>
            <div class="intro-dimensions" id="introDimensions">
                <span class="dim-h-top" aria-hidden="true"></span>
                <span class="dim-h-bottom" aria-hidden="true"></span>
                <span class="dim-v-left" aria-hidden="true"></span>
                <span class="dim-v-right" aria-hidden="true"></span>
            </div>
            <p class="intro-meta" id="introMeta">SCALE 1:1 — SHEET 1 OF 1 — REV. 2024</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="blueprint" id="blueprint">

        <div class="blueprint-narrative">
            <h1 class="drawing-title">DESIGN INTENT: CAREER ARCHITECTURE — D'AGNELLI, D.</h1>
            <div class="drawing-meta">drawing no. 001 | scale: 1:career | date: 2012-present</div>

            <div class="blueprint-section">
                <h2>STRUCTURAL SYSTEM</h2>
                <p>load-bearing foundation in software engineering (accenture, milan). lateral bracing through consulting (codec, dublin; accenture, london). steel-frame management layer (deloitte, london — practice built from ground up). crown structure: senior engagement manager at c3 ai, directing $15m programme across all business units.</p>
            </div>

            <div class="blueprint-section">
                <h2>MATERIAL SPECIFICATIONS</h2>
                <p><strong>primary:</strong> solution architecture, enterprise architecture, cloud engineering (aws/azure/gcp)</p>
                <p><strong>reinforcement:</strong> ml pipelines, llms & genai, rag systems, data engineering</p>
                <p><strong>finishing:</strong> programme management, stakeholder management, digital transformation</p>
            </div>

            <div class="blueprint-stats">
                <p>LOAD CAPACITY: 70+ resources | 100+ plant deployments | $18m ebit | nps >70</p>
                <p>CERTIFICATIONS: prince2 practitioner | gchq-certified msc | stanford ml</p>
            </div>

            <div class="blueprint-footer">
                <a href="mailto:daniele@dagnelli.net">[engineer]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE RESET & VARIABLES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --blueprint: #1a3a5c;
        --blueprint-dark: #122a44;
        --white: #ffffff;
        --light-blue: #a8d4ff;
        --annotation-blue: #4a9eff;
        --dim-red: #e74c3c;
        --highlight-yellow: #f1c40f;
        --mono: 'Roboto Mono', 'Courier New', monospace;
        --display: 'Archivo', 'Helvetica Neue', sans-serif;
    }

    body {
        background: var(--blueprint);
        color: var(--white);
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.65;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a {
        color: var(--annotation-blue);
        text-decoration: none;
        transition: color 0.2s;
    }
    a:hover {
        color: var(--highlight-yellow);
        text-decoration: underline;
    }

    ::selection {
        background: var(--annotation-blue);
        color: var(--blueprint-dark);
    }

    /* =========================================
       BLUEPRINT GRID BACKGROUND
       ========================================= */
    .grid-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
            /* Major grid lines every ~100px */
            linear-gradient(to right, rgba(255,255,255,0.15) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255,255,255,0.15) 1px, transparent 1px),
            /* Minor grid lines every ~20px */
            linear-gradient(to right, rgba(255,255,255,0.05) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size:
            100px 100px,
            100px 100px,
            20px 20px,
            20px 20px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: var(--blueprint);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.5s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-inner {
        position: relative;
        width: 0;
        max-width: 800px;
        height: 200px;
        border: 2px solid var(--white);
        overflow: hidden;
        opacity: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px 40px;
    }
    .intro-inner.unrolling {
        animation: unroll 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .intro-inner.visible {
        opacity: 1;
    }

    @keyframes unroll {
        from { width: 0; opacity: 0; }
        10% { opacity: 1; }
        to { width: min(80vw, 800px); opacity: 1; }
    }

    .intro-title-svg {
        width: 100%;
        max-width: 700px;
        height: 60px;
        overflow: visible;
    }

    .intro-title-text {
        font-family: var(--display);
        font-size: 22px;
        font-weight: 800;
        fill: none;
        stroke: var(--white);
        stroke-width: 1;
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        letter-spacing: 4px;
    }
    .intro-title-text.draw {
        animation: drawText 2s ease forwards;
    }

    .intro-subtitle-text {
        font-family: var(--display);
        font-size: 16px;
        font-weight: 600;
        fill: none;
        stroke: var(--light-blue);
        stroke-width: 0.8;
        stroke-dasharray: 800;
        stroke-dashoffset: 800;
        letter-spacing: 6px;
    }
    .intro-subtitle-text.draw {
        animation: drawText 2s ease 0.5s forwards;
    }

    @keyframes drawText {
        to { stroke-dashoffset: 0; fill: var(--white); }
    }

    .intro-dimensions {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .dim-h-top, .dim-h-bottom, .dim-v-left, .dim-v-right {
        position: absolute;
        background: var(--dim-red);
        opacity: 0;
    }
    .dim-h-top, .dim-h-bottom {
        height: 1px;
        left: 10px;
        right: 10px;
    }
    .dim-v-left, .dim-v-right {
        width: 1px;
        top: 10px;
        bottom: 10px;
    }
    .dim-h-top { top: 8px; }
    .dim-h-bottom { bottom: 8px; }
    .dim-v-left { left: 8px; }
    .dim-v-right { right: 8px; }

    .dim-h-top::before, .dim-h-bottom::before {
        content: '';
        position: absolute;
        left: 0;
        top: -3px;
        width: 1px;
        height: 7px;
        background: var(--dim-red);
    }
    .dim-h-top::after, .dim-h-bottom::after {
        content: '';
        position: absolute;
        right: 0;
        top: -3px;
        width: 1px;
        height: 7px;
        background: var(--dim-red);
    }
    .dim-v-left::before, .dim-v-right::before {
        content: '';
        position: absolute;
        top: 0;
        left: -3px;
        width: 7px;
        height: 1px;
        background: var(--dim-red);
    }
    .dim-v-left::after, .dim-v-right::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: -3px;
        width: 7px;
        height: 1px;
        background: var(--dim-red);
    }

    .intro-dimensions.show span {
        opacity: 1;
        transition: opacity 0.6s ease;
    }

    .intro-meta {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--light-blue);
        letter-spacing: 3px;
        margin-top: 12px;
        opacity: 0;
        transition: opacity 0.5s ease 0.3s;
    }
    .intro-meta.show {
        opacity: 1;
    }

    /* =========================================
       MAIN CONTENT — VIEWPORT LOCKED
       ========================================= */
    .blueprint {
        position: relative;
        z-index: 1;
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .blueprint.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* =========================================
       BLUEPRINT NARRATIVE
       ========================================= */
    .blueprint-narrative {
        max-width: 650px;
        padding: 1.5rem;
    }

    .drawing-title {
        font-size: 1rem;
        text-align: center;
        margin-bottom: 0.3rem;
    }

    .drawing-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .blueprint-section {
        margin-bottom: 0.8rem;
    }

    .blueprint-section h2 {
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.3rem;
    }

    .blueprint-section p {
        font-size: 0.78rem;
        line-height: 1.5;
        margin-bottom: 0.3rem;
    }

    .blueprint-stats {
        font-size: 0.72rem;
        opacity: 0.8;
        margin: 0.8rem 0;
    }

    .blueprint-stats p {
        margin-bottom: 0.2rem;
    }

    .blueprint-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .blueprint-footer a {
        text-decoration: none;
    }

    /* =========================================
       RESPONSIVE: 768px
       ========================================= */
    @media (max-width: 768px) {
        .blueprint-section p {
            font-size: 0.72rem;
        }

        .intro-inner {
            height: 160px;
            padding: 16px 20px;
        }

        .intro-title-text {
            font-size: 16px;
        }

        .intro-subtitle-text {
            font-size: 12px;
        }
    }

    /* =========================================
       RESPONSIVE: 480px
       ========================================= */
    @media (max-width: 480px) {
        .intro-inner {
            height: 130px;
            padding: 12px 16px;
        }

        .intro-title-text {
            font-size: 13px;
        }

        .intro-subtitle-text {
            font-size: 10px;
        }
    }

    /* =========================================
       RESPONSIVE: 380px
       ========================================= */
    @media (max-width: 380px) {
        .intro-inner {
            height: 110px;
        }

        .intro-title-text {
            font-size: 11px;
        }

        .intro-subtitle-text {
            font-size: 9px;
        }
    }
</style>

<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const introInner = document.getElementById('introInner')!;
    const introSvg = document.getElementById('introSvg')!;
    const introTitleText = document.getElementById('introTitleText')!;
    const introSubtitleText = document.getElementById('introSubtitleText')!;
    const introDimensions = document.querySelector('.intro-dimensions')!;
    const introMeta = document.getElementById('introMeta')!;
    const blueprintEl = document.getElementById('blueprint')!;

    function skipIntro() {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            blueprintEl.classList.add('visible');
        }, 500);
    }

    async function runIntro() {
        if (sessionStorage.getItem('architect-intro')) {
            skipIntro();
            return;
        }

        await sleep(300);

        // Unroll the rectangle
        introInner.classList.add('visible');
        introInner.classList.add('unrolling');

        await sleep(1200);

        // Draw title text via stroke animation
        introTitleText.classList.add('draw');
        introSubtitleText.classList.add('draw');

        await sleep(1500);

        // Show dimension lines
        introDimensions.classList.add('show');

        await sleep(600);

        // Show meta text
        introMeta.classList.add('show');

        await sleep(1200);

        sessionStorage.setItem('architect-intro', '1');
        skipIntro();
    }

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    // Skip on click / key
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('architect-intro', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            e.preventDefault();
            sessionStorage.setItem('architect-intro', '1');
            skipIntro();
        }
    });

    runIntro();
</script>
