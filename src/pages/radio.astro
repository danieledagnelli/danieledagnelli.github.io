---
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Vintage Radio Broadcast | Senior Engagement Manager</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager with 15+ years in Professional Services. Tune in to the broadcast." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/radio" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta property="og:description" content="Tune in to the broadcast. 15+ years leading high-impact digital transformations." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/radio" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta name="twitter:description" content="Tune in to the broadcast. 15+ years leading high-impact digital transformations." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": siteMetadata.email,
        "sameAs": [
            `https://github.com/${siteMetadata.github_handle}`,
            `https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`,
            `https://bsky.app/profile/${siteMetadata.bsky_handle}`
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- WOOD GRAIN OVERLAY -->
    <div class="wood-overlay" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-radio">
            <div class="intro-dial-label">Tuning...</div>
            <div class="intro-frequency-bars" id="introFreqBars">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
            </div>
            <div class="intro-dial-numbers">
                <span>53</span><span>60</span><span>70</span><span>80</span><span>90</span>
                <span>100</span><span>108</span>
            </div>
            <div class="intro-needle" id="introNeedle"></div>
            <div class="intro-status" id="introStatus">Searching for signal...</div>
            <div class="intro-on-air" id="introOnAir">ON AIR</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="broadcast" id="broadcast">
        <div class="radio-narrative">
            <div class="on-air-badge">[ON AIR]</div>
            <h1 class="station-title">STATION DAGNELLI — BROADCASTING FROM LONDON</h1>
            <div class="programme-title">TONIGHT'S PROGRAMME: "THE MULTIPLIER EFFECT"</div>

            <div class="transcript">
                <p>good evening, listeners. tonight we're talking about what happens when you don't just deliver — you build the capability for others to deliver too.</p>
                <p>our subject: daniele d'agnelli. at deloitte, he didn't just run projects. he built an entire anaplan practice from nothing. zero practitioners to twenty-five plus. that's not consulting. that's institution-building.</p>
                <p>at c3 ai, the pattern continued. partner enablement across consulting firms. practice-building. training the trainers. leading a 20+ cross-functional team across app dev, data science, qa, and devops. not just shipping software — shipping the ability to ship software.</p>
                <p>the result? $15m in programme value. $18m ebit impact for clients. nps above 70, which in this business is like getting a standing ovation from people who don't stand.</p>
            </div>

            <div class="sign-off">this has been station dagnelli. transmitting on all frequencies.</div>

            <div class="radio-footer">
                <a href="mailto:daniele@dagnelli.net">[signal]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>
    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --mahogany: #2a1810;
        --amber: #d4930d;
        --cream: #f5e6c8;
        --brass: #b8860b;
        --walnut: #1a0f08;
        --radio-green: #4a7c59;
        --amber-glow: rgba(212, 147, 13, 0.3);
        --brass-glow: rgba(184, 134, 11, 0.2);
        --display: 'Abril Fatface', serif;
        --body: 'Source Sans 3', sans-serif;
        --mono: 'JetBrains Mono', monospace;
    }

    body {
        background: var(--walnut);
        color: var(--cream);
        font-family: var(--body);
        font-size: 16px;
        line-height: 1.6;
        overflow: hidden;
        margin: 0;
    }

    a { color: var(--amber); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--cream); }

    ::selection { background: var(--amber); color: var(--walnut); }

    /* =========================================
       WOOD GRAIN OVERLAY
       ========================================= */
    .wood-overlay {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background:
            repeating-linear-gradient(
                90deg,
                transparent 0px,
                transparent 3px,
                rgba(42, 24, 16, 0.15) 3px,
                rgba(42, 24, 16, 0.15) 4px
            ),
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 20px,
                rgba(26, 15, 8, 0.1) 20px,
                rgba(26, 15, 8, 0.1) 22px
            ),
            radial-gradient(
                ellipse at 30% 50%,
                rgba(42, 24, 16, 0.08) 0%,
                transparent 70%
            );
        opacity: 0.6;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--walnut);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.5s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-radio {
        text-align: center;
        max-width: 500px;
        width: 100%;
        position: relative;
    }

    .intro-dial-label {
        font-family: var(--display);
        font-size: 28px;
        color: var(--amber);
        margin-bottom: 24px;
        text-shadow: 0 0 20px var(--amber-glow);
    }

    .intro-frequency-bars {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        gap: 4px;
        height: 60px;
        margin-bottom: 16px;
    }
    .intro-frequency-bars span {
        width: 8px;
        background: var(--amber);
        border-radius: 2px 2px 0 0;
        height: 10px;
        transition: height 0.1s ease;
        opacity: 0.7;
        box-shadow: 0 0 6px var(--amber-glow);
    }

    .intro-dial-numbers {
        display: flex;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--brass);
        padding: 0 10px;
        margin-bottom: 12px;
        opacity: 0.7;
    }

    .intro-needle {
        width: 2px;
        height: 20px;
        background: var(--amber);
        margin: 0 auto;
        box-shadow: 0 0 8px var(--amber-glow);
        transition: transform 0.3s ease;
        position: relative;
    }

    .intro-status {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--brass);
        margin-top: 20px;
        opacity: 0.8;
    }

    .intro-on-air {
        font-family: var(--display);
        font-size: 48px;
        color: #c0392b;
        margin-top: 24px;
        opacity: 0;
        transition: opacity 0.3s ease;
        text-shadow: 0 0 30px rgba(192, 57, 43, 0.6), 0 0 60px rgba(192, 57, 43, 0.3);
        letter-spacing: 8px;
    }
    .intro-on-air.lit {
        opacity: 1;
        animation: onAirPulse 1.5s ease-in-out infinite;
    }

    /* =========================================
       MAIN CONTENT — VIEWPORT-LOCKED
       ========================================= */
    .broadcast {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 1;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }
    .broadcast.visible { opacity: 1; }

    .radio-narrative {
        max-width: 580px;
        padding: 1.5rem;
        text-align: center;
    }

    .on-air-badge {
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        margin-bottom: 0.5rem;
        font-family: var(--mono);
        color: #c0392b;
        text-shadow: 0 0 10px rgba(192, 57, 43, 0.5);
        animation: onAirPulse 2s ease-in-out infinite;
    }

    .station-title {
        font-size: 1rem;
        margin-bottom: 0.3rem;
        font-family: var(--display);
        color: var(--amber);
        text-shadow: 0 0 15px var(--amber-glow);
    }

    .programme-title {
        font-size: 0.75rem;
        opacity: 0.7;
        margin-bottom: 1rem;
        font-family: var(--mono);
        color: var(--brass);
        letter-spacing: 0.05em;
    }

    .transcript {
        text-align: left;
    }

    .transcript p {
        font-size: 0.78rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
        color: var(--cream);
        font-family: var(--body);
    }

    .sign-off {
        font-size: 0.75rem;
        font-style: italic;
        opacity: 0.8;
        margin: 0.8rem 0;
        text-align: center;
        color: var(--cream);
        font-family: var(--body);
    }

    .radio-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 0.8rem;
    }

    .radio-footer a {
        text-decoration: none;
        font-family: var(--mono);
        font-size: 0.75rem;
    }

    /* =========================================
       KEYFRAMES
       ========================================= */
    @keyframes onAirPulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    /* =========================================
       RESPONSIVE — MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .transcript p {
            font-size: 0.72rem;
        }
    }

    @media (max-width: 600px) {
        .intro-dial-label { font-size: 22px; }
        .intro-on-air { font-size: 36px; letter-spacing: 6px; }
    }

    @media (max-width: 380px) {
        .intro-dial-label { font-size: 18px; }
        .intro-on-air { font-size: 28px; letter-spacing: 4px; }
        .intro-frequency-bars { height: 40px; }
        .intro-frequency-bars span { width: 5px; }
    }
</style>

<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const broadcastEl = document.getElementById('broadcast')!;
    const freqBars = document.querySelectorAll('#introFreqBars span');
    const needleEl = document.getElementById('introNeedle')!;
    const statusEl = document.getElementById('introStatus')!;
    const onAirEl = document.getElementById('introOnAir')!;

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    function skipIntro(): void {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            broadcastEl.classList.add('visible');
        }, 500);
    }

    let introAnimationId: number | null = null;
    let introAborted = false;

    async function animateFreqBars(duration: number): Promise<void> {
        const start = Date.now();
        return new Promise<void>((resolve) => {
            function tick(): void {
                if (introAborted) { resolve(); return; }
                const elapsed = Date.now() - start;
                if (elapsed > duration) { resolve(); return; }
                freqBars.forEach((bar) => {
                    const el = bar as HTMLElement;
                    el.style.height = (5 + Math.random() * 50) + 'px';
                });
                introAnimationId = requestAnimationFrame(tick);
            }
            tick();
        });
    }

    async function runIntro(): Promise<void> {
        if (sessionStorage.getItem('radio-intro-seen')) {
            skipIntro();
            return;
        }

        // Phase 1: Static / searching
        statusEl.textContent = 'Scanning the airwaves...';
        await animateFreqBars(1500);
        if (introAborted) return;

        // Phase 2: Tuning
        statusEl.textContent = 'Signal detected... tuning in...';
        needleEl.style.transform = 'translateX(40px)';
        await animateFreqBars(1200);
        if (introAborted) return;

        // Phase 3: Locked
        statusEl.textContent = 'Station locked: WDDA 98.7 FM';
        needleEl.style.transform = 'translateX(80px)';
        freqBars.forEach((bar) => {
            const el = bar as HTMLElement;
            el.style.height = '30px';
            el.style.opacity = '1';
        });
        await sleep(600);
        if (introAborted) return;

        // Phase 4: ON AIR
        statusEl.textContent = '';
        onAirEl.classList.add('lit');
        await sleep(1200);
        if (introAborted) return;

        sessionStorage.setItem('radio-intro-seen', '1');
        skipIntro();
    }

    // Click/key to skip
    introEl.addEventListener('click', () => {
        introAborted = true;
        if (introAnimationId) cancelAnimationFrame(introAnimationId);
        sessionStorage.setItem('radio-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            introAborted = true;
            if (introAnimationId) cancelAnimationFrame(introAnimationId);
            sessionStorage.setItem('radio-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();
</script>
