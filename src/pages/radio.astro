</style>

<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const broadcastEl = document.getElementById('broadcast')!;
    const freqBars = document.querySelectorAll('#introFreqBars span');
    const needleEl = document.getElementById('introNeedle')!;
    const statusEl = document.getElementById('introStatus')!;
    const onAirEl = document.getElementById('introOnAir')!;

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    function skipIntro(): void {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            broadcastEl.classList.add('visible');
        }, 500);
    }

    let introAnimationId: number | null = null;
    let introAborted = false;

    async function animateFreqBars(duration: number): Promise<void> {
        const start = Date.now();
        return new Promise<void>((resolve) => {
            function tick(): void {
                if (introAborted) { resolve(); return; }
                const elapsed = Date.now() - start;
                if (elapsed > duration) { resolve(); return; }
                freqBars.forEach((bar) => {
                    const el = bar as HTMLElement;
                    el.style.height = (5 + Math.random() * 50) + 'px';
                });
                introAnimationId = requestAnimationFrame(tick);
            }
            tick();
        });
    }

    async function runIntro(): Promise<void> {
        if (sessionStorage.getItem('radio-intro-seen')) {
            skipIntro();
            return;
        }

        // Phase 1: Static / searching
        statusEl.textContent = 'Scanning the airwaves...';
        await animateFreqBars(1500);
        if (introAborted) return;

        // Phase 2: Tuning
        statusEl.textContent = 'Signal detected... tuning in...';
        needleEl.style.transform = 'translateX(40px)';
        await animateFreqBars(1200);
        if (introAborted) return;

        // Phase 3: Locked
        statusEl.textContent = 'Station locked: WDDA 98.7 FM';
        needleEl.style.transform = 'translateX(80px)';
        freqBars.forEach((bar) => {
            const el = bar as HTMLElement;
            el.style.height = '30px';
            el.style.opacity = '1';
        });
        await sleep(600);
        if (introAborted) return;

        // Phase 4: ON AIR
        statusEl.textContent = '';
        onAirEl.classList.add('lit');
        await sleep(1200);
        if (introAborted) return;

        sessionStorage.setItem('radio-intro-seen', '1');
        skipIntro();
    }

    // Click/key to skip
    introEl.addEventListener('click', () => {
        introAborted = true;
        if (introAnimationId) cancelAnimationFrame(introAnimationId);
        sessionStorage.setItem('radio-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            introAborted = true;
            if (introAnimationId) cancelAnimationFrame(introAnimationId);
            sessionStorage.setItem('radio-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       VU METER ANIMATION
       ============================================= */
    const vuFillLeft = document.getElementById('vuFillLeft') as HTMLElement;
    const vuFillRight = document.getElementById('vuFillRight') as HTMLElement;

    function animateVU(): void {
        const baseL = 40 + Math.random() * 35;
        const baseR = 40 + Math.random() * 35;
        vuFillLeft.style.width = baseL + '%';
        vuFillRight.style.width = baseR + '%';
        setTimeout(animateVU, 120 + Math.random() * 180);
    }
    animateVU();
</script>
