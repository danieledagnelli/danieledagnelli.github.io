---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Vintage Radio Broadcast | Senior Engagement Manager</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager with 15+ years in Professional Services. Tune in to the broadcast." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/radio" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta property="og:description" content="Tune in to the broadcast. 15+ years leading high-impact digital transformations." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/radio" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Vintage Radio Broadcast" />
    <meta name="twitter:description" content="Tune in to the broadcast. 15+ years leading high-impact digital transformations." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": siteMetadata.email,
        "sameAs": [
            `https://github.com/${siteMetadata.github_handle}`,
            `https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`,
            `https://bsky.app/profile/${siteMetadata.bsky_handle}`
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- WOOD GRAIN OVERLAY -->
    <div class="wood-overlay" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-radio">
            <div class="intro-dial-label">Tuning...</div>
            <div class="intro-frequency-bars" id="introFreqBars">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
            </div>
            <div class="intro-dial-numbers">
                <span>53</span><span>60</span><span>70</span><span>80</span><span>90</span>
                <span>100</span><span>108</span>
            </div>
            <div class="intro-needle" id="introNeedle"></div>
            <div class="intro-status" id="introStatus">Searching for signal...</div>
            <div class="intro-on-air" id="introOnAir">ON AIR</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="broadcast" id="broadcast">

        <!-- ON AIR HEADER WITH DIAL -->
        <header class="section header-section">
            <div class="on-air-badge">ON AIR</div>
            <div class="dial-display">
                <div class="dial-window">
                    <div class="dial-frequencies">
                        <span>53</span><span>60</span><span>70</span><span>80</span>
                        <span>90</span><span>100</span><span>108</span>
                    </div>
                    <div class="dial-indicator"></div>
                </div>
                <div class="vu-meters">
                    <div class="vu-meter" id="vuLeft">
                        <div class="vu-label">L</div>
                        <div class="vu-bar"><div class="vu-fill" id="vuFillLeft"></div></div>
                    </div>
                    <div class="vu-meter" id="vuRight">
                        <div class="vu-label">R</div>
                        <div class="vu-bar"><div class="vu-fill" id="vuFillRight"></div></div>
                    </div>
                </div>
            </div>
            <div class="station-info">
                <div class="station-name">WDDA 98.7 FM</div>
                <div class="station-tagline">The Voice of Professional Excellence</div>
            </div>
        </header>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- OPENING ANNOUNCEMENT -->
        <section class="section reveal" id="announcement">
            <div class="section-header">
                <span class="section-icon">&#9834;</span>
                <h2 class="section-title">Opening Announcement</h2>
                <span class="section-icon">&#9834;</span>
            </div>
            <div class="announcer-card">
                <div class="announcer-photo">
                    <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="160" height="160" />
                    <div class="photo-glow"></div>
                </div>
                <div class="announcer-info">
                    <h1 class="announcer-name">{siteMetadata.name}</h1>
                    <div class="announcer-role">Senior Engagement Manager &mdash; AI &amp; Cybersecurity</div>
                    <div class="announcer-meta">
                        <span class="meta-item">Broadcasting from {siteMetadata.location}</span>
                    </div>
                    <div class="announcer-links">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                        <span class="link-dot">&bull;</span>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                        <span class="link-dot">&bull;</span>
                        <a href={`mailto:${siteMetadata.email}`}>Contact</a>
                    </div>
                </div>
            </div>
            <div class="announcer-script">
                <p class="script-text">&ldquo;Good evening, listeners. You are tuned in to WDDA 98.7 FM. Tonight&rsquo;s featured guest brings over fifteen years of professional services expertise to our airwaves.&rdquo;</p>
                <p class="summary-text">{summary}</p>
            </div>
            <div class="metrics-ticker">
                {metrics.map(m => (
                    <div class="ticker-item">
                        <span class="ticker-value">{m.value}</span>
                        <span class="ticker-label">{m.label}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- PROGRAM SCHEDULE (Experience) -->
        <section class="section reveal" id="program">
            <div class="section-header">
                <span class="section-icon">&#9834;</span>
                <h2 class="section-title">Tonight&rsquo;s Program Schedule</h2>
                <span class="section-icon">&#9834;</span>
            </div>
            <div class="program-list">
                {experience.map((exp, i) => (
                    <div class="program-block reveal">
                        <div class="program-time-slot">
                            <div class="program-indicator">
                                <span class="indicator-light"></span>
                            </div>
                            <div class="program-details">
                                <div class="program-top">
                                    <span class="program-company">{exp.company}</span>
                                    <span class="program-location">{exp.location}</span>
                                </div>
                                {exp.roles.map(role => (
                                    <div class="program-role">
                                        <div class="role-header">
                                            <span class="role-title">{role.title}</span>
                                            <span class="role-time">{role.period}</span>
                                        </div>
                                        {role.description && <p class="role-description">{role.description}</p>}
                                        {role.bullets && role.bullets.length > 0 && (
                                            <ul class="role-highlights">
                                                {role.bullets.map(b => <li>{b}</li>)}
                                            </ul>
                                        )}
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- STATION DIRECTORY (Skills) -->
        <section class="section reveal" id="directory">
            <div class="section-header">
                <span class="section-icon">&#9834;</span>
                <h2 class="section-title">Station Frequency Directory</h2>
                <span class="section-icon">&#9834;</span>
            </div>
            <div class="frequency-group">
                <h3 class="freq-group-label">Technical Frequencies</h3>
                <div class="frequency-grid">
                    {skills.map((s, i) => (
                        <div class="freq-chip" style={`--i:${i}`}>
                            <span class="freq-number">{(88.1 + i * 0.8).toFixed(1)}</span>
                            <span class="freq-name">{s}</span>
                        </div>
                    ))}
                </div>
            </div>
            <div class="frequency-group">
                <h3 class="freq-group-label">Management Frequencies</h3>
                <div class="frequency-grid">
                    {managementSkills.map((s, i) => (
                        <div class="freq-chip management" style={`--i:${i}`}>
                            <span class="freq-number">{(101.1 + i * 0.4).toFixed(1)}</span>
                            <span class="freq-name">{s}</span>
                        </div>
                    ))}
                </div>
            </div>
            <div class="frequency-group">
                <h3 class="freq-group-label">Industry Coverage</h3>
                <div class="frequency-grid">
                    {industries.map((ind, i) => (
                        <div class="freq-chip industry" style={`--i:${i}`}>
                            <span class="freq-number">{(90.1 + i * 1.2).toFixed(1)}</span>
                            <span class="freq-name">{ind}</span>
                        </div>
                    ))}
                </div>
            </div>
            <div class="frequency-group">
                <h3 class="freq-group-label">Languages On Air</h3>
                <div class="frequency-grid">
                    {languages.map((lang, i) => (
                        <div class="freq-chip language" style={`--i:${i}`}>
                            <span class="freq-number">{(107.1 + i * 0.6).toFixed(1)}</span>
                            <span class="freq-name">{lang}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- NEWS BULLETINS (Engagements) -->
        <section class="section reveal" id="bulletins">
            <div class="section-header">
                <span class="section-icon">&#9834;</span>
                <h2 class="section-title">Breaking News Bulletins</h2>
                <span class="section-icon">&#9834;</span>
            </div>
            <div class="bulletin-intro">We interrupt this broadcast for the following special reports&hellip;</div>
            <div class="bulletin-grid">
                {engagements.map(eng => (
                    <div class="bulletin-card reveal">
                        <div class="bulletin-flash">BULLETIN</div>
                        <div class="bulletin-content">
                            <div class="bulletin-top">
                                <span class="bulletin-client">{eng.client}</span>
                                <span class="bulletin-sector">{eng.sector}</span>
                            </div>
                            <div class="bulletin-details">
                                <span class="bulletin-scope">{eng.scope}</span>
                                <span class={`bulletin-impact ${eng.trend}`}>{eng.impact}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- SPONSOR MESSAGES (Education & Certifications) -->
        <section class="section reveal" id="sponsors">
            <div class="section-header">
                <span class="section-icon">&#9834;</span>
                <h2 class="section-title">Brought to You By</h2>
                <span class="section-icon">&#9834;</span>
            </div>
            <div class="sponsor-group">
                <h3 class="sponsor-label">Academic Sponsors</h3>
                {education.map(edu => (
                    <div class="sponsor-card reveal">
                        <div class="sponsor-badge">{edu.distinction || "Alumnus"}</div>
                        <div class="sponsor-details">
                            <div class="sponsor-degree">{edu.degree}</div>
                            <div class="sponsor-meta">{edu.institution} &mdash; {edu.location}</div>
                            <div class="sponsor-period">{edu.period}</div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="sponsor-group">
                <h3 class="sponsor-label">Professional Certifications</h3>
                <div class="cert-grid">
                    {certifications.map(c => (
                        <div class="cert-chip">{c}</div>
                    ))}
                </div>
            </div>
            <div class="sponsor-group">
                <h3 class="sponsor-label">Continuing Education Programs</h3>
                <div class="learning-list">
                    {continuousLearning.map(l => (
                        <div class="learning-item">{l}</div>
                    ))}
                </div>
            </div>
        </section>

        <div class="deco-border" aria-hidden="true"></div>

        <!-- SIGN-OFF FOOTER -->
        <footer class="section sign-off">
            <div class="sign-off-text">
                <p>&ldquo;That concludes tonight&rsquo;s broadcast on WDDA 98.7 FM. Thank you for tuning in, dear listeners.&rdquo;</p>
                <p class="sign-off-sub">This has been {siteMetadata.name}, broadcasting from {siteMetadata.location}.</p>
                <p class="sign-off-sub">Until next time &mdash; keep your dial tuned and your signal strong.</p>
            </div>
            <div class="sign-off-bar">
                <span class="off-air-badge">OFF AIR</span>
            </div>
        </footer>
    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --mahogany: #2a1810;
        --amber: #d4930d;
        --cream: #f5e6c8;
        --brass: #b8860b;
        --walnut: #1a0f08;
        --radio-green: #4a7c59;
        --amber-glow: rgba(212, 147, 13, 0.3);
        --brass-glow: rgba(184, 134, 11, 0.2);
        --display: 'Abril Fatface', serif;
        --body: 'Source Sans 3', sans-serif;
        --mono: 'JetBrains Mono', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--brass) var(--walnut);
    }

    body {
        background: var(--walnut);
        color: var(--cream);
        font-family: var(--body);
        font-size: 16px;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--amber); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--cream); }

    ::selection { background: var(--amber); color: var(--walnut); }

    /* =========================================
       WOOD GRAIN OVERLAY
       ========================================= */
    .wood-overlay {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background:
            repeating-linear-gradient(
                90deg,
                transparent 0px,
                transparent 3px,
                rgba(42, 24, 16, 0.15) 3px,
                rgba(42, 24, 16, 0.15) 4px
            ),
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 20px,
                rgba(26, 15, 8, 0.1) 20px,
                rgba(26, 15, 8, 0.1) 22px
            ),
            radial-gradient(
                ellipse at 30% 50%,
                rgba(42, 24, 16, 0.08) 0%,
                transparent 70%
            );
        opacity: 0.6;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--walnut);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.5s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-radio {
        text-align: center;
        max-width: 500px;
        width: 100%;
        position: relative;
    }

    .intro-dial-label {
        font-family: var(--display);
        font-size: 28px;
        color: var(--amber);
        margin-bottom: 24px;
        text-shadow: 0 0 20px var(--amber-glow);
    }

    .intro-frequency-bars {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        gap: 4px;
        height: 60px;
        margin-bottom: 16px;
    }
    .intro-frequency-bars span {
        width: 8px;
        background: var(--amber);
        border-radius: 2px 2px 0 0;
        height: 10px;
        transition: height 0.1s ease;
        opacity: 0.7;
        box-shadow: 0 0 6px var(--amber-glow);
    }

    .intro-dial-numbers {
        display: flex;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--brass);
        padding: 0 10px;
        margin-bottom: 12px;
        opacity: 0.7;
    }

    .intro-needle {
        width: 2px;
        height: 20px;
        background: var(--amber);
        margin: 0 auto;
        box-shadow: 0 0 8px var(--amber-glow);
        transition: transform 0.3s ease;
        position: relative;
    }

    .intro-status {
        font-family: var(--mono);
        font-size: 14px;
        color: var(--brass);
        margin-top: 20px;
        opacity: 0.8;
    }

    .intro-on-air {
        font-family: var(--display);
        font-size: 48px;
        color: #c0392b;
        margin-top: 24px;
        opacity: 0;
        transition: opacity 0.3s ease;
        text-shadow: 0 0 30px rgba(192, 57, 43, 0.6), 0 0 60px rgba(192, 57, 43, 0.3);
        letter-spacing: 8px;
    }
    .intro-on-air.lit {
        opacity: 1;
        animation: onAirPulse 1.5s ease-in-out infinite;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .broadcast {
        max-width: 860px;
        margin: 0 auto;
        padding: 40px 24px 120px;
        position: relative;
        z-index: 1;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }
    .broadcast.visible { opacity: 1; }

    /* =========================================
       SECTION STYLING
       ========================================= */
    .section { margin-bottom: 0; }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        margin-bottom: 28px;
    }

    .section-title {
        font-family: var(--display);
        font-size: 28px;
        color: var(--amber);
        text-align: center;
        text-shadow: 0 0 15px var(--amber-glow);
    }

    .section-icon {
        color: var(--brass);
        font-size: 18px;
        opacity: 0.6;
    }

    /* ART DECO BORDER */
    .deco-border {
        height: 3px;
        margin: 40px 0;
        background: linear-gradient(
            90deg,
            transparent 0%,
            var(--brass) 15%,
            var(--amber) 40%,
            var(--cream) 50%,
            var(--amber) 60%,
            var(--brass) 85%,
            transparent 100%
        );
        opacity: 0.4;
        position: relative;
    }
    .deco-border::before,
    .deco-border::after {
        content: '';
        position: absolute;
        top: -3px;
        width: 9px;
        height: 9px;
        background: var(--brass);
        transform: rotate(45deg);
        opacity: 0.6;
    }
    .deco-border::before { left: 14%; }
    .deco-border::after { right: 14%; }

    /* REVEAL ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* =========================================
       ON AIR HEADER
       ========================================= */
    .header-section {
        text-align: center;
        padding-top: 20px;
    }

    .on-air-badge {
        display: inline-block;
        font-family: var(--display);
        font-size: 42px;
        color: #c0392b;
        letter-spacing: 10px;
        padding: 8px 32px;
        border: 3px solid #c0392b;
        border-radius: 8px;
        margin-bottom: 28px;
        text-shadow: 0 0 20px rgba(192, 57, 43, 0.5);
        box-shadow: 0 0 20px rgba(192, 57, 43, 0.15), inset 0 0 20px rgba(192, 57, 43, 0.05);
        animation: onAirPulse 2s ease-in-out infinite;
    }

    .dial-display {
        background: linear-gradient(145deg, var(--mahogany), var(--walnut));
        border: 2px solid var(--brass);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.5), 0 0 12px var(--brass-glow);
    }

    .dial-window {
        background: linear-gradient(180deg, #1a1408, #0d0a04);
        border: 1px solid var(--brass);
        border-radius: 6px;
        padding: 16px 20px 12px;
        position: relative;
        margin-bottom: 16px;
    }

    .dial-frequencies {
        display: flex;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 14px;
        color: var(--amber);
        opacity: 0.8;
    }

    .dial-indicator {
        width: 2px;
        height: 24px;
        background: #c0392b;
        margin: 8px auto 0;
        box-shadow: 0 0 6px rgba(192, 57, 43, 0.6);
        animation: dialSlide 8s ease-in-out infinite;
    }

    .vu-meters {
        display: flex;
        gap: 12px;
        justify-content: center;
    }

    .vu-meter {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .vu-label {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--brass);
        width: 14px;
    }

    .vu-bar {
        width: 160px;
        height: 10px;
        background: #0d0a04;
        border: 1px solid var(--brass);
        border-radius: 3px;
        overflow: hidden;
        position: relative;
    }

    .vu-fill {
        height: 100%;
        width: 60%;
        background: linear-gradient(90deg, var(--radio-green), var(--radio-green) 70%, var(--amber) 85%, #c0392b);
        border-radius: 2px;
        transition: width 0.15s ease;
        box-shadow: 0 0 4px var(--amber-glow);
    }

    .station-info {
        margin-top: 8px;
    }

    .station-name {
        font-family: var(--display);
        font-size: 24px;
        color: var(--amber);
        letter-spacing: 3px;
        text-shadow: 0 0 10px var(--amber-glow);
    }

    .station-tagline {
        font-family: var(--body);
        font-size: 14px;
        color: var(--brass);
        font-style: italic;
        margin-top: 4px;
        opacity: 0.8;
    }

    /* =========================================
       OPENING ANNOUNCEMENT
       ========================================= */
    .announcer-card {
        display: flex;
        gap: 28px;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .announcer-photo {
        position: relative;
        flex-shrink: 0;
    }

