    /* =========================================
       ANIMATIONS
       ========================================= */
    @keyframes subtleRock {
        0%, 100% { transform: rotate(-0.3deg); }
        50% { transform: rotate(0.3deg); }
    }
</style>

<script>
    (function () {
        const STORAGE_KEY = 'pirate-intro';
        const intro = document.getElementById('intro');
        const introText = document.getElementById('introText');
        const introCompass = document.getElementById('introCompass');
        const logbook = document.getElementById('logbook');
        const introScroll = document.getElementById('introScroll');

        const fullText = "The Logbook of Captain D'Agnelli \u2014 Voyages & Conquests";
        let charIndex = 0;
        let typeTimer = null;
        let dismissed = false;

        function showContent() {
            if (dismissed) return;
            dismissed = true;
            if (typeTimer) clearTimeout(typeTimer);
            if (intro) intro.classList.add('done');
            if (logbook) logbook.classList.add('visible');
            try { sessionStorage.setItem(STORAGE_KEY, '1'); } catch (e) { /* noop */ }
            setTimeout(() => {
                if (intro) intro.style.display = 'none';
            }, 700);
        }

        // Skip if already seen
        try {
            if (sessionStorage.getItem(STORAGE_KEY)) {
                if (intro) { intro.style.display = 'none'; intro.classList.add('done'); }
                if (logbook) { logbook.style.opacity = '1'; logbook.classList.add('visible'); }
                dismissed = true;
                initReveal();
                return;
            }
        } catch (e) { /* noop */ }

        // Skip handlers
        function skipHandler(e) {
            if (e.type === 'keydown') {
                if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter') {
                    e.preventDefault();
                    showContent();
                }
            } else {
                showContent();
            }
        }

        document.addEventListener('keydown', skipHandler);
        if (intro) intro.addEventListener('click', skipHandler);

        // Typewriter effect
        function typeChar() {
            if (dismissed || !introText) return;
            if (charIndex < fullText.length) {
                introText.innerHTML = fullText.slice(0, charIndex + 1) + '<span class="quill-cursor" aria-hidden="true"></span>';
                charIndex++;
                typeTimer = setTimeout(typeChar, 50 + Math.random() * 40);
            } else {
                // Done typing, wait then show
                introText.innerHTML = fullText;
                setTimeout(showContent, 1200);
            }
        }

        // Start after scroll unrolls
        setTimeout(() => {
            if (!dismissed) typeChar();
        }, 1300);

        // Auto-dismiss after timeout
        setTimeout(() => {
            if (!dismissed) showContent();
        }, 8000);

        // Cleanup
        function cleanup() {
            document.removeEventListener('keydown', skipHandler);
            if (intro) intro.removeEventListener('click', skipHandler);
        }

        // After content shown, init reveals
        const origShowContent = showContent;

        function initReveal() {
            const reveals = document.querySelectorAll('.reveal');
            if (!reveals.length) return;

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('in-view');
                            observer.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
            );

            reveals.forEach((el) => observer.observe(el));
        }

        // Observe for content visibility
        const contentObserver = new MutationObserver(() => {
            if (logbook && logbook.classList.contains('visible')) {
                initReveal();
                contentObserver.disconnect();
            }
        });

        if (logbook) {
            contentObserver.observe(logbook, { attributes: true, attributeFilter: ['class'] });
        }
    })();
</script>
