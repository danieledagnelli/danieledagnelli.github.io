---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";

const today = new Date();
const dateStr = today.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
const vol = today.getFullYear() - 1920;
const issueNo = Math.floor((today.getTime() - new Date('1920-01-01').getTime()) / (1000 * 60 * 60 * 24));
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — The Daily Chronicle | 1920s Newspaper Portfolio</title>
    <meta name="description" content="Daniele D'Agnelli's career presented as a 1920s broadsheet newspaper. Senior Engagement Manager with 15+ years in AI, cybersecurity, and digital transformation." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/newspaper" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta property="og:description" content="A career told in headlines. 15+ years of digital transformation, AI deployments, and cybersecurity — presented as a vintage 1920s broadsheet." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/newspaper" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta name="twitter:description" content="A career told in headlines. 15+ years of AI, cybersecurity, and digital transformation." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,700;1,400&family=UnifrakturMaguntia&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- PAPER TEXTURE OVERLAY -->
    <div class="paper-texture" aria-hidden="true"></div>
    <div class="ink-bleed" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE: SPINNING NEWSPAPER -->
    <div class="intro" id="intro">
        <div class="spinning-paper" id="spinningPaper">
            <div class="spin-headline">EXTRA! EXTRA!</div>
            <div class="spin-subhead">Read All About It!</div>
            <div class="spin-rule"></div>
            <div class="spin-story">D'Agnelli Leads Digital<br/>Transformation Revolution</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="broadsheet" id="broadsheet">

        <!-- MASTHEAD -->
        <header class="masthead">
            <div class="masthead-top-rule"></div>
            <div class="masthead-meta-row">
                <span class="masthead-meta">Vol. {vol}</span>
                <span class="masthead-meta">No. {issueNo}</span>
                <span class="masthead-meta">{siteMetadata.location}</span>
            </div>
            <div class="masthead-ornament" aria-hidden="true">&#10045; &#10045; &#10045;</div>
            <h1 class="masthead-title">The D'Agnelli Chronicle</h1>
            <div class="masthead-ornament" aria-hidden="true">&#10045; &#10045; &#10045;</div>
            <div class="masthead-subtitle">"All the News That's Fit to Deploy"</div>
            <div class="masthead-meta-row">
                <span class="masthead-meta">{dateStr}</span>
                <span class="masthead-meta">Price: One Shilling</span>
                <span class="masthead-meta">Final Edition</span>
            </div>
            <div class="masthead-bottom-rule"></div>
        </header>

        <!-- FRONT PAGE NARRATIVE -->
        <div class="front-page">
            <h1 class="headline">LOCAL MAN DEPLOYS AI ACROSS 100+ MANUFACTURING PLANTS, NOBODY STOPS HIM</h1>
            <div class="front-page-body">
                <p>LONDON — In what sources describe as "an unusually productive career," Daniele D'Agnelli, Senior Engagement Manager at C3 AI, has been directing a $15M programme across all business units, managing over 70 resources, and somehow maintaining an NPS above 70.</p>
                <p>The CEO-sponsored initiative — a predictive maintenance rollout across 100+ plants serving 2,000+ end users — has generated an estimated $18M in EBIT impact, according to internal figures obtained by this publication.</p>
                <p>"He also deployed a GenAI RAG system across the enterprise knowledge base," said a source close to the programme, speaking on condition of anonymity because they were not authorized to be impressed.</p>
                <p>Previously at Deloitte, D'Agnelli grew the UK Anaplan practice from zero to 25+ practitioners. Before that: Accenture, Codec, Accenture again. The man has range.</p>
            </div>
            <div class="classifieds-strip">
                CLASSIFIEDS: <a href="mailto:daniele@dagnelli.net">daniele@dagnelli.net</a> | <a href="https://github.com/danieledagnelli">github</a> | <a href="https://linkedin.com/in/dagnelli">linkedin</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --newsprint: #f4efe4;
        --ink: #111111;
        --faded-ink: #333333;
        --rule-color: #999999;
        --aged-paper: #e8e0d0;
        --accent: #8b4513;
        --headline-font: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --body-font: 'Lora', Georgia, 'Times New Roman', serif;
        --masthead-font: 'UnifrakturMaguntia', 'Playfair Display', Georgia, serif;
    }

    body {
        background: var(--newsprint);
        color: var(--ink);
        font-family: var(--body-font);
        font-size: 15px;
        line-height: 1.7;
        overflow: hidden;
        height: 100dvh;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    ::selection { background: var(--ink); color: var(--newsprint); }

    /* =========================================
       PAPER TEXTURE OVERLAY
       ========================================= */
    .paper-texture {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        background:
            radial-gradient(ellipse at 20% 50%, rgba(139, 119, 80, 0.06) 0%, transparent 60%),
            radial-gradient(ellipse at 80% 30%, rgba(139, 119, 80, 0.04) 0%, transparent 50%),
            radial-gradient(ellipse at 50% 90%, rgba(100, 80, 50, 0.05) 0%, transparent 40%);
        mix-blend-mode: multiply;
    }

    .ink-bleed {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        opacity: 0.015;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 256px 256px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        background: var(--newsprint);
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 800px;
        transition: opacity 0.6s ease;
    }

    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .spinning-paper {
        text-align: center;
        transform: scale(0.05) rotateZ(720deg);
        opacity: 0;
        animation: newspaperSpin 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        background: var(--newsprint);
        border: 3px solid var(--ink);
        padding: 2rem 3rem;
        box-shadow: 4px 4px 20px rgba(0,0,0,0.3);
        max-width: 500px;
    }

    .spin-headline {
        font-family: var(--headline-font);
        font-size: 3rem;
        font-weight: 900;
        color: var(--ink);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        line-height: 1.1;
    }

    .spin-subhead {
        font-family: var(--body-font);
        font-size: 1rem;
        font-style: italic;
        color: var(--faded-ink);
        margin-top: 0.3rem;
    }

    .spin-rule {
        height: 3px;
        background: var(--ink);
        margin: 0.8rem 0;
    }

    .spin-story {
        font-family: var(--headline-font);
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.3;
    }

    @keyframes newspaperSpin {
        0% {
            transform: scale(0.05) rotateZ(720deg);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: scale(1) rotateZ(0deg);
            opacity: 1;
        }
    }

    /* =========================================
       MAIN BROADSHEET — VIEWPORT-LOCKED
       ========================================= */
    .broadsheet {
        max-width: 960px;
        margin: 0 auto;
        padding: 20px 30px;
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }

    .broadsheet.visible { opacity: 1; }

    /* =========================================
       MASTHEAD
       ========================================= */
    .masthead {
        text-align: center;
        margin-bottom: 1rem;
        flex-shrink: 0;
    }

    .masthead-top-rule,
    .masthead-bottom-rule {
        height: 4px;
        background: var(--ink);
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
        margin: 0.3rem 0;
    }

    .masthead-top-rule {
        background: linear-gradient(
            to right,
            var(--ink) 0%, var(--ink) 30%,
            transparent 30%, transparent 32%,
            var(--ink) 32%, var(--ink) 68%,
            transparent 68%, transparent 70%,
            var(--ink) 70%, var(--ink) 100%
        );
        height: 6px;
    }

    .masthead-bottom-rule {
        background: linear-gradient(
            to right,
            var(--ink) 0%, var(--ink) 30%,
            transparent 30%, transparent 32%,
            var(--ink) 32%, var(--ink) 68%,
            transparent 68%, transparent 70%,
            var(--ink) 70%, var(--ink) 100%
        );
        height: 6px;
    }

    .masthead-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.2rem 0;
        font-size: 0.75rem;
        font-family: var(--body-font);
        color: var(--faded-ink);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .masthead-ornament {
        font-size: 0.9rem;
        color: var(--rule-color);
        letter-spacing: 0.5em;
        margin: 0.15rem 0;
    }

    .masthead-title {
        font-family: var(--masthead-font);
        font-size: 4rem;
        font-weight: 400;
        color: var(--ink);
        line-height: 1.1;
        margin: 0.2rem 0;
        letter-spacing: 0.02em;
    }

    .masthead-subtitle {
        font-family: var(--body-font);
        font-style: italic;
        font-size: 0.9rem;
        color: var(--faded-ink);
        margin: 0.1rem 0;
    }

    /* =========================================
       FRONT PAGE NARRATIVE
       ========================================= */
    .front-page {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 0;
    }

    .headline {
        font-family: var(--headline-font);
        font-size: 1.1rem;
        font-weight: 900;
        line-height: 1.3;
        color: var(--ink);
        text-align: center;
        margin-bottom: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .front-page-body {
        font-family: var(--body-font);
        color: var(--faded-ink);
        text-align: justify;
        hyphens: auto;
    }

    .front-page-body p {
        font-size: 0.82rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }

    .front-page-body p:last-child {
        margin-bottom: 0;
    }

    .classifieds-strip {
        font-family: var(--body-font);
        font-size: 0.7rem;
        text-align: center;
        margin-top: 0.8rem;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        flex-shrink: 0;
    }

    .classifieds-strip a {
        color: var(--accent);
    }

    /* =========================================
       RESPONSIVE
       ========================================= */
    @media (max-width: 768px) {
        .broadsheet {
            padding: 12px 14px;
        }

        .masthead-title {
            font-size: 2.4rem;
        }

        .headline {
            font-size: 1rem;
        }

        .front-page-body p {
            font-size: 0.78rem;
            line-height: 1.45;
            margin-bottom: 0.4rem;
        }

        .classifieds-strip {
            font-size: 0.65rem;
        }

        .spin-headline {
            font-size: 2rem;
        }

        .spin-story {
            font-size: 1rem;
        }

        .masthead-meta-row {
            flex-direction: column;
            gap: 0.1rem;
        }
    }

    @media (max-width: 480px) {
        .masthead-title {
            font-size: 1.8rem;
        }

        .headline {
            font-size: 0.9rem;
        }

        .front-page-body p {
            font-size: 0.74rem;
            line-height: 1.4;
        }

        .spin-headline {
            font-size: 1.5rem;
        }

        .spinning-paper {
            padding: 1rem 1.5rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const intro = document.getElementById('intro');
        const broadsheet = document.getElementById('broadsheet');
        const KEY = 'newspaper-intro-seen';

        function endIntro() {
            if (!intro || !broadsheet) return;
            intro.classList.add('done');
            broadsheet.classList.add('visible');
            try { sessionStorage.setItem(KEY, '1'); } catch(e) {}
            setTimeout(() => {
                intro.style.display = 'none';
            }, 700);
        }

        /* Skip if already seen */
        let alreadySeen = false;
        try { alreadySeen = sessionStorage.getItem(KEY) === '1'; } catch(e) {}

        if (alreadySeen) {
            if (intro) { intro.style.display = 'none'; intro.classList.add('done'); }
            if (broadsheet) { broadsheet.style.opacity = '1'; broadsheet.classList.add('visible'); }
        } else {
            /* Let the spin animation play, then reveal */
            setTimeout(endIntro, 2800);

            /* Click or keydown to skip */
            const skipHandler = () => {
                endIntro();
                document.removeEventListener('click', skipHandler);
                document.removeEventListener('keydown', skipHandler);
            };
            document.addEventListener('click', skipHandler);
            document.addEventListener('keydown', skipHandler);
        }
    });
</script>
