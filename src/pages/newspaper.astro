---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";

const today = new Date();
const dateStr = today.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
const vol = today.getFullYear() - 1920;
const issueNo = Math.floor((today.getTime() - new Date('1920-01-01').getTime()) / (1000 * 60 * 60 * 24));
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — The Daily Chronicle | 1920s Newspaper Portfolio</title>
    <meta name="description" content="Daniele D'Agnelli's career presented as a 1920s broadsheet newspaper. Senior Engagement Manager with 15+ years in AI, cybersecurity, and digital transformation." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/newspaper" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta property="og:description" content="A career told in headlines. 15+ years of digital transformation, AI deployments, and cybersecurity — presented as a vintage 1920s broadsheet." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/newspaper" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — The Daily Chronicle" />
    <meta name="twitter:description" content="A career told in headlines. 15+ years of AI, cybersecurity, and digital transformation." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,700;1,400&family=UnifrakturMaguntia&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- PAPER TEXTURE OVERLAY -->
    <div class="paper-texture" aria-hidden="true"></div>
    <div class="ink-bleed" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE: SPINNING NEWSPAPER -->
    <div class="intro" id="intro">
        <div class="spinning-paper" id="spinningPaper">
            <div class="spin-headline">EXTRA! EXTRA!</div>
            <div class="spin-subhead">Read All About It!</div>
            <div class="spin-rule"></div>
            <div class="spin-story">D'Agnelli Leads Digital<br/>Transformation Revolution</div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="broadsheet" id="broadsheet">

        <!-- MASTHEAD -->
        <header class="masthead">
            <div class="masthead-top-rule"></div>
            <div class="masthead-meta-row">
                <span class="masthead-meta">Vol. {vol}</span>
                <span class="masthead-meta">No. {issueNo}</span>
                <span class="masthead-meta">{siteMetadata.location}</span>
            </div>
            <div class="masthead-ornament" aria-hidden="true">&#10045; &#10045; &#10045;</div>
            <h1 class="masthead-title">The D'Agnelli Chronicle</h1>
            <div class="masthead-ornament" aria-hidden="true">&#10045; &#10045; &#10045;</div>
            <div class="masthead-subtitle">"All the News That's Fit to Deploy"</div>
            <div class="masthead-meta-row">
                <span class="masthead-meta">{dateStr}</span>
                <span class="masthead-meta">Price: One Shilling</span>
                <span class="masthead-meta">Final Edition</span>
            </div>
            <div class="masthead-bottom-rule"></div>
        </header>

        <!-- EXTRA BANNER -->
        <div class="extra-banner reveal">
            <span class="extra-text">&#9733; EXTRA! EXTRA! &#9733;</span>
        </div>

        <!-- LEAD STORY -->
        <section class="lead-story reveal" data-section="summary">
            <div class="lead-columns">
                <div class="lead-main">
                    <h2 class="headline">Senior Engagement Manager Commands $15M Programme, Delivers $18M Impact</h2>
                    <div class="byline">By Our Special Correspondent &mdash; {siteMetadata.location}</div>
                    <div class="rule-thin"></div>
                    <div class="article-body">
                        <p class="drop-cap">{summary}</p>
                    </div>
                    <div class="metrics-box">
                        <div class="metrics-title">By The Numbers</div>
                        <div class="metrics-grid">
                            {metrics.map(m => (
                                <div class="metric-item">
                                    <span class="metric-value">{m.value}</span>
                                    <span class="metric-label">{m.label}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
                <div class="lead-sidebar">
                    <div class="portrait-frame">
                        <img src="/assets/dani.jpeg" alt={`Portrait of ${siteMetadata.name}`} width="220" height="220" class="portrait-img" />
                        <div class="portrait-caption">{siteMetadata.name}, Esq.<br/>Pictured at his {siteMetadata.location} offices</div>
                    </div>
                    <div class="sidebar-box">
                        <div class="sidebar-title">Correspondent Details</div>
                        <div class="sidebar-items">
                            <div class="sidebar-item">
                                <span class="sidebar-label">Telegram:</span>
                                <a href={`mailto:${siteMetadata.email}`}>{siteMetadata.email}</a>
                            </div>
                            <div class="sidebar-item">
                                <span class="sidebar-label">Registry:</span>
                                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                            </div>
                            <div class="sidebar-item">
                                <span class="sidebar-label">Society:</span>
                                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                            </div>
                            <div class="sidebar-item">
                                <span class="sidebar-label">Wire:</span>
                                <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">Bluesky</a>
                            </div>
                        </div>
                    </div>
                    <div class="sidebar-box">
                        <div class="sidebar-title">Languages Spoken</div>
                        <div class="sidebar-items">
                            {languages.map(l => (
                                <div class="sidebar-item">{l}</div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-rule" aria-hidden="true">
            <span class="rule-ornament">&#9830;</span>
        </div>

        <!-- CAREER CHRONICLE -->
        <section class="career-section reveal" data-section="experience">
            <h2 class="section-heading">The Career Chronicle</h2>
            <div class="section-subhead">A Complete Account of Professional Endeavours, Herein Faithfully Recorded</div>
            <div class="news-columns">
                {experience.map((exp, i) => (
                    <article class="news-article reveal">
                        <h3 class="article-headline">{exp.company} Appoints {exp.roles[0].title}</h3>
                        <div class="dateline">{exp.location} &mdash; {exp.roles[0].period}</div>
                        <div class="article-body">
                            {exp.roles.map(role => (
                                <div class="role-block">
                                    {role.description && <p class="drop-cap-small">{role.description}</p>}
                                    {role.bullets && role.bullets.length > 0 && (
                                        <ul class="article-list">
                                            {role.bullets.map(b => <li>{b}</li>)}
                                        </ul>
                                    )}
                                    {!role.description && (!role.bullets || role.bullets.length === 0) && (
                                        <p>Served with distinction in the role of {role.title}, contributing to the firm's enterprise endeavours from {exp.location}.</p>
                                    )}
                                </div>
                            ))}
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <div class="section-rule" aria-hidden="true">
            <span class="rule-ornament">&#9830;</span>
        </div>

        <!-- CLASSIFIEDS: SKILLS -->
        <section class="classifieds-section reveal" data-section="skills">
            <h2 class="section-heading">Classified Advertisements</h2>
            <div class="section-subhead">Professional Capabilities &amp; Technical Proficiencies Available for Engagement</div>
            <div class="classifieds-columns">
                <div class="classified-group">
                    <div class="classified-header">&#9998; Technical Skills</div>
                    <div class="classified-border">
                        <div class="classified-items">
                            {skills.map(s => (
                                <span class="classified-tag">{s}</span>
                            ))}
                        </div>
                    </div>
                </div>
                <div class="classified-group">
                    <div class="classified-header">&#9881; Management &amp; Leadership</div>
                    <div class="classified-border">
                        <div class="classified-items">
                            {managementSkills.map(s => (
                                <span class="classified-tag">{s}</span>
                            ))}
                        </div>
                    </div>
                </div>
                <div class="classified-group">
                    <div class="classified-header">&#9878; Industries Served</div>
                    <div class="classified-border">
                        <div class="classified-items">
                            {industries.map(ind => (
                                <span class="classified-tag">{ind}</span>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-rule" aria-hidden="true">
            <span class="rule-ornament">&#9830;</span>
        </div>

        <!-- BUSINESS SECTION: ENGAGEMENTS -->
        <section class="business-section reveal" data-section="engagements">
            <h2 class="section-heading">The Business Section</h2>
            <div class="section-subhead">Notable Client Engagements &amp; Commercial Dispatches</div>
            <div class="business-columns">
                {engagements.map(eng => (
                    <div class="business-card reveal">
                        <div class="business-headline">{eng.client.charAt(0).toUpperCase() + eng.client.slice(1)}</div>
                        <div class="business-sector">{eng.sector.toUpperCase()}</div>
                        <div class="business-rule"></div>
                        <div class="business-detail">
                            <span class="business-label">Scope:</span> {eng.scope}
                        </div>
                        <div class="business-detail">
                            <span class="business-label">Impact:</span>
                            <span class={eng.trend === 'positive' ? 'impact-positive' : 'impact-neutral'}>{eng.impact}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-rule" aria-hidden="true">
            <span class="rule-ornament">&#9830;</span>
        </div>

        <!-- ANNOUNCEMENTS: EDUCATION & CERTS -->
        <section class="announcements-section reveal" data-section="education">
            <h2 class="section-heading">Public Announcements</h2>
            <div class="section-subhead">Degrees Conferred, Certifications Awarded &amp; Scholarly Pursuits</div>
            <div class="announcements-columns">
                <div class="announcement-group">
                    <div class="announcement-header">&#127891; Academic Degrees</div>
                    {education.map(edu => (
                        <div class="announcement-card reveal">
                            <div class="announcement-degree">{edu.degree}</div>
                            <div class="announcement-inst">{edu.institution}, {edu.location}</div>
                            <div class="announcement-period">{edu.period}</div>
                            {edu.distinction && <div class="announcement-distinction">Awarded with {edu.distinction}</div>}
                        </div>
                    ))}
                </div>
                <div class="announcement-group">
                    <div class="announcement-header">&#128220; Certifications &amp; Honours</div>
                    {certifications.map(c => (
                        <div class="announcement-item">{c}</div>
                    ))}
                </div>
                <div class="announcement-group">
                    <div class="announcement-header">&#128214; Continuous Learning</div>
                    {continuousLearning.map(l => (
                        <div class="announcement-item">{l}</div>
                    ))}
                </div>
            </div>
        </section>

        <div class="section-rule" aria-hidden="true">
            <span class="rule-ornament">&#9830;</span>
        </div>

        <!-- FOOTER / BACK PAGE -->
        <footer class="paper-footer">
            <div class="footer-rule"></div>
            <div class="footer-content">
                <div class="footer-col">
                    <span class="footer-label">Published by</span>
                    <span class="footer-value">{siteMetadata.name}</span>
                </div>
                <div class="footer-col">
                    <span class="footer-label">Offices at</span>
                    <span class="footer-value">{siteMetadata.location}</span>
                </div>
                <div class="footer-col">
                    <span class="footer-label">Telegraphic Address</span>
                    <a href={`mailto:${siteMetadata.email}`} class="footer-value">{siteMetadata.email}</a>
                </div>
            </div>
            <div class="footer-bottom">
                <span>&copy; {today.getFullYear()} The D'Agnelli Chronicle. All Rights Reserved.</span>
                <span class="footer-ornament" aria-hidden="true">&#10045; &#10045; &#10045;</span>
                <span class="footer-links">
                    <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                    <span class="footer-dot">&bull;</span>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                    <span class="footer-dot">&bull;</span>
                    <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">Bluesky</a>
                </span>
            </div>
            <div class="footer-fine-print">
                Printed on the finest digital parchment. No trees were harmed in the production of this broadsheet.
            </div>
        </footer>

    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --newsprint: #f4efe4;
        --ink: #111111;
        --faded-ink: #333333;
        --rule-color: #999999;
        --aged-paper: #e8e0d0;
        --accent: #8b4513;
        --headline-font: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --body-font: 'Lora', Georgia, 'Times New Roman', serif;
        --masthead-font: 'UnifrakturMaguntia', 'Playfair Display', Georgia, serif;
        scrollbar-width: thin;
        scrollbar-color: var(--faded-ink) var(--newsprint);
    }

    body {
        background: var(--newsprint);
        color: var(--ink);
        font-family: var(--body-font);
        font-size: 15px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    ::selection { background: var(--ink); color: var(--newsprint); }

    /* =========================================
       PAPER TEXTURE OVERLAY
       ========================================= */
    .paper-texture {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        background:
            radial-gradient(ellipse at 20% 50%, rgba(139, 119, 80, 0.06) 0%, transparent 60%),
            radial-gradient(ellipse at 80% 30%, rgba(139, 119, 80, 0.04) 0%, transparent 50%),
            radial-gradient(ellipse at 50% 90%, rgba(100, 80, 50, 0.05) 0%, transparent 40%);
        mix-blend-mode: multiply;
    }

    .ink-bleed {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        opacity: 0.015;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 256px 256px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        background: var(--newsprint);
        display: flex;
        align-items: center;
        justify-content: center;
        perspective: 800px;
        transition: opacity 0.6s ease;
    }

    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .spinning-paper {
        text-align: center;
        transform: scale(0.05) rotateZ(720deg);
        opacity: 0;
        animation: newspaperSpin 2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        background: var(--newsprint);
        border: 3px solid var(--ink);
        padding: 2rem 3rem;
        box-shadow: 4px 4px 20px rgba(0,0,0,0.3);
        max-width: 500px;
    }

    .spin-headline {
        font-family: var(--headline-font);
        font-size: 3rem;
        font-weight: 900;
        color: var(--ink);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        line-height: 1.1;
    }

    .spin-subhead {
        font-family: var(--body-font);
        font-size: 1rem;
        font-style: italic;
        color: var(--faded-ink);
        margin-top: 0.3rem;
    }

    .spin-rule {
        height: 3px;
        background: var(--ink);
        margin: 0.8rem 0;
    }

    .spin-story {
        font-family: var(--headline-font);
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.3;
    }

    @keyframes newspaperSpin {
        0% {
            transform: scale(0.05) rotateZ(720deg);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: scale(1) rotateZ(0deg);
            opacity: 1;
        }
    }

    /* =========================================
       MAIN BROADSHEET
       ========================================= */
    .broadsheet {
        max-width: 960px;
        margin: 0 auto;
        padding: 20px 30px 60px;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }

    .broadsheet.visible { opacity: 1; }

    /* =========================================
       MASTHEAD
       ========================================= */
    .masthead {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .masthead-top-rule,
    .masthead-bottom-rule {
        height: 4px;
        background: var(--ink);
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
        margin: 0.3rem 0;
    }

    .masthead-top-rule {
        background: linear-gradient(
            to right,
            var(--ink) 0%, var(--ink) 30%,
            transparent 30%, transparent 32%,
            var(--ink) 32%, var(--ink) 68%,
            transparent 68%, transparent 70%,
            var(--ink) 70%, var(--ink) 100%
        );
        height: 6px;
    }

    .masthead-bottom-rule {
        background: linear-gradient(
            to right,
            var(--ink) 0%, var(--ink) 30%,
            transparent 30%, transparent 32%,
            var(--ink) 32%, var(--ink) 68%,
            transparent 68%, transparent 70%,
            var(--ink) 70%, var(--ink) 100%
        );
        height: 6px;
    }

    .masthead-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.2rem 0;
        font-size: 0.75rem;
        font-family: var(--body-font);
        color: var(--faded-ink);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .masthead-ornament {
        font-size: 0.9rem;
        color: var(--rule-color);
        letter-spacing: 0.5em;
        margin: 0.15rem 0;
    }

    .masthead-title {
        font-family: var(--masthead-font);
        font-size: 4rem;
        font-weight: 400;
        color: var(--ink);
        line-height: 1.1;
        margin: 0.2rem 0;
        letter-spacing: 0.02em;
    }

    .masthead-subtitle {
        font-family: var(--body-font);
        font-style: italic;
        font-size: 0.9rem;
        color: var(--faded-ink);
        margin: 0.1rem 0;
    }

    /* =========================================
       EXTRA BANNER
       ========================================= */
    .extra-banner {
        text-align: center;
        padding: 0.5rem 0;
        margin-bottom: 1.5rem;
        border-top: 2px solid var(--ink);
        border-bottom: 2px solid var(--ink);
        background: var(--ink);
    }

    .extra-text {
        font-family: var(--headline-font);
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--newsprint);
        letter-spacing: 0.3em;
        text-transform: uppercase;
    }

    /* =========================================
       SECTION HEADINGS & RULES
       ========================================= */
    .section-heading {
        font-family: var(--headline-font);
        font-size: 2rem;
        font-weight: 900;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink);
        margin-bottom: 0.3rem;
    }

    .section-subhead {
        font-family: var(--body-font);
        font-style: italic;
        font-size: 0.85rem;
        text-align: center;
        color: var(--faded-ink);
        margin-bottom: 1.2rem;
    }

    .section-rule {
        text-align: center;
        margin: 2rem 0;
        border-top: 1px solid var(--rule-color);
        position: relative;
    }

    .rule-ornament {
        position: relative;
        top: -0.6em;
        background: var(--newsprint);
        padding: 0 1rem;
        color: var(--rule-color);
        font-size: 0.9rem;
    }

    .rule-thin {
        height: 1px;
        background: var(--rule-color);
        margin: 0.6rem 0;
    }

    /* =========================================
       LEAD STORY
       ========================================= */
    .lead-story {
        margin-bottom: 1rem;
    }

    .lead-columns {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 1.5rem;
    }

    .headline {
        font-family: var(--headline-font);
        font-size: 2.2rem;
        font-weight: 900;
        line-height: 1.15;
        color: var(--ink);
        margin-bottom: 0.5rem;
    }

    .byline {
        font-family: var(--body-font);
        font-style: italic;
