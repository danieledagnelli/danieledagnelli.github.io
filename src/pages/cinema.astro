---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — A Film Production</title>
    <meta name="description" content="The cinematic portfolio of Daniele D'Agnelli — 15+ years of digital transformation, AI, and cybersecurity presented as a golden-age Hollywood production." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/cinema" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — A Film Production" />
    <meta property="og:description" content="The cinematic portfolio of Daniele D'Agnelli — career highlights presented as golden-age Hollywood." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/cinema" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — A Film Production" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — A Film Production" />
    <meta name="twitter:description" content="The cinematic portfolio of Daniele D'Agnelli — career as golden-age Hollywood." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- FILM GRAIN CANVAS -->
    <canvas class="grain-canvas" id="grainCanvas" aria-hidden="true"></canvas>

    <!-- SPOTLIGHT SWEEP -->
    <div class="spotlight-sweep" aria-hidden="true"></div>

    <!-- FILM PERFORATIONS -->
    <div class="film-perfs film-perfs--left" aria-hidden="true"></div>
    <div class="film-perfs film-perfs--right" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="countdown" id="countdown" aria-label="Film countdown"></div>
        <div class="white-flash" id="whiteFlash"></div>
        <div class="production-title" id="productionTitle">
            <div class="production-deco-top" aria-hidden="true"></div>
            <span class="production-label">A</span>
            <span class="production-name">Daniele D'Agnelli</span>
            <span class="production-label">Production</span>
            <div class="production-deco-bottom" aria-hidden="true"></div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="film" id="film">

        <!-- DIRECTOR'S STATEMENT -->
        <section class="section section--hero">
            <div class="hero-inner">
                <div class="hero-photo">
                    <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="200" height="200" />
                    <div class="photo-border" aria-hidden="true"></div>
                </div>
                <h1 class="hero-name">{siteMetadata.name}</h1>
                <p class="hero-tagline">Senior Engagement Manager &mdash; AI &amp; Cybersecurity</p>
                <div class="hero-meta">
                    <span>{siteMetadata.location}</span>
                    <span class="hero-dot" aria-hidden="true"></span>
                    <span>15+ Years in Production</span>
                </div>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- DIRECTOR'S STATEMENT -->
        <section class="section reveal">
            <h2 class="section-heading">Director's Statement</h2>
            <div class="statement-card">
                <span class="quote-mark" aria-hidden="true">&ldquo;</span>
                <p class="statement-text">{summary}</p>
                <span class="quote-mark quote-mark--end" aria-hidden="true">&rdquo;</span>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- FILMOGRAPHY -->
        <section class="section reveal">
            <h2 class="section-heading">Filmography</h2>
            <div class="poster-grid">
                {experience.map((exp) => (
                    <div class="poster-card reveal">
                        <div class="poster-deco-corner poster-deco-corner--tl" aria-hidden="true"></div>
                        <div class="poster-deco-corner poster-deco-corner--tr" aria-hidden="true"></div>
                        <div class="poster-deco-corner poster-deco-corner--bl" aria-hidden="true"></div>
                        <div class="poster-deco-corner poster-deco-corner--br" aria-hidden="true"></div>
                        <div class="poster-header">
                            <span class="poster-presents">A {exp.company} Production</span>
                        </div>
                        {exp.roles.map((role) => (
                            <div class="poster-body">
                                <h3 class="poster-title">{role.title}</h3>
                                <div class="poster-starring">
                                    <span class="poster-label">Starring</span>
                                    <span class="poster-star">Daniele D'Agnelli</span>
                                </div>
                                <div class="poster-meta-row">
                                    <span class="poster-location">{exp.location}</span>
                                    <span class="poster-period">{role.period}</span>
                                </div>
                                {role.description && (
                                    <div class="poster-synopsis">
                                        <span class="poster-label">Synopsis</span>
                                        <p>{role.description}</p>
                                    </div>
                                )}
                                {role.bullets && role.bullets.length > 0 && (
                                    <ul class="poster-highlights">
                                        {role.bullets.map((b) => (
                                            <li>{b}</li>
                                        ))}
                                    </ul>
                                )}
                            </div>
                        ))}
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- PRODUCTION DEPARTMENTS (Skills) -->
        <section class="section reveal">
            <h2 class="section-heading">Production Departments</h2>
            <div class="dept-grid">
                <div class="dept-card reveal">
                    <h3 class="dept-title">Department of Engineering</h3>
                    <div class="dept-credits">
                        {skills.map((s) => (
                            <div class="credit-line">
                                <span class="credit-role">{s}</span>
                                <span class="credit-dots" aria-hidden="true"></span>
                                <span class="credit-name">D. D'Agnelli</span>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="dept-card reveal">
                    <h3 class="dept-title">Department of Strategy</h3>
                    <div class="dept-credits">
                        {managementSkills.map((s) => (
                            <div class="credit-line">
                                <span class="credit-role">{s}</span>
                                <span class="credit-dots" aria-hidden="true"></span>
                                <span class="credit-name">D. D'Agnelli</span>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="dept-card reveal">
                    <h3 class="dept-title">Languages</h3>
                    <div class="dept-credits">
                        {languages.map((l) => (
                            <div class="credit-line">
                                <span class="credit-role">{l}</span>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="dept-card reveal">
                    <h3 class="dept-title">Industries on Location</h3>
                    <div class="dept-credits">
                        {industries.map((ind) => (
                            <div class="credit-line">
                                <span class="credit-role">{ind}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- FEATURED FILMS (Engagements) -->
        <section class="section reveal">
            <h2 class="section-heading">Featured Films</h2>
            <div class="featured-grid">
                {engagements.map((eng) => (
                    <div class="featured-card reveal">
                        <div class="featured-genre">{eng.sector}</div>
                        <h3 class="featured-title">{eng.client}</h3>
                        <div class="featured-scope">{eng.scope}</div>
                        <div class="featured-divider" aria-hidden="true"></div>
                        <div class="featured-impact">
                            <span class="featured-impact-label">{eng.trend === 'positive' ? 'Box Office' : 'Critical Acclaim'}</span>
                            <span class="featured-impact-value">{eng.impact}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- FILM SCHOOL (Education) -->
        <section class="section reveal">
            <h2 class="section-heading">Film School</h2>
            <div class="awards-list">
                {education.map((edu) => (
                    <div class="award-card reveal">
                        <div class="award-trophy" aria-hidden="true">&#127942;</div>
                        <div class="award-info">
                            <h3 class="award-degree">{edu.degree}</h3>
                            <p class="award-institution">{edu.institution} &mdash; {edu.location}</p>
                            <p class="award-period">{edu.period}</p>
                            {edu.distinction && (
                                <span class="award-badge">{edu.distinction}</span>
                            )}
                            <p class="award-to">Awarded to Daniele D'Agnelli</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- AWARDS & NOMINATIONS (Certifications) -->
        <section class="section reveal">
            <h2 class="section-heading">Awards &amp; Nominations</h2>
            <div class="awards-list">
                {certifications.map((c) => (
                    <div class="award-card award-card--cert reveal">
                        <div class="award-trophy" aria-hidden="true">&#9733;</div>
                        <div class="award-info">
                            <h3 class="award-degree">{c}</h3>
                            <p class="award-to">Presented to Daniele D'Agnelli</p>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- MASTERCLASSES (Continuous Learning) -->
        <section class="section reveal">
            <h2 class="section-heading">Masterclasses</h2>
            <div class="masterclass-grid">
                {continuousLearning.map((cl) => (
                    <div class="masterclass-item reveal">
                        <span class="masterclass-reel" aria-hidden="true">&#9654;</span>
                        <span class="masterclass-name">{cl}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- KEY METRICS -->
        <section class="section reveal">
            <h2 class="section-heading">Box Office Numbers</h2>
            <div class="metrics-grid">
                {metrics.map((m) => (
                    <div class="metric-card reveal">
                        <span class="metric-value">{m.value}</span>
                        <span class="metric-label">{m.label}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-diamond"></span>
        </div>

        <!-- SCROLLING CREDITS -->
        <section class="section section--credits reveal">
            <h2 class="section-heading">End Credits</h2>
            <div class="credits-viewport">
                <div class="credits-scroll" id="creditsScroll">
                    <p class="credits-heading">Directed, Produced &amp; Written by</p>
                    <p class="credits-name">Daniele D'Agnelli</p>

                    <p class="credits-heading">Education</p>
                    {education.map((edu) => (
                        <p class="credits-line">{edu.degree}<br/><span class="credits-sub">{edu.institution} &mdash; {edu.period}</span></p>
                    ))}

                    <p class="credits-heading">Certifications</p>
                    {certifications.map((c) => (
                        <p class="credits-line">{c}</p>
                    ))}

                    <p class="credits-heading">Continuous Learning</p>
                    {continuousLearning.map((cl) => (
                        <p class="credits-line">{cl}</p>
                    ))}

                    <p class="credits-heading">Technical Skills</p>
                    {skills.map((s) => (
                        <p class="credits-line">{s}</p>
                    ))}

                    <p class="credits-heading">Management</p>
                    {managementSkills.map((ms) => (
                        <p class="credits-line">{ms}</p>
                    ))}

                    <p class="credits-heading">Languages</p>
                    {languages.map((l) => (
                        <p class="credits-line">{l}</p>
                    ))}

                    <p class="credits-heading">Industries</p>
                    {industries.map((ind) => (
                        <p class="credits-line">{ind}</p>
                    ))}

                    <p class="credits-spacer" aria-hidden="true">&nbsp;</p>
                    <p class="credits-name">A Daniele D'Agnelli Production</p>
                    <p class="credits-line credits-year">&copy; {new Date().getFullYear()}</p>
                </div>
            </div>
        </section>

        <!-- FOOTER / FIN -->
        <footer class="cinema-footer">
            <div class="fin-text">FIN</div>
            <p class="fin-disclaimer">No animals were harmed in the making of this portfolio.</p>
            <div class="fin-contact">
                <span class="fin-contact-label">Contact the Production Office</span>
                <div class="fin-links">
                    <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                    <a href={`mailto:${siteMetadata.email}`}>Email</a>
                </div>
            </div>
        </footer>

    </main>
</body>
</html>

<style>
    /* =========================================
       RESET & BASE
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --gold: #d4af37;
        --gold-light: #e8c84a;
        --gold-dark: #b8941f;
        --red: #8b0000;
        --red-light: #a52a2a;
        --cream: #faf3e0;
        --white: #ffffff;
        --bg: #0d0d0d;
        --bg-card: #1a1a1a;
        --bg-card-hover: #222222;
        --serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        scrollbar-width: thin;
        scrollbar-color: var(--gold) var(--bg);
    }

    body {
        background: var(--bg);
        color: var(--cream);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--gold); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--gold-light); text-decoration: underline; }

    ::selection { background: var(--gold); color: var(--bg); }

    /* =========================================
       FILM GRAIN CANVAS
       ========================================= */
    .grain-canvas {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        mix-blend-mode: screen;
    }

    /* =========================================
       SPOTLIGHT SWEEP
       ========================================= */
    .spotlight-sweep {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        background: radial-gradient(
            ellipse 600px 600px at var(--spot-x, 30%) var(--spot-y, 40%),
            rgba(212, 175, 55, 0.03) 0%,
            transparent 70%
        );
        animation: spotlightMove 20s ease-in-out infinite alternate;
    }

    @keyframes spotlightMove {
        0%   { --spot-x: 20%; --spot-y: 30%; }
        25%  { --spot-x: 70%; --spot-y: 20%; }
        50%  { --spot-x: 80%; --spot-y: 60%; }
        75%  { --spot-x: 30%; --spot-y: 70%; }
        100% { --spot-x: 50%; --spot-y: 40%; }
    }

    /* =========================================
       FILM PERFORATIONS
       ========================================= */
    .film-perfs {
        position: fixed;
        top: 0;
        bottom: 0;
        width: 28px;
        z-index: 9997;
        pointer-events: none;
        background:
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 18px,
                rgba(212, 175, 55, 0.12) 18px,
                rgba(212, 175, 55, 0.12) 19px,
                transparent 19px,
                transparent 26px,
                var(--bg) 26px,
                var(--bg) 27px,
                transparent 27px,
                transparent 40px
            );
    }
    .film-perfs::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 12px;
        background:
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 14px,
                rgba(212, 175, 55, 0.08) 14px,
                rgba(212, 175, 55, 0.08) 26px,
                transparent 26px,
                transparent 40px
            );
        border-radius: 2px;
    }
    .film-perfs--left {
        left: 0;
        border-right: 1px solid rgba(212, 175, 55, 0.08);
    }
    .film-perfs--left::before { left: 8px; }
    .film-perfs--right {
        right: 0;
        border-left: 1px solid rgba(212, 175, 55, 0.08);
    }
    .film-perfs--right::before { right: 8px; }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.6s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .countdown {
        font-family: var(--serif);
        font-size: clamp(80px, 15vw, 200px);
        font-weight: 900;
        color: var(--cream);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 200px;
        height: 200px;
    }
    .countdown::before {
        content: '';
        position: absolute;
        width: 160px;
        height: 160px;
        border: 3px solid rgba(250, 243, 224, 0.6);
        border-radius: 50%;
    }
    .countdown::after {
        content: '';
        position: absolute;
        width: 2px;
        height: 180px;
        background: rgba(250, 243, 224, 0.3);
    }

    .white-flash {
        position: fixed;
        inset: 0;
        background: #fff;
        opacity: 0;
        z-index: 10002;
        pointer-events: none;
        transition: opacity 0.05s;
    }
    .white-flash.active {
        opacity: 1;
    }

    .production-title {
        position: absolute;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.8s ease;
        text-align: center;
        padding: 0 20px;
    }
    .production-title.visible {
        opacity: 1;
    }
    .production-label {
        font-family: var(--sans);
        font-size: clamp(12px, 2vw, 16px);
        letter-spacing: 6px;
        text-transform: uppercase;
        color: var(--cream);
        font-weight: 300;
    }
    .production-name {
        font-family: var(--serif);
        font-size: clamp(28px, 6vw, 56px);
        font-weight: 900;
        color: var(--gold);
        letter-spacing: 2px;
        line-height: 1.2;
    }

    .production-deco-top,
    .production-deco-bottom {
        width: clamp(120px, 30vw, 300px);
        height: 2px;
        background: linear-gradient(
            90deg,
            transparent 0%,
            var(--gold) 20%,
            var(--gold) 80%,
            transparent 100%
        );
        position: relative;
    }
    .production-deco-top::before,
    .production-deco-bottom::before {
        content: '';
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: 8px;
        height: 8px;
        border: 1px solid var(--gold);
        transform: translateX(-50%) rotate(45deg);
    }
    .production-deco-top::before { top: -5px; }
    .production-deco-bottom::before { bottom: -5px; }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .film {
        max-width: 960px;
        margin: 0 auto;
        padding: 40px 40px 0;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
    }
    .film.visible { opacity: 1; }

    /* =========================================
       SECTION HEADINGS
       ========================================= */
    .section {
        margin-bottom: 0;
        padding: 40px 0;
    }

    .section-heading {
        font-family: var(--serif);
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 900;
        color: var(--gold);
        text-align: center;
        margin-bottom: 40px;
        letter-spacing: 1px;
        position: relative;
    }
    .section-heading::after {
        content: '';
        display: block;
        width: 60px;
        height: 2px;
        background: var(--gold);
        margin: 12px auto 0;
    }

    /* =========================================
       SECTION DIVIDER
       ========================================= */
    .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px 0;
    }
    .section-divider::before,
    .section-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(212, 175, 55, 0.3),
            transparent
        );
    }
    .divider-diamond {
        width: 8px;
        height: 8px;
        border: 1px solid var(--gold-dark);
        transform: rotate(45deg);
        margin: 0 16px;
        opacity: 0.5;
    }

    /* =========================================
       REVEAL ANIMATION
       ========================================= */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* =========================================
       HERO SECTION
       ========================================= */
    .section--hero {
        text-align: center;
        padding: 60px 0 40px;
    }

    .hero-inner {
        display: flex;
        flex-direction: column;
