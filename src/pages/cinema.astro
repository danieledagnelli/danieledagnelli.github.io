<style>
    /* =========================================
       RESET & BASE
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --gold: #d4af37;
        --gold-light: #e8c84a;
        --gold-dark: #b8941f;
        --red: #8b0000;
        --red-light: #a52a2a;
        --cream: #faf3e0;
        --white: #ffffff;
        --bg: #0d0d0d;
        --bg-card: #1a1a1a;
        --bg-card-hover: #222222;
        --serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
        --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        scrollbar-width: thin;
        scrollbar-color: var(--gold) var(--bg);
    }

    body {
        background: var(--bg);
        color: var(--cream);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--gold); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--gold-light); text-decoration: underline; }

    ::selection { background: var(--gold); color: var(--bg); }

    /* =========================================
       FILM GRAIN CANVAS
       ========================================= */
    .grain-canvas {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        width: 100%;
        height: 100%;
        opacity: 0.03;
        mix-blend-mode: screen;
    }

    /* =========================================
       SPOTLIGHT SWEEP
       ========================================= */
    .spotlight-sweep {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        background: radial-gradient(
            ellipse 600px 600px at var(--spot-x, 30%) var(--spot-y, 40%),
            rgba(212, 175, 55, 0.03) 0%,
            transparent 70%
        );
        animation: spotlightMove 20s ease-in-out infinite alternate;
    }

    @keyframes spotlightMove {
        0%   { --spot-x: 20%; --spot-y: 30%; }
        25%  { --spot-x: 70%; --spot-y: 20%; }
        50%  { --spot-x: 80%; --spot-y: 60%; }
        75%  { --spot-x: 30%; --spot-y: 70%; }
        100% { --spot-x: 50%; --spot-y: 40%; }
    }

    /* =========================================
       FILM PERFORATIONS
       ========================================= */
    .film-perfs {
        position: fixed;
        top: 0;
        bottom: 0;
        width: 28px;
        z-index: 9997;
        pointer-events: none;
        background:
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 18px,
                rgba(212, 175, 55, 0.12) 18px,
                rgba(212, 175, 55, 0.12) 19px,
                transparent 19px,
                transparent 26px,
                var(--bg) 26px,
                var(--bg) 27px,
                transparent 27px,
                transparent 40px
            );
    }
    .film-perfs::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 12px;
        background:
            repeating-linear-gradient(
                180deg,
                transparent 0px,
                transparent 14px,
                rgba(212, 175, 55, 0.08) 14px,
                rgba(212, 175, 55, 0.08) 26px,
                transparent 26px,
                transparent 40px
            );
        border-radius: 2px;
    }
    .film-perfs--left {
        left: 0;
        border-right: 1px solid rgba(212, 175, 55, 0.08);
    }
    .film-perfs--left::before { left: 8px; }
    .film-perfs--right {
        right: 0;
        border-left: 1px solid rgba(212, 175, 55, 0.08);
    }
    .film-perfs--right::before { right: 8px; }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10001;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.6s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .countdown {
        font-family: var(--serif);
        font-size: clamp(80px, 15vw, 200px);
        font-weight: 900;
        color: var(--cream);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 200px;
        height: 200px;
    }
    .countdown::before {
        content: '';
        position: absolute;
        width: 160px;
        height: 160px;
        border: 3px solid rgba(250, 243, 224, 0.6);
        border-radius: 50%;
    }
    .countdown::after {
        content: '';
        position: absolute;
        width: 2px;
        height: 180px;
        background: rgba(250, 243, 224, 0.3);
    }

    .white-flash {
        position: fixed;
        inset: 0;
        background: #fff;
        opacity: 0;
        z-index: 10002;
        pointer-events: none;
        transition: opacity 0.05s;
    }
    .white-flash.active {
        opacity: 1;
    }

    .production-title {
        position: absolute;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.8s ease;
        text-align: center;
        padding: 0 20px;
    }
    .production-title.visible {
        opacity: 1;
    }
    .production-label {
        font-family: var(--sans);
        font-size: clamp(12px, 2vw, 16px);
        letter-spacing: 6px;
        text-transform: uppercase;
        color: var(--cream);
        font-weight: 300;
    }
    .production-name {
        font-family: var(--serif);
        font-size: clamp(28px, 6vw, 56px);
        font-weight: 900;
        color: var(--gold);
        letter-spacing: 2px;
        line-height: 1.2;
    }

    .production-deco-top,
    .production-deco-bottom {
        width: clamp(120px, 30vw, 300px);
        height: 2px;
        background: linear-gradient(
            90deg,
            transparent 0%,
            var(--gold) 20%,
            var(--gold) 80%,
            transparent 100%
        );
        position: relative;
    }
    .production-deco-top::before,
    .production-deco-bottom::before {
        content: '';
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        width: 8px;
        height: 8px;
        border: 1px solid var(--gold);
        transform: translateX(-50%) rotate(45deg);
    }
    .production-deco-top::before { top: -5px; }
    .production-deco-bottom::before { bottom: -5px; }

    /* =========================================
       MAIN CONTENT — viewport-locked
       ========================================= */
    .film {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
    }
    .film.visible { opacity: 1; }

    /* =========================================
       CREDITS NARRATIVE
       ========================================= */
    .credits-narrative {
        max-width: 500px;
        padding: 1.5rem;
        text-align: center;
    }

    .credits-studio {
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        margin-bottom: 1rem;
    }

    .credits-role {
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        opacity: 0.6;
        margin-top: 0.7rem;
    }

    .credits-name {
        font-size: 1rem;
        margin: 0.2rem 0;
    }

    .credits-detail {
        font-size: 0.75rem;
        opacity: 0.8;
        line-height: 1.4;
    }

    .credits-numbers {
        font-size: 0.85rem;
        margin: 0.8rem 0;
        font-weight: bold;
    }

    .credits-quote {
        font-style: italic;
        font-size: 0.75rem;
        margin-top: 0.8rem;
        opacity: 0.8;
    }

    .credits-footer {
        margin-top: 1rem;
        font-size: 0.7rem;
    }

    .credits-footer a {
        text-decoration: none;
    }

    /* =========================================
       RESPONSIVE — TABLET (<=768px)
       ========================================= */
    @media (max-width: 768px) {
        .film-perfs { display: none; }

        .credits-name {
            font-size: 0.85rem;
        }

        .credits-detail {
            font-size: 0.7rem;
        }
    }

    /* =========================================
       TOUCH TARGETS
       ========================================= */
    @media (hover: none) and (pointer: coarse) {
        .credits-footer a {
            padding: 10px 8px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
        }
    }
</style>

<script>
    /* =============================================
       FILM GRAIN CANVAS
       ============================================= */
    const canvas = document.getElementById('grainCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    function resizeGrain() {
        canvas.width = window.innerWidth / 4;
        canvas.height = window.innerHeight / 4;
    }
    resizeGrain();
    window.addEventListener('resize', resizeGrain);

    function drawGrain() {
        const w = canvas.width, h = canvas.height;
        const imageData = ctx.createImageData(w, h);
        const d = imageData.data;
        for (let i = 0; i < d.length; i += 4) {
            const v = Math.random() * 255;
            d[i] = d[i + 1] = d[i + 2] = v;
            d[i + 3] = 255;
        }
        ctx.putImageData(imageData, 0, 0);
        requestAnimationFrame(drawGrain);
    }
    drawGrain();

    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const countdownEl = document.getElementById('countdown')!;
    const flashEl = document.getElementById('whiteFlash')!;
    const titleEl = document.getElementById('productionTitle')!;
    const filmEl = document.getElementById('film')!;

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    let introSkipped = false;

    async function runIntro() {
        if (sessionStorage.getItem('cinema-intro')) {
            skipIntro();
            return;
        }

        // Film countdown: 5, 4, 3, 2, 1
        for (let n = 5; n >= 1; n--) {
            if (introSkipped) return;
            countdownEl.textContent = String(n);
            await sleep(800);
        }

        if (introSkipped) return;

        // White flash
        countdownEl.textContent = '';
        flashEl.classList.add('active');
        await sleep(120);
        flashEl.classList.remove('active');

        if (introSkipped) return;

        // Brief pause with grain visible
        await sleep(300);

        if (introSkipped) return;

        // Show production title
        countdownEl.style.display = 'none';
        titleEl.classList.add('visible');
        await sleep(2000);

        if (introSkipped) return;

        // Complete
        sessionStorage.setItem('cinema-intro', '1');
        skipIntro();
    }

    function skipIntro() {
        introSkipped = true;
        sessionStorage.setItem('cinema-intro', '1');
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            filmEl.classList.add('visible');
        }, 600);
    }

    // Skip on click, Escape, Space, Enter
    introEl.addEventListener('click', skipIntro);
    document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (!introEl.classList.contains('done') &&
            (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            e.preventDefault();
            skipIntro();
        }
    });

    runIntro();
</script>
