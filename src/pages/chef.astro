<style>
    /* =========================================
       RESET & BASE
       ========================================= */
    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #fdf5e6;
        color: #8a8070;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* =========================================
       WARM GRADIENT PULSE (AMBIENT)
       ========================================= */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        animation: warmPulse 8s ease-in-out infinite;
        background: radial-gradient(ellipse at 50% 30%, rgba(212, 147, 13, 0.03) 0%, transparent 70%);
    }

    @keyframes warmPulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 1; }
    }

    /* =========================================
       STEAM PARTICLES
       ========================================= */
    .steam-container {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1000;
        overflow: hidden;
    }

    .steam-particle {
        position: absolute;
        bottom: -20px;
        width: 8px;
        height: 8px;
        background: rgba(200, 195, 185, 0.15);
        border-radius: 50%;
        filter: blur(4px);
        animation: steamRise linear infinite;
    }

    .steam-particle:nth-child(1) { left: 10%; animation-duration: 6s; animation-delay: 0s; width: 10px; height: 10px; }
    .steam-particle:nth-child(2) { left: 25%; animation-duration: 8s; animation-delay: 1s; width: 6px; height: 6px; }
    .steam-particle:nth-child(3) { left: 40%; animation-duration: 7s; animation-delay: 2s; width: 12px; height: 12px; }
    .steam-particle:nth-child(4) { left: 55%; animation-duration: 9s; animation-delay: 0.5s; }
    .steam-particle:nth-child(5) { left: 70%; animation-duration: 6.5s; animation-delay: 3s; width: 10px; height: 10px; }
    .steam-particle:nth-child(6) { left: 85%; animation-duration: 7.5s; animation-delay: 1.5s; width: 7px; height: 7px; }
    .steam-particle:nth-child(7) { left: 15%; animation-duration: 8.5s; animation-delay: 4s; width: 9px; height: 9px; }
    .steam-particle:nth-child(8) { left: 60%; animation-duration: 7s; animation-delay: 2.5s; width: 11px; height: 11px; }

    @keyframes steamRise {
        0% {
            transform: translateY(0) translateX(0) scale(1);
            opacity: 0;
        }
        10% {
            opacity: 0.4;
        }
        50% {
            opacity: 0.2;
        }
        100% {
            transform: translateY(-100vh) translateX(30px) scale(2.5);
            opacity: 0;
        }
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #fdf5e6;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.6s ease;
    }

    .intro.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .ticket {
        background: #fff;
        border: 1px solid #e0d8cc;
        padding: 2.5rem 2rem;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        max-width: 320px;
        width: 90%;
        transform: translateY(-40px);
        animation: ticketSlideIn 0.5s ease forwards;
        position: relative;
    }

    .ticket::before,
    .ticket::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        height: 6px;
        background: repeating-linear-gradient(
            90deg,
            transparent,
            transparent 4px,
            #e0d8cc 4px,
            #e0d8cc 8px
        );
    }

    .ticket::before { top: 0; }
    .ticket::after { bottom: 0; }

    @keyframes ticketSlideIn {
        from { transform: translateY(-100vh); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .ticket-text {
        font-family: 'Courier New', monospace;
        font-size: 0.85rem;
        line-height: 1.8;
        color: #2c2c2c;
        white-space: pre;
        min-height: 200px;
    }

    .ticket.slide-out {
        animation: ticketSlideOut 0.6s ease forwards;
    }

    @keyframes ticketSlideOut {
        from { transform: translateY(0); opacity: 1; }
        to { transform: translateY(-100vh); opacity: 0; }
    }

    /* =========================================
       MAIN MENU CONTAINER (VIEWPORT-LOCKED)
       ========================================= */
    .menu {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.8s ease;
        position: relative;
        z-index: 1;
    }

    .menu.visible {
        opacity: 1;
    }

    /* =========================================
       RECIPE NARRATIVE
       ========================================= */
    .recipe-narrative {
        max-width: 600px;
        padding: 1.5rem;
    }

    .recipe-title {
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 0.3rem;
    }

    .recipe-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .recipe-section {
        margin-bottom: 0.8rem;
    }

    .recipe-section h2 {
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.3rem;
    }

    .recipe-section p {
        font-size: 0.78rem;
        line-height: 1.5;
        margin-bottom: 0.4rem;
    }

    .recipe-pairing {
        font-size: 0.75rem;
        font-style: italic;
        text-align: center;
        margin: 1rem 0;
        opacity: 0.8;
    }

    .recipe-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .recipe-footer a {
        text-decoration: none;
    }

    /* =========================================
       RESPONSIVE: 768px
       ========================================= */
    @media (max-width: 768px) {
        .recipe-section p {
            font-size: 0.72rem;
        }

        .recipe-narrative {
            padding: 1rem;
        }
    }

    /* =========================================
       RESPONSIVE: 480px
       ========================================= */
    @media (max-width: 480px) {
        .ticket {
            padding: 2rem 1.5rem;
        }

        .ticket-text {
            font-size: 0.75rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const intro = document.getElementById('intro') as HTMLDivElement;
        const ticket = document.getElementById('ticket') as HTMLDivElement;
        const ticketText = document.getElementById('ticketText') as HTMLPreElement;
        const menu = document.getElementById('menu') as HTMLElement;

        // Check sessionStorage
        const skipIntro = sessionStorage.getItem('chef-intro');

        if (skipIntro) {
            intro.style.display = 'none';
            menu.classList.add('visible');
            return;
        }

        // Ticket lines
        const lines = [
            'ORDER #007',
            'TABLE: PORTFOLIO',
            'GUEST: [VISITOR]',
            'CHEF: DANIELE D\'AGNELLI',
            '─────────────────────',
            'COURSES: 5',
            'SPECIAL REQUESTS: NONE',
            '─────────────────────',
            '*** FIRE ***',
        ];

        let currentLine = 0;
        let currentChar = 0;
        let displayText = '';
        let typingTimer: ReturnType<typeof setTimeout>;
        let dismissed = false;

        function typeNextChar() {
            if (dismissed) return;

            if (currentLine >= lines.length) {
                // All lines typed — pause, then slide out
                setTimeout(() => {
                    if (dismissed) return;
                    finishIntro();
                }, 800);
                return;
            }

            const line = lines[currentLine];

            if (currentChar <= line.length) {
                ticketText.textContent = displayText + line.substring(0, currentChar) + '\u2588';
                currentChar++;
                const delay = currentLine === lines.length - 1 ? 60 : 35;
                typingTimer = setTimeout(typeNextChar, delay);
            } else {
                displayText += line + '\n';
                currentLine++;
                currentChar = 0;
                const pauseDelay = line.startsWith('\u2500') ? 200 : 120;
                typingTimer = setTimeout(typeNextChar, pauseDelay);
            }
        }

        function finishIntro() {
            if (dismissed) return;
            dismissed = true;
            clearTimeout(typingTimer);
            sessionStorage.setItem('chef-intro', '1');

            ticket.classList.add('slide-out');

            setTimeout(() => {
                intro.classList.add('hidden');
                menu.classList.add('visible');
            }, 600);

            setTimeout(() => {
                intro.style.display = 'none';
            }, 1200);
        }

        function skipIntroHandler(e: KeyboardEvent | MouseEvent) {
            if (e instanceof KeyboardEvent) {
                if (!['Escape', ' ', 'Enter'].includes(e.key)) return;
                e.preventDefault();
            }
            finishIntro();
        }

        document.addEventListener('keydown', skipIntroHandler);
        intro.addEventListener('click', skipIntroHandler);

        // Start typing after ticket slides in
        setTimeout(() => {
            typeNextChar();
        }, 600);
    });
</script>
