---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";

const courseNames: Record<string, { course: string; number: string; wine?: string }> = {
  "Accenture-engineer": { course: "Amuse-Bouche", number: "I", wine: "Prosecco di Valdobbiadene" },
  "Codec": { course: "Intermezzo", number: "II", wine: "Vermentino di Sardegna" },
  "Accenture-consultant": { course: "Poisson", number: "III", wine: "Chablis Premier Cru" },
  "Deloitte": { course: "Entrée", number: "IV", wine: "Barolo Riserva" },
  "C3 AI": { course: "Plat Principal", number: "V", wine: "Château Margaux" },
};

function getCourseKey(exp: { company: string; roles: { title: string }[] }): string {
  if (exp.company === "Accenture") {
    return exp.roles[0].title.toLowerCase().includes("engineer") ? "Accenture-engineer" : "Accenture-consultant";
  }
  return exp.company;
}

const orderedExperience = [...experience].reverse();
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Chef's Tasting Menu</title>
    <meta name="description" content="A fine dining experience through Daniele D'Agnelli's career — 15+ years of professional services served as an elegant tasting menu." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/chef" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Chef's Tasting Menu" />
    <meta property="og:description" content="A fine dining experience through 15+ years of digital transformation, AI deployments, and cybersecurity — served course by course." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/chef" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Chef's Tasting Menu" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Chef's Tasting Menu" />
    <meta name="twitter:description" content="A fine dining tasting menu through 15+ years of professional services, AI, and cybersecurity." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Caveat:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- STEAM PARTICLES -->
    <div class="steam-container" aria-hidden="true">
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
        <div class="steam-particle"></div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="ticket" id="ticket">
            <pre class="ticket-text" id="ticketText"></pre>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="menu" id="menu">

        <!-- MENU COVER / HEADER -->
        <header class="menu-header">
            <div class="ornament">&#9670;</div>
            <p class="menu-subtitle">presents</p>
            <h1 class="menu-title">Chef's Tasting Menu</h1>
            <div class="rule-ornament">
                <span class="rule-line"></span>
                <span class="rule-diamond">&#9670;</span>
                <span class="rule-line"></span>
            </div>
            <div class="chef-portrait">
                <img src="/assets/dani.jpeg" alt="Chef Daniele D'Agnelli" width="160" height="160" />
            </div>
            <p class="chef-name">Chef Daniele D'Agnelli</p>
            <p class="chef-location">{siteMetadata.location}</p>
            <div class="rule-ornament">
                <span class="rule-line"></span>
                <span class="rule-diamond">&#9670;</span>
                <span class="rule-line"></span>
            </div>
            <p class="courses-count">Five Courses &middot; Paired Wines &middot; Seasonal</p>
        </header>

        <!-- CHEF'S PHILOSOPHY -->
        <section class="section cream-section reveal">
            <div class="section-header">
                <span class="rule-line"></span>
                <h2>Chef's Philosophy</h2>
                <span class="rule-line"></span>
            </div>
            <blockquote class="philosophy">
                {summary}
            </blockquote>
            <p class="handwritten-note">— every dish tells a story</p>
        </section>

        <!-- TASTING MENU (EXPERIENCE) -->
        <section class="section chalkboard-section reveal">
            <div class="section-header chalkboard-header">
                <span class="rule-line light"></span>
                <h2>The Tasting Menu</h2>
                <span class="rule-line light"></span>
            </div>
            <p class="section-annotation">Five courses, each a chapter in a culinary journey</p>

            <div class="courses">
                {orderedExperience.map((exp) => {
                    const key = getCourseKey(exp);
                    const course = courseNames[key];
                    if (!course) return null;
                    const role = exp.roles[0];
                    return (
                        <article class="course reveal">
                            <div class="course-number">{course.number}</div>
                            <div class="course-header">
                                <h3 class="course-name">{course.course}</h3>
                                <span class="course-company">{exp.company}</span>
                            </div>
                            <p class="course-role">{role.title}</p>
                            <p class="course-period">{role.period} &middot; {exp.location}</p>
                            {role.description && (
                                <p class="course-description">{role.description}</p>
                            )}
                            {role.bullets && role.bullets.length > 0 && (
                                <ul class="course-details">
                                    {role.bullets.map((b) => <li>{b}</li>)}
                                </ul>
                            )}
                            {course.wine && (
                                <p class="wine-pairing">
                                    <span class="wine-icon">&#127863;</span> Paired with {course.wine}
                                </p>
                            )}
                        </article>
                    );
                })}
            </div>
        </section>

        <!-- THE PANTRY (SKILLS) -->
        <section class="section cream-section reveal">
            <div class="section-header">
                <span class="rule-line"></span>
                <h2>The Pantry</h2>
                <span class="rule-line"></span>
            </div>
            <p class="section-annotation handwritten">Fresh, seasonal, sourced with care</p>

            <div class="pantry-grid">
                <div class="pantry-column">
                    <h3 class="pantry-heading">Technical Ingredients</h3>
                    <div class="ingredient-list">
                        {skills.map((skill) => (
                            <span class="ingredient">{skill}</span>
                        ))}
                    </div>
                </div>
                <div class="pantry-column">
                    <h3 class="pantry-heading">Management Seasoning</h3>
                    <div class="ingredient-list">
                        {managementSkills.map((skill) => (
                            <span class="ingredient">{skill}</span>
                        ))}
                    </div>
                </div>
            </div>

            <div class="languages-row">
                <h3 class="pantry-heading">Languages Spoken in the Kitchen</h3>
                <div class="language-tags">
                    {languages.map((lang) => (
                        <span class="language-tag">{lang}</span>
                    ))}
                </div>
            </div>
        </section>

        <!-- SIGNATURE DISHES (ENGAGEMENTS) -->
        <section class="section chalkboard-section reveal">
            <div class="section-header chalkboard-header">
                <span class="rule-line light"></span>
                <h2>Signature Dishes</h2>
                <span class="rule-line light"></span>
            </div>
            <p class="section-annotation">Our most celebrated creations</p>

            <div class="signature-dishes">
                {engagements.map((eng) => (
                    <article class="dish reveal">
                        <div class="dish-header">
                            <h3 class="dish-name">{eng.client}</h3>
                            <span class="dish-sector">{eng.sector}</span>
                        </div>
                        <p class="dish-description">{eng.scope}</p>
                        <p class="dish-review">
                            <em>"{eng.impact}"</em>
                            {eng.trend === "positive" && <span class="star-rating"> &#9733;&#9733;&#9733;</span>}
                            {eng.trend === "neutral" && <span class="star-rating"> &#9733;&#9733;</span>}
                        </p>
                    </article>
                ))}
            </div>
        </section>

        <!-- CULINARY SCHOOL (EDUCATION) -->
        <section class="section cream-section reveal">
            <div class="section-header">
                <span class="rule-line"></span>
                <h2>Culinary School</h2>
                <span class="rule-line"></span>
            </div>

            <div class="education-list">
                {education.map((edu) => (
                    <article class="education-item reveal">
                        <h3 class="edu-institution">{edu.institution}</h3>
                        <p class="edu-degree">{edu.degree}</p>
                        <p class="edu-meta">{edu.period} &middot; {edu.location}</p>
                        {edu.distinction && (
                            <p class="edu-distinction">Graduated with {edu.distinction}</p>
                        )}
                    </article>
                ))}
            </div>
        </section>

        <!-- STARS & AWARDS (CERTIFICATIONS) -->
        <section class="section chalkboard-section reveal">
            <div class="section-header chalkboard-header">
                <span class="rule-line light"></span>
                <h2>Stars & Awards</h2>
                <span class="rule-line light"></span>
            </div>
            <p class="section-annotation">Recognised by the guides</p>

            <div class="awards-grid">
                {certifications.map((cert) => (
                    <div class="award-item reveal">
                        <span class="award-star">&#9733;</span>
                        <span class="award-name">{cert}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- CONTINUING EDUCATION -->
        <section class="section cream-section reveal">
            <div class="section-header">
                <span class="rule-line"></span>
                <h2>Continuing Education</h2>
                <span class="rule-line"></span>
            </div>
            <p class="section-annotation handwritten">A chef never stops learning</p>

            <div class="learning-list">
                {continuousLearning.map((item) => (
                    <div class="learning-item reveal">
                        <span class="learning-bullet">&#9670;</span>
                        <span>{item}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="menu-footer">
            <div class="rule-ornament">
                <span class="rule-line"></span>
                <span class="rule-diamond">&#9670;</span>
                <span class="rule-line"></span>
            </div>
            <p class="footer-merci">Merci &mdash; The Kitchen is Closed</p>
            <p class="footer-gratuity">Gratuity not included</p>
            <div class="footer-links">
                <span class="footer-links-label">Reservations</span>
                <div class="footer-link-row">
                    <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                    <span class="footer-dot">&middot;</span>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                    <span class="footer-dot">&middot;</span>
                    <a href={`mailto:${siteMetadata.email}`}>Email</a>
                </div>
            </div>
            <p class="footer-copy">&copy; {new Date().getFullYear()} Daniele D'Agnelli</p>
        </footer>

    </main>

</body>
</html>

<style>
    /* =========================================
       RESET & BASE
       ========================================= */
    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #fdf5e6;
        color: #8a8070;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    /* =========================================
       WARM GRADIENT PULSE (AMBIENT)
       ========================================= */
    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        animation: warmPulse 8s ease-in-out infinite;
        background: radial-gradient(ellipse at 50% 30%, rgba(212, 147, 13, 0.03) 0%, transparent 70%);
    }

    @keyframes warmPulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 1; }
    }

    /* =========================================
       STEAM PARTICLES
       ========================================= */
    .steam-container {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1000;
        overflow: hidden;
    }

    .steam-particle {
        position: absolute;
        bottom: -20px;
        width: 8px;
        height: 8px;
        background: rgba(200, 195, 185, 0.15);
        border-radius: 50%;
        filter: blur(4px);
        animation: steamRise linear infinite;
    }

    .steam-particle:nth-child(1) { left: 10%; animation-duration: 6s; animation-delay: 0s; width: 10px; height: 10px; }
    .steam-particle:nth-child(2) { left: 25%; animation-duration: 8s; animation-delay: 1s; width: 6px; height: 6px; }
    .steam-particle:nth-child(3) { left: 40%; animation-duration: 7s; animation-delay: 2s; width: 12px; height: 12px; }
    .steam-particle:nth-child(4) { left: 55%; animation-duration: 9s; animation-delay: 0.5s; }
    .steam-particle:nth-child(5) { left: 70%; animation-duration: 6.5s; animation-delay: 3s; width: 10px; height: 10px; }
    .steam-particle:nth-child(6) { left: 85%; animation-duration: 7.5s; animation-delay: 1.5s; width: 7px; height: 7px; }
    .steam-particle:nth-child(7) { left: 15%; animation-duration: 8.5s; animation-delay: 4s; width: 9px; height: 9px; }
    .steam-particle:nth-child(8) { left: 60%; animation-duration: 7s; animation-delay: 2.5s; width: 11px; height: 11px; }

    @keyframes steamRise {
        0% {
            transform: translateY(0) translateX(0) scale(1);
            opacity: 0;
        }
        10% {
            opacity: 0.4;
        }
        50% {
            opacity: 0.2;
        }
        100% {
            transform: translateY(-100vh) translateX(30px) scale(2.5);
            opacity: 0;
        }
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #fdf5e6;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.6s ease;
    }

    .intro.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .ticket {
        background: #fff;
        border: 1px solid #e0d8cc;
        padding: 2.5rem 2rem;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        max-width: 320px;
        width: 90%;
        transform: translateY(-40px);
        animation: ticketSlideIn 0.5s ease forwards;
        position: relative;
    }

    .ticket::before,
    .ticket::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        height: 6px;
        background: repeating-linear-gradient(
            90deg,
            transparent,
            transparent 4px,
            #e0d8cc 4px,
            #e0d8cc 8px
        );
    }

    .ticket::before { top: 0; }
    .ticket::after { bottom: 0; }

    @keyframes ticketSlideIn {
        from { transform: translateY(-100vh); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .ticket-text {
        font-family: 'Courier New', monospace;
        font-size: 0.85rem;
        line-height: 1.8;
        color: #2c2c2c;
        white-space: pre;
        min-height: 200px;
    }

    .ticket.slide-out {
        animation: ticketSlideOut 0.6s ease forwards;
    }

    @keyframes ticketSlideOut {
        from { transform: translateY(0); opacity: 1; }
        to { transform: translateY(-100vh); opacity: 0; }
    }

    /* =========================================
       MAIN MENU CONTAINER
       ========================================= */
    .menu {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 2rem 2rem;
        opacity: 0;
        transition: opacity 0.8s ease;
        position: relative;
        z-index: 1;
    }

    .menu.visible {
        opacity: 1;
    }

    /* =========================================
       MENU HEADER
       ========================================= */
    .menu-header {
        text-align: center;
        padding: 3rem 0 2rem;
    }

    .ornament {
        font-size: 1rem;
        color: #d4930d;
        margin-bottom: 0.5rem;
        letter-spacing: 0.5em;
    }

    .menu-subtitle {
        font-family: 'Caveat', cursive;
        font-size: 1.3rem;
        color: #8a8070;
        margin-bottom: 0.25rem;
    }

    .menu-title {
        font-family: 'Cormorant Garamond', 'Georgia', serif;
        font-weight: 300;
        font-size: 3.2rem;
        color: #2c2c2c;
        letter-spacing: 0.06em;
        margin-bottom: 1rem;
        line-height: 1.15;
    }

    .rule-ornament {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin: 1.5rem 0;
    }

    .rule-line {
        flex: 1;
        height: 1px;
        background: #d4930d;
        max-width: 120px;
        opacity: 0.5;
    }

    .rule-diamond {
        color: #d4930d;
        font-size: 0.6rem;
    }

    .chef-portrait {
        width: 160px;
        height: 160px;
        margin: 1.5rem auto;
        border: 2px solid #d4930d;
        padding: 4px;
        overflow: hidden;
    }

    .chef-portrait img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .chef-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 500;
        color: #2c2c2c;
        margin-top: 0.75rem;
        letter-spacing: 0.05em;
    }

    .chef-location {
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        color: #8a8070;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-top: 0.25rem;
    }

    .courses-count {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        font-style: italic;
        color: #8a8070;
        letter-spacing: 0.05em;
    }

    /* =========================================
       SECTION STYLES
       ========================================= */
    .section {
        padding: 3rem 0;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .section-header h2 {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 400;
        font-size: 2rem;
        color: #2c2c2c;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .section-header .rule-line {
        flex: 1;
        height: 1px;
        background: #d4930d;
        opacity: 0.4;
        max-width: none;
    }

    .section-annotation {
        text-align: center;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        color: #8a8070;
        font-style: italic;
        margin-bottom: 2rem;
        letter-spacing: 0.03em;
    }

    .section-annotation.handwritten {
        font-family: 'Caveat', cursive;
        font-size: 1.2rem;
        font-style: normal;
    }

    /* CREAM SECTIONS */
    .cream-section {
        background: transparent;
    }

    /* CHALKBOARD SECTIONS */
    .chalkboard-section {
        background: #2c2c2c;
        margin-left: -2rem;
        margin-right: -2rem;
        padding-left: 2rem;
        padding-right: 2rem;
        border-top: 1px solid rgba(212, 147, 13, 0.2);
        border-bottom: 1px solid rgba(212, 147, 13, 0.2);
    }

    .chalkboard-section .section-annotation {
        color: rgba(253, 245, 230, 0.6);
    }

    .chalkboard-header h2 {
        color: #fdf5e6;
        font-family: 'Caveat', cursive;
        font-weight: 600;
        font-size: 2.2rem;
        letter-spacing: 0.02em;
    }

    .chalkboard-header .rule-line.light {
        background: rgba(253, 245, 230, 0.25);
    }

    /* =========================================
       CHEF'S PHILOSOPHY
       ========================================= */
    .philosophy {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.15rem;
        line-height: 1.85;
        color: #5a5248;
        text-align: center;
        max-width: 640px;
        margin: 0 auto 1.5rem;
        font-style: italic;
        border-left: none;
        padding: 0 1rem;
    }

    .handwritten-note {
        font-family: 'Caveat', cursive;
        font-size: 1.3rem;
        color: #c0501a;
        text-align: center;
    }

    /* =========================================
       TASTING MENU COURSES
       ========================================= */
    .courses {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .course {
        border: 1px solid rgba(253, 245, 230, 0.1);
        padding: 2rem;
        position: relative;
        background: rgba(253, 245, 230, 0.03);
    }

    .course-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        font-weight: 300;
        color: #d4930d;
        line-height: 1;
        margin-bottom: 0.5rem;
        opacity: 0.7;
    }

    .course-header {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 0.5rem;
    }

    .course-name {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 500;
        font-size: 1.6rem;
        color: #fdf5e6;
        letter-spacing: 0.04em;
    }

    .course-company {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: #d4930d;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .course-role {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        font-style: italic;
        color: rgba(253, 245, 230, 0.75);
        margin-bottom: 0.25rem;
    }

    .course-period {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: rgba(253, 245, 230, 0.4);
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
