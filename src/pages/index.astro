---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Senior Engagement Manager | AI & Cybersecurity</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager with 15+ years in Professional Services. Specializing in AI deployments, cybersecurity, and digital transformation for global enterprises." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Senior Engagement Manager | AI & Cybersecurity" />
    <meta property="og:description" content="15+ years leading high-impact digital transformations. AI deployments, cybersecurity, and programme management for global enterprises." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Senior Engagement Manager" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Senior Engagement Manager | AI & Cybersecurity" />
    <meta name="twitter:description" content="15+ years leading high-impact digital transformations. AI deployments, cybersecurity, and programme management." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations. Specializing in AI deployments and cybersecurity for global enterprises."
    })} />

    <!-- Structured Data (WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "description": "Personal website of Daniele D'Agnelli — Senior Engagement Manager specializing in AI and cybersecurity."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,700;1,400&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- CRT + SCANLINE OVERLAY -->
    <div class="crt-overlay" aria-hidden="true"></div>
    <div class="scanlines" aria-hidden="true"></div>
    <div class="vhs-tracking" aria-hidden="true"></div>
    <canvas class="noise-canvas" id="noiseCanvas" aria-hidden="true"></canvas>

    <!-- HUD: REC + TIMESTAMP + SIGNAL -->
    <div class="hud">
        <div class="hud-left">
            <span class="rec-dot"></span>
            <span class="rec-label">REC</span>
            <span class="hud-separator">|</span>
            <span class="hud-cam">CAM_01</span>
        </div>
        <div class="hud-right">
            <span class="hud-signal">
                SIGNAL
                <span class="signal-bars">
                    <i class="bar on"></i><i class="bar on"></i><i class="bar on"></i><i class="bar dim"></i><i class="bar dim"></i>
                </span>
            </span>
            <span class="hud-separator">|</span>
            <span class="hud-ts" id="hudTimestamp">00:00:00</span>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <pre class="intro-terminal" id="introTerminal"></pre>
    </div>

    <!-- WARNING FLASH -->
    <div class="warning-flash" id="warningFlash" aria-hidden="true">
        <span>⚠ WARNING: SIGNAL DEGRADING ⚠</span>
    </div>

    <!-- GLITCH BURST -->
    <div class="glitch-burst" id="glitchBurst" aria-hidden="true"></div>

    <!-- MAIN CONTENT -->
    <main class="tape" id="tape">

        <!-- DOSSIER HEADER -->
        <section class="section dossier">
            <div class="stamp">CLASSIFIED // EYES ONLY</div>
            <div class="dossier-grid">
                <div class="dossier-info">
                    <h1 class="subject-name" data-text={siteMetadata.name.toLowerCase()}>
                        {siteMetadata.name.toLowerCase()}
                    </h1>
                    <div class="subject-title">{siteMetadata.description}</div>
                    <div class="meta-row">
                        <span class="meta-chip">LOC: {siteMetadata.location.toLowerCase()}</span>
                        <span class="meta-chip active">STATUS: active</span>
                        <span class="meta-chip warn">THREAT: high</span>
                    </div>
                    <div class="link-row">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">[github]</a>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">[linkedin]</a>
                        <a href={`mailto:${siteMetadata.email}`}>[comms]</a>
                    </div>
                </div>
                <div class="dossier-photo">
                    <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="140" height="140" />
                    <div class="photo-scanlines"></div>
                    <span class="photo-label">SUBJ_001</span>
                </div>
            </div>
        </section>

        <hr class="corrupt-line" />

        <!-- PROFILE -->
        <section class="section reveal">
            <div class="sec-head">
                <span class="tag decoded">[DECRYPTED]</span>
                <span class="sec-title">SUBJECT PROFILE</span>
                <span class="sec-pct">■■■■■ 100%</span>
            </div>
            <p class="body-text">{summary.toLowerCase()}</p>
        </section>

        <hr class="corrupt-line" />

        <!-- CAREER FEED -->
        <section class="section reveal">
            <div class="sec-head">
                <span class="tag intercepted">[INTERCEPTED]</span>
                <span class="sec-title">CAREER FEED</span>
                <span class="sec-pct">■■■■■ 100%</span>
            </div>
            {experience.map((exp, i) => (
                <div class="career-block reveal">
                    <div class="career-top">
                        <span class="career-co">{exp.company.toLowerCase()}</span>
                        <span class="career-loc">{exp.location.split(',')[0].toLowerCase()}</span>
                    </div>
                    {exp.roles.map(role => (
                        <div class="career-role">
                            <div class="role-head">
                                <span class="role-name">{role.title.toLowerCase()}</span>
                                <span class="role-period">{role.period.toLowerCase()}</span>
                            </div>
                            {role.description && <p class="role-desc">{role.description.toLowerCase()}</p>}
                            {role.bullets && role.bullets.length > 0 && (
                                <ul class="role-list">
                                    {role.bullets.map(b => <li>▸ {b.toLowerCase()}</li>)}
                                </ul>
                            )}
                        </div>
                    ))}
                </div>
            ))}
        </section>

        <hr class="corrupt-line" />

        <!-- SYSTEM MODULES -->
        <section class="section reveal">
            <div class="sec-head">
                <span class="tag scanned">[SCANNED]</span>
                <span class="sec-title">SYSTEM MODULES</span>
                <span class="sec-pct">■■■■■ 100%</span>
            </div>
            <div class="module-grid">
                {skills.map((s, i) => (
                    <span class="module" style={`--i:${i}`}>{s.toLowerCase()}</span>
                ))}
            </div>
        </section>

        <hr class="corrupt-line" />

        <!-- MISSION LOG -->
        <section class="section reveal">
            <div class="sec-head">
                <span class="tag surveillance">[SURVEILLANCE]</span>
                <span class="sec-title">MISSION LOG</span>
                <span class="sec-pct">■■■■■ 100%</span>
            </div>
            <div class="mission-grid">
                {engagements.map(eng => (
                    <div class="mission-card reveal">
                        <div class="mission-row">
                            <span class="mission-client">{eng.client}</span>
                            <span class="mission-sector">{eng.sector}</span>
                        </div>
                        <div class="mission-row">
                            <span class="mission-scope">{eng.scope}</span>
                            <span class={`mission-impact ${eng.trend}`}>{eng.impact}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <hr class="corrupt-line" />

        <!-- CREDENTIALS -->
        <section class="section reveal">
            <div class="sec-head">
                <span class="tag verified">[VERIFIED]</span>
                <span class="sec-title">CREDENTIALS DUMP</span>
                <span class="sec-pct">■■■■■ 100%</span>
            </div>
            <div class="cred-groups">
                <div class="cred-group">
                    <span class="cred-label">// education</span>
                    {education.map(edu => (
                        <div class="cred-item">
                            <span class="cred-name">{edu.degree.toLowerCase()}</span>
                            <span class="cred-meta">{edu.institution.toLowerCase()} — {edu.period}</span>
                            {edu.distinction && <span class="cred-badge">{edu.distinction.toLowerCase()}</span>}
                        </div>
                    ))}
                </div>
                <div class="cred-group">
                    <span class="cred-label">// certifications</span>
                    {certifications.map(c => (
                        <div class="cred-item"><span class="cred-name">{c.toLowerCase()}</span></div>
                    ))}
                </div>
                <div class="cred-group">
                    <span class="cred-label">// training_log</span>
                    {continuousLearning.map(l => (
                        <div class="cred-item"><span class="cred-name">{l.toLowerCase()}</span></div>
                    ))}
                </div>
            </div>
        </section>

        <hr class="corrupt-line" />

        <!-- END TRANSMISSION -->
        <section class="section end-transmission">
            <span>// END OF INTERCEPTED TRANSMISSION</span>
            <span>// CONNECTION TERMINATED</span>
            <span class="cursor-blink">█</span>
        </section>
    </main>
</body>
</html>

<style>
    /* =========================================
       BASE
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --green: #00ff41;
        --red: #ff0040;
        --cyan: #00d4ff;
        --amber: #ff6600;
        --dim: #444;
        --body-bg: #050505;
        --mono: 'JetBrains Mono', 'Share Tech Mono', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--green) var(--body-bg);
    }

    body {
        background: var(--body-bg);
        color: #ccc;
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--cyan); text-decoration: none; }
    a:hover { color: var(--green); text-decoration: underline; }

    ::selection { background: var(--green); color: #000; }

    /* =========================================
       CRT + SCANLINES + VHS OVERLAYS
       ========================================= */
    .crt-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        box-shadow: inset 0 0 120px rgba(0,0,0,0.7), inset 0 0 40px rgba(0,0,0,0.4);
        border-radius: 12px;
    }

    .scanlines {
        position: fixed; inset: 0; z-index: 9998; pointer-events: none;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 1px,
            rgba(0, 0, 0, 0.15) 1px,
            rgba(0, 0, 0, 0.15) 2px
        );
    }

    .vhs-tracking {
        position: fixed; inset: 0; z-index: 9997; pointer-events: none;
        opacity: 0;
        animation: vhsTrackingPulse 12s ease-in-out infinite;
    }
    .vhs-tracking::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 30px;
        background: linear-gradient(
            180deg,
            transparent,
            rgba(255,255,255,0.08) 30%,
            rgba(255,255,255,0.12) 50%,
            rgba(255,255,255,0.08) 70%,
            transparent
        );
        animation: trackingBar 6s linear infinite;
    }
    .vhs-tracking::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 4px;
        background: rgba(255,255,255,0.15);
        animation: trackingBar 4s linear infinite reverse;
        animation-delay: -2s;
    }

    .noise-canvas {
        position: fixed; inset: 0; z-index: 9996; pointer-events: none;
        width: 100%; height: 100%;
        opacity: 0.035;
        mix-blend-mode: screen;
    }

    /* =========================================
       HUD (REC / TIMESTAMP / SIGNAL)
       ========================================= */
    .hud {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 16px;
        font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
        color: var(--dim);
        pointer-events: none;
        font-family: var(--mono);
    }
    .hud-left, .hud-right { display: flex; align-items: center; gap: 8px; }
    .hud-separator { color: #222; }
    .hud-cam { color: #555; }

    .rec-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--red);
        animation: recBlink 1.5s step-end infinite;
        box-shadow: 0 0 6px var(--red);
    }
    .rec-label { color: var(--red); font-weight: 700; }

    .hud-signal { display: flex; align-items: center; gap: 6px; }
    .signal-bars { display: flex; gap: 2px; align-items: flex-end; }
    .signal-bars .bar {
        display: block; width: 3px; background: var(--dim);
        font-style: normal;
    }
    .signal-bars .bar:nth-child(1) { height: 4px; }
    .signal-bars .bar:nth-child(2) { height: 6px; }
    .signal-bars .bar:nth-child(3) { height: 8px; }
    .signal-bars .bar:nth-child(4) { height: 10px; }
    .signal-bars .bar:nth-child(5) { height: 12px; }
    .signal-bars .bar.on { background: var(--green); }
    .signal-bars .bar.dim { background: #222; }

    .hud-ts { color: #555; font-variant-numeric: tabular-nums; }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--body-bg);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.3s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }
    .intro-terminal {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--green);
        line-height: 1.8;
        max-width: 600px;
        width: 100%;
        white-space: pre-wrap;
        word-break: break-all;
    }

    /* =========================================
       WARNING FLASH + GLITCH BURST
       ========================================= */
    .warning-flash {
        position: fixed; inset: 0; z-index: 10002;
        display: flex; align-items: center; justify-content: center;
        background: rgba(255, 0, 30, 0.06);
        border: 2px solid var(--red);
        opacity: 0; pointer-events: none;
        transition: opacity 0.05s;
        font-size: 18px; font-weight: 700; color: var(--red);
        letter-spacing: 3px; text-transform: uppercase;
        font-family: var(--mono);
    }
    .warning-flash.active { opacity: 1; }

    .glitch-burst {
        position: fixed; inset: 0; z-index: 10001;
        pointer-events: none; opacity: 0;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 2px,
            rgba(0,255,65,0.04) 2px,
            rgba(0,255,65,0.04) 4px
        );
        mix-blend-mode: screen;
    }
    .glitch-burst.active {
        opacity: 1;
        animation: burstShake 0.15s steps(2) 3;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .tape {
        max-width: 820px;
        margin: 0 auto;
        padding: 60px 24px 120px;
        opacity: 0;
        transition: opacity 0.5s ease 0.2s;
    }
    .tape.visible { opacity: 1; }

    /* =========================================
       SECTIONS
       ========================================= */
    .section { margin-bottom: 0; }

    .sec-head {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 12px;
        font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
    }
    .sec-title { color: #888; }
    .sec-pct { margin-left: auto; color: var(--green); font-size: 10px; }

    .tag {
        padding: 1px 6px;
        font-size: 9px; font-weight: 700; letter-spacing: 1px;
        border: 1px solid;
    }
    .tag.decoded { color: var(--green); border-color: var(--green); }
    .tag.intercepted { color: var(--amber); border-color: var(--amber); }
    .tag.scanned { color: var(--cyan); border-color: var(--cyan); }
    .tag.surveillance { color: var(--red); border-color: var(--red); }
    .tag.verified { color: #aaa; border-color: #555; }

    /* REVEAL ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(12px) skewX(-0.3deg);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0) skewX(0deg);
    }

    /* CORRUPT DIVIDER */
    .corrupt-line {
        border: none;
        height: 1px;
        margin: 2.5rem 0;
        background: linear-gradient(
            90deg,
            transparent 0%,
            var(--dim) 10%,
            var(--green) 30%,
            var(--red) 50%,
            var(--green) 70%,
            var(--dim) 90%,
            transparent 100%
        );
        opacity: 0.3;
        position: relative;
    }
    .corrupt-line::after {
        content: '■';
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        color: var(--dim);
        font-size: 8px;
        background: var(--body-bg);
        padding: 0 8px;
    }

    /* =========================================
       DOSSIER HEADER
       ========================================= */
    .stamp {
        font-size: 10px;
        letter-spacing: 3px;
        color: var(--red);
        border: 1px solid var(--red);
        display: inline-block;
        padding: 2px 10px;
        margin-bottom: 20px;
        opacity: 0.8;
        animation: stampFlicker 4s ease-in-out infinite;
    }

    .dossier-grid {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
    }

    .subject-name {
        font-size: clamp(28px, 5vw, 48px);
        font-weight: 700;
        color: #fff;
        line-height: 1.1;
        margin-bottom: 6px;
        position: relative;
        display: inline-block;
    }
    .subject-name::before,
    .subject-name::after {
        content: attr(data-text);
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        overflow: hidden;
    }
    .subject-name::before {
        color: var(--red);
        z-index: -1;
        animation: rgbShift1 3s infinite steps(2);
    }
    .subject-name::after {
        color: var(--cyan);
        z-index: -1;
        animation: rgbShift2 2.5s infinite steps(3);
    }

    .subject-title {
        font-size: 13px;
        color: var(--green);
        margin-bottom: 14px;
        letter-spacing: 0.5px;
    }

    .meta-row {
        display: flex; flex-wrap: wrap; gap: 8px;
        margin-bottom: 14px;
    }
    .meta-chip {
        font-size: 10px; letter-spacing: 1px; text-transform: uppercase;
        padding: 2px 8px;
        border: 1px solid var(--dim);
        color: #777;
    }
    .meta-chip.active { color: var(--green); border-color: var(--green); }
    .meta-chip.warn { color: var(--red); border-color: var(--red); animation: stampFlicker 3s ease-in-out infinite; }

    .link-row {
        display: flex; gap: 14px;
        font-size: 12px;
    }

    /* PHOTO */
    .dossier-photo {
        position: relative;
        flex-shrink: 0;
        width: 140px;
    }
    .dossier-photo img {
        width: 140px; height: 140px;
        object-fit: cover;
        filter: grayscale(0.3) contrast(1.2) brightness(0.85);
        display: block;
        border: 1px solid var(--green);
    }
    .photo-scanlines {
        position: absolute; inset: 0;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px, transparent 2px,
            rgba(0,255,65,0.05) 2px, rgba(0,255,65,0.05) 4px
        );
        pointer-events: none;
        mix-blend-mode: overlay;
    }
    .photo-label {
        display: block;
        text-align: center;
        font-size: 9px;
        color: var(--dim);
        letter-spacing: 2px;
        margin-top: 4px;
    }

    /* =========================================
       BODY TEXT
       ========================================= */
    .body-text {
        color: #999;
        font-size: 12.5px;
        line-height: 1.7;
    }

    /* =========================================
       CAREER FEED
       ========================================= */
    .career-block {
        border-left: 2px solid var(--dim);
        padding-left: 16px;
        margin-bottom: 20px;
        position: relative;
    }
    .career-block::before {
        content: '▸';
        position: absolute;
        left: -7px; top: 0;
        color: var(--green);
        font-size: 12px;
    }
    .career-top {
        display: flex; justify-content: space-between; align-items: baseline;
        margin-bottom: 4px;
    }
    .career-co {
        font-weight: 700;
        color: var(--amber);
        font-size: 14px;
        letter-spacing: 0.5px;
    }
    .career-loc { color: var(--dim); font-size: 11px; }

    .career-role { margin-bottom: 8px; }
    .role-head {
        display: flex; justify-content: space-between; align-items: baseline;
        flex-wrap: wrap; gap: 8px;
    }
    .role-name { color: #ddd; font-size: 12px; }
    .role-period { color: var(--dim); font-size: 10px; letter-spacing: 0.5px; }
    .role-desc { color: #888; font-size: 11.5px; margin-top: 4px; }
    .role-list {
        list-style: none; margin-top: 4px;
    }
    .role-list li {
        color: #777; font-size: 11px; line-height: 1.7;
    }

    /* =========================================
       SYSTEM MODULES (SKILLS)
       ========================================= */
    .module-grid {
        display: flex; flex-wrap: wrap; gap: 6px;
    }
    .module {
        font-size: 11px;
        padding: 3px 10px;
        border: 1px solid #2a2a2a;
        color: var(--green);
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
    }
    .module:hover {
        border-color: var(--green);
        box-shadow: 0 0 8px rgba(0,255,65,0.15);
        color: #fff;
    }
    .module::after {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(0,255,65,0.08), transparent);
        animation: moduleScan 4s ease-in-out infinite;
        animation-delay: calc(var(--i) * 0.15s);
    }

    /* =========================================
       MISSION LOG
       ========================================= */
    .mission-grid {
        display: flex; flex-direction: column; gap: 8px;
    }
    .mission-card {
        border: 1px solid #1a1a1a;
        padding: 10px 14px;
        background: rgba(255,255,255,0.01);
        transition: border-color 0.2s;
    }
    .mission-card:hover { border-color: var(--dim); }
    .mission-row {
        display: flex; justify-content: space-between; align-items: baseline;
    }
    .mission-client { color: var(--amber); font-size: 12px; font-weight: 700; }
    .mission-sector { color: var(--dim); font-size: 10px; text-transform: uppercase; letter-spacing: 1px; }
    .mission-scope { color: #888; font-size: 11px; }
    .mission-impact { font-size: 11px; font-weight: 700; }
    .mission-impact.positive { color: var(--green); }
    .mission-impact.neutral { color: #888; }

    /* =========================================
       CREDENTIALS
       ========================================= */
    .cred-groups {
        display: flex; flex-direction: column; gap: 18px;
    }
    .cred-label {
        display: block;
        color: var(--dim);
        font-size: 10px;
        letter-spacing: 1px;
        margin-bottom: 6px;
        font-style: italic;
    }
    .cred-item {
        display: flex; flex-direction: column;
        margin-bottom: 4px;
    }
    .cred-name { color: #bbb; font-size: 12px; }
    .cred-meta { color: var(--dim); font-size: 10px; }
    .cred-badge {
        color: var(--green); font-size: 10px; text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* =========================================
       END TRANSMISSION
       ========================================= */
    .end-transmission {
        display: flex; flex-direction: column; align-items: center;
        gap: 4px;
        color: var(--dim);
        font-size: 12px;
        padding: 3rem 0;
        letter-spacing: 1px;
    }
    .cursor-blink {
        color: var(--green);
        animation: blink 1s step-end infinite;
    }

    /* =========================================
       KEYFRAMES
       ========================================= */
    @keyframes recBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    @keyframes blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    @keyframes stampFlicker {
        0%, 92%, 100% { opacity: 0.8; }
        93% { opacity: 0.2; }
        94% { opacity: 0.9; }
        95% { opacity: 0.3; }
        96% { opacity: 0.85; }
    }

    @keyframes rgbShift1 {
        0% { clip-path: inset(0 0 85% 0); left: 2px; }
        20% { clip-path: inset(15% 0 65% 0); left: -2px; }
        40% { clip-path: inset(40% 0 45% 0); left: 3px; }
        60% { clip-path: inset(60% 0 25% 0); left: -1px; }
        80% { clip-path: inset(80% 0 5% 0); left: 2px; }
        100% { clip-path: inset(0 0 85% 0); left: -2px; }
    }
    @keyframes rgbShift2 {
        0% { clip-path: inset(65% 0 0 0); left: -2px; }
        25% { clip-path: inset(45% 0 30% 0); left: 2px; }
        50% { clip-path: inset(20% 0 55% 0); left: -3px; }
        75% { clip-path: inset(70% 0 10% 0); left: 1px; }
        100% { clip-path: inset(65% 0 0 0); left: 2px; }
    }

    @keyframes trackingBar {
        0% { top: -30px; }
        100% { top: 100vh; }
    }

    @keyframes vhsTrackingPulse {
        0%, 85%, 100% { opacity: 0; }
        88% { opacity: 1; }
        92% { opacity: 0.6; }
        95% { opacity: 0; }
    }

    @keyframes moduleScan {
        0%, 100% { left: -100%; }
        50% { left: 100%; }
    }

    @keyframes burstShake {
        0% { transform: translate(0, 0) skewX(0deg); }
        25% { transform: translate(-3px, 1px) skewX(-1deg); }
        50% { transform: translate(2px, -1px) skewX(0.5deg); }
        75% { transform: translate(-1px, 2px) skewX(-0.5deg); }
        100% { transform: translate(0, 0) skewX(0deg); }
    }

    /* body-level CRT flicker */
    body {
        animation: crtFlicker 0.1s infinite alternate;
    }
    @keyframes crtFlicker {
        0% { opacity: 0.985; }
        100% { opacity: 1; }
    }

    /* =========================================
       RESPONSIVE
       ========================================= */
    @media (max-width: 600px) {
        .tape { padding: 50px 14px 80px; }
        .dossier-grid { flex-direction: column-reverse; align-items: flex-start; }
        .dossier-photo { width: 100px; }
        .dossier-photo img { width: 100px; height: 100px; }
        .career-top { flex-direction: column; gap: 0; }
        .role-head { flex-direction: column; gap: 2px; }
        .meta-row { gap: 4px; }
        .hud { font-size: 9px; padding: 6px 10px; }
    }
</style>

<script>
    /* =============================================
       NOISE CANVAS
       ============================================= */
    const canvas = document.getElementById('noiseCanvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let noiseFrame = 0;

    function resizeNoise() {
        canvas.width = window.innerWidth / 4;
        canvas.height = window.innerHeight / 4;
    }
    resizeNoise();
    window.addEventListener('resize', resizeNoise);

    function drawNoise() {
        const w = canvas.width, h = canvas.height;
        const imageData = ctx.createImageData(w, h);
        const d = imageData.data;
        for (let i = 0; i < d.length; i += 4) {
            const v = Math.random() * 255;
            d[i] = d[i+1] = d[i+2] = v;
            d[i+3] = 255;
        }
        ctx.putImageData(imageData, 0, 0);
        noiseFrame = requestAnimationFrame(drawNoise);
    }
    drawNoise();

    /* =============================================
       HUD TIMESTAMP
       ============================================= */
    const tsEl = document.getElementById('hudTimestamp')!;
    function updateTS() {
        const now = new Date();
        tsEl.textContent =
            String(now.getHours()).padStart(2,'0') + ':' +
            String(now.getMinutes()).padStart(2,'0') + ':' +
            String(now.getSeconds()).padStart(2,'0');
    }
    updateTS();
    setInterval(updateTS, 1000);

    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const termEl = document.getElementById('introTerminal')!;
    const tapeEl = document.getElementById('tape')!;

    const introLines = [
        { text: '> scanning frequencies...', delay: 60 },
        { text: '> ██████ signal detected at 2.4ghz', delay: 40 },
        { text: '> attempting handshake...', delay: 70 },
        { text: '> firewall detected [████████.███.██]', delay: 50 },
        { text: '> deploying exploit...', delay: 80 },
        { text: '> ███████████████ success', delay: 30 },
        { text: '> establishing encrypted tunnel...', delay: 60 },
        { text: '> decrypting personnel file...', delay: 50 },
        { text: '> target: daniele d\'agnelli', delay: 40 },
        { text: '> classification: level_5 // eyes only', delay: 45 },
        { text: '', delay: 0 },
        { text: '  [ACCESS GRANTED]', delay: 35, cls: 'access' },
    ];

    function sleep(ms: number) {
        return new Promise(r => setTimeout(r, ms));
    }

    async function typeLine(text: string, charDelay: number, cls?: string) {
        const lineEl = document.createElement('div');
        if (cls) lineEl.className = cls;
        termEl.appendChild(lineEl);

        for (const ch of text) {
            lineEl.textContent += ch;
            await sleep(charDelay);
        }
        await sleep(200 + Math.random() * 300);
    }

    async function runIntro() {
        // Skip if already seen this session
        if (sessionStorage.getItem('v2-intro')) {
            skipIntro();
            return;
        }

        for (const line of introLines) {
            if (line.text === '') {
                await sleep(400);
                continue;
            }
            await typeLine(line.text, line.delay, line.cls);
        }

        await sleep(600);
        sessionStorage.setItem('v2-intro', '1');
        skipIntro();
    }

    function skipIntro() {
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            tapeEl.classList.add('visible');
        }, 350);
    }

    // Click/key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('v2-intro', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('v2-intro', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       RANDOM GLITCH BURSTS
       ============================================= */
    const burstEl = document.getElementById('glitchBurst')!;

    function triggerGlitch() {
        burstEl.classList.add('active');
        // Temporarily shift some elements
        document.body.style.filter = `hue-rotate(${Math.random() * 30 - 15}deg)`;
        setTimeout(() => {
            burstEl.classList.remove('active');
            document.body.style.filter = '';
        }, 150 + Math.random() * 200);
    }

    function scheduleGlitch() {
        const delay = 5000 + Math.random() * 15000;
        setTimeout(() => {
            triggerGlitch();
            scheduleGlitch();
        }, delay);
    }
    scheduleGlitch();

    /* =============================================
       WARNING FLASH
       ============================================= */
    const warnEl = document.getElementById('warningFlash')!;

    function triggerWarning() {
        warnEl.classList.add('active');
        setTimeout(() => warnEl.classList.remove('active'), 400 + Math.random() * 300);
    }

    function scheduleWarning() {
        const delay = 20000 + Math.random() * 40000;
        setTimeout(() => {
            triggerWarning();
            scheduleWarning();
        }, delay);
    }
    scheduleWarning();

    /* =============================================
       TEXT SCRAMBLE on random elements
       ============================================= */
    const scrambleChars = '!@#$%^&*()_+-=[]{}|;:,.<>?/~`░▒▓█▄▀';
    const scrambleTargets = document.querySelectorAll('.career-co, .mission-client, .module');

    function scrambleElement(el: Element) {
        const original = el.textContent || '';
        const len = original.length;
        let iterations = 0;
        const maxIter = 6;
        const interval = setInterval(() => {
            let scrambled = '';
            for (let i = 0; i < len; i++) {
                if (iterations > maxIter * (i / len)) {
                    scrambled += original[i];
                } else {
                    scrambled += scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
                }
            }
            el.textContent = scrambled;
            iterations++;
            if (iterations > maxIter) {
                clearInterval(interval);
                el.textContent = original;
            }
        }, 40);
    }

    function scheduleScramble() {
        const delay = 8000 + Math.random() * 20000;
        setTimeout(() => {
            const target = scrambleTargets[Math.floor(Math.random() * scrambleTargets.length)];
            if (target) scrambleElement(target);
            scheduleScramble();
        }, delay);
    }
    scheduleScramble();

    /* =============================================
       INTRO STYLE INJECTION (access granted color)
       ============================================= */
    const style = document.createElement('style');
    style.textContent = `.access { color: #ff0040; font-weight: 700; letter-spacing: 2px; }`;
    document.head.appendChild(style);
</script>
