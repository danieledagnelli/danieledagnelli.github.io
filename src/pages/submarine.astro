---
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Deep Sea Operations Console</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. Deep Sea Submarine Operations Console. 15+ years navigating complex digital transformations." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/submarine" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta property="og:description" content="15+ years navigating complex digital transformations. AI deployments, cybersecurity, and programme management for global enterprises." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/submarine" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta name="twitter:description" content="15+ years navigating complex digital transformations. AI deployments, cybersecurity, and programme management." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- WATER OVERLAY WITH BUBBLES -->
    <div class="water-overlay" aria-hidden="true"></div>
    <div class="bubble-layer" id="bubbleLayer" aria-hidden="true"></div>
    <div class="caustics-overlay" aria-hidden="true"></div>

    <!-- DEPTH GAUGE (side panel) -->
    <div class="depth-gauge" aria-hidden="true">
        <div class="gauge-label">depth</div>
        <div class="gauge-track">
            <div class="gauge-fill" id="depthGaugeFill"></div>
        </div>
        <div class="gauge-reading" id="depthReading">0m</div>
    </div>

    <!-- PRESSURE GAUGE (right side) -->
    <div class="pressure-gauge" aria-hidden="true">
        <div class="gauge-label">psi</div>
        <div class="pressure-value" id="pressureValue">14.7</div>
        <div class="pressure-unit">atm</div>
    </div>

    <!-- SONAR HUD -->
    <div class="sonar-hud" aria-hidden="true">
        <div class="sonar-ring" id="sonarRing"></div>
        <div class="sonar-sweep" id="sonarSweep"></div>
        <div class="sonar-dot"></div>
    </div>

    <!-- STATUS BAR -->
    <div class="status-bar">
        <div class="status-left">
            <span class="status-indicator"></span>
            <span class="status-label">ops active</span>
            <span class="status-sep">|</span>
            <span class="status-coord" id="statusCoord">51.5074n 0.1278w</span>
        </div>
        <div class="status-right">
            <span class="status-o2">O2: <span id="o2Level">98</span>%</span>
            <span class="status-sep">|</span>
            <span class="status-time" id="statusTime">00:00:00</span>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-console" id="introConsole">
            <div class="intro-depth-counter">
                <span class="depth-label">current depth</span>
                <span class="depth-number" id="introDepth">0</span>
                <span class="depth-unit">meters</span>
            </div>
            <div class="intro-pressure-bar">
                <span class="pressure-label">hull pressure</span>
                <div class="pressure-track">
                    <div class="pressure-fill" id="introPressureFill"></div>
                </div>
                <span class="pressure-pct" id="introPressurePct">0%</span>
            </div>
            <pre class="intro-terminal" id="introTerminal"></pre>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="console-main" id="consoleMain">

        <div class="sub-narrative">
            <h1 class="scan-title">DEEP SCAN — TECHNICAL PROFILE</h1>
            <div class="scan-meta">depth: full stack | pressure: enterprise-grade | status: operational</div>

            <div class="layer">
                <h2>LAYER 1: LANGUAGES</h2>
                <p>python · java · go · rust · sql · bash — six-language capability. polyglot architecture.</p>
            </div>

            <div class="layer">
                <h2>LAYER 2: ML & AI</h2>
                <p>ml pipelines · deep learning · reinforcement learning · llms & generative ai · rag systems · mlops — stanford-trained. deeplearning.ai certified.</p>
            </div>

            <div class="layer">
                <h2>LAYER 3: INFRASTRUCTURE</h2>
                <p>cloud (aws/azure/gcp) · data engineering · data integration · solution architecture · enterprise architecture · gitops · linux</p>
            </div>

            <div class="layer">
                <h2>LAYER 4: SECURITY</h2>
                <p>penetration testing · reverse engineering · security tooling — msc ethical hacking (distinction, gchq-certified). active on hack the box.</p>
            </div>

            <div class="surface-reading">
                <p>SURFACE READING: what the org chart says: senior engagement manager, c3 ai. what the stack says: full-spectrum engineer who chose to lead.</p>
            </div>

            <div class="sub-footer">
                <a href="mailto:daniele@dagnelli.net">[ping]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE + CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --abyss: #0a0f14;
        --sonar: #00cc66;
        --depth-blue: #0066cc;
        --warning: #ff3333;
        --hull: #1a2030;
        --amber: #ffaa00;
        --dim: #2a3545;
        --text-dim: #506070;
        --mono: 'Share Tech Mono', monospace;
        --heading: 'Exo 2', sans-serif;
        scrollbar-width: thin;
        scrollbar-color: var(--sonar) var(--abyss);
    }

    body {
        background: var(--abyss);
        color: #8899aa;
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--sonar); text-decoration: none; }
    a:hover { color: var(--depth-blue); text-decoration: underline; }

    ::selection { background: var(--sonar); color: var(--abyss); }

    /* =========================================
       WATER OVERLAY + CAUSTICS
       ========================================= */
    .water-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background: linear-gradient(
            180deg,
            rgba(0, 20, 40, 0.3) 0%,
            rgba(0, 10, 30, 0.5) 50%,
            rgba(0, 5, 15, 0.7) 100%
        );
        box-shadow: inset 0 0 200px rgba(0,0,0,0.6);
    }

    .caustics-overlay {
        position: fixed; inset: 0; z-index: 9998; pointer-events: none;
        opacity: 0.03;
        background:
            radial-gradient(ellipse at 20% 30%, rgba(0,102,204,0.3) 0%, transparent 50%),
            radial-gradient(ellipse at 70% 60%, rgba(0,204,102,0.2) 0%, transparent 40%),
            radial-gradient(ellipse at 50% 80%, rgba(0,102,204,0.2) 0%, transparent 45%);
        animation: causticsDrift 12s ease-in-out infinite alternate;
    }

    .bubble-layer {
        position: fixed; inset: 0; z-index: 9997; pointer-events: none;
        overflow: hidden;
    }

    /* =========================================
       DEPTH GAUGE (left side)
       ========================================= */
    .depth-gauge {
        position: fixed; left: 12px; top: 50%; transform: translateY(-50%);
        z-index: 10000; display: flex; flex-direction: column; align-items: center;
        gap: 6px; pointer-events: none;
    }
    .depth-gauge .gauge-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 2px; color: var(--sonar); opacity: 0.7;
    }
    .gauge-track {
        width: 4px; height: 120px; background: var(--hull);
        border-radius: 2px; position: relative; overflow: hidden;
        border: 1px solid rgba(0,204,102,0.15);
    }
    .gauge-fill {
        position: absolute; bottom: 0; width: 100%; height: 0%;
        background: linear-gradient(0deg, var(--sonar), var(--depth-blue));
        border-radius: 2px; transition: height 0.3s ease;
    }
    .gauge-reading {
        font-family: var(--mono); font-size: 10px; color: var(--sonar);
        font-variant-numeric: tabular-nums;
    }

    /* =========================================
       PRESSURE GAUGE (right side)
       ========================================= */
    .pressure-gauge {
        position: fixed; right: 12px; top: 50%; transform: translateY(-50%);
        z-index: 10000; display: flex; flex-direction: column; align-items: center;
        gap: 4px; pointer-events: none;
    }
    .pressure-gauge .gauge-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 2px; color: var(--amber); opacity: 0.7;
    }
    .pressure-value {
        font-family: var(--mono); font-size: 14px; color: var(--amber);
        font-weight: 700; font-variant-numeric: tabular-nums;
    }
    .pressure-unit {
        font-family: var(--mono); font-size: 8px; color: var(--text-dim);
        text-transform: uppercase; letter-spacing: 1px;
    }

    /* =========================================
       SONAR HUD (top right corner)
       ========================================= */
    .sonar-hud {
        position: fixed; top: 50px; right: 50px; z-index: 10000;
        width: 60px; height: 60px; pointer-events: none;
    }
    .sonar-ring {
        position: absolute; inset: 0;
        border: 1px solid rgba(0,204,102,0.2);
        border-radius: 50%;
    }
    .sonar-ring::before, .sonar-ring::after {
        content: ''; position: absolute; border-radius: 50%;
        border: 1px solid rgba(0,204,102,0.1);
    }
    .sonar-ring::before {
        inset: 8px;
    }
    .sonar-ring::after {
        inset: 18px;
    }
    .sonar-sweep {
        position: absolute; top: 50%; left: 50%;
        width: 50%; height: 1px;
        background: linear-gradient(90deg, var(--sonar), transparent);
        transform-origin: left center;
        animation: sonarSweep 3s linear infinite;
        opacity: 0.6;
    }
    .sonar-dot {
        position: absolute; top: 50%; left: 50%;
        width: 4px; height: 4px;
        background: var(--sonar);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 6px var(--sonar);
    }

    /* =========================================
       STATUS BAR
       ========================================= */
    .status-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 16px;
        font-size: 11px; text-transform: lowercase; letter-spacing: 1px;
        color: var(--text-dim);
        pointer-events: none;
        font-family: var(--mono);
        background: linear-gradient(180deg, rgba(10,15,20,0.9) 0%, transparent 100%);
    }
    .status-left, .status-right { display: flex; align-items: center; gap: 8px; }
    .status-sep { color: var(--dim); }
    .status-indicator {
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--sonar);
        animation: pulse 2s ease-in-out infinite;
        box-shadow: 0 0 6px var(--sonar);
    }
    .status-label { color: var(--sonar); font-weight: 700; }
    .status-o2 { color: var(--sonar); }
    .status-time { color: var(--text-dim); font-variant-numeric: tabular-nums; }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--abyss);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.5s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }
    .intro-console {
        max-width: 500px; width: 100%;
        display: flex; flex-direction: column; gap: 20px; align-items: center;
    }
    .intro-depth-counter {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
    }
    .depth-label {
        font-family: var(--mono); font-size: 10px; text-transform: uppercase;
        letter-spacing: 3px; color: var(--text-dim);
    }
    .depth-number {
        font-family: var(--heading); font-size: 64px; font-weight: 900;
        color: var(--sonar); line-height: 1;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 0 20px rgba(0,204,102,0.4);
    }
    .depth-unit {
        font-family: var(--mono); font-size: 11px; text-transform: uppercase;
        letter-spacing: 4px; color: var(--depth-blue);
    }
    .intro-pressure-bar {
        width: 100%; display: flex; align-items: center; gap: 12px;
    }
    .pressure-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 1px; color: var(--text-dim); white-space: nowrap;
    }
    .pressure-track {
        flex: 1; height: 6px; background: var(--hull);
        border-radius: 3px; overflow: hidden;
        border: 1px solid rgba(0,204,102,0.1);
    }
    .pressure-fill {
        height: 100%; width: 0%; border-radius: 3px;
        background: linear-gradient(90deg, var(--depth-blue), var(--sonar));
        transition: width 0.1s linear;
    }
    .pressure-pct {
        font-family: var(--mono); font-size: 10px; color: var(--sonar);
        min-width: 30px; text-align: right;
    }
    .intro-terminal {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--sonar);
        line-height: 1.8;
        width: 100%;
        white-space: pre-wrap;
        word-break: break-all;
        opacity: 0.9;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .console-main {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }
    .console-main.visible { opacity: 1; }

    /* =========================================
       SUB NARRATIVE
       ========================================= */
    .sub-narrative {
        max-width: 600px;
        padding: 1.5rem;
    }
    .scan-title {
        font-size: 1rem;
        text-align: center;
        margin-bottom: 0.2rem;
        color: var(--sonar);
        font-family: var(--heading);
        font-weight: 700;
        letter-spacing: 0.1em;
    }
    .scan-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
        color: var(--text-dim);
        letter-spacing: 0.05em;
    }
    .layer {
        margin-bottom: 0.6rem;
    }
    .layer h2 {
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.2rem;
        color: var(--depth-blue);
        font-family: var(--heading);
        font-weight: 600;
    }
    .layer p {
        font-size: 0.78rem;
        line-height: 1.5;
        color: #8899aa;
    }
    .surface-reading {
        font-size: 0.75rem;
        opacity: 0.8;
        margin: 0.8rem 0;
        color: #8899aa;
        line-height: 1.5;
    }
    .sub-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 0.8rem;
    }
    .sub-footer a {
        text-decoration: none;
    }

    /* =========================================
       KEYFRAMES
       ========================================= */
    @keyframes pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--sonar); }
        50% { opacity: 0.4; box-shadow: 0 0 2px var(--sonar); }
    }

    @keyframes blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    @keyframes sonarSweep {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @keyframes consolePulse {
        0%, 90%, 100% { opacity: 1; }
        92% { opacity: 0.3; }
        94% { opacity: 0.9; }
        96% { opacity: 0.4; }
    }

    @keyframes systemScan {
        0%, 100% { left: -100%; }
        50% { left: 100%; }
    }

    @keyframes causticsDrift {
        0% { background-position: 0% 0%; opacity: 0.03; }
        50% { opacity: 0.05; }
        100% { background-position: 100% 100%; opacity: 0.03; }
    }

    @keyframes waveMotion {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(3px); }
        75% { transform: translateX(-3px); }
    }

    @keyframes sonarPing {
        0% {
            transform: translate(-50%, -50%) scale(0);
            opacity: 0.6;
            border-color: var(--sonar);
        }
        100% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 0;
            border-color: transparent;
        }
    }

    @keyframes bubbleRise {
        0% {
            transform: translateY(100vh) translateX(0) scale(1);
            opacity: 0.4;
        }
        25% { transform: translateY(75vh) translateX(10px) scale(1.05); }
        50% { transform: translateY(50vh) translateX(-8px) scale(0.95); }
        75% { transform: translateY(25vh) translateX(12px) scale(1.02); }
        100% {
            transform: translateY(-20px) translateX(5px) scale(0.9);
            opacity: 0;
        }
    }

    /* =========================================
       RESPONSIVE -- MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .layer p { font-size: 0.72rem; }
        .sub-narrative { padding: 1rem; }
        .status-bar { font-size: 9px; padding: 6px 10px; }
        .depth-gauge { display: none; }
        .pressure-gauge { display: none; }
        .sonar-hud { width: 40px; height: 40px; top: 38px; right: 14px; }
    }

    @media (max-width: 380px) {
        .status-bar { font-size: 8px; padding: 4px 8px; }
        .status-coord { display: none; }
        .sonar-hud { display: none; }
        .intro-terminal { font-size: 10px; }
        .depth-number { font-size: 48px; }
    }
</style>

<script>
    /* =============================================
       STATUS BAR CLOCK
       ============================================= */
    const timeEl = document.getElementById('statusTime')!;
    function updateTime() {
        const now = new Date();
        timeEl.textContent =
            String(now.getHours()).padStart(2,'0') + ':' +
            String(now.getMinutes()).padStart(2,'0') + ':' +
            String(now.getSeconds()).padStart(2,'0');
    }
    updateTime();
    setInterval(updateTime, 1000);

    /* =============================================
       DEPTH GAUGE (tracks scroll)
       ============================================= */
    const depthFill = document.getElementById('depthGaugeFill');
    const depthReading = document.getElementById('depthReading');
    const pressureVal = document.getElementById('pressureValue');

    function updateGauges() {
        const scrollPct = Math.min(1, window.scrollY / (document.body.scrollHeight - window.innerHeight || 1));
        const depth = Math.round(scrollPct * 4200);
        const pressure = (14.7 + scrollPct * 400).toFixed(1);

        if (depthFill) depthFill.style.height = (scrollPct * 100) + '%';
        if (depthReading) depthReading.textContent = depth + 'm';
        if (pressureVal) pressureVal.textContent = pressure;
    }
    window.addEventListener('scroll', updateGauges, { passive: true });
    updateGauges();

    /* =============================================
       O2 LEVEL (slowly decreases)
       ============================================= */
    const o2El = document.getElementById('o2Level');
    let o2 = 98;
    setInterval(() => {
        if (o2 > 85) {
            o2 -= Math.random() * 0.3;
            if (o2El) o2El.textContent = Math.round(o2).toString();
        }
    }, 5000);

    /* =============================================
       BUBBLE PARTICLES
       ============================================= */
    const bubbleLayer = document.getElementById('bubbleLayer');

    function createBubble() {
        if (!bubbleLayer) return;
        const bubble = document.createElement('div');
        const size = 2 + Math.random() * 6;
        const left = Math.random() * 100;
        const duration = 8 + Math.random() * 12;
        const delay = Math.random() * 2;

        bubble.style.cssText = `
            position: absolute;
            bottom: -10px;
            left: ${left}%;
            width: ${size}px;
            height: ${size}px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, rgba(0,204,102,0.3), rgba(0,102,204,0.1));
            border: 1px solid rgba(0,204,102,0.15);
            animation: bubbleRise ${duration}s ease-in ${delay}s forwards;
            pointer-events: none;
        `;
        bubbleLayer.appendChild(bubble);

        setTimeout(() => {
            bubble.remove();
        }, (duration + delay) * 1000 + 500);
    }

    // Spawn bubbles periodically
    function scheduleBubble() {
        createBubble();
        setTimeout(scheduleBubble, 800 + Math.random() * 2000);
    }
    scheduleBubble();

    /* =============================================
       SONAR PING ANIMATION
       ============================================= */
    const sonarHud = document.querySelector('.sonar-hud');

    function sonarPing() {
        if (!sonarHud) return;
        const ping = document.createElement('div');
        ping.style.cssText = `
            position: absolute;
            top: 50%; left: 50%;
            width: 100%; height: 100%;
            border: 1px solid var(--sonar);
            border-radius: 50%;
            transform: translate(-50%, -50%) scale(0);
            animation: sonarPing 1.5s ease-out forwards;
            pointer-events: none;
        `;
        sonarHud.appendChild(ping);
        setTimeout(() => ping.remove(), 1600);
    }

    function schedulePing() {
        sonarPing();
        setTimeout(schedulePing, 3000 + Math.random() * 4000);
    }
    setTimeout(schedulePing, 2000);

    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const termEl = document.getElementById('introTerminal')!;
    const mainEl = document.getElementById('consoleMain')!;
    const introDepthEl = document.getElementById('introDepth')!;
    const introPressureFill = document.getElementById('introPressureFill')!;
    const introPressurePct = document.getElementById('introPressurePct')!;

    const introLines = [
        { text: '> submarine ops console v3.7 initializing...', delay: 50 },
        { text: '> flood ballast tanks... engaged', delay: 40 },
        { text: '> hull integrity check... nominal', delay: 55 },
        { text: '> sonar array... activated', delay: 45 },
        { text: '> life support... online', delay: 35 },
        { text: '> depth sensors... calibrated', delay: 50 },
        { text: '> comm buoy... deployed', delay: 40 },
        { text: '> navigation... locked to coordinates 51.50n 0.12w', delay: 45 },
        { text: '> captain: daniele d\'agnelli', delay: 35 },
        { text: '> mission status: active', delay: 40 },
        { text: '', delay: 0 },
        { text: '  [ALL SYSTEMS NOMINAL — DIVE DIVE DIVE]', delay: 30, cls: 'dive-cmd' },
    ];

    function sleep(ms: number) {
        return new Promise(r => setTimeout(r, ms));
    }

    // Depth counter animation
    let depthAnimRunning = false;
    async function animateDepth() {
        depthAnimRunning = true;
        const target = 4200;
        const steps = 60;
        for (let i = 0; i <= steps; i++) {
            if (!depthAnimRunning) break;
            const current = Math.round((i / steps) * target);
            const pct = Math.round((i / steps) * 100);
            introDepthEl.textContent = current.toString();
            introPressureFill.style.width = pct + '%';
            introPressurePct.textContent = pct + '%';
            await sleep(50);
        }
    }

    async function typeLine(text: string, charDelay: number, cls?: string) {
        const lineEl = document.createElement('div');
        if (cls) lineEl.className = cls;
        termEl.appendChild(lineEl);

        for (const ch of text) {
            lineEl.textContent += ch;
            await sleep(charDelay);
        }
        await sleep(150 + Math.random() * 200);
    }

    async function runIntro() {
        if (sessionStorage.getItem('submarine-intro-seen')) {
            skipIntro();
            return;
        }

        // Start depth animation in parallel
        animateDepth();

        for (const line of introLines) {
            if (line.text === '') {
                await sleep(300);
                continue;
            }
            await typeLine(line.text, line.delay, line.cls);
        }

        await sleep(500);
        depthAnimRunning = false;
        sessionStorage.setItem('submarine-intro-seen', '1');
        skipIntro();
    }

    function skipIntro() {
        depthAnimRunning = false;
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            mainEl.classList.add('visible');
        }, 500);
    }

    // Click/key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('submarine-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('submarine-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       INTRO STYLE INJECTION
       ============================================= */
    const style = document.createElement('style');
    style.textContent = `.dive-cmd { color: #00cc66; font-weight: 700; letter-spacing: 2px; text-shadow: 0 0 10px rgba(0,204,102,0.5); }`;
    document.head.appendChild(style);
</script>
