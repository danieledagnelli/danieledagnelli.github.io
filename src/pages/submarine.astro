---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Deep Sea Operations Console</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. Deep Sea Submarine Operations Console. 15+ years navigating complex digital transformations." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/submarine" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta property="og:description" content="15+ years navigating complex digital transformations. AI deployments, cybersecurity, and programme management for global enterprises." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/submarine" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Deep Sea Operations Console" />
    <meta name="twitter:description" content="15+ years navigating complex digital transformations. AI deployments, cybersecurity, and programme management." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@400;600;700;900&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- WATER OVERLAY WITH BUBBLES -->
    <div class="water-overlay" aria-hidden="true"></div>
    <div class="bubble-layer" id="bubbleLayer" aria-hidden="true"></div>
    <div class="caustics-overlay" aria-hidden="true"></div>

    <!-- DEPTH GAUGE (side panel) -->
    <div class="depth-gauge" aria-hidden="true">
        <div class="gauge-label">depth</div>
        <div class="gauge-track">
            <div class="gauge-fill" id="depthGaugeFill"></div>
        </div>
        <div class="gauge-reading" id="depthReading">0m</div>
    </div>

    <!-- PRESSURE GAUGE (right side) -->
    <div class="pressure-gauge" aria-hidden="true">
        <div class="gauge-label">psi</div>
        <div class="pressure-value" id="pressureValue">14.7</div>
        <div class="pressure-unit">atm</div>
    </div>

    <!-- SONAR HUD -->
    <div class="sonar-hud" aria-hidden="true">
        <div class="sonar-ring" id="sonarRing"></div>
        <div class="sonar-sweep" id="sonarSweep"></div>
        <div class="sonar-dot"></div>
    </div>

    <!-- STATUS BAR -->
    <div class="status-bar">
        <div class="status-left">
            <span class="status-indicator"></span>
            <span class="status-label">ops active</span>
            <span class="status-sep">|</span>
            <span class="status-coord" id="statusCoord">51.5074n 0.1278w</span>
        </div>
        <div class="status-right">
            <span class="status-o2">O2: <span id="o2Level">98</span>%</span>
            <span class="status-sep">|</span>
            <span class="status-time" id="statusTime">00:00:00</span>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-console" id="introConsole">
            <div class="intro-depth-counter">
                <span class="depth-label">current depth</span>
                <span class="depth-number" id="introDepth">0</span>
                <span class="depth-unit">meters</span>
            </div>
            <div class="intro-pressure-bar">
                <span class="pressure-label">hull pressure</span>
                <div class="pressure-track">
                    <div class="pressure-fill" id="introPressureFill"></div>
                </div>
                <span class="pressure-pct" id="introPressurePct">0%</span>
            </div>
            <pre class="intro-terminal" id="introTerminal"></pre>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="console-main" id="consoleMain">

        <!-- CONSOLE HEADER -->
        <section class="section console-header" data-section="header">
            <div class="console-title-bar">
                <span class="console-badge">submarine ops console v3.7</span>
                <span class="console-classification">classified // deep water ops</span>
            </div>
            <div class="header-grid">
                <div class="header-info">
                    <h1 class="captain-name">{siteMetadata.name.toLowerCase()}</h1>
                    <div class="captain-rank">captain // {siteMetadata.description}</div>
                    <div class="header-metrics">
                        <span class="metric-chip">loc: {siteMetadata.location.toLowerCase()}</span>
                        <span class="metric-chip active">status: submerged</span>
                        <span class="metric-chip depth">depth: 4,200m</span>
                    </div>
                    <div class="nav-links">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">[sonar.link//github]</a>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">[sonar.link//linkedin]</a>
                        <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">[sonar.link//bluesky]</a>
                        <a href={`mailto:${siteMetadata.email}`}>[comms.radio]</a>
                    </div>
                </div>
                <div class="periscope-viewport">
                    <div class="periscope-frame">
                        <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="140" height="140" />
                        <div class="periscope-overlay"></div>
                        <div class="periscope-crosshair"></div>
                    </div>
                    <span class="periscope-label">periscope // subj_001</span>
                </div>
            </div>

            <!-- Key metrics -->
            <div class="metrics-bar">
                {metrics.map(m => (
                    <div class="metric-block">
                        <span class="metric-value">{m.value.toLowerCase()}</span>
                        <span class="metric-label">{m.label.toLowerCase()}</span>
                    </div>
                ))}
            </div>
        </section>

        <hr class="depth-line" />

        <!-- CAPTAIN'S PROFILE (Summary) -->
        <section class="section reveal" data-section="summary">
            <div class="sec-head">
                <span class="tag sonar">[sonar.scan]</span>
                <span class="sec-title">captain's log</span>
                <span class="sec-depth">~~ 200m</span>
            </div>
            <p class="body-text">{summary.toLowerCase()}</p>
            <div class="industry-tags">
                <span class="industry-label">// operational waters</span>
                <div class="industry-list">
                    {industries.map(ind => (
                        <span class="industry-chip">{ind.toLowerCase()}</span>
                    ))}
                </div>
            </div>
        </section>

        <hr class="depth-line" />

        <!-- DEPTH CHART (Experience) -->
        <section class="section reveal" data-section="experience">
            <div class="sec-head">
                <span class="tag depth-tag">[depth.chart]</span>
                <span class="sec-title">dive record</span>
                <span class="sec-depth">~~ 800m</span>
            </div>
            {experience.map((exp, i) => (
                <div class="depth-block reveal">
                    <div class="depth-marker">
                        <span class="depth-level">{(i + 1) * 800}m</span>
                        <div class="depth-indicator"></div>
                    </div>
                    <div class="depth-content">
                        <div class="depth-top">
                            <span class="depth-company">{exp.company.toLowerCase()}</span>
                            <span class="depth-location">{exp.location.split(',')[0].toLowerCase()}</span>
                        </div>
                        {exp.roles.map(role => (
                            <div class="depth-role">
                                <div class="role-head">
                                    <span class="role-name">{role.title.toLowerCase()}</span>
                                    <span class="role-period">{role.period.toLowerCase()}</span>
                                </div>
                                {role.description && <p class="role-desc">{role.description.toLowerCase()}</p>}
                                {role.bullets && role.bullets.length > 0 && (
                                    <ul class="role-list">
                                        {role.bullets.map(b => <li>{b.toLowerCase()}</li>)}
                                    </ul>
                                )}
                            </div>
                        ))}
                    </div>
                </div>
            ))}
        </section>

        <hr class="depth-line" />

        <!-- ONBOARD SYSTEMS (Skills) -->
        <section class="section reveal" data-section="skills">
            <div class="sec-head">
                <span class="tag systems">[sys.check]</span>
                <span class="sec-title">onboard systems</span>
                <span class="sec-depth">~~ 2000m</span>
            </div>
            <div class="systems-container">
                <div class="system-group">
                    <span class="system-label">// technical_systems</span>
                    <div class="system-grid">
                        {skills.map((s, i) => (
                            <span class="system-module" style={`--i:${i}`}>{s.toLowerCase()}</span>
                        ))}
                    </div>
                </div>
                <div class="system-group">
                    <span class="system-label">// command_systems</span>
                    <div class="system-grid">
                        {managementSkills.map((s, i) => (
                            <span class="system-module command" style={`--i:${i}`}>{s.toLowerCase()}</span>
                        ))}
                    </div>
                </div>
                <div class="system-group">
                    <span class="system-label">// comms_array</span>
                    <div class="system-grid">
                        {languages.map((l, i) => (
                            <span class="system-module comms" style={`--i:${i}`}>{l.toLowerCase()}</span>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <hr class="depth-line" />

        <!-- MISSION LOGS (Engagements) -->
        <section class="section reveal" data-section="engagements">
            <div class="sec-head">
                <span class="tag mission">[ops.log]</span>
                <span class="sec-title">mission logs</span>
                <span class="sec-depth">~~ 3000m</span>
            </div>
            <div class="mission-grid">
                {engagements.map(eng => (
                    <div class="mission-card reveal">
                        <div class="mission-header">
                            <span class="mission-client">{eng.client}</span>
                            <span class="mission-sector">{eng.sector}</span>
                        </div>
                        <div class="mission-body">
                            <span class="mission-scope">scope: {eng.scope}</span>
                            <span class={`mission-impact ${eng.trend}`}>impact: {eng.impact}</span>
                        </div>
                        <div class="mission-status">
                            <span class={`status-dot ${eng.trend}`}></span>
                            <span class="status-text">{eng.trend === 'positive' ? 'mission success' : 'mission complete'}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <hr class="depth-line" />

        <!-- CREW CERTIFICATIONS (Education + Certs) -->
        <section class="section reveal" data-section="education">
            <div class="sec-head">
                <span class="tag cert">[crew.cert]</span>
                <span class="sec-title">crew certifications</span>
                <span class="sec-depth">~~ 3800m</span>
            </div>
            <div class="cert-groups">
                <div class="cert-group">
                    <span class="cert-label">// naval_academy</span>
                    {education.map(edu => (
                        <div class="cert-item">
                            <span class="cert-name">{edu.degree.toLowerCase()}</span>
                            <span class="cert-meta">{edu.institution.toLowerCase()} — {edu.period} — {edu.location.toLowerCase()}</span>
                            {edu.distinction && <span class="cert-badge">{edu.distinction.toLowerCase()}</span>}
                        </div>
                    ))}
                </div>
                <div class="cert-group">
                    <span class="cert-label">// officer_qualifications</span>
                    {certifications.map(c => (
                        <div class="cert-item">
                            <span class="cert-name">{c.toLowerCase()}</span>
                        </div>
                    ))}
                </div>
                <div class="cert-group">
                    <span class="cert-label">// advanced_training_log</span>
                    {continuousLearning.map(l => (
                        <div class="cert-item">
                            <span class="cert-name">{l.toLowerCase()}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <hr class="depth-line" />

        <!-- SURFACE FOOTER -->
        <section class="section surface-footer" data-section="footer">
            <div class="surface-ascii">~~~~~~~~~~~~~~~~~~~~~~~~~~~</div>
            <span>// initiating surface protocol</span>
            <span>// all systems nominal</span>
            <span>// submarine ops console — session end</span>
            <span class="cursor-blink">_</span>
        </section>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE + CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --abyss: #0a0f14;
        --sonar: #00cc66;
        --depth-blue: #0066cc;
        --warning: #ff3333;
        --hull: #1a2030;
        --amber: #ffaa00;
        --dim: #2a3545;
        --text-dim: #506070;
        --mono: 'Share Tech Mono', monospace;
        --heading: 'Exo 2', sans-serif;
        scrollbar-width: thin;
        scrollbar-color: var(--sonar) var(--abyss);
    }

    body {
        background: var(--abyss);
        color: #8899aa;
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--sonar); text-decoration: none; }
    a:hover { color: var(--depth-blue); text-decoration: underline; }

    ::selection { background: var(--sonar); color: var(--abyss); }

    /* =========================================
       WATER OVERLAY + CAUSTICS
       ========================================= */
    .water-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background: linear-gradient(
            180deg,
            rgba(0, 20, 40, 0.3) 0%,
            rgba(0, 10, 30, 0.5) 50%,
            rgba(0, 5, 15, 0.7) 100%
        );
        box-shadow: inset 0 0 200px rgba(0,0,0,0.6);
    }

    .caustics-overlay {
        position: fixed; inset: 0; z-index: 9998; pointer-events: none;
        opacity: 0.03;
        background:
            radial-gradient(ellipse at 20% 30%, rgba(0,102,204,0.3) 0%, transparent 50%),
            radial-gradient(ellipse at 70% 60%, rgba(0,204,102,0.2) 0%, transparent 40%),
            radial-gradient(ellipse at 50% 80%, rgba(0,102,204,0.2) 0%, transparent 45%);
        animation: causticsDrift 12s ease-in-out infinite alternate;
    }

    .bubble-layer {
        position: fixed; inset: 0; z-index: 9997; pointer-events: none;
        overflow: hidden;
    }

    /* =========================================
       DEPTH GAUGE (left side)
       ========================================= */
    .depth-gauge {
        position: fixed; left: 12px; top: 50%; transform: translateY(-50%);
        z-index: 10000; display: flex; flex-direction: column; align-items: center;
        gap: 6px; pointer-events: none;
    }
    .depth-gauge .gauge-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 2px; color: var(--sonar); opacity: 0.7;
    }
    .gauge-track {
        width: 4px; height: 120px; background: var(--hull);
        border-radius: 2px; position: relative; overflow: hidden;
        border: 1px solid rgba(0,204,102,0.15);
    }
    .gauge-fill {
        position: absolute; bottom: 0; width: 100%; height: 0%;
        background: linear-gradient(0deg, var(--sonar), var(--depth-blue));
        border-radius: 2px; transition: height 0.3s ease;
    }
    .gauge-reading {
        font-family: var(--mono); font-size: 10px; color: var(--sonar);
        font-variant-numeric: tabular-nums;
    }

    /* =========================================
       PRESSURE GAUGE (right side)
       ========================================= */
    .pressure-gauge {
        position: fixed; right: 12px; top: 50%; transform: translateY(-50%);
        z-index: 10000; display: flex; flex-direction: column; align-items: center;
        gap: 4px; pointer-events: none;
    }
    .pressure-gauge .gauge-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 2px; color: var(--amber); opacity: 0.7;
    }
    .pressure-value {
        font-family: var(--mono); font-size: 14px; color: var(--amber);
        font-weight: 700; font-variant-numeric: tabular-nums;
    }
    .pressure-unit {
        font-family: var(--mono); font-size: 8px; color: var(--text-dim);
        text-transform: uppercase; letter-spacing: 1px;
    }

    /* =========================================
       SONAR HUD (top right corner)
       ========================================= */
    .sonar-hud {
        position: fixed; top: 50px; right: 50px; z-index: 10000;
        width: 60px; height: 60px; pointer-events: none;
    }
    .sonar-ring {
        position: absolute; inset: 0;
        border: 1px solid rgba(0,204,102,0.2);
        border-radius: 50%;
    }
    .sonar-ring::before, .sonar-ring::after {
        content: ''; position: absolute; border-radius: 50%;
        border: 1px solid rgba(0,204,102,0.1);
    }
    .sonar-ring::before {
        inset: 8px;
    }
    .sonar-ring::after {
        inset: 18px;
    }
    .sonar-sweep {
        position: absolute; top: 50%; left: 50%;
        width: 50%; height: 1px;
        background: linear-gradient(90deg, var(--sonar), transparent);
        transform-origin: left center;
        animation: sonarSweep 3s linear infinite;
        opacity: 0.6;
    }
    .sonar-dot {
        position: absolute; top: 50%; left: 50%;
        width: 4px; height: 4px;
        background: var(--sonar);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 6px var(--sonar);
    }

    /* =========================================
       STATUS BAR
       ========================================= */
    .status-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 16px;
        font-size: 11px; text-transform: lowercase; letter-spacing: 1px;
        color: var(--text-dim);
        pointer-events: none;
        font-family: var(--mono);
        background: linear-gradient(180deg, rgba(10,15,20,0.9) 0%, transparent 100%);
    }
    .status-left, .status-right { display: flex; align-items: center; gap: 8px; }
    .status-sep { color: var(--dim); }
    .status-indicator {
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--sonar);
        animation: pulse 2s ease-in-out infinite;
        box-shadow: 0 0 6px var(--sonar);
    }
    .status-label { color: var(--sonar); font-weight: 700; }
    .status-o2 { color: var(--sonar); }
    .status-time { color: var(--text-dim); font-variant-numeric: tabular-nums; }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--abyss);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.5s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }
    .intro-console {
        max-width: 500px; width: 100%;
        display: flex; flex-direction: column; gap: 20px; align-items: center;
    }
    .intro-depth-counter {
        display: flex; flex-direction: column; align-items: center; gap: 4px;
    }
    .depth-label {
        font-family: var(--mono); font-size: 10px; text-transform: uppercase;
        letter-spacing: 3px; color: var(--text-dim);
    }
    .depth-number {
        font-family: var(--heading); font-size: 64px; font-weight: 900;
        color: var(--sonar); line-height: 1;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 0 20px rgba(0,204,102,0.4);
    }
    .depth-unit {
        font-family: var(--mono); font-size: 11px; text-transform: uppercase;
        letter-spacing: 4px; color: var(--depth-blue);
    }
    .intro-pressure-bar {
        width: 100%; display: flex; align-items: center; gap: 12px;
    }
    .pressure-label {
        font-family: var(--mono); font-size: 9px; text-transform: uppercase;
        letter-spacing: 1px; color: var(--text-dim); white-space: nowrap;
    }
    .pressure-track {
        flex: 1; height: 6px; background: var(--hull);
        border-radius: 3px; overflow: hidden;
        border: 1px solid rgba(0,204,102,0.1);
    }
    .pressure-fill {
        height: 100%; width: 0%; border-radius: 3px;
        background: linear-gradient(90deg, var(--depth-blue), var(--sonar));
        transition: width 0.1s linear;
    }
    .pressure-pct {
        font-family: var(--mono); font-size: 10px; color: var(--sonar);
        min-width: 30px; text-align: right;
    }
    .intro-terminal {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--sonar);
        line-height: 1.8;
        width: 100%;
        white-space: pre-wrap;
        word-break: break-all;
        opacity: 0.9;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .console-main {
        max-width: 820px;
        margin: 0 auto;
        padding: 60px 24px 120px;
        opacity: 0;
        transition: opacity 0.6s ease 0.2s;
    }
    .console-main.visible { opacity: 1; }

    /* =========================================
       SECTIONS
       ========================================= */
    .section { margin-bottom: 0; }

    .sec-head {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 14px;
        font-size: 11px; text-transform: lowercase; letter-spacing: 1.5px;
    }
    .sec-title { color: #667788; font-family: var(--heading); font-weight: 600; }
    .sec-depth { margin-left: auto; color: var(--depth-blue); font-size: 10px; }

    .tag {
        padding: 2px 8px;
        font-size: 9px; font-weight: 700; letter-spacing: 1px;
        border: 1px solid;
    }
