<script>
    /* =========================================
       STARFIELD CANVAS
       ========================================= */
    (function initStarfield() {
        const canvas = document.getElementById('starfield') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let stars: { x: number; y: number; r: number; baseAlpha: number; phase: number; speed: number }[] = [];
        let animFrame = 0;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            generateStars();
        }

        function generateStars() {
            const count = Math.max(250, Math.floor((canvas.width * canvas.height) / 4000));
            stars = [];
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.5 + 0.3,
                    baseAlpha: Math.random() * 0.6 + 0.2,
                    phase: Math.random() * Math.PI * 2,
                    speed: Math.random() * 0.01 + 0.003,
                });
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            const time = Date.now() * 0.001;

            for (const s of stars) {
                const alpha = s.baseAlpha + Math.sin(time * s.speed * 10 + s.phase) * 0.3;
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(240, 240, 255, ${Math.max(0.05, Math.min(1, alpha))})`;
                ctx.fill();
            }

            animFrame = requestAnimationFrame(draw);
        }

        resize();
        draw();
        window.addEventListener('resize', resize);
    })();

    /* =========================================
       SHOOTING STAR
       ========================================= */
    (function initShootingStar() {
        const el = document.getElementById('shootingStar');
        if (!el) return;

        function trigger() {
            const startX = Math.random() * window.innerWidth * 0.6;
            const startY = Math.random() * window.innerHeight * 0.3;

            el.style.left = startX + 'px';
            el.style.top = startY + 'px';
            el.style.width = (80 + Math.random() * 80) + 'px';
            el.style.animation = 'none';
            el.offsetHeight; /* reflow */
            el.style.animation = `shootAcross ${1.5 + Math.random()}s ease-out forwards`;

            schedule();
        }

        function schedule() {
            setTimeout(trigger, 6000 + Math.random() * 12000);
        }

        schedule();
    })();

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    (function initIntro() {
        const intro = document.getElementById('intro');
        const catalog = document.getElementById('catalog');
        const viewfinder = document.getElementById('viewfinder');
        const introText = document.getElementById('introText');
        const introStarfield = document.getElementById('introStarfield');

        if (!intro || !catalog || !viewfinder || !introText || !introStarfield) return;

        /* check sessionStorage */
        if (sessionStorage.getItem('observatory-intro') === 'done') {
            intro.style.display = 'none';
            catalog.classList.add('visible');
            return;
        }

        let skipped = false;

        function skip() {
            if (skipped) return;
            skipped = true;
            sessionStorage.setItem('observatory-intro', 'done');
            intro.classList.add('hidden');
            setTimeout(() => {
                intro.style.display = 'none';
                catalog.classList.add('visible');
            }, 800);
        }

        intro.addEventListener('click', skip);
        document.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter') {
                e.preventDefault();
                skip();
            }
        });

        /* Phase 1: Stars fade in */
        const starCount = 60;
        for (let i = 0; i < starCount; i++) {
            const star = document.createElement('div');
            star.className = 'intro-star';
            star.style.left = Math.random() * 100 + '%';
            star.style.top = Math.random() * 100 + '%';
            star.style.width = (1 + Math.random() * 2) + 'px';
            star.style.height = star.style.width;
            star.style.animationDelay = (Math.random() * 1500) + 'ms';
            introStarfield.appendChild(star);
        }

        /* Phase 2: Viewfinder appears */
        setTimeout(() => {
            if (skipped) return;
            viewfinder.classList.add('visible');
        }, 1200);

        /* Phase 3: Text typewriter */
        const lines = [
            'CELESTIAL OBJECT CATALOG \u2014 ENTRY #D4N-13L3',
            'OBJECT: D\'AGNELLI SYSTEM \u2014 CLASS: G2V (MAIN SEQUENCE)',
            'OBSERVATORY: LONDON STATION',
            'OBSERVATION BEGINS...',
        ];

        let lineIndex = 0;
        let charIndex = 0;
        let currentText = '';
        const typeDelay = 30;
        const lineDelay = 400;

        function typeWriter() {
            if (skipped) return;

            if (lineIndex >= lines.length) {
                /* Phase 4: Viewfinder expand & transition */
                setTimeout(() => {
                    if (skipped) return;
                    viewfinder.classList.add('expand');
                    setTimeout(skip, 800);
                }, 600);
                return;
            }

            if (charIndex < lines[lineIndex].length) {
                currentText += lines[lineIndex][charIndex];
                introText.textContent = currentText;
                charIndex++;
                setTimeout(typeWriter, typeDelay);
            } else {
                currentText += '\n';
                lineIndex++;
                charIndex = 0;
                setTimeout(typeWriter, lineDelay);
            }
        }

        setTimeout(() => {
            if (skipped) return;
            typeWriter();
        }, 2000);
    })();

    /* =========================================
       SCROLL REVEAL (IntersectionObserver)
       ========================================= */
    (function initReveal() {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('in-view');
                    }
                });
            },
            { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    })();

    /* =========================================
       CONSTELLATION LINES (connect section markers)
       ========================================= */
    (function initConstellations() {
        const svg = document.getElementById('constellationSvg') as unknown as SVGSVGElement;
        if (!svg) return;

        function drawLines() {
            svg.innerHTML = '';
            const markers = document.querySelectorAll('.sec-marker');
            if (markers.length < 2) return;

            const points: { x: number; y: number }[] = [];
            markers.forEach((m) => {
                const rect = m.getBoundingClientRect();
                points.push({
                    x: rect.left + rect.width / 2 + window.scrollX,
                    y: rect.top + rect.height / 2 + window.scrollY,
                });
            });

            svg.setAttribute('width', document.documentElement.scrollWidth.toString());
            svg.setAttribute('height', document.documentElement.scrollHeight.toString());
            svg.style.position = 'absolute';
            svg.style.top = '0';
            svg.style.left = '0';
            svg.style.width = document.documentElement.scrollWidth + 'px';
            svg.style.height = document.documentElement.scrollHeight + 'px';

            for (let i = 0; i < points.length - 1; i++) {
                const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                line.setAttribute('x1', points[i].x.toString());
                line.setAttribute('y1', points[i].y.toString());
                line.setAttribute('x2', points[i + 1].x.toString());
                line.setAttribute('y2', points[i + 1].y.toString());
                line.setAttribute('stroke', 'rgba(106, 106, 138, 0.12)');
                line.setAttribute('stroke-width', '1');
                line.setAttribute('stroke-dasharray', '4,8');
                svg.appendChild(line);
            }

            /* dots at each point */
            points.forEach((p) => {
                const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                circle.setAttribute('cx', p.x.toString());
                circle.setAttribute('cy', p.y.toString());
                circle.setAttribute('r', '2');
                circle.setAttribute('fill', 'rgba(255, 215, 0, 0.3)');
                svg.appendChild(circle);
            });
        }

        /* Draw after intro finishes and content is visible */
        const catalog = document.getElementById('catalog');
        if (catalog) {
            const mo = new MutationObserver(() => {
                if (catalog.classList.contains('visible')) {
                    setTimeout(drawLines, 300);
                    mo.disconnect();
                }
            });
            mo.observe(catalog, { attributes: true, attributeFilter: ['class'] });

            /* Also draw if already visible */
            if (catalog.classList.contains('visible')) {
                setTimeout(drawLines, 300);
            }
        }

        let resizeTimer: ReturnType<typeof setTimeout>;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(drawLines, 200);
        });

        window.addEventListener('scroll', () => {
            /* Redraw on scroll since positions are absolute */
        }, { passive: true });
    })();
</script>
