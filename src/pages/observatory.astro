---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Observatory Catalog</title>
    <meta name="description" content="Celestial Object Catalog — Daniele D'Agnelli's career mapped as an astronomical observation log. Stars, constellations, and cosmic phenomena charting 15+ years of digital transformation." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/observatory" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Observatory Catalog" />
    <meta property="og:description" content="Astronomical observation log: 15+ years of career mapped as celestial objects. AI, cybersecurity, and digital transformation charted across the cosmos." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/observatory" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Observatory Catalog" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Observatory Catalog" />
    <meta name="twitter:description" content="Celestial object catalog: 15+ years charted as stars, constellations, and cosmic phenomena." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations. Specializing in AI deployments and cybersecurity for global enterprises."
    })} />

    <!-- Structured Data (WebSite) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "description": "Personal website of Daniele D'Agnelli — Senior Engagement Manager specializing in AI and cybersecurity."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- STARFIELD CANVAS -->
    <canvas class="starfield" id="starfield" aria-hidden="true"></canvas>

    <!-- NEBULA PATCHES -->
    <div class="nebula-layer" aria-hidden="true">
        <div class="nebula nebula-1"></div>
        <div class="nebula nebula-2"></div>
        <div class="nebula nebula-3"></div>
    </div>

    <!-- COORDINATE GRID -->
    <div class="coord-grid" aria-hidden="true"></div>

    <!-- SHOOTING STAR -->
    <div class="shooting-star-container" aria-hidden="true">
        <div class="shooting-star" id="shootingStar"></div>
    </div>

    <!-- CONSTELLATION LINES (drawn via JS) -->
    <svg class="constellation-svg" id="constellationSvg" aria-hidden="true"></svg>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-starfield" id="introStarfield"></div>
        <div class="viewfinder" id="viewfinder">
            <div class="viewfinder-ring">
                <div class="crosshair crosshair-h"></div>
                <div class="crosshair crosshair-v"></div>
                <div class="tick tick-n"></div>
                <div class="tick tick-e"></div>
                <div class="tick tick-s"></div>
                <div class="tick tick-w"></div>
            </div>
        </div>
        <div class="intro-text" id="introText"></div>
        <div class="intro-skip">click / esc / space to skip</div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="catalog" id="catalog">

        <!-- CATALOG HEADER -->
        <section class="section catalog-header" data-section="header">
            <div class="header-grid">
                <div class="celestial-body">
                    <div class="body-glow"></div>
                    <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="160" height="160" class="body-image" />
                    <div class="body-corona"></div>
                    <span class="body-label">OBJ #D4N-13L3</span>
                </div>
                <div class="header-info">
                    <div class="catalog-id">CELESTIAL OBJECT CATALOG</div>
                    <h1 class="object-name">{siteMetadata.name}</h1>
                    <div class="object-class">CLASS G2V — MAIN SEQUENCE STAR</div>
                    <div class="data-readouts">
                        {metrics.map((m, i) => (
                            <div class="readout">
                                <span class="readout-value">{m.value}</span>
                                <span class="readout-label">{m.label}</span>
                            </div>
                        ))}
                    </div>
                    <div class="coord-line">
                        <span class="coord">RA 51.5074 N</span>
                        <span class="coord">DEC 0.1278 W</span>
                        <span class="coord">DIST: LONDON STATION</span>
                    </div>
                    <div class="link-row">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener" class="obs-link">github</a>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener" class="obs-link">linkedin</a>
                        <a href={`mailto:${siteMetadata.email}`} class="obs-link">comms</a>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- OBJECT CLASSIFICATION (summary) -->
        <section class="section reveal" id="sec-classification" data-section="summary">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Object Classification</h2>
                <span class="sec-coord">RA 00h 00m</span>
            </div>
            <div class="classification-box">
                <p class="body-text">{summary}</p>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- ORBITAL HISTORY (experience) -->
        <section class="section reveal" id="sec-orbital" data-section="experience">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Orbital History</h2>
                <span class="sec-coord">RA 06h 45m</span>
            </div>
            <div class="orbital-timeline">
                {experience.map((exp, i) => (
                    <div class="orbit-entry reveal">
                        <div class="orbit-marker">
                            <div class="orbit-dot"></div>
                            <div class="orbit-line"></div>
                        </div>
                        <div class="orbit-content">
                            <div class="orbit-header">
                                <span class="orbit-body-name">{exp.company}</span>
                                <span class="orbit-location">{exp.location}</span>
                            </div>
                            {exp.roles.map(role => (
                                <div class="orbit-phase">
                                    <div class="phase-head">
                                        <span class="phase-title">{role.title}</span>
                                        <span class="phase-period">{role.period}</span>
                                    </div>
                                    {role.description && <p class="phase-desc">{role.description}</p>}
                                    {role.bullets && role.bullets.length > 0 && (
                                        <ul class="phase-observations">
                                            {role.bullets.map(b => <li>{b}</li>)}
                                        </ul>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- SPECTRAL ANALYSIS (skills) -->
        <section class="section reveal" id="sec-spectral" data-section="skills">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Spectral Analysis</h2>
                <span class="sec-coord">RA 12h 30m</span>
            </div>
            <div class="spectrum-container">
                <div class="spectrum-bands">
                    {skills.map((s, i) => (
                        <div class="spectrum-line" style={`--i:${i}; --total:${skills.length}`}>
                            <span class="spectrum-label">{s}</span>
                            <div class="spectrum-bar">
                                <div class="spectrum-fill"></div>
                                <div class="spectrum-glow"></div>
                            </div>
                            <span class="spectrum-wavelength">{(380 + (i * 20)).toString()}nm</span>
                        </div>
                    ))}
                </div>
            </div>
            <div class="management-spectrum">
                <h3 class="sub-heading">Command Frequencies</h3>
                <div class="freq-grid">
                    {managementSkills.map((ms, i) => (
                        <span class="freq-chip" style={`--i:${i}`}>{ms}</span>
                    ))}
                </div>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- NOTABLE OBSERVATIONS (engagements) -->
        <section class="section reveal" id="sec-observations" data-section="engagements">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Notable Observations</h2>
                <span class="sec-coord">RA 16h 15m</span>
            </div>
            <div class="observation-log">
                {engagements.map((eng, i) => (
                    <div class="log-entry reveal">
                        <div class="log-number">OBS-{(i + 1).toString().padStart(3, '0')}</div>
                        <div class="log-details">
                            <div class="log-row">
                                <span class="log-field">TARGET</span>
                                <span class="log-value">{eng.client}</span>
                            </div>
                            <div class="log-row">
                                <span class="log-field">SECTOR</span>
                                <span class="log-value">{eng.sector}</span>
                            </div>
                            <div class="log-row">
                                <span class="log-field">SCOPE</span>
                                <span class="log-value">{eng.scope}</span>
                            </div>
                            <div class="log-row">
                                <span class="log-field">IMPACT</span>
                                <span class={`log-value log-impact ${eng.trend}`}>{eng.impact}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- CALIBRATION RECORDS (education) -->
        <section class="section reveal" id="sec-calibration" data-section="education">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Calibration Records</h2>
                <span class="sec-coord">RA 19h 00m</span>
            </div>
            <div class="calibration-entries">
                {education.map((edu, i) => (
                    <div class="cal-entry reveal">
                        <div class="cal-icon">
                            <div class="cal-ring"></div>
                        </div>
                        <div class="cal-info">
                            <span class="cal-degree">{edu.degree}</span>
                            <span class="cal-institution">{edu.institution} — {edu.location}</span>
                            <span class="cal-period">{edu.period}</span>
                            {edu.distinction && <span class="cal-distinction">{edu.distinction}</span>}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- VERIFIED DISCOVERIES (certifications) -->
        <section class="section reveal" id="sec-discoveries" data-section="certifications">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Verified Discoveries</h2>
                <span class="sec-coord">RA 21h 30m</span>
            </div>
            <div class="discovery-grid">
                {certifications.map((c, i) => (
                    <div class="discovery-card reveal" style={`--i:${i}`}>
                        <div class="discovery-star-icon"></div>
                        <span class="discovery-name">{c}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- ONGOING SURVEY (continuousLearning) -->
        <section class="section reveal" id="sec-survey" data-section="training">
            <div class="sec-head">
                <span class="sec-marker"></span>
                <h2 class="sec-title">Ongoing Survey</h2>
                <span class="sec-coord">RA 23h 45m</span>
            </div>
            <div class="survey-list">
                {continuousLearning.map((item, i) => (
                    <div class="survey-item reveal" style={`--i:${i}`}>
                        <span class="survey-dot"></span>
                        <span class="survey-text">{item}</span>
                    </div>
                ))}
            </div>
            <div class="languages-block">
                <h3 class="sub-heading">Communication Frequencies</h3>
                <div class="lang-chips">
                    {languages.map(l => (
                        <span class="lang-chip">{l}</span>
                    ))}
                </div>
            </div>
            <div class="industries-block">
                <h3 class="sub-heading">Observed Sectors</h3>
                <div class="sector-chips">
                    {industries.map((ind, i) => (
                        <span class="sector-chip" style={`--i:${i}`}>{ind}</span>
                    ))}
                </div>
            </div>
        </section>

        <div class="section-divider" aria-hidden="true">
            <span class="divider-star"></span>
        </div>

        <!-- END OF OBSERVATION -->
        <section class="section end-observation" data-section="footer">
            <div class="end-text">
                <span>END OF OBSERVATION LOG</span>
                <span>TELESCOPE RETURNING TO STANDBY</span>
                <span class="cursor-blink">_</span>
            </div>
        </section>

    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & VARIABLES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --cosmos: #050510;
        --nebula: #2a1a4a;
        --star-white: #f0f0ff;
        --blue-giant: #4a8aff;
        --red-giant: #ff4a4a;
        --solar-gold: #ffd700;
        --dim-star: #6a6a8a;
        --nebula-blue: #1a2a5a;
        --nebula-rose: #3a1a3a;
        --sans: 'Space Grotesk', system-ui, sans-serif;
        --mono: 'IBM Plex Mono', 'Courier New', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--blue-giant) var(--cosmos);
    }

    body {
        background: var(--cosmos);
        color: var(--star-white);
        font-family: var(--sans);
        font-size: 15px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--blue-giant); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--solar-gold); }

    ::selection { background: var(--blue-giant); color: var(--cosmos); }

    /* =========================================
       STARFIELD CANVAS
       ========================================= */
    .starfield {
        position: fixed;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* =========================================
       NEBULA PATCHES
       ========================================= */
    .nebula-layer {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
    }

    .nebula {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
    }

    .nebula-1 {
        width: 600px; height: 600px;
        top: -100px; right: -150px;
        background: radial-gradient(circle, var(--nebula) 0%, transparent 70%);
    }

    .nebula-2 {
        width: 500px; height: 500px;
        top: 40%; left: -200px;
        background: radial-gradient(circle, var(--nebula-blue) 0%, transparent 70%);
    }

    .nebula-3 {
        width: 450px; height: 450px;
        bottom: 10%; right: 10%;
        background: radial-gradient(circle, var(--nebula-rose) 0%, transparent 70%);
    }

    /* =========================================
       COORDINATE GRID
       ========================================= */
    .coord-grid {
        position: fixed;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        opacity: 0.04;
        background-image:
            linear-gradient(var(--dim-star) 1px, transparent 1px),
            linear-gradient(90deg, var(--dim-star) 1px, transparent 1px);
        background-size: 80px 80px;
    }

    /* =========================================
       SHOOTING STAR
       ========================================= */
    .shooting-star-container {
        position: fixed;
        inset: 0;
        z-index: 3;
        pointer-events: none;
        overflow: hidden;
    }

    .shooting-star {
        position: absolute;
        width: 120px;
        height: 2px;
        background: linear-gradient(90deg, var(--star-white), transparent);
        border-radius: 2px;
        opacity: 0;
        transform: rotate(-35deg);
        box-shadow: 0 0 6px 1px rgba(240, 240, 255, 0.4);
    }

    @keyframes shootAcross {
        0% { opacity: 0; transform: translate(0, 0) rotate(-35deg); }
        5% { opacity: 1; }
        60% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(100vw + 200px), calc(60vh)) rotate(-35deg); }
    }

    /* =========================================
       CONSTELLATION SVG
       ========================================= */
    .constellation-svg {
        position: fixed;
        inset: 0;
        z-index: 4;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: var(--cosmos);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease;
        cursor: pointer;
    }

    .intro.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .intro-starfield {
        position: absolute;
        inset: 0;
    }

    .intro-starfield .intro-star {
        position: absolute;
        width: 2px;
        height: 2px;
        background: var(--star-white);
        border-radius: 50%;
        opacity: 0;
        animation: starFadeIn 1s ease forwards;
    }

    @keyframes starFadeIn {
        to { opacity: 1; }
    }

    .viewfinder {
        position: relative;
        width: 240px;
        height: 240px;
        z-index: 2;
        opacity: 0;
        transform: scale(0.5);
        transition: all 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .viewfinder.visible {
        opacity: 1;
        transform: scale(1);
    }

    .viewfinder.expand {
        transform: scale(8);
        opacity: 0;
    }

    .viewfinder-ring {
        width: 100%;
        height: 100%;
        border: 2px solid var(--dim-star);
        border-radius: 50%;
        position: relative;
    }

    .crosshair {
        position: absolute;
        background: var(--dim-star);
    }

    .crosshair-h {
        width: 100%;
        height: 1px;
        top: 50%;
        left: 0;
    }

    .crosshair-v {
        width: 1px;
        height: 100%;
        top: 0;
        left: 50%;
    }

    .tick {
        position: absolute;
        width: 1px;
        height: 12px;
        background: var(--blue-giant);
    }

    .tick-n { top: -6px; left: 50%; }
    .tick-s { bottom: -6px; left: 50%; }
    .tick-e { top: 50%; right: -6px; width: 12px; height: 1px; }
    .tick-w { top: 50%; left: -6px; width: 12px; height: 1px; }

    .intro-text {
        position: relative;
        z-index: 3;
        margin-top: 32px;
        font-family: var(--mono);
        font-size: 13px;
        color: var(--blue-giant);
        text-align: center;
        line-height: 2;
        white-space: pre-line;
        min-height: 120px;
    }

    .intro-skip {
        position: absolute;
        bottom: 32px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--dim-star);
        letter-spacing: 1px;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .catalog {
        position: relative;
        z-index: 5;
        max-width: 900px;
        margin: 0 auto;
        padding: 60px 24px 80px;
        opacity: 0;
        transition: opacity 0.8s ease;
    }

    .catalog.visible {
        opacity: 1;
    }

    .section {
        margin-bottom: 48px;
    }

    /* Reveal animation */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* =========================================
       SECTION DIVIDER
       ========================================= */
    .section-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 0;
        position: relative;
    }

    .section-divider::before,
    .section-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--dim-star), transparent);
    }

    .divider-star {
        display: block;
        width: 6px;
        height: 6px;
        background: var(--solar-gold);
        border-radius: 50%;
        margin: 0 16px;
        box-shadow: 0 0 8px var(--solar-gold);
        animation: twinkle 3s ease-in-out infinite;
    }

    @keyframes twinkle {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    /* =========================================
       CATALOG HEADER
       ========================================= */
    .header-grid {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 40px;
        align-items: center;
    }

    .celestial-body {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .body-glow {
        position: absolute;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(74, 138, 255, 0.3) 0%, transparent 70%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -55%);
        animation: pulseGlow 4s ease-in-out infinite;
    }

    @keyframes pulseGlow {
        0%, 100% { transform: translate(-50%, -55%) scale(1); opacity: 0.8; }
