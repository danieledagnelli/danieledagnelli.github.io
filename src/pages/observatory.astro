</html>

<style>
    /* =========================================
       BASE & VARIABLES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --cosmos: #050510;
        --nebula: #2a1a4a;
        --star-white: #f0f0ff;
        --blue-giant: #4a8aff;
        --red-giant: #ff4a4a;
        --solar-gold: #ffd700;
        --dim-star: #6a6a8a;
        --nebula-blue: #1a2a5a;
        --nebula-rose: #3a1a3a;
        --sans: 'Space Grotesk', system-ui, sans-serif;
        --mono: 'IBM Plex Mono', 'Courier New', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--blue-giant) var(--cosmos);
    }

    body {
        background: var(--cosmos);
        color: var(--star-white);
        font-family: var(--sans);
        font-size: 15px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--blue-giant); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--solar-gold); }

    ::selection { background: var(--blue-giant); color: var(--cosmos); }

    /* =========================================
       STARFIELD CANVAS
       ========================================= */
    .starfield {
        position: fixed;
        inset: 0;
        z-index: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* =========================================
       NEBULA PATCHES
       ========================================= */
    .nebula-layer {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
    }

    .nebula {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
    }

    .nebula-1 {
        width: 600px; height: 600px;
        top: -100px; right: -150px;
        background: radial-gradient(circle, var(--nebula) 0%, transparent 70%);
    }

    .nebula-2 {
        width: 500px; height: 500px;
        top: 40%; left: -200px;
        background: radial-gradient(circle, var(--nebula-blue) 0%, transparent 70%);
    }

    .nebula-3 {
        width: 450px; height: 450px;
        bottom: 10%; right: 10%;
        background: radial-gradient(circle, var(--nebula-rose) 0%, transparent 70%);
    }

    /* =========================================
       COORDINATE GRID
       ========================================= */
    .coord-grid {
        position: fixed;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        opacity: 0.04;
        background-image:
            linear-gradient(var(--dim-star) 1px, transparent 1px),
            linear-gradient(90deg, var(--dim-star) 1px, transparent 1px);
        background-size: 80px 80px;
    }

    /* =========================================
       SHOOTING STAR
       ========================================= */
    .shooting-star-container {
        position: fixed;
        inset: 0;
        z-index: 3;
        pointer-events: none;
        overflow: hidden;
    }

    .shooting-star {
        position: absolute;
        width: 120px;
        height: 2px;
        background: linear-gradient(90deg, var(--star-white), transparent);
        border-radius: 2px;
        opacity: 0;
        transform: rotate(-35deg);
        box-shadow: 0 0 6px 1px rgba(240, 240, 255, 0.4);
    }

    @keyframes shootAcross {
        0% { opacity: 0; transform: translate(0, 0) rotate(-35deg); }
        5% { opacity: 1; }
        60% { opacity: 1; }
        100% { opacity: 0; transform: translate(calc(100vw + 200px), calc(60vh)) rotate(-35deg); }
    }

    /* =========================================
       CONSTELLATION SVG
       ========================================= */
    .constellation-svg {
        position: fixed;
        inset: 0;
        z-index: 4;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: var(--cosmos);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease;
        cursor: pointer;
    }

    .intro.hidden {
        opacity: 0;
        pointer-events: none;
    }

    .intro-starfield {
        position: absolute;
        inset: 0;
    }

    .intro-starfield .intro-star {
        position: absolute;
        width: 2px;
        height: 2px;
        background: var(--star-white);
        border-radius: 50%;
        opacity: 0;
        animation: starFadeIn 1s ease forwards;
    }

    @keyframes starFadeIn {
        to { opacity: 1; }
    }

    .viewfinder {
        position: relative;
        width: 240px;
        height: 240px;
        z-index: 2;
        opacity: 0;
        transform: scale(0.5);
        transition: all 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .viewfinder.visible {
        opacity: 1;
        transform: scale(1);
    }

    .viewfinder.expand {
        transform: scale(8);
        opacity: 0;
    }

    .viewfinder-ring {
        width: 100%;
        height: 100%;
        border: 2px solid var(--dim-star);
        border-radius: 50%;
        position: relative;
    }

    .crosshair {
        position: absolute;
        background: var(--dim-star);
    }

    .crosshair-h {
        width: 100%;
        height: 1px;
        top: 50%;
        left: 0;
    }

    .crosshair-v {
        width: 1px;
        height: 100%;
        top: 0;
        left: 50%;
    }

    .tick {
        position: absolute;
        width: 1px;
        height: 12px;
        background: var(--blue-giant);
    }

    .tick-n { top: -6px; left: 50%; }
    .tick-s { bottom: -6px; left: 50%; }
    .tick-e { top: 50%; right: -6px; width: 12px; height: 1px; }
    .tick-w { top: 50%; left: -6px; width: 12px; height: 1px; }

    .intro-text {
        position: relative;
        z-index: 3;
        margin-top: 32px;
        font-family: var(--mono);
        font-size: 13px;
        color: var(--blue-giant);
        text-align: center;
        line-height: 2;
        white-space: pre-line;
        min-height: 120px;
    }

    .intro-skip {
        position: absolute;
        bottom: 32px;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--dim-star);
        letter-spacing: 1px;
    }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .catalog {
        position: relative;
        z-index: 5;
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.8s ease;
    }

    .catalog.visible {
        opacity: 1;
    }

    /* =========================================
       OBSERVATION NARRATIVE
       ========================================= */
    .obs-narrative {
        max-width: 620px;
        padding: 1.5rem;
        font-family: var(--mono);
        color: rgba(240, 240, 255, 0.85);
    }

    .obs-title {
        font-size: 1rem;
        text-align: center;
        margin-bottom: 0.2rem;
        font-family: var(--mono);
        font-weight: 600;
        color: var(--solar-gold);
    }

    .obs-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
    }

    .catalog-title {
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.5rem;
        font-family: var(--mono);
        font-weight: 500;
        color: var(--blue-giant);
    }

    .star-entry {
        font-size: 0.78rem;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }

    .observer-info {
        font-size: 0.7rem;
        opacity: 0.7;
        margin: 0.8rem 0;
    }

    .obs-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 0.8rem;
    }

    .obs-footer a {
        text-decoration: none;
    }

    /* (unused legacy styles removed) */

    /* =========================================
       RESPONSIVE: 768px
       ========================================= */
    @media (max-width: 768px) {
        .star-entry {
            font-size: 0.72rem;
        }

        .viewfinder {
            width: 180px;
            height: 180px;
        }

        .nebula-1 { width: 400px; height: 400px; }
        .nebula-2 { width: 350px; height: 350px; }
        .nebula-3 { width: 300px; height: 300px; }
    }

    /* =========================================
       RESPONSIVE: 480px
       ========================================= */
    @media (max-width: 480px) {
        .viewfinder {
            width: 140px;
            height: 140px;
        }

        .intro-text {
            font-size: 11px;
            padding: 0 16px;
        }
    }

    /* =========================================
       REDUCED MOTION
       ========================================= */
    @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }

        .shooting-star {
            display: none;
        }
    }
</style>

<script>
    /* =========================================
       STARFIELD CANVAS
       ========================================= */
    (function initStarfield() {
        const canvas = document.getElementById('starfield') as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let stars: { x: number; y: number; r: number; baseAlpha: number; phase: number; speed: number }[] = [];
        let animFrame = 0;

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            generateStars();
        }

        function generateStars() {
            const count = Math.max(250, Math.floor((canvas.width * canvas.height) / 4000));
            stars = [];
            for (let i = 0; i < count; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    r: Math.random() * 1.5 + 0.3,
                    baseAlpha: Math.random() * 0.6 + 0.2,
                    phase: Math.random() * Math.PI * 2,
                    speed: Math.random() * 0.01 + 0.003,
                });
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            const time = Date.now() * 0.001;

            for (const s of stars) {
                const alpha = s.baseAlpha + Math.sin(time * s.speed * 10 + s.phase) * 0.3;
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(240, 240, 255, ${Math.max(0.05, Math.min(1, alpha))})`;
                ctx.fill();
            }

            animFrame = requestAnimationFrame(draw);
        }

        resize();
        draw();
        window.addEventListener('resize', resize);
    })();

    /* =========================================
       SHOOTING STAR
       ========================================= */
    (function initShootingStar() {
        const el = document.getElementById('shootingStar');
        if (!el) return;

        function trigger() {
            const startX = Math.random() * window.innerWidth * 0.6;
            const startY = Math.random() * window.innerHeight * 0.3;

            el.style.left = startX + 'px';
            el.style.top = startY + 'px';
            el.style.width = (80 + Math.random() * 80) + 'px';
            el.style.animation = 'none';
            el.offsetHeight; /* reflow */
            el.style.animation = `shootAcross ${1.5 + Math.random()}s ease-out forwards`;

            schedule();
        }

        function schedule() {
            setTimeout(trigger, 6000 + Math.random() * 12000);
        }

        schedule();
    })();

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    (function initIntro() {
        const intro = document.getElementById('intro');
        const catalog = document.getElementById('catalog');
        const viewfinder = document.getElementById('viewfinder');
        const introText = document.getElementById('introText');
        const introStarfield = document.getElementById('introStarfield');

        if (!intro || !catalog || !viewfinder || !introText || !introStarfield) return;

        /* check sessionStorage */
        if (sessionStorage.getItem('observatory-intro') === 'done') {
            intro.style.display = 'none';
            catalog.classList.add('visible');
            return;
        }

        let skipped = false;

        function skip() {
            if (skipped) return;
            skipped = true;
            sessionStorage.setItem('observatory-intro', 'done');
            intro.classList.add('hidden');
            setTimeout(() => {
                intro.style.display = 'none';
                catalog.classList.add('visible');
            }, 800);
        }

        intro.addEventListener('click', skip);
        document.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter') {
                e.preventDefault();
                skip();
            }
        });

        /* Phase 1: Stars fade in */
        const starCount = 60;
        for (let i = 0; i < starCount; i++) {
            const star = document.createElement('div');
            star.className = 'intro-star';
            star.style.left = Math.random() * 100 + '%';
            star.style.top = Math.random() * 100 + '%';
            star.style.width = (1 + Math.random() * 2) + 'px';
            star.style.height = star.style.width;
            star.style.animationDelay = (Math.random() * 1500) + 'ms';
            introStarfield.appendChild(star);
        }

        /* Phase 2: Viewfinder appears */
        setTimeout(() => {
            if (skipped) return;
            viewfinder.classList.add('visible');
        }, 1200);

        /* Phase 3: Text typewriter */
        const lines = [
            'CELESTIAL OBJECT CATALOG \u2014 ENTRY #D4N-13L3',
            'OBJECT: D\'AGNELLI SYSTEM \u2014 CLASS: G2V (MAIN SEQUENCE)',
            'OBSERVATORY: LONDON STATION',
            'OBSERVATION BEGINS...',
        ];

        let lineIndex = 0;
        let charIndex = 0;
        let currentText = '';
        const typeDelay = 30;
        const lineDelay = 400;

        function typeWriter() {
            if (skipped) return;

            if (lineIndex >= lines.length) {
                /* Phase 4: Viewfinder expand & transition */
                setTimeout(() => {
                    if (skipped) return;
                    viewfinder.classList.add('expand');
                    setTimeout(skip, 800);
                }, 600);
                return;
            }

            if (charIndex < lines[lineIndex].length) {
                currentText += lines[lineIndex][charIndex];
                introText.textContent = currentText;
                charIndex++;
                setTimeout(typeWriter, typeDelay);
            } else {
                currentText += '\n';
                lineIndex++;
                charIndex = 0;
                setTimeout(typeWriter, lineDelay);
            }
        }

        setTimeout(() => {
            if (skipped) return;
            typeWriter();
        }, 2000);
    })();
</script>
