---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Orient Express | A Journey Through Professional Excellence</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. A luxury railway journey through 15+ years of digital transformation, AI deployments, and cybersecurity expertise." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/train" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Orient Express | Professional Journey" />
    <meta property="og:description" content="Board the Orient Express: 15+ years of digital transformation, AI, and cybersecurity across global enterprises." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/train" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Orient Express Journey" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Orient Express | Professional Journey" />
    <meta name="twitter:description" content="Board the Orient Express: a luxury journey through 15+ years of professional excellence." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Raleway:wght@300;400;500;600&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- TEXTURE OVERLAY -->
    <div class="texture-overlay" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner">
            <div class="steam-cloud steam-1" aria-hidden="true"></div>
            <div class="steam-cloud steam-2" aria-hidden="true"></div>
            <div class="steam-cloud steam-3" aria-hidden="true"></div>
            <div class="whistle-visual" id="whistleVisual" aria-hidden="true">
                <span class="whistle-line"></span>
                <span class="whistle-line"></span>
                <span class="whistle-line"></span>
            </div>
            <div class="departure-board-intro" id="departureBoardIntro">
                <div class="board-frame">
                    <div class="board-header">Departures</div>
                    <div class="board-row-intro">
                        <span class="board-time">00:00</span>
                        <span class="board-dest" id="boardDest">
                            <span class="flip-letter" data-final="D">&#9608;</span><span class="flip-letter" data-final="A">&#9608;</span><span class="flip-letter" data-final="N">&#9608;</span><span class="flip-letter" data-final="I">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-spacer">&nbsp;</span><span class="flip-letter" data-final="D">&#9608;</span><span class="flip-letter" data-final="'">&#9608;</span><span class="flip-letter" data-final="A">&#9608;</span><span class="flip-letter" data-final="G">&#9608;</span><span class="flip-letter" data-final="N">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="I">&#9608;</span>
                        </span>
                        <span class="board-platform">Platform 1</span>
                    </div>
                    <div class="board-status" id="boardStatus">Boarding</div>
                </div>
            </div>
            <p class="intro-skip">Click or press any key to board</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journey" id="journey">

        <!-- RAILWAY TRACK LINE (decorative) -->
        <div class="track-line" aria-hidden="true"></div>

        <!-- DEPARTURE BOARD HEADER -->
        <section class="section header-section">
            <div class="ornament-top" aria-hidden="true"></div>
            <div class="window-frame">
                <div class="departure-header">
                    <div class="route-badge">Orient Express</div>
                    <h1 class="passenger-name">{siteMetadata.name}</h1>
                    <p class="route-subtitle">Senior Engagement Manager &mdash; AI &amp; Cybersecurity</p>
                    <div class="timetable-meta">
                        <span class="meta-item"><span class="meta-label">Origin</span> <span class="meta-value">{siteMetadata.location}</span></span>
                        <span class="meta-divider">&bull;</span>
                        <span class="meta-item"><span class="meta-label">Route</span> <span class="meta-value">15+ Years of Excellence</span></span>
                        <span class="meta-divider">&bull;</span>
                        <span class="meta-item"><span class="meta-label">Class</span> <span class="meta-value">First</span></span>
                    </div>
                    <div class="header-links">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GitHub</a>
                        <span class="link-ornament">&loz;</span>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LinkedIn</a>
                        <span class="link-ornament">&loz;</span>
                        <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">Bluesky</a>
                        <span class="link-ornament">&loz;</span>
                        <a href={`mailto:${siteMetadata.email}`}>Contact</a>
                    </div>
                </div>
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- PASSENGER PROFILE -->
        <section class="section reveal">
            <div class="station-marker" aria-hidden="true"><span class="station-dot"></span></div>
            <div class="section-header">
                <span class="section-number">I</span>
                <h2 class="section-title">Passenger Profile</h2>
            </div>
            <div class="window-frame profile-frame">
                <div class="profile-grid">
                    <div class="passport-photo">
                        <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="160" height="160" />
                        <div class="photo-stamp">Verified Passenger</div>
                    </div>
                    <div class="profile-text">
                        <p class="summary-text">{summary}</p>
                        <div class="passenger-details">
                            <div class="detail-row">
                                <span class="detail-label">Languages</span>
                                <span class="detail-value">{languages.join(" / ")}</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Industries</span>
                                <span class="detail-value">{industries.join(", ")}</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="metrics-bar">
                    {metrics.map(m => (
                        <div class="metric-item">
                            <span class="metric-value">{m.value}</span>
                            <span class="metric-label">{m.label}</span>
                        </div>
                    ))}
                </div>
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- ROUTE MAP / STATIONS (Experience) -->
        <section class="section reveal">
            <div class="station-marker" aria-hidden="true"><span class="station-dot"></span></div>
            <div class="section-header">
                <span class="section-number">II</span>
                <h2 class="section-title">Route Map &mdash; Stations of Service</h2>
            </div>
            <div class="stations-list">
                {experience.map((exp, i) => (
                    <div class="station-card reveal">
                        <div class="station-connector" aria-hidden="true">
                            <span class="connector-dot"></span>
                            {i < experience.length - 1 && <span class="connector-line"></span>}
                        </div>
                        <div class="window-frame station-content">
                            <div class="station-top">
                                <h3 class="station-name">{exp.company}</h3>
                                <span class="station-location">{exp.location}</span>
                            </div>
                            {exp.roles.map(role => (
                                <div class="role-block">
                                    <div class="role-header">
                                        <span class="role-title">{role.title}</span>
                                        <span class="role-period">{role.period}</span>
                                    </div>
                                    {role.description && <p class="role-description">{role.description}</p>}
                                    {role.bullets && role.bullets.length > 0 && (
                                        <ul class="role-bullets">
                                            {role.bullets.map(b => <li>{b}</li>)}
                                        </ul>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- ONBOARD AMENITIES (Skills) -->
        <section class="section reveal">
            <div class="station-marker" aria-hidden="true"><span class="station-dot"></span></div>
            <div class="section-header">
                <span class="section-number">III</span>
                <h2 class="section-title">Onboard Amenities</h2>
            </div>
            <div class="window-frame amenities-frame">
                <div class="amenity-group">
                    <h3 class="amenity-category">Technical Expertise</h3>
                    <div class="amenity-tags">
                        {skills.map(s => (
                            <span class="amenity-tag">{s}</span>
                        ))}
                    </div>
                </div>
                <div class="amenity-group">
                    <h3 class="amenity-category">Management &amp; Strategy</h3>
                    <div class="amenity-tags">
                        {managementSkills.map(s => (
                            <span class="amenity-tag management">{s}</span>
                        ))}
                    </div>
                </div>
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- JOURNEY HIGHLIGHTS (Engagements) -->
        <section class="section reveal">
            <div class="station-marker" aria-hidden="true"><span class="station-dot"></span></div>
            <div class="section-header">
                <span class="section-number">IV</span>
                <h2 class="section-title">Journey Highlights</h2>
            </div>
            <div class="highlights-grid">
                {engagements.map(eng => (
                    <div class="window-frame highlight-card reveal">
                        <div class="highlight-top">
                            <span class="highlight-client">{eng.client}</span>
                            <span class="highlight-sector">{eng.sector}</span>
                        </div>
                        <div class="highlight-details">
                            <div class="highlight-row">
                                <span class="highlight-label">Scope</span>
                                <span class="highlight-value">{eng.scope}</span>
                            </div>
                            <div class="highlight-row">
                                <span class="highlight-label">Impact</span>
                                <span class={`highlight-value impact ${eng.trend}`}>{eng.impact}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- PASSENGER CREDENTIALS (Education & Certs) -->
        <section class="section reveal">
            <div class="station-marker" aria-hidden="true"><span class="station-dot"></span></div>
            <div class="section-header">
                <span class="section-number">V</span>
                <h2 class="section-title">Passenger Credentials</h2>
            </div>
            <div class="window-frame credentials-frame">
                <div class="cred-section">
                    <h3 class="cred-heading">Education</h3>
                    {education.map(edu => (
                        <div class="cred-entry">
                            <div class="cred-main">
                                <span class="cred-degree">{edu.degree}</span>
                                {edu.distinction && <span class="cred-distinction">{edu.distinction}</span>}
                            </div>
                            <div class="cred-sub">
                                <span class="cred-institution">{edu.institution}</span>
                                <span class="cred-period">{edu.period}</span>
                                <span class="cred-location">{edu.location}</span>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="cred-section">
                    <h3 class="cred-heading">Certifications</h3>
                    <div class="cert-list">
                        {certifications.map(c => (
                            <span class="cert-item">{c}</span>
                        ))}
                    </div>
                </div>
                <div class="cred-section">
                    <h3 class="cred-heading">Continuous Learning</h3>
                    <div class="learning-list">
                        {continuousLearning.map(l => (
                            <div class="learning-item">{l}</div>
                        ))}
                    </div>
                </div>
            </div>
            <div class="golden-divider" aria-hidden="true"></div>
        </section>

        <!-- TERMINUS / END OF LINE -->
        <section class="section terminus reveal">
            <div class="station-marker terminus-marker" aria-hidden="true"><span class="station-dot final"></span></div>
            <div class="terminus-content">
                <div class="terminus-ornament" aria-hidden="true"></div>
                <p class="terminus-text">End of the Line</p>
                <p class="terminus-sub">Thank you for travelling with the Orient Express</p>
                <div class="terminus-links">
                    <a href={`mailto:${siteMetadata.email}`}>Send a Telegram</a>
                    <span class="link-ornament">&loz;</span>
                    <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">Connect</a>
                </div>
                <div class="terminus-ornament" aria-hidden="true"></div>
            </div>
        </section>

    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --midnight: #1a1a3a;
        --gold: #c9a84c;
        --gold-dim: rgba(201, 168, 76, 0.3);
        --cream: #f5f0e0;
        --burgundy: #6b1d2a;
        --mahogany: #3d1c11;
        --ivory: #faf8f0;
        --bg: #0f0e1a;
        --bg-card: rgba(26, 26, 58, 0.6);
        --text: #e8e0d0;
        --text-dim: #9a9080;
        --text-muted: #6b6358;
        --heading: 'Playfair Display', Georgia, serif;
        --body: 'Raleway', 'Helvetica Neue', sans-serif;
        --mono: 'JetBrains Mono', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--gold) var(--bg);
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--body);
        font-size: 15px;
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--gold); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--cream); }

    ::selection { background: var(--gold); color: var(--midnight); }

    /* =========================================
       TEXTURE OVERLAY
       ========================================= */
    .texture-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background:
            repeating-linear-gradient(
                0deg,
                transparent 0px,
                transparent 3px,
                rgba(201, 168, 76, 0.01) 3px,
                rgba(201, 168, 76, 0.01) 4px
            );
        mix-blend-mode: overlay;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--bg);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.8s ease;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-inner {
        text-align: center;
        position: relative;
    }

    /* Steam clouds */
    .steam-cloud {
        position: absolute;
        width: 120px; height: 60px;
        border-radius: 50%;
        background: radial-gradient(ellipse, rgba(245, 240, 224, 0.15), transparent 70%);
        opacity: 0;
        animation: steamRise 3s ease-out infinite;
    }
    .steam-1 { left: -80px; bottom: 100px; animation-delay: 0s; }
    .steam-2 { right: -60px; bottom: 80px; animation-delay: 0.8s; }
    .steam-3 { left: 30px; bottom: 120px; animation-delay: 1.5s; }

    @keyframes steamRise {
        0% { opacity: 0; transform: translateY(0) scale(0.6); }
        30% { opacity: 0.4; }
        100% { opacity: 0; transform: translateY(-80px) scale(1.4); }
    }

    /* Whistle visual */
    .whistle-visual {
        display: flex; gap: 8px; justify-content: center;
        margin-bottom: 2rem;
        opacity: 0;
        animation: whistlePulse 2s ease-in-out infinite;
        animation-delay: 0.5s;
    }
    .whistle-line {
        display: block;
        width: 3px; height: 30px;
        background: var(--gold);
        border-radius: 2px;
        animation: whistleBounce 0.6s ease-in-out infinite alternate;
    }
    .whistle-line:nth-child(2) { height: 45px; animation-delay: 0.15s; }
    .whistle-line:nth-child(3) { height: 20px; animation-delay: 0.3s; }

    @keyframes whistlePulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 1; }
    }
    @keyframes whistleBounce {
        0% { transform: scaleY(0.6); }
        100% { transform: scaleY(1); }
    }

    /* Departure board intro */
    .departure-board-intro {
        margin-bottom: 2rem;
    }

    .board-frame {
        background: #1a1814;
        border: 2px solid var(--gold-dim);
        border-radius: 4px;
        padding: 1.5rem 2rem;
        display: inline-block;
        min-width: 380px;
        text-align: left;
    }

    .board-header {
        font-family: var(--heading);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold);
        border-bottom: 1px solid var(--gold-dim);
        padding-bottom: 8px;
        margin-bottom: 12px;
    }

    .board-row-intro {
        display: flex;
        align-items: baseline;
        gap: 16px;
        font-family: var(--mono);
        font-size: 15px;
        margin-bottom: 8px;
    }

    .board-time {
        color: var(--gold);
        font-weight: 700;
        min-width: 50px;
    }

    .board-dest {
        color: var(--cream);
        letter-spacing: 2px;
        font-weight: 700;
    }

    .flip-letter {
        display: inline-block;
        min-width: 0.7em;
        text-align: center;
        transition: none;
    }

    .flip-letter.flipping {
        animation: flipChar 0.15s steps(1) forwards;
    }

    .flip-spacer {
        display: inline-block;
        width: 0.5em;
    }

    .board-platform {
        color: var(--text-dim);
        font-size: 11px;
        margin-left: auto;
    }

    .board-status {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--gold);
        letter-spacing: 1px;
        animation: statusBlink 1.5s step-end infinite;
    }

    @keyframes flipChar {
        0% { opacity: 0.3; transform: rotateX(90deg); }
        50% { opacity: 0.7; transform: rotateX(-10deg); }
        100% { opacity: 1; transform: rotateX(0deg); }
    }

    @keyframes statusBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0.3; }
    }

    .intro-skip {
        color: var(--text-muted);
        font-family: var(--body);
        font-size: 12px;
        letter-spacing: 1px;
        margin-top: 1rem;
    }

    /* =========================================
       MAIN CONTENT / JOURNEY
       ========================================= */
    .journey {
        max-width: 860px;
        margin: 0 auto;
        padding: 60px 24px 120px;
        position: relative;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
    }
    .journey.visible { opacity: 1; }

    /* =========================================
       RAILWAY TRACK LINE
       ========================================= */
    .track-line {
        position: absolute;
        left: 36px;
        top: 200px;
        bottom: 200px;
        width: 2px;
        background: linear-gradient(
            180deg,
            transparent,
            var(--gold-dim) 5%,
            var(--gold-dim) 95%,
            transparent
        );
    }
    .track-line::before,
    .track-line::after {
        content: '';
        position: absolute;
        left: -3px;
        width: 8px;
        height: 2px;
        background: var(--gold-dim);
    }
    .track-line::before { top: 5%; }
    .track-line::after { bottom: 5%; }

    /* =========================================
       STATION MARKERS
       ========================================= */
    .station-marker {
        position: absolute;
        left: 28px;
        margin-top: 8px;
    }
    .station-dot {
        display: block;
        width: 18px; height: 18px;
        border-radius: 50%;
        border: 2px solid var(--gold);
        background: var(--bg);
        position: relative;
    }
    .station-dot::after {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--gold);
    }
    .station-dot.final {
        border-color: var(--burgundy);
        background: var(--burgundy);
    }
    .station-dot.final::after {
        background: var(--gold);
    }

    /* =========================================
       SECTIONS
       ========================================= */
    .section {
        margin-bottom: 3rem;
        position: relative;
        padding-left: 40px;
    }
    .header-section {
        padding-left: 0;
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.2rem;
    }

    .section-number {
        font-family: var(--heading);
        font-size: 14px;
        color: var(--gold);
        font-weight: 700;
        min-width: 24px;
    }

    .section-title {
        font-family: var(--heading);
        font-size: 22px;
        font-weight: 700;
        color: var(--cream);
        letter-spacing: 0.5px;
    }

    /* =========================================
       WINDOW FRAME (Art Nouveau borders)
       ========================================= */
    .window-frame {
        border: 1px solid var(--gold-dim);
        border-radius: 4px;
        padding: 1.5rem;
        background: var(--bg-card);
