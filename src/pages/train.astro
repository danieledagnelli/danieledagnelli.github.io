---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Orient Express | A Journey Through Professional Excellence</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. A luxury railway journey through 15+ years of digital transformation, AI deployments, and cybersecurity expertise." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/train" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Orient Express | Professional Journey" />
    <meta property="og:description" content="Board the Orient Express: 15+ years of digital transformation, AI, and cybersecurity across global enterprises." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/train" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Orient Express Journey" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Orient Express | Professional Journey" />
    <meta name="twitter:description" content="Board the Orient Express: a luxury journey through 15+ years of professional excellence." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta name="twitter:creator" content="@danieledagnelli" />

    <!-- Structured Data (Person) -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ],
        "alumniOf": [
            { "@type": "CollegeOrUniversity", "name": "Abertay University" },
            { "@type": "CollegeOrUniversity", "name": "University of Bari Aldo Moro" }
        ],
        "knowsAbout": ["AI", "Cybersecurity", "Machine Learning", "Solution Architecture", "Program Management", "Digital Transformation", "GenAI", "RAG Systems"],
        "description": "Senior Engagement Manager with 15+ years in Professional Services, leading high-impact digital transformations."
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Raleway:wght@300;400;500;600&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- TEXTURE OVERLAY -->
    <div class="texture-overlay" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner">
            <div class="steam-cloud steam-1" aria-hidden="true"></div>
            <div class="steam-cloud steam-2" aria-hidden="true"></div>
            <div class="steam-cloud steam-3" aria-hidden="true"></div>
            <div class="whistle-visual" id="whistleVisual" aria-hidden="true">
                <span class="whistle-line"></span>
                <span class="whistle-line"></span>
                <span class="whistle-line"></span>
            </div>
            <div class="departure-board-intro" id="departureBoardIntro">
                <div class="board-frame">
                    <div class="board-header">Departures</div>
                    <div class="board-row-intro">
                        <span class="board-time">00:00</span>
                        <span class="board-dest" id="boardDest">
                            <span class="flip-letter" data-final="D">&#9608;</span><span class="flip-letter" data-final="A">&#9608;</span><span class="flip-letter" data-final="N">&#9608;</span><span class="flip-letter" data-final="I">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-spacer">&nbsp;</span><span class="flip-letter" data-final="D">&#9608;</span><span class="flip-letter" data-final="'">&#9608;</span><span class="flip-letter" data-final="A">&#9608;</span><span class="flip-letter" data-final="G">&#9608;</span><span class="flip-letter" data-final="N">&#9608;</span><span class="flip-letter" data-final="E">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="L">&#9608;</span><span class="flip-letter" data-final="I">&#9608;</span>
                        </span>
                        <span class="board-platform">Platform 1</span>
                    </div>
                    <div class="board-status" id="boardStatus">Boarding</div>
                </div>
            </div>
            <p class="intro-skip">Click or press any key to board</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journey" id="journey">

        <div class="train-narrative">
            <h1 class="route-title">ORIENT EXPRESS — CAREER LINE</h1>
            <div class="route-meta">service: 2012-present | class: first | status: on time</div>

            <div class="station">
                <div class="station-header">STATION 1 ─────── ACCENTURE, MILAN</div>
                <div class="station-dates">apr 2012 — dec 2014 | software engineer</div>
                <div class="station-note">[the departure. where it all began.]</div>
            </div>

            <div class="station">
                <div class="station-header">STATION 2 ─────── CODEC, DUBLIN</div>
                <div class="station-dates">jan 2015 — mar 2017 | senior consultant</div>
                <div class="station-note">[crossing the channel. new market, same drive.]</div>
            </div>

            <div class="station">
                <div class="station-header">STATION 3 ─────── ACCENTURE, LONDON</div>
                <div class="station-dates">apr 2017 — sep 2018 | management consultant</div>
                <div class="station-note">[the return. aerospace & defence.]</div>
            </div>

            <div class="station">
                <div class="station-header">STATION 4 ─────── DELOITTE, LONDON</div>
                <div class="station-dates">oct 2018 — jul 2021 | manager</div>
                <div class="station-note">[building the practice. 0 → 25+.]</div>
            </div>

            <div class="station terminal">
                <div class="station-header">TERMINAL ─────── C3 AI, LONDON</div>
                <div class="station-dates">aug 2021 — present | senior engagement manager</div>
                <div class="station-note">[$15m programme. 70+ crew. the journey continues.]</div>
            </div>

            <div class="train-footer">
                <a href="mailto:daniele@dagnelli.net">[tickets]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>

    </main>
</body>
</html>

<style>
    /* =========================================
       CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --midnight: #1a1a3a;
        --gold: #c9a84c;
        --gold-dim: rgba(201, 168, 76, 0.3);
        --cream: #f5f0e0;
        --burgundy: #6b1d2a;
        --mahogany: #3d1c11;
        --ivory: #faf8f0;
        --bg: #0f0e1a;
        --bg-card: rgba(26, 26, 58, 0.6);
        --text: #e8e0d0;
        --text-dim: #9a9080;
        --text-muted: #6b6358;
        --heading: 'Playfair Display', Georgia, serif;
        --body: 'Raleway', 'Helvetica Neue', sans-serif;
        --mono: 'JetBrains Mono', monospace;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--mono);
        font-size: 15px;
        line-height: 1.7;
        overflow: hidden;
    }

    a { color: var(--gold); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--cream); }

    ::selection { background: var(--gold); color: var(--midnight); }

    /* =========================================
       TEXTURE OVERLAY
       ========================================= */
    .texture-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background:
            repeating-linear-gradient(
                0deg,
                transparent 0px,
                transparent 3px,
                rgba(201, 168, 76, 0.01) 3px,
                rgba(201, 168, 76, 0.01) 4px
            );
        mix-blend-mode: overlay;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--bg);
        display: flex; align-items: center; justify-content: center;
        padding: 2rem;
        transition: opacity 0.8s ease;
    }

    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-inner {
        text-align: center;
        position: relative;
    }

    /* Steam clouds */
    .steam-cloud {
        position: absolute;
        width: 120px; height: 60px;
        border-radius: 50%;
        background: radial-gradient(ellipse, rgba(245, 240, 224, 0.15), transparent 70%);
        opacity: 0;
        animation: steamRise 3s ease-out infinite;
    }
    .steam-1 { left: -80px; bottom: 100px; animation-delay: 0s; }
    .steam-2 { right: -60px; bottom: 80px; animation-delay: 0.8s; }
    .steam-3 { left: 30px; bottom: 120px; animation-delay: 1.5s; }

    @keyframes steamRise {
        0% { opacity: 0; transform: translateY(0) scale(0.6); }
        30% { opacity: 0.4; }
        100% { opacity: 0; transform: translateY(-80px) scale(1.4); }
    }

    /* Whistle visual */
    .whistle-visual {
        display: flex; gap: 8px; justify-content: center;
        margin-bottom: 2rem;
        opacity: 0;
        animation: whistlePulse 2s ease-in-out infinite;
        animation-delay: 0.5s;
    }
    .whistle-line {
        display: block;
        width: 3px; height: 30px;
        background: var(--gold);
        border-radius: 2px;
        animation: whistleBounce 0.6s ease-in-out infinite alternate;
    }
    .whistle-line:nth-child(2) { height: 45px; animation-delay: 0.15s; }
    .whistle-line:nth-child(3) { height: 20px; animation-delay: 0.3s; }

    @keyframes whistlePulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 1; }
    }
    @keyframes whistleBounce {
        0% { transform: scaleY(0.6); }
        100% { transform: scaleY(1); }
    }

    /* Departure board intro */
    .departure-board-intro {
        margin-bottom: 2rem;
    }

    .board-frame {
        background: #1a1814;
        border: 2px solid var(--gold-dim);
        border-radius: 4px;
        padding: 1.5rem 2rem;
        display: inline-block;
        min-width: 380px;
        text-align: left;
    }

    .board-header {
        font-family: var(--heading);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--gold);
        border-bottom: 1px solid var(--gold-dim);
        padding-bottom: 8px;
        margin-bottom: 12px;
    }

    .board-row-intro {
        display: flex;
        align-items: baseline;
        gap: 16px;
        font-family: var(--mono);
        font-size: 15px;
        margin-bottom: 8px;
    }

    .board-time {
        color: var(--gold);
        font-weight: 700;
        min-width: 50px;
    }

    .board-dest {
        color: var(--cream);
        letter-spacing: 2px;
        font-weight: 700;
    }

    .flip-letter {
        display: inline-block;
        min-width: 0.7em;
        text-align: center;
        transition: none;
    }

    .flip-letter.flipping {
        animation: flipChar 0.15s steps(1) forwards;
    }

    .flip-spacer {
        display: inline-block;
        width: 0.5em;
    }

    .board-platform {
        color: var(--text-dim);
        font-size: 11px;
        margin-left: auto;
    }

    .board-status {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--gold);
        letter-spacing: 1px;
        animation: statusBlink 1.5s step-end infinite;
    }

    @keyframes flipChar {
        0% { opacity: 0.3; transform: rotateX(90deg); }
        50% { opacity: 0.7; transform: rotateX(-10deg); }
        100% { opacity: 1; transform: rotateX(0deg); }
    }

    @keyframes statusBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0.3; }
    }

    .intro-skip {
        color: var(--text-muted);
        font-family: var(--body);
        font-size: 12px;
        letter-spacing: 1px;
        margin-top: 1rem;
    }

    /* =========================================
       MAIN CONTENT / JOURNEY
       ========================================= */
    .journey {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
    }
    .journey.visible { opacity: 1; }

    /* =========================================
       TRAIN NARRATIVE
       ========================================= */
    .train-narrative {
        max-width: 600px;
        padding: 1.5rem;
    }

    .route-title {
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 0.2rem;
        font-family: var(--mono);
        color: var(--gold);
        font-weight: 700;
        letter-spacing: 2px;
    }

    .route-meta {
        font-size: 0.7rem;
        text-align: center;
        opacity: 0.7;
        margin-bottom: 1rem;
        color: var(--text-dim);
        letter-spacing: 1px;
    }

    .station {
        margin-bottom: 0.6rem;
    }

    .station-header {
        font-size: 0.8rem;
        font-weight: bold;
        color: var(--cream);
        letter-spacing: 1px;
    }

    .station-dates {
        font-size: 0.7rem;
        opacity: 0.7;
        color: var(--text-dim);
    }

    .station-note {
        font-size: 0.75rem;
        opacity: 0.8;
        font-style: italic;
        color: var(--text);
    }

    .station.terminal .station-header {
        font-size: 0.9rem;
        color: var(--gold);
    }

    .train-footer {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .train-footer a {
        text-decoration: none;
    }

    /* =========================================
       RESPONSIVE -- MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .station-note { font-size: 0.7rem; }
        .station { margin-bottom: 0.4rem; }
    }

    /* =========================================
       RESPONSIVE -- SMALL PHONE
       ========================================= */
    @media (max-width: 600px) {
        /* Intro */
        .board-frame { min-width: 0; width: 100%; padding: 1rem; }
        .board-row-intro { flex-wrap: wrap; gap: 8px; font-size: 13px; }
        .board-platform { margin-left: 0; }
    }

    @media (max-width: 380px) {
        .board-row-intro { font-size: 11px; }
        .train-narrative { padding: 1rem; }
        .route-title { font-size: 0.95rem; }
    }

    /* =========================================
       PRINT
       ========================================= */
    @media print {
        .texture-overlay,
        .intro { display: none; }
        .journey { opacity: 1; height: auto; overflow: visible; }
        body { background: #fff; color: #222; }
        a { color: #333; }
    }
</style>

<script>
    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const journeyEl = document.getElementById('journey')!;
    const boardDest = document.getElementById('boardDest')!;
    const boardStatus = document.getElementById('boardStatus')!;
    const boardTime = document.querySelector('.board-time') as HTMLElement;
    const flipLetters = boardDest.querySelectorAll('.flip-letter');

    function sleep(ms: number) {
        return new Promise(r => setTimeout(r, ms));
    }

    function skipIntro() {
        sessionStorage.setItem('train-intro-seen', '1');
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            journeyEl.classList.add('visible');
        }, 800);
    }

    async function runIntro() {
        if (sessionStorage.getItem('train-intro-seen')) {
            introEl.classList.add('done');
            setTimeout(() => {
                introEl.style.display = 'none';
                journeyEl.classList.add('visible');
            }, 100);
            return;
        }

        // Set current time on board
        const now = new Date();
        boardTime.textContent =
            String(now.getHours()).padStart(2, '0') + ':' +
            String(now.getMinutes()).padStart(2, '0');

        // Wait for steam and whistle visual
        await sleep(1200);

        // Flip letters one by one
        for (let i = 0; i < flipLetters.length; i++) {
            const letter = flipLetters[i] as HTMLElement;
            const finalChar = letter.dataset.final || '';

            // Quick scramble through a few random chars
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            for (let j = 0; j < 3; j++) {
                letter.textContent = chars[Math.floor(Math.random() * chars.length)];
                await sleep(50);
            }

            letter.textContent = finalChar;
            letter.classList.add('flipping');
            await sleep(80);
        }

        await sleep(600);
        boardStatus.textContent = 'Now Departing';
        boardStatus.style.color = '#c9a84c';

        await sleep(1000);
        skipIntro();
    }

    // Click/key to skip
    introEl.addEventListener('click', () => skipIntro());
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            skipIntro();
        }
    });

    runIntro();
</script>
