---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Case File: Daniele D'Agnelli — Film Noir Detective Dossier</title>
    <meta name="description" content="Case File #4721 — A detective's dossier on Daniele D'Agnelli. Senior Engagement Manager with 15+ years in Professional Services, AI deployments, and cybersecurity." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/noir" />

    <!-- Open Graph -->
    <meta property="og:title" content="Case File: Daniele D'Agnelli — Film Noir Detective Dossier" />
    <meta property="og:description" content="Case File #4721. A detective's investigation into a Senior Engagement Manager with 15+ years leading high-impact digital transformations." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/noir" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Case File: Daniele D'Agnelli" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Case File: Daniele D'Agnelli — Film Noir Detective Dossier" />
    <meta name="twitter:description" content="Case File #4721. A detective's investigation into a Senior Engagement Manager." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>

<body>
    <!-- Paper texture overlay -->
    <div class="paper-texture" aria-hidden="true"></div>

    <!-- Intro sequence -->
    <div id="intro-overlay" class="intro-overlay">
        <div class="intro-content">
            <div class="typewriter-container">
                <p id="typewriter-text" class="typewriter-text"></p>
                <span id="typewriter-cursor" class="typewriter-cursor">|</span>
            </div>
            <div id="folder-opening" class="folder-opening">
                <div class="folder-tab">CLASSIFIED</div>
                <div class="folder-body"></div>
            </div>
            <p class="skip-hint" id="skip-hint">Press Escape, Space, or Enter to skip</p>
        </div>
    </div>

    <!-- Main Content -->
    <main id="main-content" class="main-content">
        <!-- Stamp decorations -->
        <div class="stamp stamp-classified" aria-hidden="true">CLASSIFIED</div>
        <div class="stamp stamp-confidential" aria-hidden="true">CONFIDENTIAL</div>

        <div class="case-narrative">
            <div class="narrative-text">
                <p>the dame walked into my office with a name on a slip of paper. d'agnelli. italian by birth, london by choice. fifteen years in the game — the kind of career you don't just stumble into. started as a code jockey in milan, made his way through dublin and london. now runs a $15m operation at c3 ai with 70 people under him.</p>
                <p>his last mark? a swiss manufacturer. 100 plants. 2,000 end users. $18m ebit impact. the client kept smiling — nps above 70. that's not just good. that's the kind of number that makes you wonder what he's got on them.</p>
                <p>but here's the twist: the subject moonlights. msc in ethical hacking. gchq-certified. the kind of guy who builds the vault by day and picks the lock by night. case remains open.</p>
            </div>
            <div class="case-footer-links">
                <a href="mailto:daniele@dagnelli.net">[contact]</a>
                <a href="https://github.com/danieledagnelli">[github]</a>
                <a href="https://linkedin.com/in/dagnelli">[linkedin]</a>
            </div>
        </div>
    </main>
</body>
</html>

<style>
    /* ===== CSS Custom Properties ===== */
    :root {
        --paper: #f5f0e8;
        --ink: #1a1a1a;
        --red-stamp: #8b1a1a;
        --manila: #d4b896;
        --coffee: rgba(139, 69, 19, 0.1);
        --coffee-dark: rgba(139, 69, 19, 0.2);
        --paper-shadow: rgba(0, 0, 0, 0.15);
        --font-typewriter: 'Special Elite', cursive;
        --font-body: 'Libre Baskerville', Georgia, serif;
    }

    /* ===== Reset & Base ===== */
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: var(--font-body);
        background-color: var(--manila);
        color: var(--ink);
        line-height: 1.7;
        font-size: 16px;
        position: relative;
        overflow-x: hidden;
    }

    a {
        color: var(--red-stamp);
        text-decoration: underline;
        text-decoration-style: dotted;
        transition: color 0.2s;
    }

    a:hover {
        color: #5a0e0e;
    }

    /* ===== Paper Texture Overlay ===== */
    .paper-texture {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
        background-image:
            repeating-linear-gradient(
                0deg,
                transparent,
                transparent 28px,
                rgba(0, 0, 0, 0.02) 28px,
                rgba(0, 0, 0, 0.02) 29px
            ),
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 100%
            );
        opacity: 0.6;
    }

    /* ===== Intro Overlay ===== */
    .intro-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: var(--ink);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease, visibility 0.8s ease;
    }

    .intro-overlay.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .intro-content {
        text-align: center;
        padding: 2rem;
    }

    .typewriter-container {
        display: inline-flex;
        align-items: center;
        gap: 0;
    }

    .typewriter-text {
        font-family: var(--font-typewriter);
        color: var(--paper);
        font-size: clamp(1rem, 3vw, 1.6rem);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        white-space: nowrap;
        overflow: hidden;
    }

    .typewriter-cursor {
        font-family: var(--font-typewriter);
        color: var(--paper);
        font-size: clamp(1rem, 3vw, 1.6rem);
        animation: blink 0.7s step-end infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    /* Folder opening animation */
    .folder-opening {
        margin-top: 2rem;
        opacity: 0;
        transform: scaleY(0);
        transform-origin: top;
        transition: opacity 0.5s ease, transform 0.6s ease;
    }

    .folder-opening.open {
        opacity: 1;
        transform: scaleY(1);
    }

    .folder-tab {
        display: inline-block;
        background: var(--manila);
        color: var(--red-stamp);
        font-family: var(--font-typewriter);
        font-size: 0.9rem;
        padding: 0.3rem 1.5rem;
        border-radius: 6px 6px 0 0;
        letter-spacing: 0.2em;
        font-weight: 700;
    }

    .folder-body {
        width: 300px;
        height: 60px;
        background: var(--paper);
        border: 2px solid var(--manila);
        margin: 0 auto;
        border-radius: 0 4px 4px 4px;
    }

    .skip-hint {
        font-family: var(--font-body);
        color: rgba(245, 240, 232, 0.3);
        font-size: 0.8rem;
        margin-top: 2rem;
        font-style: italic;
    }

    /* ===== Main Content ===== */
    .main-content {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        z-index: 2;
        background: var(--paper);
        box-shadow: -4px 0 15px var(--paper-shadow), 4px 0 15px var(--paper-shadow);
    }

    /* ===== Stamps ===== */
    .stamp {
        position: absolute;
        font-family: var(--font-typewriter);
        color: var(--red-stamp);
        opacity: 0.12;
        font-size: 4rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        pointer-events: none;
        z-index: 3;
        border: 4px solid var(--red-stamp);
        padding: 0.2em 0.5em;
        border-radius: 8px;
    }

    .stamp-classified {
        top: 4rem;
        right: -1rem;
        transform: rotate(12deg);
    }

    .stamp-confidential {
        top: 50%;
        left: -1.5rem;
        transform: rotate(-8deg);
        font-size: 3rem;
    }

    /* ===== Case Narrative ===== */
    .case-narrative {
        max-width: 580px;
        padding: 1.5rem;
        margin: 0 auto;
    }

    .narrative-text p {
        font-size: 0.82rem;
        line-height: 1.6;
        margin-bottom: 0.6rem;
    }

    .case-footer-links {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1rem;
    }

    .case-footer-links a {
        font-family: var(--font-typewriter);
        font-size: 0.85rem;
        letter-spacing: 0.05em;
    }

    /* ===== Responsive Design ===== */
    @media (max-width: 768px) {
        .stamp {
            display: none;
        }

        .folder-body {
            width: 200px;
        }

        .typewriter-text {
            white-space: normal;
            text-align: center;
        }

        .typewriter-container {
            flex-direction: column;
        }

        .narrative-text p {
            font-size: 0.76rem;
        }

        .case-footer-links a {
            font-size: 0.78rem;
        }
    }

    @media (max-width: 480px) {
        body {
            font-size: 14px;
        }

        .narrative-text p {
            font-size: 0.72rem;
            line-height: 1.5;
        }

        .case-footer-links {
            gap: 0.6rem;
        }

        .case-footer-links a {
            font-size: 0.72rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const introOverlay = document.getElementById('intro-overlay') as HTMLElement;
        const typewriterText = document.getElementById('typewriter-text') as HTMLElement;
        const typewriterCursor = document.getElementById('typewriter-cursor') as HTMLElement;
        const folderOpening = document.getElementById('folder-opening') as HTMLElement;
        const mainContent = document.getElementById('main-content') as HTMLElement;
        const skipHint = document.getElementById('skip-hint') as HTMLElement;

        const STORAGE_KEY = 'noir-intro-seen';
        const fullText = "CASE FILE #4721 — SUBJECT: DANIELE D'AGNELLI";

        let introComplete = false;
        let typewriterTimeout: ReturnType<typeof setTimeout> | null = null;
        let currentCharIndex = 0;

        function finishIntro() {
            if (introComplete) return;
            introComplete = true;

            if (typewriterTimeout) {
                clearTimeout(typewriterTimeout);
            }

            sessionStorage.setItem(STORAGE_KEY, 'true');
            introOverlay.classList.add('hidden');
        }

        function typeNextChar() {
            if (currentCharIndex < fullText.length) {
                typewriterText.textContent = fullText.substring(0, currentCharIndex + 1);
                currentCharIndex++;
                typewriterTimeout = setTimeout(typeNextChar, 55 + Math.random() * 40);
            } else {
                // Typing done, show folder
                typewriterCursor.style.display = 'none';
                setTimeout(() => {
                    folderOpening.classList.add('open');
                    setTimeout(finishIntro, 1000);
                }, 400);
            }
        }

        function skipIntro(e: Event) {
            if (e instanceof KeyboardEvent) {
                if (e.key !== 'Escape' && e.key !== ' ' && e.key !== 'Enter') return;
            }
            finishIntro();
        }

        // Check sessionStorage
        if (sessionStorage.getItem(STORAGE_KEY) === 'true') {
            introOverlay.style.display = 'none';
            introComplete = true;
        } else {
            // Start typewriter
            document.addEventListener('keydown', skipIntro);
            introOverlay.addEventListener('click', skipIntro);
            typeNextChar();
        }
    });
</script>
