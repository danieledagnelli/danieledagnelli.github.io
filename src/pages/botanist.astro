---
import Main from "../layouts/Main.astro";
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Botanical Field Journal</title>
    <meta name="description" content="A botanical field study journal cataloging the professional growth seasons, root systems, and species expertise of Daniele D'Agnelli — Senior Engagement Manager." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/botanist" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta property="og:description" content="A Victorian-era botanical field study documenting 15+ years of professional cultivation in AI, cybersecurity, and digital transformation." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/botanist" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta name="twitter:description" content="A Victorian-era botanical field study documenting 15+ years of professional cultivation." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Caveat:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- FALLING LEAVES -->
    <div class="leaves-container" aria-hidden="true">
        <div class="leaf leaf-1">&#x1F33F;</div>
        <div class="leaf leaf-2">&#x1F342;</div>
        <div class="leaf leaf-3">&#x1F33F;</div>
        <div class="leaf leaf-4">&#x1F343;</div>
        <div class="leaf leaf-5">&#x1F342;</div>
        <div class="leaf leaf-6">&#x1F33F;</div>
        <div class="leaf leaf-7">&#x1F343;</div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner">
            <svg class="sprout-svg" viewBox="0 0 100 200" xmlns="http://www.w3.org/2000/svg">
                <path class="stem" d="M50 200 L50 80" stroke="#2d5016" stroke-width="3" fill="none" stroke-linecap="round" />
                <path class="leaf-left" d="M50 100 C30 90, 15 70, 25 55 C35 45, 48 65, 50 100" fill="#4a7c29" opacity="0" />
                <path class="leaf-right" d="M50 85 C70 75, 85 55, 75 40 C65 30, 52 50, 50 85" fill="#2d5016" opacity="0" />
                <ellipse class="seed" cx="50" cy="180" rx="12" ry="8" fill="#5c3d2e" />
            </svg>
            <div class="intro-cracks" id="introCracks">
                <div class="crack crack-1"></div>
                <div class="crack crack-2"></div>
                <div class="crack crack-3"></div>
                <div class="crack crack-4"></div>
            </div>
            <p class="intro-text" id="introText">Field Study Journal No. 7 — Subject: Daniele D'Agnelli</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journal" id="journal">
        <div class="botanist-narrative">
            <h1 class="journal-title">FIELD JOURNAL — OBSERVATIONS ON PROFESSIONAL GROWTH</h1>
            <div class="journal-meta">botanist: daniele d'agnelli | location: london | season: 15th year</div>
            <div class="specimen">
                <h2>SPECIMEN: PRACTICE CULTIVATION (DELOITTE, 2018-2021)</h2>
                <p>the most remarkable specimen in the collection. planted the first seed of an anaplan practice at deloitte uk. soil conditions: zero existing practitioners. no root system. no canopy.</p>
                <p>through careful cultivation — three years of client work, recruitment, training, and knowledge transfer — the specimen grew to 25+ practitioners. a self-sustaining ecosystem. the practice survived and thrived after the original botanist departed. that is the mark of true cultivation.</p>
            </div>
            <div class="specimen">
                <h2>SPECIMEN: TEAM GROWTH (C3 AI, 2021-PRESENT)</h2>
                <p>the current garden: 70+ resources across app dev, data science, qa, devops. a 20+ cross-functional team directly led. the organism has reached programme-level scale — $15m budget, operations spanning 100+ sites.</p>
            </div>
            <div class="root-system">
                <h2>ROOT SYSTEM</h2>
                <p>bsc computer science (bari) → software engineer → senior consultant → management consultant → manager → senior engagement manager. each layer of growth built on the one beneath.</p>
            </div>
            <div class="field-note">NOTES: the subject shows no signs of dormancy.</div>
            <div class="botanist-footer"><a href="mailto:daniele@dagnelli.net">[contact]</a><a href="https://github.com/danieledagnelli">[herbarium]</a><a href="https://linkedin.com/in/dagnelli">[linkedin]</a></div>
        </div>
    </main>

</body>
</html>

<style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --parchment: #f4e9d2;
        --earth: #5c3d2e;
        --dark-green: #2d5016;
        --mid-green: #4a7c29;
        --gold: #c4a35a;
        --sage: #e8e0c8;
        --parchment-dark: #e6d9be;
    }

    html {
        height: 100%;
    }

    body {
        font-family: 'Lora', Georgia, serif;
        background: var(--parchment);
        color: var(--earth);
        line-height: 1.7;
        overflow: hidden;
        height: 100%;
        margin: 0;
    }

    /* ===== INTRO SEQUENCE ===== */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: var(--earth);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease, visibility 0.8s ease;
    }

    .intro.done {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .intro-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .sprout-svg {
        width: 80px;
        height: 160px;
    }

    .sprout-svg .stem {
        stroke-dasharray: 120;
        stroke-dashoffset: 120;
        animation: growStem 1.5s ease-out 0.3s forwards;
    }

    .sprout-svg .leaf-left {
        animation: unfurlLeaf 0.6s ease-out 1.4s forwards;
    }

    .sprout-svg .leaf-right {
        animation: unfurlLeaf 0.6s ease-out 1.7s forwards;
    }

    .sprout-svg .seed {
        animation: seedPulse 0.5s ease-in-out 0s forwards;
    }

    @keyframes growStem {
        to { stroke-dashoffset: 0; }
    }

    @keyframes unfurlLeaf {
        from { opacity: 0; transform: scale(0.3); }
        to { opacity: 1; transform: scale(1); }
    }

    @keyframes seedPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }

    .intro-cracks {
        position: fixed;
        inset: 0;
        pointer-events: none;
    }

    .crack {
        position: absolute;
        background: var(--parchment);
        opacity: 0;
    }

    .crack-1 {
        top: 0; left: 0; right: 50%; bottom: 50%;
        transform-origin: bottom right;
        animation: crackReveal 0.6s ease-out 2.2s forwards;
    }

    .crack-2 {
        top: 0; left: 50%; right: 0; bottom: 50%;
        transform-origin: bottom left;
        animation: crackReveal 0.6s ease-out 2.3s forwards;
    }

    .crack-3 {
        top: 50%; left: 0; right: 50%; bottom: 0;
        transform-origin: top right;
        animation: crackReveal 0.6s ease-out 2.4s forwards;
    }

    .crack-4 {
        top: 50%; left: 50%; right: 0; bottom: 0;
        transform-origin: top left;
        animation: crackReveal 0.6s ease-out 2.5s forwards;
    }

    @keyframes crackReveal {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    .intro-text {
        font-family: 'Caveat', cursive;
        font-size: 1.6rem;
        color: var(--parchment);
        opacity: 0;
        text-align: center;
        padding: 0 1rem;
        animation: fadeInText 0.8s ease-out 1.8s forwards;
    }

    @keyframes fadeInText {
        to { opacity: 1; }
    }

    /* ===== FALLING LEAVES ===== */
    .leaves-container {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        overflow: hidden;
    }

    .leaf {
        position: absolute;
        font-size: 1.2rem;
        opacity: 0.5;
        top: -40px;
        animation: leafFall linear infinite;
    }

    .leaf-1 { left: 8%; animation-duration: 14s; animation-delay: 0s; font-size: 1rem; }
    .leaf-2 { left: 22%; animation-duration: 18s; animation-delay: 3s; font-size: 1.4rem; }
    .leaf-3 { left: 45%; animation-duration: 16s; animation-delay: 6s; }
    .leaf-4 { left: 62%; animation-duration: 20s; animation-delay: 2s; font-size: 1.1rem; }
    .leaf-5 { left: 78%; animation-duration: 15s; animation-delay: 8s; font-size: 1.3rem; }
    .leaf-6 { left: 35%; animation-duration: 22s; animation-delay: 5s; font-size: 0.9rem; }
    .leaf-7 { left: 90%; animation-duration: 17s; animation-delay: 10s; }

    @keyframes leafFall {
        0% {
            transform: translateY(0) translateX(0) rotate(0deg);
            opacity: 0;
        }
        5% {
            opacity: 0.45;
        }
        25% {
            transform: translateY(25vh) translateX(30px) rotate(90deg);
        }
        50% {
            transform: translateY(50vh) translateX(-20px) rotate(180deg);
        }
        75% {
            transform: translateY(75vh) translateX(25px) rotate(270deg);
        }
        95% {
            opacity: 0.4;
        }
        100% {
            transform: translateY(105vh) translateX(-10px) rotate(360deg);
            opacity: 0;
        }
    }

    /* ===== JOURNAL MAIN (viewport-locked) ===== */
    .journal {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.6s ease;
        padding: 1.5rem;
    }

    .journal.visible {
        opacity: 1;
    }

    /* ===== BOTANIST NARRATIVE ===== */
    .botanist-narrative {
        max-width: 720px;
        width: 100%;
        text-align: left;
    }

    .journal-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--dark-green);
        letter-spacing: 0.05em;
        margin-bottom: 0.4rem;
        border-bottom: 2px solid var(--gold);
        padding-bottom: 0.4rem;
        text-transform: uppercase;
    }

    .journal-meta {
        font-family: 'Caveat', cursive;
        font-size: 1.05rem;
        color: var(--earth);
        opacity: 0.7;
        margin-bottom: 1.25rem;
    }

    .specimen {
        margin-bottom: 1rem;
    }

    .specimen h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--dark-green);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.3rem;
        border-left: 3px solid var(--mid-green);
        padding-left: 0.6rem;
    }

    .specimen p {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        line-height: 1.65;
        margin-bottom: 0.35rem;
        color: var(--earth);
    }

    .root-system {
        margin-bottom: 1rem;
    }

    .root-system h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--dark-green);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.3rem;
        border-left: 3px solid var(--gold);
        padding-left: 0.6rem;
    }

    .root-system p {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        line-height: 1.65;
        color: var(--earth);
    }

    .field-note {
        font-family: 'Caveat', cursive;
        font-size: 1.1rem;
        color: var(--mid-green);
        font-weight: 600;
        margin-top: 1rem;
        margin-bottom: 1rem;
        padding: 0.5rem 0;
        border-top: 1px dashed var(--gold);
        border-bottom: 1px dashed var(--gold);
        text-align: center;
    }

    .botanist-footer {
        display: flex;
        gap: 1.25rem;
        justify-content: center;
    }

    .botanist-footer a {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        color: var(--dark-green);
        text-decoration: none;
        border: 1px solid var(--dark-green);
        padding: 0.3rem 0.75rem;
        border-radius: 2px;
        transition: all 0.2s ease;
    }

    .botanist-footer a:hover {
        background: var(--dark-green);
        color: var(--parchment);
    }

    /* ===== RESPONSIVE: 768px ===== */
    @media (max-width: 768px) {
        .journal {
            padding: 1.25rem;
        }

        .journal-title {
            font-size: 1.2rem;
        }

        .journal-meta {
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .specimen h2,
        .root-system h2 {
            font-size: 0.9rem;
        }

        .specimen p,
        .root-system p {
            font-size: 0.8rem;
            line-height: 1.55;
        }

        .field-note {
            font-size: 1rem;
        }

        .botanist-footer a {
            font-size: 0.8rem;
            padding: 0.35rem 0.6rem;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
        }
    }

    /* ===== RESPONSIVE: 480px ===== */
    @media (max-width: 480px) {
        .journal {
            padding: 1rem 0.75rem;
        }

        .journal-title {
            font-size: 1rem;
            letter-spacing: 0.02em;
        }

        .journal-meta {
            font-size: 0.85rem;
            margin-bottom: 0.75rem;
        }

        .specimen {
            margin-bottom: 0.75rem;
        }

        .specimen h2,
        .root-system h2 {
            font-size: 0.82rem;
        }

        .specimen p,
        .root-system p {
            font-size: 0.75rem;
            line-height: 1.5;
            margin-bottom: 0.25rem;
        }

        .root-system {
            margin-bottom: 0.75rem;
        }

        .field-note {
            font-size: 0.9rem;
            margin-top: 0.75rem;
            margin-bottom: 0.75rem;
            padding: 0.35rem 0;
        }

        .botanist-footer {
            gap: 0.75rem;
        }

        .botanist-footer a {
            font-size: 0.75rem;
            padding: 0.3rem 0.5rem;
        }

        .intro-text {
            font-size: 1.2rem;
        }
    }

    /* ===== RESPONSIVE: 380px ===== */
    @media (max-width: 380px) {
        .journal {
            padding: 0.75rem 0.5rem;
        }

        .journal-title {
            font-size: 0.88rem;
        }

        .journal-meta {
            font-size: 0.78rem;
            margin-bottom: 0.6rem;
        }

        .specimen h2,
        .root-system h2 {
            font-size: 0.78rem;
        }

        .specimen p,
        .root-system p {
            font-size: 0.7rem;
            line-height: 1.45;
        }

        .field-note {
            font-size: 0.82rem;
        }

        .botanist-footer a {
            font-size: 0.7rem;
        }
    }

    /* ===== REDUCED MOTION ===== */
    @media (prefers-reduced-motion: reduce) {
        .leaf {
            animation: none;
            display: none;
        }

        .sprout-svg .stem,
        .sprout-svg .leaf-left,
        .sprout-svg .leaf-right,
        .sprout-svg .seed {
            animation: none;
            stroke-dashoffset: 0;
            opacity: 1;
        }

        .crack {
            animation: none;
            opacity: 1;
        }

        .intro-text {
            animation: none;
            opacity: 1;
        }
    }
</style>

<script>
    /* ===== INTRO SEQUENCE ===== */
    (function () {
        const intro = document.getElementById('intro');
        const journal = document.getElementById('journal');
        const storageKey = 'botanist-intro';

        function endIntro() {
            if (!intro) return;
            intro.classList.add('done');
            if (journal) journal.classList.add('visible');
            try {
                sessionStorage.setItem(storageKey, '1');
            } catch (e) { /* private browsing */ }
        }

        // Skip if already seen
        try {
            if (sessionStorage.getItem(storageKey)) {
                if (intro) {
                    intro.style.display = 'none';
                }
                if (journal) {
                    journal.style.opacity = '1';
                    journal.classList.add('visible');
                }
                return;
            }
        } catch (e) { /* private browsing */ }

        // Skip on user interaction
        function skipIntro(e: Event) {
            if (e instanceof KeyboardEvent) {
                if (!['Escape', ' ', 'Enter'].includes(e.key)) return;
            }
            endIntro();
            cleanup();
        }

        function cleanup() {
            document.removeEventListener('click', skipIntro);
            document.removeEventListener('keydown', skipIntro);
        }

        document.addEventListener('click', skipIntro);
        document.addEventListener('keydown', skipIntro);

        // Auto-end after animation completes
        setTimeout(() => {
            endIntro();
            cleanup();
        }, 3200);
    })();
</script>
