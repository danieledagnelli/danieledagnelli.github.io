<script>
    /* ===== INTRO SEQUENCE ===== */
    (function () {
        const intro = document.getElementById('intro');
        const journal = document.getElementById('journal');
        const storageKey = 'botanist-intro';

        function endIntro() {
            if (!intro) return;
            intro.classList.add('done');
            if (journal) journal.classList.add('visible');
            try {
                sessionStorage.setItem(storageKey, '1');
            } catch (e) { /* private browsing */ }
        }

        // Skip if already seen
        try {
            if (sessionStorage.getItem(storageKey)) {
                if (intro) {
                    intro.style.display = 'none';
                }
                if (journal) {
                    journal.style.opacity = '1';
                    journal.classList.add('visible');
                }
                initScrollReveal();
                initVineBorders();
                return;
            }
        } catch (e) { /* private browsing */ }

        // Skip on user interaction
        function skipIntro(e: Event) {
            if (e instanceof KeyboardEvent) {
                if (!['Escape', ' ', 'Enter'].includes(e.key)) return;
            }
            endIntro();
            cleanup();
        }

        function cleanup() {
            document.removeEventListener('click', skipIntro);
            document.removeEventListener('keydown', skipIntro);
        }

        document.addEventListener('click', skipIntro);
        document.addEventListener('keydown', skipIntro);

        // Auto-end after animation completes
        setTimeout(() => {
            endIntro();
            cleanup();
        }, 3200);

        // Init scroll reveal and vine animations after intro
        setTimeout(() => {
            initScrollReveal();
            initVineBorders();
        }, 100);
    })();

    /* ===== SCROLL REVEAL ===== */
    function initScrollReveal() {
        const reveals = document.querySelectorAll('.reveal');
        if (!reveals.length) return;

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        reveals.forEach((el) => observer.observe(el));
    }

    /* ===== VINE BORDER ANIMATIONS ===== */
    function initVineBorders() {
        const vineBorders = document.querySelectorAll('.vine-border-top, .vine-border-bottom');
        if (!vineBorders.length) return;

        const vineObserver = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animated');
                        vineObserver.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.3 }
        );

        vineBorders.forEach((el) => vineObserver.observe(el));
    }
</script>
