---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, managementSkills, languages, industries, metrics } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Botanical Field Journal</title>
    <meta name="description" content="A botanical field study journal cataloging the professional growth seasons, root systems, and species expertise of Daniele D'Agnelli — Senior Engagement Manager." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/botanist" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta property="og:description" content="A Victorian-era botanical field study documenting 15+ years of professional cultivation in AI, cybersecurity, and digital transformation." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/botanist" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Botanical Field Journal" />
    <meta name="twitter:description" content="A Victorian-era botanical field study documenting 15+ years of professional cultivation." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Daniele D'Agnelli",
        "url": "https://dagnelli.net",
        "image": "https://dagnelli.net/assets/dani.jpeg",
        "jobTitle": "Senior Engagement Manager",
        "worksFor": { "@type": "Organization", "name": "C3 AI" },
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "GB" },
        "email": "daniele@dagnelli.net",
        "sameAs": [
            "https://github.com/danieledagnelli",
            "https://www.linkedin.com/in/dagnelli",
            "https://bsky.app/profile/dagnelli.net"
        ]
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Caveat:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>

    <!-- FALLING LEAVES -->
    <div class="leaves-container" aria-hidden="true">
        <div class="leaf leaf-1">&#x1F33F;</div>
        <div class="leaf leaf-2">&#x1F342;</div>
        <div class="leaf leaf-3">&#x1F33F;</div>
        <div class="leaf leaf-4">&#x1F343;</div>
        <div class="leaf leaf-5">&#x1F342;</div>
        <div class="leaf leaf-6">&#x1F33F;</div>
        <div class="leaf leaf-7">&#x1F343;</div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-inner">
            <svg class="sprout-svg" viewBox="0 0 100 200" xmlns="http://www.w3.org/2000/svg">
                <path class="stem" d="M50 200 L50 80" stroke="#2d5016" stroke-width="3" fill="none" stroke-linecap="round" />
                <path class="leaf-left" d="M50 100 C30 90, 15 70, 25 55 C35 45, 48 65, 50 100" fill="#4a7c29" opacity="0" />
                <path class="leaf-right" d="M50 85 C70 75, 85 55, 75 40 C65 30, 52 50, 50 85" fill="#2d5016" opacity="0" />
                <ellipse class="seed" cx="50" cy="180" rx="12" ry="8" fill="#5c3d2e" />
            </svg>
            <div class="intro-cracks" id="introCracks">
                <div class="crack crack-1"></div>
                <div class="crack crack-2"></div>
                <div class="crack crack-3"></div>
                <div class="crack crack-4"></div>
            </div>
            <p class="intro-text" id="introText">Field Study Journal No. 7 — Subject: Daniele D'Agnelli</p>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <main class="journal" id="journal">

        <!-- JOURNAL COVER -->
        <header class="journal-cover reveal">
            <svg class="vine-border-top" viewBox="0 0 800 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path class="vine-path" d="M0 20 C100 5, 200 35, 300 20 C400 5, 500 35, 600 20 C700 5, 800 20, 800 20" stroke="#4a7c29" stroke-width="2" fill="none" />
                <circle cx="150" cy="12" r="4" fill="#2d5016" class="vine-dot" />
                <circle cx="400" cy="28" r="4" fill="#2d5016" class="vine-dot" />
                <circle cx="650" cy="12" r="4" fill="#2d5016" class="vine-dot" />
            </svg>

            <div class="cover-content">
                <div class="cover-photo-frame">
                    <img src="/assets/dani.jpeg" alt="Daniele D'Agnelli" width="180" height="180" class="cover-photo" />
                    <span class="photo-caption">Specimen Collector, circa present day</span>
                </div>
                <div class="cover-text">
                    <p class="cover-subtitle">The Royal Society of Professional Cultivation</p>
                    <h1 class="cover-title">Botanical Field Journal</h1>
                    <p class="cover-subject">Subject: {siteMetadata.name}</p>
                    <div class="cover-meta">
                        <span class="meta-item">Location: {siteMetadata.location}</span>
                        <span class="meta-item">Classification: {siteMetadata.description}</span>
                    </div>
                    <div class="cover-links">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener" class="journal-link">Herbarium Archive</a>
                        <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener" class="journal-link">Society Register</a>
                        <a href={`mailto:${siteMetadata.email}`} class="journal-link">Send Correspondence</a>
                    </div>
                </div>
            </div>

            <svg class="vine-border-bottom" viewBox="0 0 800 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path class="vine-path" d="M0 20 C100 35, 200 5, 300 20 C400 35, 500 5, 600 20 C700 35, 800 20, 800 20" stroke="#4a7c29" stroke-width="2" fill="none" />
                <circle cx="200" cy="28" r="4" fill="#2d5016" class="vine-dot" />
                <circle cx="500" cy="8" r="4" fill="#2d5016" class="vine-dot" />
                <circle cx="750" cy="25" r="4" fill="#2d5016" class="vine-dot" />
            </svg>
        </header>

        <!-- BOTANICAL DIVIDER -->
        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M85 15 C90 5, 100 2, 100 15 C100 2, 110 5, 115 15 C110 25, 100 28, 100 15 C100 28, 90 25, 85 15Z" fill="none" stroke="#2d5016" stroke-width="1.5" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- GARDEN OVERVIEW (summary) -->
        <section class="journal-section reveal" data-section="summary">
            <h2 class="section-heading">Garden Overview</h2>
            <p class="annotation">Initial observations upon first survey of the grounds</p>
            <div class="journal-page">
                <p class="body-text">{summary}</p>
                <div class="metrics-row">
                    {metrics.map(m => (
                        <div class="metric-card">
                            <span class="metric-value">{m.value}</span>
                            <span class="metric-label">{m.label}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M90 8 C95 15, 100 20, 100 15 M100 15 C100 20, 105 15, 110 8" fill="none" stroke="#2d5016" stroke-width="1.5" />
                <path d="M95 22 L100 10 L105 22" fill="none" stroke="#4a7c29" stroke-width="1" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- GROWTH SEASONS (experience) -->
        <section class="journal-section reveal" data-section="experience">
            <h2 class="section-heading">Growth Seasons</h2>
            <p class="annotation">A chronological record of cultivation periods and their yields</p>
            <div class="journal-page">
                <div class="timeline">
                    {experience.map((exp, i) => (
                        <div class="timeline-entry reveal">
                            <div class="timeline-marker">
                                <svg viewBox="0 0 24 24" class="leaf-icon" aria-hidden="true">
                                    <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22L6.66 19.7C7.14 19.87 7.64 20 8 20C19 20 22 3 22 3C21 5 14 5.25 9 6.25C4 7.25 2 11.5 2 13.5C2 15.5 3.75 17.25 3.75 17.25" fill="none" stroke="#2d5016" stroke-width="1.5" stroke-linecap="round" />
                                </svg>
                            </div>
                            <div class="timeline-content">
                                <div class="season-header">
                                    <h3 class="season-company">{exp.company}</h3>
                                    <span class="season-location">{exp.location}</span>
                                </div>
                                {exp.roles.map(role => (
                                    <div class="season-role">
                                        <div class="role-header">
                                            <span class="role-title">{role.title}</span>
                                            <span class="role-period">{role.period}</span>
                                        </div>
                                        {role.description && <p class="role-description">{role.description}</p>}
                                        {role.bullets && role.bullets.length > 0 && (
                                            <ul class="role-bullets">
                                                {role.bullets.map(b => <li>{b}</li>)}
                                            </ul>
                                        )}
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <circle cx="100" cy="15" r="8" fill="none" stroke="#2d5016" stroke-width="1.5" />
                <circle cx="100" cy="15" r="3" fill="#c4a35a" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- SPECIES CATALOG (skills) -->
        <section class="journal-section reveal" data-section="skills">
            <h2 class="section-heading">Species Catalog</h2>
            <p class="annotation">Documented specimens observed across all field expeditions</p>
            <div class="journal-page">
                <h3 class="catalog-subhead">Technical Specimens</h3>
                <div class="catalog-grid">
                    {skills.map((skill, i) => (
                        <div class="catalog-card reveal">
                            <span class="specimen-number">No. {String(i + 1).padStart(2, '0')}</span>
                            <span class="specimen-name">{skill}</span>
                        </div>
                    ))}
                </div>
                <h3 class="catalog-subhead">Cultivar Management Varieties</h3>
                <div class="catalog-grid">
                    {managementSkills.map((skill, i) => (
                        <div class="catalog-card reveal">
                            <span class="specimen-number">No. {String(skills.length + i + 1).padStart(2, '0')}</span>
                            <span class="specimen-name">{skill}</span>
                        </div>
                    ))}
                </div>
                <h3 class="catalog-subhead">Terrain Classifications</h3>
                <div class="terrain-tags">
                    {industries.map(ind => (
                        <span class="terrain-tag">{ind}</span>
                    ))}
                </div>
                <h3 class="catalog-subhead">Linguistic Adaptations</h3>
                <div class="terrain-tags">
                    {languages.map(lang => (
                        <span class="terrain-tag">{lang}</span>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M88 10 Q94 5 100 10 Q106 5 112 10 Q106 20 100 25 Q94 20 88 10Z" fill="none" stroke="#2d5016" stroke-width="1.5" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- FIELD STUDIES (engagements) -->
        <section class="journal-section reveal" data-section="engagements">
            <h2 class="section-heading">Field Studies</h2>
            <p class="annotation">Detailed accounts of notable expeditions and their botanical impact</p>
            <div class="journal-page">
                <div class="field-studies">
                    {engagements.map((eng, i) => (
                        <div class="field-study-card reveal">
                            <div class="study-number">Study {String(i + 1).padStart(2, '0')}</div>
                            <div class="study-body">
                                <div class="study-header">
                                    <span class="study-client">{eng.client}</span>
                                    <span class="study-sector">{eng.sector}</span>
                                </div>
                                <div class="study-details">
                                    <span class="study-scope"><strong>Scope:</strong> {eng.scope}</span>
                                    <span class="study-impact"><strong>Yield:</strong> {eng.impact}</span>
                                </div>
                                <div class={`study-trend trend-${eng.trend}`}>
                                    {eng.trend === 'positive' ? 'Flourishing' : 'Established'}
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M92 8 L100 22 L108 8" fill="none" stroke="#2d5016" stroke-width="1.5" />
                <path d="M96 15 L104 15" stroke="#4a7c29" stroke-width="1" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- ROOT SYSTEM (education) -->
        <section class="journal-section reveal" data-section="education">
            <h2 class="section-heading">Root System</h2>
            <p class="annotation">The foundational root structure from which all growth extends</p>
            <div class="journal-page">
                <div class="root-system">
                    <div class="root-trunk" aria-hidden="true">
                        <svg viewBox="0 0 40 100" class="root-svg">
                            <path d="M20 0 L20 30 C15 50, 5 60, 3 80 M20 30 C25 50, 35 60, 37 80 M20 30 L20 100" stroke="#5c3d2e" stroke-width="2.5" fill="none" stroke-linecap="round" />
                        </svg>
                    </div>
                    {education.map(edu => (
                        <div class="root-entry reveal">
                            <div class="root-node" aria-hidden="true"></div>
                            <div class="root-content">
                                <h3 class="root-institution">{edu.institution}</h3>
                                <p class="root-degree">{edu.degree}</p>
                                <div class="root-meta">
                                    <span>{edu.period}</span>
                                    <span>{edu.location}</span>
                                    {edu.distinction && <span class="root-distinction">{edu.distinction}</span>}
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M95 8 A8 8 0 1 1 105 8 A8 8 0 1 1 95 8Z" fill="none" stroke="#c4a35a" stroke-width="1.5" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- SOCIETY MEMBERSHIPS (certifications) -->
        <section class="journal-section reveal" data-section="certifications">
            <h2 class="section-heading">Society Memberships</h2>
            <p class="annotation">Formal recognitions bestowed by learned institutions</p>
            <div class="journal-page">
                <div class="memberships-grid">
                    {certifications.map(cert => (
                        <div class="membership-badge reveal">
                            <div class="badge-seal" aria-hidden="true">
                                <svg viewBox="0 0 60 60" class="seal-svg">
                                    <circle cx="30" cy="30" r="26" fill="none" stroke="#c4a35a" stroke-width="1.5" />
                                    <circle cx="30" cy="30" r="22" fill="none" stroke="#c4a35a" stroke-width="0.5" stroke-dasharray="3,3" />
                                    <circle cx="30" cy="30" r="5" fill="#c4a35a" opacity="0.3" />
                                </svg>
                            </div>
                            <span class="badge-name">{cert}</span>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <div class="botanical-divider" aria-hidden="true">
            <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="15" x2="70" y2="15" stroke="#c4a35a" stroke-width="1" />
                <path d="M93 10 Q100 25, 107 10 M96 12 Q100 22, 104 12" fill="none" stroke="#2d5016" stroke-width="1" />
                <line x1="130" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
            </svg>
        </div>

        <!-- SEASONAL STUDIES (continuousLearning) -->
        <section class="journal-section reveal" data-section="training">
            <h2 class="section-heading">Seasonal Studies</h2>
            <p class="annotation">Ongoing investigations into emerging species and methodologies</p>
            <div class="journal-page">
                <ul class="seasonal-list">
                    {continuousLearning.map((item, i) => (
                        <li class="seasonal-item reveal">
                            <span class="seasonal-marker" aria-hidden="true">
                                <svg viewBox="0 0 16 16">
                                    <path d="M8 2 C6 4, 3 6, 3 9 C3 12, 5 14, 8 14 C11 14, 13 12, 13 9 C13 6, 10 4, 8 2Z" fill="none" stroke="#2d5016" stroke-width="1.2" />
                                    <line x1="8" y1="7" x2="8" y2="12" stroke="#4a7c29" stroke-width="0.8" />
                                </svg>
                            </span>
                            <span class="seasonal-text">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="journal-footer">
            <div class="botanical-divider" aria-hidden="true">
                <svg viewBox="0 0 200 30" xmlns="http://www.w3.org/2000/svg">
                    <line x1="0" y1="15" x2="60" y2="15" stroke="#c4a35a" stroke-width="1" />
                    <path d="M75 15 C80 5, 90 2, 100 8 C110 2, 120 5, 125 15 C120 25, 110 28, 100 22 C90 28, 80 25, 75 15Z" fill="none" stroke="#2d5016" stroke-width="1.5" />
                    <circle cx="100" cy="15" r="3" fill="#c4a35a" opacity="0.5" />
                    <line x1="140" y1="15" x2="200" y2="15" stroke="#c4a35a" stroke-width="1" />
                </svg>
            </div>

            <div class="pressed-flower" aria-hidden="true">
                <svg viewBox="0 0 120 140" class="flower-svg">
                    <!-- stem -->
                    <line x1="60" y1="70" x2="60" y2="135" stroke="#4a7c29" stroke-width="1.5" />
                    <!-- leaves on stem -->
                    <path d="M60 95 C50 88, 42 82, 45 78 C48 74, 55 80, 60 95" fill="#2d5016" opacity="0.4" />
                    <path d="M60 110 C70 103, 78 97, 75 93 C72 89, 65 95, 60 110" fill="#2d5016" opacity="0.3" />
                    <!-- petals -->
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.25" transform="rotate(0,60,60)" />
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.2" transform="rotate(60,60,60)" />
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.2" transform="rotate(120,60,60)" />
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.25" transform="rotate(180,60,60)" />
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.2" transform="rotate(240,60,60)" />
                    <ellipse cx="60" cy="45" rx="10" ry="22" fill="#c4a35a" opacity="0.2" transform="rotate(300,60,60)" />
                    <!-- center -->
                    <circle cx="60" cy="60" r="8" fill="#5c3d2e" opacity="0.35" />
                    <circle cx="60" cy="60" r="4" fill="#c4a35a" opacity="0.4" />
                </svg>
            </div>

            <p class="footer-end">End of Field Study</p>
            <p class="footer-note">Compiled with great care and botanical rigour</p>
            <div class="footer-links">
                <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">Herbarium</a>
                <span class="footer-sep" aria-hidden="true">&mdash;</span>
                <a href={`https://www.linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">Society Register</a>
                <span class="footer-sep" aria-hidden="true">&mdash;</span>
                <a href={`mailto:${siteMetadata.email}`}>Correspondence</a>
            </div>
            <p class="footer-copy">&copy; {new Date().getFullYear()} {siteMetadata.name}. All specimens catalogued.</p>
        </footer>

    </main>

</body>
</html>

<style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --parchment: #f4e9d2;
        --earth: #5c3d2e;
        --dark-green: #2d5016;
        --mid-green: #4a7c29;
        --gold: #c4a35a;
        --sage: #e8e0c8;
        --parchment-dark: #e6d9be;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Lora', Georgia, serif;
        background: var(--parchment);
        color: var(--earth);
        line-height: 1.7;
        overflow-x: hidden;
        min-height: 100vh;
    }

    /* ===== INTRO SEQUENCE ===== */
    .intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: var(--earth);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.8s ease, visibility 0.8s ease;
    }

    .intro.done {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }

    .intro-inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .sprout-svg {
        width: 80px;
        height: 160px;
    }

    .sprout-svg .stem {
        stroke-dasharray: 120;
        stroke-dashoffset: 120;
        animation: growStem 1.5s ease-out 0.3s forwards;
    }

    .sprout-svg .leaf-left {
        animation: unfurlLeaf 0.6s ease-out 1.4s forwards;
    }

    .sprout-svg .leaf-right {
        animation: unfurlLeaf 0.6s ease-out 1.7s forwards;
    }

    .sprout-svg .seed {
        animation: seedPulse 0.5s ease-in-out 0s forwards;
    }

    @keyframes growStem {
        to { stroke-dashoffset: 0; }
    }

    @keyframes unfurlLeaf {
        from { opacity: 0; transform: scale(0.3); }
        to { opacity: 1; transform: scale(1); }
    }

    @keyframes seedPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }

    .intro-cracks {
        position: fixed;
        inset: 0;
        pointer-events: none;
    }

    .crack {
        position: absolute;
        background: var(--parchment);
        opacity: 0;
    }

    .crack-1 {
        top: 0; left: 0; right: 50%; bottom: 50%;
        transform-origin: bottom right;
        animation: crackReveal 0.6s ease-out 2.2s forwards;
    }

    .crack-2 {
        top: 0; left: 50%; right: 0; bottom: 50%;
        transform-origin: bottom left;
        animation: crackReveal 0.6s ease-out 2.3s forwards;
    }

    .crack-3 {
        top: 50%; left: 0; right: 50%; bottom: 0;
        transform-origin: top right;
        animation: crackReveal 0.6s ease-out 2.4s forwards;
    }

    .crack-4 {
        top: 50%; left: 50%; right: 0; bottom: 0;
        transform-origin: top left;
        animation: crackReveal 0.6s ease-out 2.5s forwards;
    }

    @keyframes crackReveal {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }

    .intro-text {
        font-family: 'Caveat', cursive;
        font-size: 1.6rem;
        color: var(--parchment);
        opacity: 0;
        text-align: center;
        padding: 0 1rem;
        animation: fadeInText 0.8s ease-out 1.8s forwards;
    }

    @keyframes fadeInText {
        to { opacity: 1; }
    }

    /* ===== FALLING LEAVES ===== */
    .leaves-container {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 100;
        overflow: hidden;
    }

    .leaf {
        position: absolute;
        font-size: 1.2rem;
        opacity: 0.5;
        top: -40px;
        animation: leafFall linear infinite;
    }

    .leaf-1 { left: 8%; animation-duration: 14s; animation-delay: 0s; font-size: 1rem; }
    .leaf-2 { left: 22%; animation-duration: 18s; animation-delay: 3s; font-size: 1.4rem; }
    .leaf-3 { left: 45%; animation-duration: 16s; animation-delay: 6s; }
    .leaf-4 { left: 62%; animation-duration: 20s; animation-delay: 2s; font-size: 1.1rem; }
    .leaf-5 { left: 78%; animation-duration: 15s; animation-delay: 8s; font-size: 1.3rem; }
    .leaf-6 { left: 35%; animation-duration: 22s; animation-delay: 5s; font-size: 0.9rem; }
    .leaf-7 { left: 90%; animation-duration: 17s; animation-delay: 10s; }

    @keyframes leafFall {
        0% {
            transform: translateY(0) translateX(0) rotate(0deg);
            opacity: 0;
        }
        5% {
            opacity: 0.45;
        }
        25% {
            transform: translateY(25vh) translateX(30px) rotate(90deg);
        }
        50% {
            transform: translateY(50vh) translateX(-20px) rotate(180deg);
        }
        75% {
            transform: translateY(75vh) translateX(25px) rotate(270deg);
        }
        95% {
            opacity: 0.4;
        }
        100% {
            transform: translateY(105vh) translateX(-10px) rotate(360deg);
            opacity: 0;
        }
    }

    /* ===== JOURNAL MAIN ===== */
    .journal {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 2rem 2rem;
        opacity: 0;
        transition: opacity 0.6s ease;
    }

    .journal.visible {
        opacity: 1;
    }

    /* ===== JOURNAL COVER ===== */
    .journal-cover {
        text-align: center;
        padding: 2.5rem 2rem;
        margin-bottom: 2rem;
    }

    .vine-border-top, .vine-border-bottom {
        width: 100%;
        height: 40px;
        display: block;
    }

    .vine-path {
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
    }

    .vine-border-top.animated .vine-path,
    .vine-border-bottom.animated .vine-path {
        animation: vineGrow 2s ease forwards;
    }

    @keyframes vineGrow {
        to { stroke-dashoffset: 0; }
    }

    .vine-dot {
        opacity: 0;
    }

    .vine-border-top.animated .vine-dot,
    .vine-border-bottom.animated .vine-dot {
        animation: dotAppear 0.3s ease forwards 1.5s;
    }

    @keyframes dotAppear {
        to { opacity: 1; }
    }

    .cover-content {
        display: flex;
        align-items: center;
        gap: 2.5rem;
        padding: 2rem 0;
        text-align: left;
    }

    .cover-photo-frame {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .cover-photo {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 4px;
        border: 4px solid var(--earth);
        padding: 4px;
        background: var(--sage);
        filter: sepia(0.35) contrast(1.05);
        box-shadow: 3px 3px 12px rgba(92, 61, 46, 0.25);
    }

    .photo-caption {
        font-family: 'Caveat', cursive;
        font-size: 0.85rem;
        color: var(--earth);
        opacity: 0.7;
    }

    .cover-text {
        flex: 1;
    }

    .cover-subtitle {
        font-family: 'Lora', serif;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 0.25rem;
    }

    .cover-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.8rem;
        font-weight: 900;
        color: var(--dark-green);
        line-height: 1.15;
        margin-bottom: 0.5rem;
    }

    .cover-subject {
        font-family: 'Caveat', cursive;
        font-size: 1.5rem;
        color: var(--earth);
        margin-bottom: 0.75rem;
    }

    .cover-meta {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        margin-bottom: 1rem;
    }

    .meta-item {
        font-size: 0.85rem;
        color: var(--earth);
        opacity: 0.8;
    }

    .cover-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .journal-link {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        color: var(--dark-green);
        text-decoration: none;
        border: 1px solid var(--dark-green);
        padding: 0.35rem 0.9rem;
        border-radius: 2px;
        transition: all 0.2s ease;
    }

    .journal-link:hover {
        background: var(--dark-green);
        color: var(--parchment);
    }

    /* ===== BOTANICAL DIVIDERS ===== */
    .botanical-divider {
        display: flex;
        justify-content: center;
        padding: 1.5rem 0;
    }

    .botanical-divider svg {
        width: 200px;
        height: 30px;
    }

    /* ===== JOURNAL SECTIONS ===== */
    .journal-section {
        margin-bottom: 1rem;
    }

    .section-heading {
        font-family: 'Caveat', cursive;
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--dark-green);
        text-align: center;
        margin-bottom: 0.25rem;
    }

    .annotation {
        font-family: 'Caveat', cursive;
        font-size: 1.05rem;
        color: var(--earth);
        opacity: 0.65;
        text-align: center;
        font-style: italic;
        margin-bottom: 1.5rem;
    }

    .journal-page {
        background: var(--sage);
        border: 1px solid var(--gold);
        padding: 2rem;
        position: relative;
        clip-path: polygon(
            0% 2%, 3% 0%, 8% 1%, 15% 0%, 22% 0.5%, 30% 0%, 40% 0.8%, 50% 0%, 60% 0.5%, 70% 0%, 78% 1%, 85% 0%, 92% 0.5%, 97% 0%, 100% 1.5%,
            100% 98%, 97% 100%, 92% 99%, 85% 100%, 78% 99.5%, 70% 100%, 60% 99%, 50% 100%, 40% 99.5%, 30% 100%, 22% 99%, 15% 100%, 8% 99.5%, 3% 100%, 0% 98.5%
        );
    }

    .journal-page::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: repeating-linear-gradient(
            transparent,
            transparent 28px,
            rgba(92, 61, 46, 0.06) 28px,
            rgba(92, 61, 46, 0.06) 29px
        );
        pointer-events: none;
    }

    .body-text {
        font-size: 0.95rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
    }

    /* ===== METRICS ===== */
    .metrics-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 1rem;
    }

    .metric-card {
        text-align: center;
        padding: 1rem 0.5rem;
        border: 1px double var(--gold);
        border-radius: 2px;
    }

    .metric-value {
        display: block;
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark-green);
    }

    .metric-label {
        display: block;
        font-family: 'Caveat', cursive;
        font-size: 0.95rem;
        color: var(--earth);
        opacity: 0.75;
        margin-top: 0.2rem;
    }

    /* ===== TIMELINE (Growth Seasons) ===== */
    .timeline {
        position: relative;
        padding-left: 2.5rem;
    }

    .timeline::before {
        content: '';
        position: absolute;
        left: 12px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(to bottom, var(--dark-green), var(--mid-green), var(--dark-green));
    }

    .timeline-entry {
        position: relative;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px dashed rgba(92, 61, 46, 0.15);
    }

    .timeline-entry:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .timeline-marker {
        position: absolute;
        left: -2.5rem;
        top: 0.25rem;
        width: 26px;
        height: 26px;
        background: var(--sage);
        border: 2px solid var(--dark-green);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .leaf-icon {
        width: 16px;
        height: 16px;
    }

    .season-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .season-company {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--dark-green);
    }

    .season-location {
        font-family: 'Caveat', cursive;
        font-size: 1rem;
        color: var(--earth);
        opacity: 0.7;
    }

    .season-role {
        margin-bottom: 0.75rem;
    }

    .role-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
    }

    .role-title {
        font-family: 'Lora', serif;
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--earth);
    }

    .role-period {
        font-family: 'Caveat', cursive;
        font-size: 0.9rem;
        color: var(--gold);
    }

    .role-description {
        font-size: 0.88rem;
        line-height: 1.7;
        margin-bottom: 0.5rem;
        opacity: 0.85;
    }

    .role-bullets {
        list-style: none;
        padding: 0;
    }

    .role-bullets li {
        font-size: 0.88rem;
        line-height: 1.6;
        padding-left: 1.2rem;
        position: relative;
        margin-bottom: 0.25rem;
    }

    .role-bullets li::before {
        content: '\273F';
        position: absolute;
        left: 0;
        color: var(--mid-green);
        font-size: 0.8rem;
    }

    /* ===== SPECIES CATALOG (skills) ===== */
    .catalog-subhead {
        font-family: 'Caveat', cursive;
        font-size: 1.3rem;
        color: var(--earth);
        margin-bottom: 0.75rem;
        margin-top: 1.5rem;
        border-bottom: 1px solid var(--gold);
        padding-bottom: 0.3rem;
    }

    .catalog-subhead:first-child {
        margin-top: 0;
    }

    .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
        gap: 0.75rem;
    }

    .catalog-card {
        border: 2px double var(--earth);
        padding: 0.6rem 0.8rem;
        text-align: center;
        background: var(--parchment);
        position: relative;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .catalog-card:hover {
        transform: translateY(-2px);
        box-shadow: 2px 2px 8px rgba(92, 61, 46, 0.15);
    }

    .specimen-number {
        display: block;
        font-family: 'Caveat', cursive;
        font-size: 0.75rem;
        color: var(--gold);
        margin-bottom: 0.15rem;
    }

    .specimen-name {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        color: var(--dark-green);
        font-weight: 600;
    }

    .terrain-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .terrain-tag {
        font-family: 'Lora', serif;
        font-size: 0.8rem;
        padding: 0.3rem 0.75rem;
        border: 1px solid var(--mid-green);
        color: var(--dark-green);
        border-radius: 2px;
        background: rgba(45, 80, 22, 0.05);
    }

    /* ===== FIELD STUDIES (engagements) ===== */
    .field-studies {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .field-study-card {
        display: flex;
        gap: 1rem;
        border: 1px solid var(--gold);
        background: var(--parchment);
        padding: 1.25rem;
        align-items: flex-start;
    }

    .study-number {
        font-family: 'Caveat', cursive;
        font-size: 1rem;
        color: var(--gold);
        white-space: nowrap;
        flex-shrink: 0;
        padding-top: 0.15rem;
    }

    .study-body {
        flex: 1;
    }

    .study-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.4rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .study-client {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: var(--dark-green);
        font-size: 1.05rem;
        text-transform: capitalize;
    }

    .study-sector {
        font-family: 'Caveat', cursive;
        font-size: 0.9rem;
        color: var(--earth);
        opacity: 0.7;
    }

    .study-details {
        display: flex;
        gap: 1.5rem;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
    }

    .study-trend {
        font-family: 'Caveat', cursive;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .trend-positive { color: var(--dark-green); }
    .trend-neutral { color: var(--gold); }

    /* ===== ROOT SYSTEM (education) ===== */
    .root-system {
        position: relative;
        padding-left: 3rem;
    }

    .root-trunk {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 40px;
    }

    .root-svg {
        width: 40px;
        height: 100%;
    }

    .root-entry {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .root-entry:last-child {
        margin-bottom: 0;
    }

    .root-node {
        position: absolute;
        left: -2.35rem;
        top: 0.5rem;
        width: 14px;
        height: 14px;
        background: var(--earth);
        border-radius: 50%;
        border: 2px solid var(--gold);
    }

    .root-institution {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--dark-green);
        margin-bottom: 0.15rem;
    }

    .root-degree {
        font-family: 'Lora', serif;
        font-size: 0.9rem;
        margin-bottom: 0.3rem;
    }

    .root-meta {
        display: flex;
        gap: 1rem;
        font-family: 'Caveat', cursive;
        font-size: 0.95rem;
        color: var(--earth);
        opacity: 0.75;
        flex-wrap: wrap;
    }

    .root-distinction {
        color: var(--dark-green);
        font-weight: 700;
        opacity: 1;
        border: 1px solid var(--gold);
        padding: 0 0.4rem;
        border-radius: 2px;
    }

    /* ===== SOCIETY MEMBERSHIPS (certifications) ===== */
    .memberships-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.25rem;
    }

    .membership-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 1.25rem 0.75rem;
        border: 1px solid var(--gold);
        background: var(--parchment);
    }

    .badge-seal {
        margin-bottom: 0.75rem;
    }

    .seal-svg {
        width: 50px;
        height: 50px;
    }

    .badge-name {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--dark-green);
    }

    /* ===== SEASONAL STUDIES (continuousLearning) ===== */
    .seasonal-list {
        list-style: none;
        padding: 0;
    }

    .seasonal-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0;
        border-bottom: 1px dashed rgba(92, 61, 46, 0.12);
    }

    .seasonal-item:last-child {
        border-bottom: none;
    }

    .seasonal-marker {
        flex-shrink: 0;
        width: 18px;
        height: 18px;
    }

    .seasonal-marker svg {
        width: 18px;
        height: 18px;
    }

    .seasonal-text {
        font-size: 0.9rem;
        color: var(--earth);
    }

    /* ===== FOOTER ===== */
    .journal-footer {
        text-align: center;
        padding: 2rem 0 3rem;
        margin-top: 2rem;
    }

    .pressed-flower {
        margin: 1rem auto;
    }

    .flower-svg {
        width: 80px;
        height: 100px;
        opacity: 0.6;
    }

    .footer-end {
        font-family: 'Caveat', cursive;
        font-size: 1.6rem;
        color: var(--dark-green);
        margin-bottom: 0.25rem;
    }

    .footer-note {
        font-family: 'Caveat', cursive;
        font-size: 1rem;
        color: var(--earth);
        opacity: 0.6;
        margin-bottom: 1.25rem;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .footer-links a {
        font-family: 'Lora', serif;
        font-size: 0.85rem;
        color: var(--dark-green);
        text-decoration: none;
        border-bottom: 1px solid var(--gold);
        padding-bottom: 2px;
        transition: color 0.2s ease;
    }

    .footer-links a:hover {
        color: var(--mid-green);
    }

    .footer-sep {
        color: var(--gold);
        font-size: 0.75rem;
    }

    .footer-copy {
        font-size: 0.75rem;
        color: var(--earth);
        opacity: 0.5;
    }

    /* ===== SCROLL REVEAL ===== */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* ===== RESPONSIVE: 1200px ===== */
    @media (max-width: 1200px) {
        .journal {
            max-width: 760px;
        }
    }

    /* ===== RESPONSIVE: 768px ===== */
    @media (max-width: 768px) {
        .journal {
            padding: 2rem 1.25rem;
        }

        .cover-content {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
        }

        .cover-text {
            text-align: center;
        }

        .cover-title {
            font-size: 2.2rem;
        }

        .cover-links {
            justify-content: center;
        }

        .cover-meta {
            align-items: center;
        }

        .cover-photo {
            width: 150px;
            height: 150px;
        }

        .journal-page {
            padding: 1.5rem;
        }

        .section-heading {
            font-size: 1.9rem;
        }

        .metrics-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .catalog-grid {
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        }

        .memberships-grid {
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        }

        .season-header {
            flex-direction: column;
            gap: 0.15rem;
        }

        .role-header {
            flex-direction: column;
            gap: 0.15rem;
        }

        .field-study-card {
            flex-direction: column;
            gap: 0.5rem;
        }

        .study-details {
            flex-direction: column;
            gap: 0.3rem;
        }
    }

    /* ===== RESPONSIVE: 480px ===== */
    @media (max-width: 480px) {
        .journal {
            padding: 1.5rem 1rem;
        }

        .cover-title {
            font-size: 1.75rem;
        }

        .cover-subject {
            font-size: 1.2rem;
        }

        .cover-photo {
            width: 130px;
            height: 130px;
        }

        .section-heading {
            font-size: 1.6rem;
        }

        .journal-page {
            padding: 1.25rem 1rem;
        }

        .metrics-row {
