        font-size: 12px;
        color: var(--white);
    }

    /* ===== RESEARCH ===== */
    .research-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid #00a8ff08;
    }
    .research-item:last-child { border-bottom: none; }
    .research-marker {
        color: var(--electric);
        font-weight: 700;
        flex-shrink: 0;
    }
    .research-name {
        font-size: 13px;
        color: #c0c8e0;
    }

    /* ===== METRICS ===== */
    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 14px;
    }
    .metric-card {
        text-align: center;
        padding: 18px 12px;
        border: 1px solid var(--panel-border);
        border-radius: 4px;
        background: #0a0e2766;
