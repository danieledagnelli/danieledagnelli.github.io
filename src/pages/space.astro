    /* ===== FOOTER ===== */
    .mission-footer {
        text-align: center;
        padding: 60px 20px 40px;
    }
    .footer-transmission {
        font-family: 'Exo 2', sans-serif;
        font-size: 14px;
        font-weight: 700;
        color: var(--dim-blue);
        letter-spacing: 3px;
        margin-bottom: 12px;
    }
    .footer-lost {
        font-size: 13px;
        color: var(--electric);
        margin-bottom: 24px;
    }
    .blink-cursor { animation: blink 1s step-end infinite; }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    .footer-links {
        display: flex;
        justify-content: center;
        gap: 20px;
    }
    .footer-links a {
        font-size: 12px;
        letter-spacing: 1px;
        color: var(--dim-blue);
    }
    .footer-links a:hover { color: var(--electric); }

    /* ===== SCROLL REVEAL ===== */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* ===== RESPONSIVE: 1200px ===== */
    @media (max-width: 1200px) {
        .mission-content { max-width: 800px; }
        .radar { width: 100px; height: 100px; }
    }

    /* ===== RESPONSIVE: 768px ===== */
    @media (max-width: 768px) {
        body { font-size: 13px; }
        .mission-content { padding: 80px 16px 40px; }
        .dossier-grid {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
        }
        .dossier-photo { order: -1; }
        .commander-meta { justify-content: center; }
        .commander-links { justify-content: center; }
        .systems-grid { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
        .expeditions-grid { grid-template-columns: 1fr; }
        .quals-grid { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
        .metrics-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
        .radar { width: 80px; height: 80px; bottom: 20px; right: 20px; }
        .hud-top-right { display: none; }
        .timeline-entry { grid-template-columns: 30px 1fr; gap: 10px; }
    }

    /* ===== RESPONSIVE: 480px ===== */
    @media (max-width: 480px) {
        .mission-content { padding: 70px 12px 30px; }
        .panel-body { padding: 16px 14px; }
        .panel-header { padding: 10px 14px; }
        .panel-tab { font-size: 11px; letter-spacing: 1px; }
        .commander-name { font-size: 22px; }
        .dossier-photo { width: 120px; height: 120px; }
        .systems-grid { grid-template-columns: 1fr; }
        .quals-grid { grid-template-columns: 1fr; }
        .timeline-entry { grid-template-columns: 1fr; }
        .timeline-connector { display: none; }
        .radar { display: none; }
        .hud-bottom-left { display: none; }
        .hud-top-left .hud-label { display: none; }
        .metrics-grid { grid-template-columns: repeat(2, 1fr); }
        .meta-tag { font-size: 9px; padding: 3px 8px; }
        .cmd-link { min-height: 44px; display: flex; align-items: center; }
        .expedition-card { padding: 14px; }
        .sector-tag { min-height: 44px; display: flex; align-items: center; }
    }

    /* ===== RESPONSIVE: 380px ===== */
    @media (max-width: 380px) {
        .mission-content { padding: 60px 8px 20px; }
        .panel-body { padding: 12px 10px; }
        .commander-name { font-size: 20px; }
        .dossier-photo { width: 100px; height: 100px; }
        .hud-top-left { top: 10px; left: 10px; }
        .metric-card { padding: 12px 8px; }
        .metric-value { font-size: 18px; }
        .briefing-text { font-size: 12px; }
        .footer-links { flex-direction: column; gap: 12px; }
        .footer-links a { min-height: 44px; display: flex; align-items: center; justify-content: center; }
    }
</style>

<script>
    // ===== INTRO SEQUENCE =====
    const intro = document.getElementById('intro');
    const countdown = document.getElementById('introCountdown');
    const flash = document.getElementById('introFlash');
    const boot = document.getElementById('introBoot');
    const content = document.getElementById('missionContent');

    const STORAGE_KEY = 'space-intro';
    let introSkipped = false;

    function skipIntro() {
        if (introSkipped) return;
        introSkipped = true;
        sessionStorage.setItem(STORAGE_KEY, 'done');
        intro?.classList.add('hidden');
        content?.classList.add('visible');
    }

    // Skip listeners
    document.addEventListener('keydown', (e) => {
        if (['Escape', ' ', 'Enter'].includes(e.key)) skipIntro();
    });
    intro?.addEventListener('click', skipIntro);

    if (sessionStorage.getItem(STORAGE_KEY) === 'done') {
        skipIntro();
    } else {
        runIntro();
    }

    async function runIntro() {
        // Countdown T-10 to T-0
        for (let i = 10; i >= 0; i--) {
            if (introSkipped) return;
            if (countdown) countdown.textContent = `T-${i}`;
            await sleep(i === 0 ? 200 : 180);
        }

        if (introSkipped) return;

        // Flash
        flash?.classList.add('active');
        await sleep(120);
        flash?.classList.remove('active');
        if (countdown) countdown.style.display = 'none';

        if (introSkipped) return;

        // Boot text
        const bootLines = [
            'Initializing navigation array...',
            'Propulsion systems nominal...',
            'Life support: ACTIVE...',
            'Comms relay: ONLINE...',
            'Loading crew manifest...',
            'Calibrating sensors...',
            'Mission dossier loaded.',
            '',
            '> READY'
        ];

        for (const line of bootLines) {
            if (introSkipped) return;
            for (let c = 0; c < line.length; c++) {
                if (introSkipped) return;
                if (boot) boot.textContent += line[c];
                await sleep(30);
            }
            if (boot) boot.textContent += '\n';
            await sleep(80);
        }

        await sleep(400);
        skipIntro();
    }

    function sleep(ms: number) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    // ===== MISSION CLOCK =====
    const clockEl = document.getElementById('hudClock');
    function updateClock() {
        const now = new Date();
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        if (clockEl) clockEl.textContent = `${h}:${m}:${s}`;
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ===== ALTITUDE (SCROLL %) =====
    const altEl = document.getElementById('hudAltitude');
    function updateAltitude() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docHeight > 0 ? scrollTop / docHeight : 0;
        const km = Math.floor(pct * 100000);
        const formatted = km.toLocaleString('en-US');
        if (altEl) altEl.textContent = `ALT: ${formatted} KM`;
    }
    window.addEventListener('scroll', updateAltitude, { passive: true });
    updateAltitude();

    // ===== SIGNAL BARS ANIMATION =====
    const sigBars = document.querySelectorAll('.sig-bar');
    function animateSignal() {
        const active = 3 + Math.floor(Math.random() * 3); // 3-5 active
        sigBars.forEach((bar, i) => {
            bar.classList.toggle('active', i < active);
        });
    }
    setInterval(animateSignal, 2000);

    // ===== SCROLL REVEAL =====
    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ===== STARFIELD CANVAS =====
    const canvas = document.getElementById('starfield') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');

    interface Star {
        x: number;
        y: number;
        size: number;
        baseOpacity: number;
        twinkleSpeed: number;
        twinkleOffset: number;
        depth: number;
    }

    let stars: Star[] = [];
    let scrollY = 0;
    let animFrame: number;

    function initStarfield() {
        if (!canvas || !ctx) return;
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const count = Math.min(300, Math.max(200, Math.floor(window.innerWidth * 0.2)));
        stars = [];
        for (let i = 0; i < count; i++) {
            stars.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 1.8 + 0.4,
                baseOpacity: Math.random() * 0.6 + 0.2,
                twinkleSpeed: Math.random() * 0.003 + 0.001,
                twinkleOffset: Math.random() * Math.PI * 2,
                depth: Math.random() * 0.8 + 0.2,
            });
        }
    }

    function drawStars(time: number) {
        if (!canvas || !ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (const star of stars) {
            const parallaxY = (scrollY * star.depth * 0.05) % canvas.height;
            let y = (star.y - parallaxY + canvas.height) % canvas.height;
            const twinkle = Math.sin(time * star.twinkleSpeed + star.twinkleOffset);
            const opacity = star.baseOpacity + twinkle * 0.25;

            ctx.beginPath();
            ctx.arc(star.x, y, star.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(220, 230, 255, ${Math.max(0.05, opacity)})`;
            ctx.fill();
        }

        animFrame = requestAnimationFrame(drawStars);
    }

    window.addEventListener('scroll', () => { scrollY = window.scrollY; }, { passive: true });
    window.addEventListener('resize', () => {
        if (canvas) {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
    });

    initStarfield();
    animFrame = requestAnimationFrame(drawStars);
</script>
