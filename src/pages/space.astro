    .subsystem-title:first-child { margin-top: 0; }
    .systems-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 8px;
    }
    .systems-grid.compact { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
    .system-item {
        display: flex;
        align-items: center;
