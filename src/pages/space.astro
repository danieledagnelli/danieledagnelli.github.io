---
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>Daniele D'Agnelli — Deep Space Mission Dossier</title>
    <meta name="description" content="Deep Space Mission Dossier — Daniele D'Agnelli's career presented as an interstellar spacecraft command terminal. 15+ years navigating digital frontiers." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/space" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Deep Space Mission Dossier" />
    <meta property="og:description" content="Interstellar mission dossier: 15+ years navigating complex digital transformations across AI, cybersecurity, and enterprise systems." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/space" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Deep Space Mission Dossier" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Deep Space Mission Dossier" />
    <meta name="twitter:description" content="Interstellar mission dossier: 15+ years navigating complex digital transformations." />
    <meta name="twitter:image" content="https://dagnelli.net/assets/og-image.png" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Exo+2:wght@300;400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
    <!-- STARFIELD CANVAS -->
    <canvas class="starfield" id="starfield" aria-hidden="true"></canvas>

    <!-- RADAR SWEEP -->
    <div class="radar" aria-hidden="true">
        <div class="radar-ring"></div>
        <div class="radar-ring radar-ring-2"></div>
        <div class="radar-sweep"></div>
        <div class="radar-dot"></div>
    </div>

    <!-- HUD READOUTS -->
    <div class="hud hud-top-left" aria-hidden="true">
        <span class="hud-label">MISSION CLOCK</span>
        <span class="hud-value" id="hudClock">00:00:00</span>
    </div>
    <div class="hud hud-top-right" aria-hidden="true">
        <span class="hud-label">ALTITUDE</span>
        <span class="hud-value" id="hudAltitude">ALT: 0 KM</span>
    </div>
    <div class="hud hud-bottom-left" aria-hidden="true">
        <span class="hud-label">SIGNAL STRENGTH</span>
        <div class="signal-bars" id="signalBars">
            <span class="sig-bar active"></span>
            <span class="sig-bar active"></span>
            <span class="sig-bar active"></span>
            <span class="sig-bar active"></span>
            <span class="sig-bar"></span>
        </div>
    </div>

    <!-- INTRO SEQUENCE -->
    <div class="intro" id="intro">
        <div class="intro-countdown" id="introCountdown"></div>
        <div class="intro-flash" id="introFlash"></div>
        <pre class="intro-boot" id="introBoot"></pre>
    </div>

    <!-- MAIN CONTENT -->
    <main class="mission-content" id="missionContent">

        <div class="space-narrative">
            <div class="mission-metrics">
                <h2 class="hud-title">MISSION METRICS</h2>
                <div class="metrics-grid">
                    <div class="metric"><span class="metric-value">$15M</span><span class="metric-label">programme directed</span></div>
                    <div class="metric"><span class="metric-value">$18M</span><span class="metric-label">ebit impact confirmed</span></div>
                    <div class="metric"><span class="metric-value">100+</span><span class="metric-label">plants deployed</span></div>
                    <div class="metric"><span class="metric-value">2,000+</span><span class="metric-label">end users online</span></div>
                    <div class="metric"><span class="metric-value">NPS>70</span><span class="metric-label">satisfaction sustained</span></div>
                    <div class="metric"><span class="metric-value">15</span><span class="metric-label">years in the field</span></div>
                </div>
            </div>
            <div class="mission-brief">
                <h2 class="hud-title">MISSION BRIEF</h2>
                <p>senior engagement manager. c3 ai, london. director-level programme lead across all business units. ceo-sponsored predictive maintenance rollout for swiss manufacturer. genai rag deployment. 20+ cross-functional team: app dev, data science, qa, devops.</p>
            </div>
            <div class="signal-footer">
                <span>SIGNAL:</span>
                <a href="mailto:daniele@dagnelli.net">daniele@dagnelli.net</a> |
                <a href="https://github.com/danieledagnelli">github</a> |
                <a href="https://linkedin.com/in/dagnelli">linkedin</a>
            </div>
        </div>

    </main>

<style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
        --void: #0a0e27;
        --electric: #00a8ff;
        --dim-blue: #0055aa;
        --white: #e8e8e8;
        --amber: #ff9500;
        --panel-bg: #0d1535;
        --panel-border: #00a8ff33;
        --grid-color: #00a8ff0a;
    }

    body {
        background: var(--void);
        color: var(--white);
        font-family: 'Space Mono', monospace;
        font-size: 14px;
        line-height: 1.7;
        overflow: hidden;
        height: 100dvh;
        background-image:
            linear-gradient(var(--grid-color) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
        background-size: 60px 60px;
    }

    a { color: var(--electric); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--amber); }

    /* ===== STARFIELD CANVAS ===== */
    .starfield {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    /* ===== RADAR ===== */
    .radar {
        position: fixed;
        bottom: 30px; right: 30px;
        width: 120px; height: 120px;
        border-radius: 50%;
        border: 1px solid var(--dim-blue);
        overflow: hidden;
        z-index: 50;
        opacity: 0.6;
        background: radial-gradient(circle, #0a0e2700 0%, #0a0e2744 100%);
    }
    .radar-ring {
        position: absolute;
        top: 50%; left: 50%;
        width: 60%; height: 60%;
        border: 1px solid var(--dim-blue);
        border-radius: 50%;
        transform: translate(-50%, -50%);
    }
    .radar-ring-2 {
        width: 30%; height: 30%;
    }
    .radar-sweep {
        position: absolute;
        top: 50%; left: 50%;
        width: 50%; height: 2px;
        background: linear-gradient(90deg, var(--electric), transparent);
        transform-origin: left center;
        animation: radarSweep 4s linear infinite;
    }
    .radar-dot {
        position: absolute;
        top: 30%; left: 60%;
        width: 4px; height: 4px;
        background: var(--electric);
        border-radius: 50%;
        animation: radarBlink 2s ease-in-out infinite;
    }
    @keyframes radarSweep { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes radarBlink { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }

    /* ===== HUD ===== */
    .hud {
        position: fixed;
        z-index: 100;
        font-family: 'Space Mono', monospace;
        font-size: 11px;
        letter-spacing: 1px;
        pointer-events: none;
    }
    .hud-label {
        display: block;
        color: var(--dim-blue);
        font-size: 9px;
        text-transform: uppercase;
        margin-bottom: 2px;
    }
    .hud-value {
        display: block;
        color: var(--electric);
        font-weight: 700;
        font-size: 13px;
    }
    .hud-top-left { top: 20px; left: 20px; }
    .hud-top-right { top: 20px; right: 20px; text-align: right; }
    .hud-bottom-left { bottom: 30px; left: 20px; }

    .signal-bars { display: flex; gap: 3px; margin-top: 4px; }
    .sig-bar {
        width: 6px; height: 14px;
        background: var(--dim-blue);
        border-radius: 1px;
        transition: background 0.3s;
    }
    .sig-bar:nth-child(2) { height: 18px; }
    .sig-bar:nth-child(3) { height: 22px; }
    .sig-bar:nth-child(4) { height: 26px; }
    .sig-bar:nth-child(5) { height: 30px; }
    .sig-bar.active { background: var(--electric); animation: sigPulse 3s ease-in-out infinite; }
    .sig-bar:nth-child(2).active { animation-delay: 0.2s; }
    .sig-bar:nth-child(3).active { animation-delay: 0.4s; }
    .sig-bar:nth-child(4).active { animation-delay: 0.6s; }
    @keyframes sigPulse { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }

    /* ===== INTRO ===== */
    .intro {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: #000;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    .intro.hidden { display: none; }
    .intro-countdown {
        font-family: 'Exo 2', sans-serif;
        font-size: clamp(48px, 12vw, 120px);
        font-weight: 800;
        color: var(--electric);
        text-align: center;
        text-shadow: 0 0 40px var(--electric), 0 0 80px #00a8ff44;
    }
    .intro-flash {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: #fff;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.1s;
    }
    .intro-flash.active { opacity: 0.8; }
    .intro-boot {
        font-family: 'Space Mono', monospace;
        font-size: 13px;
        color: var(--electric);
        line-height: 1.8;
        max-width: 600px;
        padding: 20px;
        white-space: pre-wrap;
    }

    /* ===== MAIN CONTENT ===== */
    .mission-content {
        position: relative;
        z-index: 10;
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.8s ease;
    }
    .mission-content.visible { opacity: 1; }

    /* ===== SPACE NARRATIVE ===== */
    .space-narrative {
        max-width: 650px;
        padding: 1.5rem;
        text-align: center;
    }

    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin: 1rem 0;
    }

    .metric-value {
        font-size: 1.4rem;
        font-weight: bold;
        display: block;
        color: var(--amber);
    }

    .metric-label {
        font-size: 0.7rem;
        opacity: 0.7;
        display: block;
    }

    .mission-brief p {
        font-size: 0.8rem;
        line-height: 1.5;
    }

    .hud-title {
        font-size: 0.8rem;
        letter-spacing: 0.2em;
        margin-bottom: 0.5rem;
        color: var(--electric);
    }

    .signal-footer {
        margin-top: 1rem;
        font-size: 0.7rem;
        opacity: 0.7;
    }

    .signal-footer a {
        text-decoration: none;
    }

    /* ===== RESPONSIVE: 768px ===== */
    @media (max-width: 768px) {
        .metrics-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }
        .metric-value {
            font-size: 1.1rem;
        }
        .radar { width: 80px; height: 80px; bottom: 20px; right: 20px; }
        .hud-top-right { display: none; }
    }

    /* ===== RESPONSIVE: 480px ===== */
    @media (max-width: 480px) {
        .radar { display: none; }
        .hud-bottom-left { display: none; }
        .hud-top-left .hud-label { display: none; }
    }
</style>

<script>
    // ===== INTRO SEQUENCE =====
    const intro = document.getElementById('intro');
    const countdown = document.getElementById('introCountdown');
    const flash = document.getElementById('introFlash');
    const boot = document.getElementById('introBoot');
    const content = document.getElementById('missionContent');

    const STORAGE_KEY = 'space-intro';
    let introSkipped = false;

    function skipIntro() {
        if (introSkipped) return;
        introSkipped = true;
        sessionStorage.setItem(STORAGE_KEY, 'done');
        intro?.classList.add('hidden');
        content?.classList.add('visible');
    }

    // Skip listeners
    document.addEventListener('keydown', (e) => {
        if (['Escape', ' ', 'Enter'].includes(e.key)) skipIntro();
    });
    intro?.addEventListener('click', skipIntro);

    if (sessionStorage.getItem(STORAGE_KEY) === 'done') {
        skipIntro();
    } else {
        runIntro();
    }

    async function runIntro() {
        // Countdown T-10 to T-0
        for (let i = 10; i >= 0; i--) {
            if (introSkipped) return;
            if (countdown) countdown.textContent = `T-${i}`;
            await sleep(i === 0 ? 200 : 180);
        }

        if (introSkipped) return;

        // Flash
        flash?.classList.add('active');
        await sleep(120);
        flash?.classList.remove('active');
        if (countdown) countdown.style.display = 'none';

        if (introSkipped) return;

        // Boot text
        const bootLines = [
            'Initializing navigation array...',
            'Propulsion systems nominal...',
            'Life support: ACTIVE...',
            'Comms relay: ONLINE...',
            'Loading crew manifest...',
            'Calibrating sensors...',
            'Mission dossier loaded.',
            '',
            '> READY'
        ];

        for (const line of bootLines) {
            if (introSkipped) return;
            for (let c = 0; c < line.length; c++) {
                if (introSkipped) return;
                if (boot) boot.textContent += line[c];
                await sleep(30);
            }
            if (boot) boot.textContent += '\n';
            await sleep(80);
        }

        await sleep(400);
        skipIntro();
    }

    function sleep(ms: number) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    // ===== MISSION CLOCK =====
    const clockEl = document.getElementById('hudClock');
    function updateClock() {
        const now = new Date();
        const h = String(now.getHours()).padStart(2, '0');
        const m = String(now.getMinutes()).padStart(2, '0');
        const s = String(now.getSeconds()).padStart(2, '0');
        if (clockEl) clockEl.textContent = `${h}:${m}:${s}`;
    }
    updateClock();
    setInterval(updateClock, 1000);

    // ===== ALTITUDE (STATIC FOR SINGLE VIEWPORT) =====
    const altEl = document.getElementById('hudAltitude');
    if (altEl) altEl.textContent = 'ALT: 42,000 KM';

    // ===== SIGNAL BARS ANIMATION =====
    const sigBars = document.querySelectorAll('.sig-bar');
    function animateSignal() {
        const active = 3 + Math.floor(Math.random() * 3); // 3-5 active
        sigBars.forEach((bar, i) => {
            bar.classList.toggle('active', i < active);
        });
    }
    setInterval(animateSignal, 2000);

    // ===== STARFIELD CANVAS =====
    const canvas = document.getElementById('starfield') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');

    interface Star {
        x: number;
        y: number;
        size: number;
        baseOpacity: number;
        twinkleSpeed: number;
        twinkleOffset: number;
        depth: number;
    }

    let stars: Star[] = [];
    let animFrame: number;

    function initStarfield() {
        if (!canvas || !ctx) return;
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const count = Math.min(300, Math.max(200, Math.floor(window.innerWidth * 0.2)));
        stars = [];
        for (let i = 0; i < count; i++) {
            stars.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 1.8 + 0.4,
                baseOpacity: Math.random() * 0.6 + 0.2,
                twinkleSpeed: Math.random() * 0.003 + 0.001,
                twinkleOffset: Math.random() * Math.PI * 2,
                depth: Math.random() * 0.8 + 0.2,
            });
        }
    }

    function drawStars(time: number) {
        if (!canvas || !ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (const star of stars) {
            const twinkle = Math.sin(time * star.twinkleSpeed + star.twinkleOffset);
            const opacity = star.baseOpacity + twinkle * 0.25;

            ctx.beginPath();
            ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(220, 230, 255, ${Math.max(0.05, opacity)})`;
            ctx.fill();
        }

        animFrame = requestAnimationFrame(drawStars);
    }

    window.addEventListener('resize', () => {
        if (canvas) {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
    });

    initStarfield();
    animFrame = requestAnimationFrame(drawStars);
</script>
</body>
</html>
