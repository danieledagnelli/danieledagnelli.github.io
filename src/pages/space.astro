    }
    .metric-card:hover { border-color: var(--amber); transform: translateY(-2px); }
    .metric-value {
        font-family: 'Exo 2', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: var(--amber);
        margin-bottom: 4px;
    }
    .metric-label {
