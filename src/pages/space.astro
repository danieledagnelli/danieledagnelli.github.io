    /* ===== QUALIFICATIONS ===== */
    .quals-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 10px;
    }
    .qual-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border: 1px solid var(--panel-border);
        border-radius: 4px;
