---
import { siteMetadata } from "../siteMetadata";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Retro Arcade Portfolio</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. 8-bit arcade-style portfolio showcasing 15+ years of AI, cybersecurity, and digital transformation experience." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/arcade" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta property="og:description" content="INSERT COIN to explore 15+ years of AI, cybersecurity, and programme management — arcade style." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/arcade" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta name="twitter:description" content="INSERT COIN to explore 15+ years of AI, cybersecurity, and programme management — arcade style." />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
</head>

<body>
    <!-- DECORATIVE OVERLAYS -->
    <div class="scanline-overlay" aria-hidden="true"></div>
    <div class="pixel-grid-overlay" aria-hidden="true"></div>
    <canvas id="starField" class="star-field" aria-hidden="true"></canvas>

    <!-- CRT CURVATURE -->
    <div class="crt-curve" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div id="intro" class="intro">
        <div class="intro-screen">
            <div class="intro-coin" id="insertCoin">INSERT COIN</div>
            <div class="intro-sub">press any key or click</div>
            <div class="intro-player" id="playerReady"></div>
            <div class="intro-wipe" id="introWipe"></div>
        </div>
    </div>

    <!-- SCORE BAR -->
    <div class="score-bar" aria-hidden="true">
        <span class="score-label">1UP</span>
        <span class="score-value" id="scoreCounter">00000000</span>
        <span class="score-label">HI-SCORE</span>
        <span class="score-value hi">15000000</span>
        <span class="score-label">CREDIT 01</span>
    </div>

    <!-- MAIN CONTENT -->
    <main id="tape" class="tape">
        <div class="arcade-narrative">
            <div class="level-display">
                <div class="level-row"><span class="level-num">LEVEL 1</span><span class="level-title">SOFTWARE ENGINEER</span><div class="level-detail">accenture, milan (2012-2014) — [first code. first build. game begins.]</div></div>
                <div class="level-row"><span class="level-num">LEVEL 2</span><span class="level-title">SENIOR CONSULTANT</span><div class="level-detail">codec, dublin (2015-2017) — [new territory unlocked. ireland arc.]</div></div>
                <div class="level-row"><span class="level-num">LEVEL 3</span><span class="level-title">MANAGEMENT CONSULTANT</span><div class="level-detail">accenture, london (2017-2018) — [class upgrade: aerospace & defence.]</div></div>
                <div class="level-row"><span class="level-num">LEVEL 4</span><span class="level-title">MANAGER</span><div class="level-detail">deloitte, london (2018-2021) — [built anaplan practice from zero. 25+ recruited.]</div></div>
                <div class="level-row boss"><span class="level-num">★ BOSS LEVEL ★</span><span class="level-title">SENIOR ENGAGEMENT MANAGER</span><div class="level-detail">c3 ai, london (2021-present) — [$15m programme. 70+ crew. 100+ plants. $18m ebit. nps>70.]</div></div>
            </div>
            <div class="arcade-footer"><a href="mailto:daniele@dagnelli.net">[INSERT COIN]</a><a href="https://github.com/danieledagnelli">[GITHUB]</a><a href="https://linkedin.com/in/dagnelli">[LINKEDIN]</a></div>
        </div>
    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --black: #0a0a0a;
        --pink: #ff00ff;
        --blue: #00ccff;
        --green: #39ff14;
        --yellow: #ffff00;
        --white: #ffffff;
        --dim: #333;
        --heading-font: 'Press Start 2P', monospace;
        --body-font: 'VT323', monospace;
    }

    body {
        background: var(--black);
        color: var(--white);
        font-family: var(--body-font);
        font-size: 18px;
        line-height: 1.6;
        overflow: hidden;
        height: 100dvh;
    }

    a { color: var(--blue); text-decoration: none; }
    a:hover { color: var(--pink); text-decoration: none; }
    ::selection { background: var(--pink); color: var(--black); }

    /* =========================================
       OVERLAYS — SCANLINES, PIXEL GRID, CRT
       ========================================= */
    .scanline-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 2px,
            rgba(0, 0, 0, 0.12) 2px,
            rgba(0, 0, 0, 0.12) 4px
        );
    }

    .pixel-grid-overlay {
        position: fixed; inset: 0; z-index: 9998; pointer-events: none;
        background-image:
            linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
        background-size: 4px 4px;
    }

    .star-field {
        position: fixed; inset: 0; z-index: 0;
        width: 100%; height: 100%;
        pointer-events: none;
    }

    .crt-curve {
        position: fixed; inset: 0; z-index: 9997; pointer-events: none;
        box-shadow:
            inset 0 0 150px rgba(0,0,0,0.6),
            inset 0 0 60px rgba(0,0,0,0.3);
        border-radius: 18px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--black);
        display: flex; align-items: center; justify-content: center;
        transition: opacity 0.3s ease;
        cursor: pointer;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-screen {
        text-align: center;
        font-family: var(--heading-font);
    }

    .intro-coin {
        font-size: clamp(18px, 4vw, 32px);
        color: var(--yellow);
        animation: coinBlink 0.8s step-end infinite;
        text-shadow: 0 0 20px var(--yellow), 0 0 40px rgba(255,255,0,0.3);
        margin-bottom: 16px;
    }

    .intro-sub {
        font-family: var(--body-font);
        font-size: clamp(14px, 2.5vw, 20px);
        color: var(--dim);
        margin-bottom: 24px;
    }

    .intro-player {
        font-size: clamp(14px, 3vw, 24px);
        color: var(--green);
        text-shadow: 0 0 15px var(--green);
        min-height: 1.5em;
    }

    .intro-wipe {
        position: fixed; inset: 0;
        background: var(--black);
        pointer-events: none;
        opacity: 0;
        z-index: 10002;
    }
    .intro-wipe.active {
        opacity: 1;
        animation: screenWipe 0.6s steps(8) forwards;
    }

    /* =========================================
       SCORE BAR
       ========================================= */
    .score-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
        display: flex; justify-content: center; align-items: center;
        gap: 20px;
        padding: 8px 16px;
        font-family: var(--heading-font);
        font-size: 10px;
        color: var(--white);
        background: rgba(10,10,10,0.9);
        border-bottom: 2px solid var(--pink);
        pointer-events: none;
    }
    .score-label { color: var(--blue); }
    .score-value { color: var(--white); font-variant-numeric: tabular-nums; }
    .score-value.hi { color: var(--yellow); }

    /* =========================================
       MAIN CONTENT — VIEWPORT LOCKED
       ========================================= */
    .tape {
        height: 100dvh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.5s ease 0.2s;
        position: relative;
        z-index: 1;
        padding: 0 24px;
    }
    .tape.visible { opacity: 1; }

    /* =========================================
       ARCADE NARRATIVE
       ========================================= */
    .arcade-narrative {
        width: 100%;
        max-width: 720px;
        display: flex;
        flex-direction: column;
        gap: 28px;
    }

    .level-display {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .level-row {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        gap: 0 16px;
        padding: 10px 14px;
        border-left: 3px solid var(--dim);
        background: rgba(255,255,255,0.01);
        transition: border-color 0.3s, background 0.3s;
    }
    .level-row:hover {
        border-color: var(--pink);
        background: rgba(255,0,255,0.03);
    }

    .level-num {
        font-family: var(--heading-font);
        font-size: clamp(7px, 1.4vw, 9px);
        color: var(--pink);
        text-shadow: 0 0 6px rgba(255,0,255,0.4);
        white-space: nowrap;
        align-self: center;
    }

    .level-title {
        font-family: var(--heading-font);
        font-size: clamp(9px, 1.8vw, 13px);
        color: var(--yellow);
        text-shadow: 0 0 8px rgba(255,255,0,0.3);
        align-self: center;
    }

    .level-detail {
        grid-column: 1 / -1;
        font-family: var(--body-font);
        font-size: clamp(14px, 2.2vw, 18px);
        color: #999;
        line-height: 1.4;
        margin-top: 4px;
    }

    /* BOSS LEVEL */
    .level-row.boss {
        border-color: var(--yellow);
        background: rgba(255,255,0,0.03);
        border-width: 3px;
        position: relative;
    }
    .level-row.boss .level-num {
        color: var(--yellow);
        text-shadow: 0 0 10px rgba(255,255,0,0.6);
        animation: coinBlink 1.2s step-end infinite;
    }
    .level-row.boss .level-title {
        color: var(--white);
        text-shadow: 0 0 10px var(--pink), 3px 3px 0 rgba(0,204,255,0.3);
    }
    .level-row.boss .level-detail {
        color: var(--green);
        text-shadow: 0 0 6px rgba(57,255,20,0.3);
    }
    .level-row.boss:hover {
        border-color: var(--pink);
        background: rgba(255,0,255,0.05);
    }

    /* ARCADE FOOTER */
    .arcade-footer {
        display: flex;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
        padding-top: 8px;
    }
    .arcade-footer a {
        font-family: var(--heading-font);
        font-size: clamp(7px, 1.4vw, 10px);
        padding: 8px 16px;
        border: 2px solid var(--blue);
        color: var(--blue);
        transition: all 0.2s;
        white-space: nowrap;
    }
    .arcade-footer a:hover {
        background: var(--blue);
        color: var(--black);
        box-shadow: 0 0 16px var(--blue);
    }
    .arcade-footer a:first-child {
        border-color: var(--green);
        color: var(--green);
    }
    .arcade-footer a:first-child:hover {
        background: var(--green);
        color: var(--black);
        box-shadow: 0 0 16px var(--green);
    }

    /* =========================================
       KEYFRAMES
       ========================================= */
    @keyframes coinBlink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    @keyframes screenWipe {
        0% { clip-path: inset(0 0 100% 0); }
        12.5% { clip-path: inset(0 0 87.5% 0); }
        25% { clip-path: inset(0 0 75% 0); }
        37.5% { clip-path: inset(0 0 62.5% 0); }
        50% { clip-path: inset(0 0 50% 0); }
        62.5% { clip-path: inset(0 0 37.5% 0); }
        75% { clip-path: inset(0 0 25% 0); }
        87.5% { clip-path: inset(0 0 12.5% 0); }
        100% { clip-path: inset(0 0 0% 0); opacity: 0; }
    }

    /* CRT body flicker */
    body {
        animation: crtFlicker 0.08s infinite alternate;
    }
    @keyframes crtFlicker {
        0% { opacity: 0.98; }
        100% { opacity: 1; }
    }

    /* =========================================
       RESPONSIVE — TABLET (601-1024px)
       ========================================= */
    @media (max-width: 1024px) {
        body { font-size: 17px; }
        .tape { padding: 0 20px; }
        .score-bar { gap: 14px; font-size: 9px; }
    }

    /* =========================================
       RESPONSIVE — SMALL TABLET / LARGE PHONE (481-600px)
       ========================================= */
    @media (max-width: 600px) {
        body { font-size: 16px; }
        .tape { padding: 0 12px; }
        .score-bar { gap: 8px; font-size: 8px; padding: 6px 10px; }

        .level-row {
            padding: 8px 10px;
            gap: 0 10px;
        }
        .level-num { font-size: 7px; }
        .level-title { font-size: 8px; }
        .level-detail { font-size: 13px; }

        .arcade-footer { gap: 10px; }
        .arcade-footer a { font-size: 7px; padding: 6px 12px; }

        .arcade-narrative { gap: 20px; }
        .level-display { gap: 8px; }
    }

    /* =========================================
       RESPONSIVE — SMALL PHONE (<=380px)
       ========================================= */
    @media (max-width: 380px) {
        body { font-size: 15px; }
        .tape { padding: 0 8px; }
        .score-bar { font-size: 7px; gap: 6px; padding: 4px 6px; }

        .level-row {
            padding: 6px 8px;
            gap: 0 8px;
        }
        .level-num { font-size: 6px; }
        .level-title { font-size: 7px; }
        .level-detail { font-size: 12px; }

        .arcade-footer a { font-size: 6px; padding: 5px 8px; }
        .arcade-narrative { gap: 16px; }
        .level-display { gap: 6px; }
    }

    /* =========================================
       TOUCH: larger tap targets
       ========================================= */
    @media (hover: none) and (pointer: coarse) {
        .arcade-footer a {
            padding: 10px 16px;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
        }
    }
</style>

<script>
    /* =============================================
       STAR FIELD CANVAS
       ============================================= */
    const canvas = document.getElementById('starField') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    interface Star {
        x: number;
        y: number;
        size: number;
        speed: number;
        brightness: number;
    }

    let stars: Star[] = [];
    const STAR_COUNT = 120;

    function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', () => {
        resizeCanvas();
        initStars();
    });

    function initStars() {
        stars = [];
        for (let i = 0; i < STAR_COUNT; i++) {
            stars.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 2 + 0.5,
                speed: Math.random() * 0.5 + 0.1,
                brightness: Math.random() * 0.6 + 0.4,
            });
        }
    }
    initStars();

    function drawStars() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const star of stars) {
            ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
            ctx.fillRect(Math.floor(star.x), Math.floor(star.y), Math.ceil(star.size), Math.ceil(star.size));
            star.y += star.speed;
            if (star.y > canvas.height) {
                star.y = 0;
                star.x = Math.random() * canvas.width;
            }
            // twinkle
            star.brightness += (Math.random() - 0.5) * 0.05;
            if (star.brightness < 0.2) star.brightness = 0.2;
            if (star.brightness > 1) star.brightness = 1;
        }
        requestAnimationFrame(drawStars);
    }
    drawStars();

    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const tapeEl = document.getElementById('tape')!;
    const playerReadyEl = document.getElementById('playerReady')!;
    const introWipeEl = document.getElementById('introWipe')!;
    let introRunning = true;

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    async function runIntro() {
        if (sessionStorage.getItem('arcade-intro-seen')) {
            skipIntro();
            return;
        }

        // Blinking INSERT COIN runs for 2 seconds
        await sleep(2000);
        if (!introRunning) return;

        // Coin drop: hide blink, show "PLAYER 1 READY"
        const coinEl = document.getElementById('insertCoin')!;
        coinEl.style.animation = 'none';
        coinEl.style.opacity = '0';

        // Coin drop sound effect simulation with text
        playerReadyEl.textContent = '* COIN INSERTED *';
        await sleep(600);
        if (!introRunning) return;

        playerReadyEl.textContent = 'PLAYER 1 READY';
        await sleep(1200);
        if (!introRunning) return;

        // Screen wipe transition
        introWipeEl.classList.add('active');
        await sleep(600);

        sessionStorage.setItem('arcade-intro-seen', '1');
        skipIntro();
    }

    function skipIntro() {
        introRunning = false;
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            tapeEl.classList.add('visible');
        }, 350);
    }

    // Click / key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('arcade-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('arcade-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCORE COUNTER ANIMATION
       ============================================= */
    const scoreEl = document.getElementById('scoreCounter')!;
    let currentScore = 0;
    const targetScore = 15000000;
    let scoreStarted = false;

    function animateScore() {
        if (!scoreStarted) return;
        if (currentScore < targetScore) {
            currentScore += Math.ceil((targetScore - currentScore) * 0.02) + 1337;
            if (currentScore > targetScore) currentScore = targetScore;
            scoreEl.textContent = String(currentScore).padStart(8, '0');
            requestAnimationFrame(animateScore);
        }
    }

    // Start score when tape becomes visible
    const tapeObserver = new MutationObserver(() => {
        if (tapeEl.classList.contains('visible') && !scoreStarted) {
            scoreStarted = true;
            animateScore();
        }
    });
    tapeObserver.observe(tapeEl, { attributes: true, attributeFilter: ['class'] });
</script>
