</style>

<script>
    /* =============================================
       STAR FIELD CANVAS
       ============================================= */
    const canvas = document.getElementById('starField') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    interface Star {
        x: number;
        y: number;
        size: number;
        speed: number;
        brightness: number;
    }

    let stars: Star[] = [];
    const STAR_COUNT = 120;

    function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', () => {
        resizeCanvas();
        initStars();
    });

    function initStars() {
        stars = [];
        for (let i = 0; i < STAR_COUNT; i++) {
            stars.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 2 + 0.5,
                speed: Math.random() * 0.5 + 0.1,
                brightness: Math.random() * 0.6 + 0.4,
            });
        }
    }
    initStars();

    function drawStars() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const star of stars) {
            ctx.fillStyle = `rgba(255, 255, 255, ${star.brightness})`;
            ctx.fillRect(Math.floor(star.x), Math.floor(star.y), Math.ceil(star.size), Math.ceil(star.size));
            star.y += star.speed;
            if (star.y > canvas.height) {
                star.y = 0;
                star.x = Math.random() * canvas.width;
            }
            // twinkle
            star.brightness += (Math.random() - 0.5) * 0.05;
            if (star.brightness < 0.2) star.brightness = 0.2;
            if (star.brightness > 1) star.brightness = 1;
        }
        requestAnimationFrame(drawStars);
    }
    drawStars();

    /* =============================================
       INTRO SEQUENCE
       ============================================= */
    const introEl = document.getElementById('intro')!;
    const tapeEl = document.getElementById('tape')!;
    const playerReadyEl = document.getElementById('playerReady')!;
    const introWipeEl = document.getElementById('introWipe')!;
    let introRunning = true;

    function sleep(ms: number): Promise<void> {
        return new Promise(r => setTimeout(r, ms));
    }

    async function runIntro() {
        if (sessionStorage.getItem('arcade-intro-seen')) {
            skipIntro();
            return;
        }

        // Blinking INSERT COIN runs for 2 seconds
        await sleep(2000);
        if (!introRunning) return;

        // Coin drop: hide blink, show "PLAYER 1 READY"
        const coinEl = document.getElementById('insertCoin')!;
        coinEl.style.animation = 'none';
        coinEl.style.opacity = '0';

        // Coin drop sound effect simulation with text
        playerReadyEl.textContent = '* COIN INSERTED *';
        await sleep(600);
        if (!introRunning) return;

        playerReadyEl.textContent = 'PLAYER 1 READY';
        await sleep(1200);
        if (!introRunning) return;

        // Screen wipe transition
        introWipeEl.classList.add('active');
        await sleep(600);

        sessionStorage.setItem('arcade-intro-seen', '1');
        skipIntro();
    }

    function skipIntro() {
        introRunning = false;
        introEl.classList.add('done');
        setTimeout(() => {
            introEl.style.display = 'none';
            tapeEl.classList.add('visible');
        }, 350);
    }

    // Click / key to skip
    introEl.addEventListener('click', () => {
        sessionStorage.setItem('arcade-intro-seen', '1');
        skipIntro();
    });
    document.addEventListener('keydown', (e) => {
        if (!introEl.classList.contains('done') && (e.key === 'Escape' || e.key === ' ' || e.key === 'Enter')) {
            sessionStorage.setItem('arcade-intro-seen', '1');
            skipIntro();
        }
    });

    runIntro();

    /* =============================================
       SCROLL REVEAL (Intersection Observer)
       ============================================= */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
            }
        });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => observer.observe(el));

    /* =============================================
       SCORE COUNTER ANIMATION
       ============================================= */
    const scoreEl = document.getElementById('scoreCounter')!;
    let currentScore = 0;
    const targetScore = 15000000;
    let scoreStarted = false;

    function animateScore() {
        if (!scoreStarted) return;
        if (currentScore < targetScore) {
            currentScore += Math.ceil((targetScore - currentScore) * 0.02) + 1337;
            if (currentScore > targetScore) currentScore = targetScore;
            scoreEl.textContent = String(currentScore).padStart(8, '0');
            requestAnimationFrame(animateScore);
        }
    }

    // Start score when tape becomes visible
    const tapeObserver = new MutationObserver(() => {
        if (tapeEl.classList.contains('visible') && !scoreStarted) {
            scoreStarted = true;
            animateScore();
        }
    });
    tapeObserver.observe(tapeEl, { attributes: true, attributeFilter: ['class'] });

    /* =============================================
       CONTINUE COUNTDOWN
       ============================================= */
    const countdownEl = document.getElementById('continueCountdown')!;
    let countVal = 10;
    const countdownObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                countdownObserver.unobserve(entry.target);
                const countInterval = setInterval(() => {
                    countVal--;
                    if (countVal <= 0) {
                        countdownEl.textContent = '00';
                        clearInterval(countInterval);
                    } else {
                        countdownEl.textContent = String(countVal).padStart(2, '0');
                    }
                }, 1000);
            }
        });
    }, { threshold: 0.5 });
    countdownObserver.observe(countdownEl);
</script>
