---
import { siteMetadata } from "../siteMetadata";
import { experience, education, certifications, skills, engagements, continuousLearning, summary, metrics, industries, managementSkills, languages } from "../data/resume";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Language" content="en" />
    <title>{siteMetadata.name} — Retro Arcade Portfolio</title>
    <meta name="description" content="Daniele D'Agnelli — Senior Engagement Manager. 8-bit arcade-style portfolio showcasing 15+ years of AI, cybersecurity, and digital transformation experience." />
    <meta name="author" content="Daniele D'Agnelli" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://dagnelli.net/arcade" />

    <!-- Open Graph -->
    <meta property="og:title" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta property="og:description" content="INSERT COIN to explore 15+ years of AI, cybersecurity, and programme management — arcade style." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://dagnelli.net/arcade" />
    <meta property="og:image" content="https://dagnelli.net/assets/og-image.png" />
    <meta property="og:image:alt" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Daniele D'Agnelli" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Daniele D'Agnelli — Retro Arcade Portfolio" />
    <meta name="twitter:description" content="INSERT COIN to explore 15+ years of AI, cybersecurity, and programme management — arcade style." />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
</head>

<body>
    <!-- DECORATIVE OVERLAYS -->
    <div class="scanline-overlay" aria-hidden="true"></div>
    <div class="pixel-grid-overlay" aria-hidden="true"></div>
    <canvas id="starField" class="star-field" aria-hidden="true"></canvas>

    <!-- CRT CURVATURE -->
    <div class="crt-curve" aria-hidden="true"></div>

    <!-- INTRO SEQUENCE -->
    <div id="intro" class="intro">
        <div class="intro-screen">
            <div class="intro-coin" id="insertCoin">INSERT COIN</div>
            <div class="intro-sub">press any key or click</div>
            <div class="intro-player" id="playerReady"></div>
            <div class="intro-wipe" id="introWipe"></div>
        </div>
    </div>

    <!-- SCORE BAR -->
    <div class="score-bar" aria-hidden="true">
        <span class="score-label">1UP</span>
        <span class="score-value" id="scoreCounter">00000000</span>
        <span class="score-label">HI-SCORE</span>
        <span class="score-value hi">15000000</span>
        <span class="score-label">CREDIT 01</span>
    </div>

    <!-- MAIN CONTENT -->
    <main id="tape" class="tape">

        <!-- ====== TITLE SCREEN ====== -->
        <section class="section title-screen reveal" data-section="header">
            <div class="arcade-title-frame">
                <div class="pixel-border-top" aria-hidden="true"></div>
                <h1 class="arcade-title" data-text={siteMetadata.name.toUpperCase()}>{siteMetadata.name.toUpperCase()}</h1>
                <div class="arcade-subtitle">SENIOR ENGAGEMENT MANAGER</div>
                <div class="arcade-subtitle sub2">AI & CYBERSECURITY</div>
                <div class="pixel-border-bottom" aria-hidden="true"></div>
            </div>
            <div class="hi-score-panel">
                <div class="hi-row">
                    <span class="hi-label">RANK</span>
                    <span class="hi-label">NAME</span>
                    <span class="hi-label">SCORE</span>
                </div>
                {metrics.map((m, i) => (
                    <div class="hi-row">
                        <span class="hi-rank">{String(i + 1).padStart(2, '0')}</span>
                        <span class="hi-name">{m.label.toUpperCase()}</span>
                        <span class="hi-score-val">{m.value}</span>
                    </div>
                ))}
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== PLAYER SELECT ====== -->
        <section class="section reveal" data-section="summary">
            <div class="sec-head">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">PLAYER SELECT</span>
            </div>
            <div class="player-card">
                <div class="player-avatar-frame">
                    <img src="/assets/dani.jpeg" alt={siteMetadata.name} class="player-avatar" width="140" height="140" />
                    <div class="avatar-scanlines" aria-hidden="true"></div>
                    <div class="avatar-label">P1</div>
                </div>
                <div class="player-info">
                    <div class="player-name">{siteMetadata.name.toUpperCase()}</div>
                    <div class="player-class">CLASS: ENGAGEMENT MANAGER</div>
                    <div class="player-stats">
                        <div class="stat-row"><span class="stat-label">LOC</span><span class="stat-val">{siteMetadata.location.toUpperCase()}</span></div>
                        <div class="stat-row"><span class="stat-label">HP</span><span class="stat-bar"><span class="stat-fill" style="width:95%"></span></span></div>
                        <div class="stat-row"><span class="stat-label">MP</span><span class="stat-bar"><span class="stat-fill mp" style="width:88%"></span></span></div>
                        <div class="stat-row"><span class="stat-label">EXP</span><span class="stat-val">15+ YEARS</span></div>
                    </div>
                    <div class="player-bio">{summary}</div>
                    <div class="player-links">
                        <a href={`https://github.com/${siteMetadata.github_handle}`} target="_blank" rel="noopener">GITHUB</a>
                        <a href={`https://linkedin.com/in/${siteMetadata.linkedin_handle}`} target="_blank" rel="noopener">LINKEDIN</a>
                        <a href={`https://bsky.app/profile/${siteMetadata.bsky_handle}`} target="_blank" rel="noopener">BLUESKY</a>
                        <a href={`mailto:${siteMetadata.email}`}>EMAIL</a>
                    </div>
                    <div class="player-langs">
                        {languages.map(l => (
                            <span class="lang-badge">{l.toUpperCase()}</span>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== LEVEL SELECT (EXPERIENCE) ====== -->
        <section class="section reveal" data-section="experience">
            <div class="sec-head">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">LEVEL SELECT</span>
                <span class="sec-sub">// CAREER STAGES</span>
            </div>
            <div class="level-grid">
                {experience.map((exp, i) => (
                    <div class="level-card reveal">
                        <div class="level-header">
                            <span class="level-num">LVL {String(experience.length - i).padStart(2, '0')}</span>
                            <span class="level-company">{exp.company.toUpperCase()}</span>
                            <span class="level-loc">{exp.location.toUpperCase()}</span>
                        </div>
                        {exp.roles.map(role => (
                            <div class="level-body">
                                <div class="level-role-row">
                                    <span class="level-role">{role.title.toUpperCase()}</span>
                                    <span class="level-period">{role.period}</span>
                                </div>
                                {role.description && <p class="level-desc">{role.description}</p>}
                                {role.bullets && role.bullets.length > 0 && (
                                    <ul class="level-loot">
                                        {role.bullets.map(b => (
                                            <li><span class="loot-icon" aria-hidden="true">&#9733;</span> {b}</li>
                                        ))}
                                    </ul>
                                )}
                            </div>
                        ))}
                    </div>
                ))}
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== POWER-UPS (SKILLS) ====== -->
        <section class="section reveal" data-section="skills">
            <div class="sec-head">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">POWER-UPS</span>
                <span class="sec-sub">// TECHNICAL SKILLS</span>
            </div>
            <div class="powerup-grid">
                {skills.map((s, i) => (
                    <span class="powerup" style={`--i:${i}`}>{s.toUpperCase()}</span>
                ))}
            </div>

            <div class="sec-head sub-sec">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">SPECIAL MOVES</span>
                <span class="sec-sub">// MANAGEMENT SKILLS</span>
            </div>
            <div class="powerup-grid mgmt">
                {managementSkills.map((s, i) => (
                    <span class="powerup mgmt-skill" style={`--i:${i}`}>{s.toUpperCase()}</span>
                ))}
            </div>

            <div class="sec-head sub-sec">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">WORLD MAP</span>
                <span class="sec-sub">// INDUSTRIES</span>
            </div>
            <div class="powerup-grid industries">
                {industries.map((ind, i) => (
                    <span class="powerup industry" style={`--i:${i}`}>{ind.toUpperCase()}</span>
                ))}
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== BOSS BATTLES (ENGAGEMENTS) ====== -->
        <section class="section reveal" data-section="engagements">
            <div class="sec-head">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">BOSS BATTLES</span>
                <span class="sec-sub">// KEY ENGAGEMENTS</span>
            </div>
            <div class="boss-grid">
                {engagements.map((eng, i) => (
                    <div class="boss-card reveal">
                        <div class="boss-header">
                            <span class="boss-num">BOSS {String(i + 1).padStart(2, '0')}</span>
                            <span class="boss-sector">{eng.sector.toUpperCase()}</span>
                        </div>
                        <div class="boss-name">{eng.client.toUpperCase()}</div>
                        <div class="boss-stats">
                            <div class="boss-stat"><span class="bs-label">SCOPE</span><span class="bs-val">{eng.scope}</span></div>
                            <div class="boss-stat"><span class="bs-label">IMPACT</span><span class={`bs-val ${eng.trend}`}>{eng.impact}</span></div>
                        </div>
                        <div class={`boss-status ${eng.trend}`}>{eng.trend === 'positive' ? 'VICTORY!' : 'CLEARED'}</div>
                    </div>
                ))}
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== TRAINING STAGES (EDUCATION + CERTS) ====== -->
        <section class="section reveal" data-section="education">
            <div class="sec-head">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">TRAINING STAGES</span>
                <span class="sec-sub">// EDUCATION</span>
            </div>
            <div class="training-list">
                {education.map((edu, i) => (
                    <div class="training-card reveal">
                        <div class="training-header">
                            <span class="training-stage">STAGE {String(i + 1).padStart(2, '0')}</span>
                            <span class="training-period">{edu.period}</span>
                        </div>
                        <div class="training-degree">{edu.degree.toUpperCase()}</div>
                        <div class="training-inst">{edu.institution.toUpperCase()} — {edu.location.toUpperCase()}</div>
                        {edu.distinction && <div class="training-badge">ACHIEVEMENT UNLOCKED: {edu.distinction.toUpperCase()}</div>}
                    </div>
                ))}
            </div>

            <div class="sec-head sub-sec">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">ACHIEVEMENTS</span>
                <span class="sec-sub">// CERTIFICATIONS</span>
            </div>
            <div class="achievement-grid">
                {certifications.map(c => (
                    <div class="achievement-badge">{c.toUpperCase()}</div>
                ))}
            </div>

            <div class="sec-head sub-sec">
                <span class="sec-icon">&#9654;</span>
                <span class="sec-title">BONUS ROUNDS</span>
                <span class="sec-sub">// CONTINUOUS LEARNING</span>
            </div>
            <div class="achievement-grid bonus">
                {continuousLearning.map(l => (
                    <div class="achievement-badge bonus-badge">{l.toUpperCase()}</div>
                ))}
            </div>
        </section>

        <div class="pixel-divider" aria-hidden="true"></div>

        <!-- ====== GAME OVER / CONTINUE ====== -->
        <section class="section game-over-section" data-section="footer">
            <div class="game-over-text">GAME OVER</div>
            <div class="continue-text">CONTINUE?</div>
            <div class="continue-countdown" id="continueCountdown">10</div>
            <div class="game-over-links">
                <a href={`mailto:${siteMetadata.email}`} class="continue-btn">YES — CONTACT ME</a>
                <a href="/" class="continue-btn alt">NO — MAIN MENU</a>
            </div>
            <div class="credits-text">
                {siteMetadata.name.toUpperCase()} &copy; {new Date().getFullYear()}<br />
                {siteMetadata.location.toUpperCase()}
            </div>
        </section>
    </main>
</body>
</html>

<style>
    /* =========================================
       BASE & CSS CUSTOM PROPERTIES
       ========================================= */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    html {
        --black: #0a0a0a;
        --pink: #ff00ff;
        --blue: #00ccff;
        --green: #39ff14;
        --yellow: #ffff00;
        --white: #ffffff;
        --dim: #333;
        --heading-font: 'Press Start 2P', monospace;
        --body-font: 'VT323', monospace;
        scrollbar-width: thin;
        scrollbar-color: var(--pink) var(--black);
    }

    body {
        background: var(--black);
        color: var(--white);
        font-family: var(--body-font);
        font-size: 18px;
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
    }

    a { color: var(--blue); text-decoration: none; }
    a:hover { color: var(--pink); text-decoration: none; }
    ::selection { background: var(--pink); color: var(--black); }

    /* =========================================
       OVERLAYS — SCANLINES, PIXEL GRID, CRT
       ========================================= */
    .scanline-overlay {
        position: fixed; inset: 0; z-index: 9999; pointer-events: none;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px,
            transparent 2px,
            rgba(0, 0, 0, 0.12) 2px,
            rgba(0, 0, 0, 0.12) 4px
        );
    }

    .pixel-grid-overlay {
        position: fixed; inset: 0; z-index: 9998; pointer-events: none;
        background-image:
            linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
        background-size: 4px 4px;
    }

    .star-field {
        position: fixed; inset: 0; z-index: 0;
        width: 100%; height: 100%;
        pointer-events: none;
    }

    .crt-curve {
        position: fixed; inset: 0; z-index: 9997; pointer-events: none;
        box-shadow:
            inset 0 0 150px rgba(0,0,0,0.6),
            inset 0 0 60px rgba(0,0,0,0.3);
        border-radius: 18px;
    }

    /* =========================================
       INTRO SEQUENCE
       ========================================= */
    .intro {
        position: fixed; inset: 0; z-index: 10001;
        background: var(--black);
        display: flex; align-items: center; justify-content: center;
        transition: opacity 0.3s ease;
        cursor: pointer;
    }
    .intro.done {
        opacity: 0;
        pointer-events: none;
    }

    .intro-screen {
        text-align: center;
        font-family: var(--heading-font);
    }

    .intro-coin {
        font-size: clamp(18px, 4vw, 32px);
        color: var(--yellow);
        animation: coinBlink 0.8s step-end infinite;
        text-shadow: 0 0 20px var(--yellow), 0 0 40px rgba(255,255,0,0.3);
        margin-bottom: 16px;
    }

    .intro-sub {
        font-family: var(--body-font);
        font-size: clamp(14px, 2.5vw, 20px);
        color: var(--dim);
        margin-bottom: 24px;
    }

    .intro-player {
        font-size: clamp(14px, 3vw, 24px);
        color: var(--green);
        text-shadow: 0 0 15px var(--green);
        min-height: 1.5em;
    }

    .intro-wipe {
        position: fixed; inset: 0;
        background: var(--black);
        pointer-events: none;
        opacity: 0;
        z-index: 10002;
    }
    .intro-wipe.active {
        opacity: 1;
        animation: screenWipe 0.6s steps(8) forwards;
    }

    /* =========================================
       SCORE BAR
       ========================================= */
    .score-bar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 10000;
        display: flex; justify-content: center; align-items: center;
        gap: 20px;
        padding: 8px 16px;
        font-family: var(--heading-font);
        font-size: 10px;
        color: var(--white);
        background: rgba(10,10,10,0.9);
        border-bottom: 2px solid var(--pink);
        pointer-events: none;
    }
    .score-label { color: var(--blue); }
    .score-value { color: var(--white); font-variant-numeric: tabular-nums; }
    .score-value.hi { color: var(--yellow); }

    /* =========================================
       MAIN CONTENT
       ========================================= */
    .tape {
        max-width: 860px;
        margin: 0 auto;
        padding: 60px 24px 80px;
        opacity: 0;
        transition: opacity 0.5s ease 0.2s;
        position: relative;
        z-index: 1;
    }
    .tape.visible { opacity: 1; }

    /* =========================================
       SECTION HEADS
       ========================================= */
    .section { margin-bottom: 0; }

    .sec-head {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 16px;
        font-family: var(--heading-font);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .sec-head.sub-sec { margin-top: 24px; }
    .sec-icon { color: var(--pink); font-size: 10px; }
    .sec-title { color: var(--yellow); text-shadow: 0 0 8px rgba(255,255,0,0.3); }
    .sec-sub { color: var(--dim); font-family: var(--body-font); font-size: 16px; }

    /* REVEAL ANIMATION */
    .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    /* PIXEL DIVIDER */
    .pixel-divider {
        height: 4px;
        margin: 2.5rem 0;
        background: repeating-linear-gradient(
            90deg,
            var(--pink) 0px, var(--pink) 8px,
            transparent 8px, transparent 12px,
            var(--blue) 12px, var(--blue) 20px,
            transparent 20px, transparent 24px,
            var(--green) 24px, var(--green) 32px,
            transparent 32px, transparent 36px,
            var(--yellow) 36px, var(--yellow) 44px,
            transparent 44px, transparent 48px
        );
        image-rendering: pixelated;
    }

    /* =========================================
       TITLE SCREEN
       ========================================= */
    .arcade-title-frame {
        text-align: center;
        margin-bottom: 28px;
        padding: 24px 16px;
        border: 3px solid var(--pink);
        position: relative;
        background: rgba(255,0,255,0.03);
        image-rendering: pixelated;
    }

    .pixel-border-top,
    .pixel-border-bottom {
        position: absolute; left: -3px; right: -3px;
        height: 3px;
        background: repeating-linear-gradient(
            90deg,
            var(--pink) 0px, var(--pink) 6px,
            var(--blue) 6px, var(--blue) 12px,
            var(--green) 12px, var(--green) 18px,
            var(--yellow) 18px, var(--yellow) 24px
        );
    }
    .pixel-border-top { top: -3px; }
    .pixel-border-bottom { bottom: -3px; }

    .arcade-title {
        font-family: var(--heading-font);
        font-size: clamp(20px, 4.5vw, 36px);
        color: var(--white);
        text-shadow:
            0 0 10px var(--pink),
            0 0 30px rgba(255,0,255,0.4),
            3px 3px 0 var(--blue);
        line-height: 1.3;
        margin-bottom: 12px;
    }

    .arcade-subtitle {
        font-family: var(--heading-font);
        font-size: clamp(8px, 1.8vw, 12px);
        color: var(--green);
        text-shadow: 0 0 10px rgba(57,255,20,0.4);
        letter-spacing: 2px;
        margin-bottom: 4px;
    }
    .arcade-subtitle.sub2 { color: var(--blue); text-shadow: 0 0 10px rgba(0,204,255,0.4); }

    /* HI-SCORE TABLE */
    .hi-score-panel {
        border: 2px solid var(--yellow);
        padding: 12px 16px;
        background: rgba(255,255,0,0.02);
    }
    .hi-row {
        display: flex; gap: 16px;
        font-family: var(--heading-font);
        font-size: 9px;
        padding: 4px 0;
        border-bottom: 1px solid rgba(255,255,0,0.1);
    }
    .hi-row:last-child { border-bottom: none; }
    .hi-label { color: var(--yellow); flex: 1; font-size: 8px; }
    .hi-rank { color: var(--pink); width: 40px; }
    .hi-name { color: var(--white); flex: 1; }
    .hi-score-val { color: var(--green); text-align: right; min-width: 80px; }

    /* =========================================
       PLAYER SELECT
       ========================================= */
    .player-card {
        display: flex; gap: 24px;
        align-items: flex-start;
        border: 2px solid var(--blue);
        padding: 20px;
        background: rgba(0,204,255,0.02);
    }

    .player-avatar-frame {
        position: relative;
        flex-shrink: 0;
        border: 3px solid var(--pink);
        padding: 4px;
        background: var(--black);
    }
    .player-avatar {
        width: 140px; height: 140px;
        object-fit: cover;
        display: block;
        image-rendering: auto;
        filter: contrast(1.15) saturate(1.1);
    }
    .avatar-scanlines {
        position: absolute; inset: 4px;
        background: repeating-linear-gradient(
            0deg,
            transparent 0px, transparent 2px,
            rgba(255,0,255,0.06) 2px, rgba(255,0,255,0.06) 4px
        );
        pointer-events: none;
    }
    .avatar-label {
        position: absolute; bottom: -10px; left: 50%;
        transform: translateX(-50%);
        font-family: var(--heading-font);
        font-size: 10px;
        color: var(--yellow);
        background: var(--black);
        padding: 0 8px;
        text-shadow: 0 0 8px rgba(255,255,0,0.5);
    }

    .player-info { flex: 1; min-width: 0; }

    .player-name {
        font-family: var(--heading-font);
        font-size: clamp(12px, 2.5vw, 18px);
        color: var(--white);
        text-shadow: 0 0 8px var(--pink);
        margin-bottom: 4px;
    }
    .player-class {
        font-family: var(--heading-font);
        font-size: 9px;
        color: var(--green);
        margin-bottom: 12px;
    }

    .player-stats { margin-bottom: 12px; }
    .stat-row {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 4px;
        font-size: 16px;
    }
    .stat-label {
        font-family: var(--heading-font);
        font-size: 8px;
