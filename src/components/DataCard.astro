---
type Props = {
    value: string;
    label: string;
    color?: string;
};

const { value, label, color = 'var(--accent-primary)' } = Astro.props;
---

<div class="data-card">
    <span class="data-card__value" style={`color: ${color}`}>{value}</span>
    <span class="data-card__label">{label}</span>
</div>

<style>
    .data-card {
        text-align: center;
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.1em;
        padding: 0.2em;
        overflow: hidden;
    }

    .data-card__value {
        font-size: var(--font-size-base);
        font-weight: bold;
        font-family: var(--font-mono);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .data-card__label {
        color: var(--text-secondary);
        font-size: var(--font-size-xxxs);
        text-transform: uppercase;
        font-family: var(--font-mono);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>
