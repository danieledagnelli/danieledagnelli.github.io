---

<div class="status-bar">
    <div class="status-bar__track">
        <span class="status-bar__text">
            DAGNELLI TERMINAL v2.0 // SR. ENGAGEMENT MANAGER @ C3 AI // LONDON, UK // <span id="tickerClock">00:00:00</span> UTC
        </span>
        <span class="status-bar__text" aria-hidden="true">
            DAGNELLI TERMINAL v2.0 // SR. ENGAGEMENT MANAGER @ C3 AI // LONDON, UK // <span class="ticker-clock-dup">00:00:00</span> UTC
        </span>
    </div>
</div>

<style>
    .status-bar {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border-color);
        height: 28px;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    .status-bar__track {
        display: flex;
        white-space: nowrap;
        animation: marquee 30s linear infinite;
    }

    .status-bar__text {
        color: var(--accent-primary);
        font-size: var(--font-size-xs);
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 1px;
        padding-right: 4em;
    }

    @keyframes marquee {
        0% {
            transform: translateX(100%);
        }
        100% {
            transform: translateX(-100%);
        }
    }
</style>

<script>
    function updateTickerClocks() {
        const now = new Date();
        const hh = String(now.getUTCHours()).padStart(2, "0");
        const mm = String(now.getUTCMinutes()).padStart(2, "0");
        const ss = String(now.getUTCSeconds()).padStart(2, "0");
        const time = `${hh}:${mm}:${ss}`;

        const primary = document.getElementById("tickerClock");
        if (primary) primary.textContent = time;

        const dups = document.querySelectorAll(".ticker-clock-dup");
        dups.forEach((el) => {
            el.textContent = time;
        });
    }

    updateTickerClocks();
    setInterval(updateTickerClocks, 1000);
</script>
